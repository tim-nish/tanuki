def cmd_policy(args):
    """Record an iteration-1 judgment answer as run policy — the mechanism
    behind 'questions only in iteration 1': iterations >= 2 consult this map
    instead of asking."""
    state = load_state(args.target, args.run)
    d = loop_dir(state["target"], state["run"])
    ppath = os.path.join(d, "policy.json")
    policy = {}
    if os.path.exists(ppath):
        with open(ppath, encoding="utf-8") as f:
            policy = json.load(f) or {}
    policy.setdefault("decisions", {})[args.finding] = {
        "decision": args.decision,
        "iter": len(state["iterations"]) or 1,
    }
    with open(ppath, "w", encoding="utf-8") as f:
        json.dump(policy, f, indent=2)
    audit(state, f"policy: {args.finding} -> {args.decision}")
    out({"ok": True, "finding": args.finding})


def cmd_finish(args):
    """Mark the run terminal, machine-readably: converged | cap | aborted.
    The dashboard's answer to 'why did it stop?'. gate-ratified is accepted
    for compatibility only (owner ruling 2026-07-17): the loop's terminal
    fact for a delivered run is the delivery itself, and settlement is
    derived — no workflow instructs this reason any more."""
    state = load_state(args.target, args.run)
    # COMPATIBILITY ONLY (owner ruling 2026-07-17, delivery boundary): the
    # loop ends at delivery and settlement is DERIVED — no human runs a
    # closing command, and no workflow documents this reason for a delivered
    # run. The guard is kept so an existing script invoking it cannot mark a
    # run ratified against forge reality: it derives the same settlement the
    # read-only surfaces use and refuses unless the work verifiably landed.
    if args.reason == "gate-ratified" and \
            (state.get("delivered") or state.get("gate_pr")):
        s = derive_settlement(state)
        if not (s and s.get("result") == "landed" and s.get("local_synced")):
            out({"ok": False, "settlement": s,
                 "hint": "compatibility guard: gate-ratified is no longer a "
                         "workflow step — settlement is derived "
                         "(status/init/unresolved). It still refuses here "
                         "because the delivered work is not verifiably "
                         "landed in the local base"})
            sys.exit(3)
        audit(state, f"finish gate-ratified (compatibility): settlement "
                     f"derived as landed — {s.get('detail')}")
    # A run can be finished twice by design (e.g. `cap` at the end of the
    # unattended run, then `gate-ratified` after the morning gate). Surface the
    # prior close rather than overwriting it silently, so a double-close is
    # visible, not accidental (F32).
    prev_finished = state.get("finished")
    now_str = time.strftime("%Y-%m-%d %H:%M:%S")
    # Stop reason vs settlement — two separated facts (spec-tanuki-loop "Stop
    # reason vs delivery settlement"; spec-tanuki-view D2 `live`). The FIRST
    # computational close is the run's stop reason and is never overwritten:
    # ratification/settlement is what became of the delivery, never a reason
    # execution stopped, so a run stopped at `cap` and merged later still
    # stopped at `cap`. `aborted` is recorded under its lifecycle name,
    # `cancelled`. Settlement itself is DERIVED (derive_settlement, owner
    # ruling 2026-07-17) — finish records nothing about it.
    if args.reason in ("converged", "cap", "aborted"):
        state.setdefault("stop", {
            "reason": "cancelled" if args.reason == "aborted" else args.reason,
            "at": now_str})
    # Execution time ends at the first close and never grows again — time the
    # run spends waiting for PR review or merge is not execution time.
    state.setdefault("wall_end", time.time())
    state["finished"] = {"reason": args.reason, "at": now_str}
    # Host drift note (spec-host-snapshot): the ONE permitted post-init read of
    # the live host — read-only `git rev-parse`, informational only. It never
    # blocks, aborts, or reconciles; the run mined against the init-time
    # fixture, and this just tells the operator whether the live host moved.
    host, base = state.get("host"), state.get("host_base_sha")
    host_drift = None
    if host and base and git(host, "rev-parse", "--git-dir")[0] == 0:
        rc, live = git(host, "rev-parse", "HEAD")
        if rc == 0 and live != base:
            rc_c, n = git(host, "rev-list", "--count", f"{base}..{live}")
            span = f"{base[:12]} -> {live[:12]}"
            host_drift = (f"live host moved during the run ({span}"
                          + (f", {n} commit(s) ahead)" if rc_c == 0 and n.isdigit()
                             else ")"))
            audit(state, f"host drift (informational): {host_drift}")
    state["host_drift"] = host_drift
    save_state(state)
    audit(state, f"run finished: {args.reason}")
    # Own the deferred "later branch cleanup" (issue #6): delete merged
    # integration branches for this target, keep unmerged tips. Safe for every
    # terminal reason — a non-gate-ratified run's branch is not reachable from
    # base, so it is kept, not deleted.
    cleaned = cleanup_merged_integration_branches(
        state["loop_repo"], state["base"], state["target"])
    if any(cleaned.values()):
        audit(state, "branch cleanup — deleted: "
                     f"{cleaned['deleted'] or 'none'}; kept (unmerged): "
                     f"{cleaned['kept'] or 'none'}; skipped: "
                     f"{cleaned['skipped_reasons'] or 'none'}")
    _ld = loop_dir(state["target"], state["run"])
    # F138: a skipped branch is surfaced top-level, not only inside the
    # branch_cleanup detail. F195: HOW it is surfaced follows whether the
    # operator must act. A merged branch whose delete FAILED is a real
    # follow-up -> `warning`. A branch skipped only because it is still
    # checked out in its live worktree is ROUTINE beside a clean success —
    # no action is required before the next init sweep: the next `init`
    # collects it once the worktree is removed — so it rides the
    # informational `note` field, never `warning`.
    warning, note = None, None
    if cleaned.get("skipped"):
        routine = {b: r for b, r in cleaned["skipped_reasons"].items()
                   if "checked out in a worktree" in r}
        alarming = {b: r for b, r in cleaned["skipped_reasons"].items()
                    if b not in routine}
        if alarming:
            warning = ("branch cleanup incomplete — skipped: "
                       + ", ".join(f"{b} ({r})"
                                   for b, r in alarming.items()))
        if routine:
            note = ("branch cleanup deferred, no action required: "
                    + ", ".join(f"{b} is still checked out in its worktree"
                                for b in routine)
                    + " — the next `init` collects it after the worktree is "
                      "removed (`git worktree remove <path>`); or re-run "
                      "finish then")
    # F108: a repeated finish used to emit only a quiet previously_finished
    # block — surface it in the tool's standard warning field so the no-op is
    # unmissable, consistent with the skipped-branch warning above.
    if prev_finished:
        rewarn = (f"run was already finished with reason "
                  f"'{prev_finished['reason']}' at {prev_finished['at']} — "
                  "this call changed nothing (the stop reason keeps the "
                  "first close)")
        warning = f"{rewarn}; {warning}" if warning else rewarn
    # F170: after a second finish, `reason` is just THIS call's argument while
    # `previously_finished.reason` is the earlier call's — neither is labeled
    # authoritative. The run's computational stop reason is state["stop"]
    # (first close wins, never overwritten); echo it so downstream consumers
    # have one field to read.
    payload = {"ok": True, "reason": args.reason,
               "stop_reason": (state.get("stop") or {}).get("reason"),
               "stop_reason_note": ("stop_reason is the run's authoritative "
                                    "computational close (first finish wins); "
                                    "'reason' is only this invocation's "
                                    "argument"),
               "warning": warning,
               # F195: informational only — finish itself succeeded and the
               # next init sweep needs nothing from the operator first.
               "note": note,
               "branch_cleanup": cleaned,
               "host_drift": host_drift,
               # The morning gate is told to present these three; point at them
               # instead of making the operator find(1) the run dir (F79).
               "artifacts": {
                   "dir": _ld,
                   "state": os.path.join(_ld, "state.json"),
                   "audit": os.path.join(_ld, "audit.md"),
                   "queue": os.path.join(_ld, "queue.md"),
               }}
    if prev_finished:
        payload["previously_finished"] = prev_finished
        audit(state, f"note: run was already finished as "
                     f"'{prev_finished['reason']}' at {prev_finished['at']} — "
                     f"re-finished as '{args.reason}'")
    out(payload)


def _fmt_duration(seconds):
    """Human duration with units for the dashboard (F190): `45s` under a
    minute (never a bare `0m`), `4m32s` under an hour, `1h04m` beyond."""
    s = int(seconds)
    if s < 60:
        return f"{s}s"
    if s < 3600:
        return f"{s // 60}m{s % 60:02d}s"
    return f"{s // 3600}h{(s % 3600) // 60:02d}m"


def _fmt_ids(ids, cap=6):
    ids = list(ids)
    if not ids:
        return "none"
    s = ", ".join(ids[:cap])
    return s + (f" +{len(ids) - cap} more" if len(ids) > cap else "")


def _short(text, n=90, pointer=None):
    # Truncation on the dashboard must never hide a reason silently (F7): when
    # it clips, it marks the clip AND points at the full text.
    text = " ".join((text or "").split())
    if len(text) <= n:
        return text
    marker = "…" + (f" — full: {pointer}" if pointer else "")
    return text[:n - 1] + marker


def _queue_reasons(state):
    """{finding-id: reason} parsed from the morning queue's DEFER/FROZEN lines."""
    path = os.path.join(loop_dir(state["target"], state["run"]), "queue.md")
    reasons = {}
    if os.path.exists(path):
        with open(path, encoding="utf-8") as f:
            for ln in f:
                for tag in ("- DEFER ", "- FROZEN "):
                    if ln.startswith(tag) and ":" in ln[len(tag):]:
                        fid, reason = ln[len(tag):].split(":", 1)
                        reasons[fid.strip()] = reason.strip()
    return reasons


def _probe_text(r):
    """Probe-axis rendering (story 1.26 / #166; spec-tanuki-trajectory §2b;
    spec-tanuki-view D3/D4): a mechanical copy of the drive-recorded values
    (tanuki-drive writes them into progress/manifest results identically) —
    never merged with `status`, never fed into yield/streak/demotion
    displays. `undeclared` (or a pre-axis result) reads as honest absence,
    never as an implicit healthy state and never a silent nothing (D3)."""
    p = r.get("probe") or "undeclared"
    if p == "undeclared":
        return "probe: coverage not assessable — no probe declared"
    txt = f"probe: {p}"
    cps = r.get("checkpoints")
    if cps is not None:
        m = ", ".join(cps.get("matched") or []) or "none"
        u = ", ".join(cps.get("unmatched") or []) or "none"
        txt += f" (checkpoints matched: {m}; unmatched: {u})"
    return txt


def _classify_anomaly(scenario, findings, state):
    """Classify an anomalous drive result against the ledger: is it a known
    finding (and what was decided about it this run), or unmatched — the
    distinction between 'expected noise' and 'look at this now'."""
    tags = []
    for fd in findings:
        if scenario not in fd.get("scenarios", []) or fd.get("tombstone"):
            continue
        if fd["id"] in state.get("deferred", []):
            tags.append((0, f"{fd['id']} deferred"))
        elif fd["id"] in state.get("frozen", []):
            tags.append((0, f"{fd['id']} frozen"))
        elif fd.get("status") in ("open", "proposed"):
            tags.append((1, f"{fd['id']} open"))
    tags.sort()
    if tags:
        more = f" +{len(tags) - 3}" if len(tags) > 3 else ""
        return True, "known: " + ", ".join(t for _, t in tags[:3]) + more
    return False, "UNMATCHED — no ledger finding yet; check this iter's mining"


def _run_deltas(state, findings):
    """This-run ledger movement, from the run-start snapshot (iteration 1's
    findings_before). Legacy id-list snapshots yield only the 'new' delta."""
    if not state["iterations"]:
        return None
    snap = state["iterations"][0].get("findings_before", [])
    legacy = isinstance(snap, list)
    before = {i: None for i in snap} if legacy else snap
    cur = {fd["id"]: fd for fd in findings}
    return {
        "new": [i for i in cur if i not in before],
        # Status transitions open/proposed -> accepted this run. Previously
        # keyed (and rendered) as "fixed", which read as a commit count beside
        # the convergence line's patch fact — it never was one.
        "accepted": [i for i, b in before.items() if b and i in cur
                     and b.get("status") in ("open", "proposed")
                     and cur[i].get("status") == "accepted"],
        "recurred": [i for i, b in before.items() if b and i in cur
                     and cur[i].get("recurrence", 1) > b.get("recurrence", 1)],
        "legacy": legacy,
    }


def _health(state, driving, unmatched):
    """One verdict line: OK / ATTENTION / DONE, with the reason — the answer
    to 'do I need to look at anything?' before any detail is read."""
    n_done = len(state["iterations"])
    pend = []
    if state.get("deferred"):
        pend.append(f"{len(state['deferred'])} deferred decision(s)")
    if state.get("frozen"):
        pend.append(f"{len(state['frozen'])} frozen finding(s)")
    gate_note = f"; {' + '.join(pend)} await your ruling" if pend else ""
    fin = state.get("finished")
    if fin:
        # A delivered run's health follows its DERIVED settlement (owner
        # ruling 2026-07-17): "cap" on a delivered run is not an unopened
        # gate, and nobody restates the forge's decision to flip this line.
        d = state.get("delivered")
        if d:
            s = derive_settlement(state) or {}
            r = s.get("result")
            return {"landed": f"DONE — delivered as PR #{d.get('pr')} and "
                              "landed (reachable from the base)",
                    "pending": f"OK — delivered as PR #{d.get('pr')}; "
                               "awaiting review on the forge",
                    "declined": f"ATTENTION — PR #{d.get('pr')} closed "
                                "without merging; the branch holds unlanded "
                                f"work{gate_note}",
                    }.get(r, f"ATTENTION — delivered as PR #{d.get('pr')} "
                             "but settlement is unknown (forge unreachable, "
                             "no prior observation)")
        # Direct-merge (non-PR) gate: the loop records no `delivered`, so the
        # settlement is derived from the merge's reachability. Once it has
        # LANDED, health is DONE — otherwise (pending/unknown) fall through to
        # the morning-gate guidance below, which is still the operator's action
        # (the morning gate IS the local merge on this path).
        if state.get("gate_mode", "merge") == "merge":
            r = (derive_settlement(state) or {}).get("result")
            if r == "landed":
                return ("DONE — direct merge landed (integration tip reachable "
                        f"from the base){gate_note}")
        return {"gate-ratified": "DONE — ratified at the morning gate",
                "converged": f"OK — converged; run the morning gate{gate_note}",
                # F29: state the numbers the verdict used — same numerator/
                # denominator as the `iterations:` line (consumed count /
                # configured cap), so a cap lower than the planned count or a
                # rolled-back iteration never reads as a contradiction.
                "cap": f"ATTENTION — cap hit ({n_done}/{state['cap']} "
                       "consumed) without convergence; run the "
                       f"morning gate{gate_note}",
                }.get(fin["reason"],
                      f"ATTENTION — run ended: {fin['reason']}{gate_note}")
    if state.get("last_breaker"):
        # F93: re-emitting a stored reason, so the cap breaker's
        # skipped-checks note must survive here too.
        return ("ATTENTION — stopped by breaker: "
                f"{with_skipped_checks_note(state['last_breaker']['reason'])}"
                f"{gate_note}")
    if unmatched:
        return (f"ATTENTION — {unmatched} scenario anomal"
                f"{'ies' if unmatched > 1 else 'y'} match no ledger finding "
                "yet (new problem or mining not done)")
    if driving:
        return f"OK — iteration {n_done} driving; anomalies (if any) are known"
    if state["quiet_streak"] >= 2:
        return f"OK — converged; run the morning gate{gate_note}"
    if n_done >= state["cap"]:
        # F29: same numbers as the `iterations:` line (see the "cap" entry
        # above) — the health verdict and the counter share one denominator.
        return (f"ATTENTION — cap hit ({n_done}/{state['cap']} consumed) "
                f"without convergence; run the morning gate{gate_note}")
    return f"OK — between iterations ({n_done}/{state['cap']} done){gate_note}"


