#!/usr/bin/env python3
"""tanuki-loop: the deterministic safety substrate for unattended cumulative
dogfooding (contract: specs/spec-tanuki-loop/SPEC.md). It owns every scriptable
check, invariant, and rollback so the orchestrating model is responsible ONLY
for judgment — classification, implementation, and running the target's tests.

Zero dependencies. State lives under ~/.tanuki/<target>/loop/<run>/:
  state.json   the loop's machine state (SHAs, attempts, quiet streak, …)
  audit.md     append-only human record of what the loop did
  policy.json  iteration-1 judgment answers, applied unasked from iteration 2
  queue.md     the morning review queue (deferred / frozen items)
A `current` pointer names the active run so subcommands need only --target.

The global `--target <slug>` is required and MUST precede the subcommand name
(`tanuki-loop --target foo init …`, never `tanuki-loop init --target foo`); the
per-subcommand flags below are in addition to it (F40).

Subcommands (JSON out unless noted; a breaker prints {"breaker": …} + exit 3):
  init --loop-repo P [--scenarios F] [--cap N] [--base B] [--worktree W]
       [--phase 1|2|3] [--wall-time S] [--token-budget N] [--policy F]
       [--attempt-cap K] [--test-cmd "<shell cmd>"] [--allow-stale-base]
       --scenarios reads the per-target "loop" block from the scenarios file
       ({"test_cmd", "iterations", "wall_time_s", "token_budget",
        "attempt_cap"}) so a run needs no repo-specific flags; CLI overrides.
       The block is NOT auto-loaded from the canonical path — init/doctor read
       it only from the --scenarios file you pass.
       Fetches <base>'s remote and FAILS CLOSED if the local base is behind
       its upstream (the loop must never dogfood stale code); --allow-stale-base
       overrides to dogfood the local tip anyway. The base is never silently
       moved to the upstream tip.
  doctor --loop-repo P [--scenarios F] [--base B] [--phase 2|3] [--policy F]
       [same overrides as init] [--allow-stale-base]
       READ-ONLY Phase 2/3 headless-readiness validator — no pipeline run, no
       state written. Checks: required loop config (test_cmd, wall_time_s,
       token_budget, attempt_cap, iterations), base freshness (same guard
       init fails closed on), test_cmd on the base tip (throwaway detached
       worktree, removed afterward), test-cmd-artifacts (build output test_cmd
       sheds untracked into a pristine checkout OR regenerates over a base-
       committed tracked file — informational; the untracked case trips
       iter-verify's clean-worktree breaker mid-run, the tracked case makes the
       gate's `git worktree remove` refuse, F111/#242), policy coverage (which
       actionable findings have no policy answer and would DEFER —
       informational), and host cloneability (throwaway clone, removed
       afterward; fatal for hosted targets, a passing note for hostless —
       spec-host-snapshot). Every check is reported in EVERY report, ready or
       not: a check that appears only on success reads as one that materialized
       out of nowhere (F91).
       Not-ready follows the breaker convention ({"breaker": …} + exit 3)
       but persists nothing — there is no run state to write.
       Minimal copy-pasteable scenarios-file skeleton (F132):
         {"target": "<slug>", "plugin": "<path>",
          "loop": {"test_cmd": "<shell cmd>", "iterations": N,
                   "wall_time_s": N, "token_budget": N, "attempt_cap": N}}
       This "loop" block is NOT auto-loaded from the canonical path — pass the
       file with --scenarios <file> (init and doctor read it only from there).
       `doctor --help` carries the fullest scenarios-file documentation
       (the canonical path formula and per-key CLI equivalents) — read it
       before writing one.
  iter-start                     cap / wall-time / external-modification breakers;
                                 records the iteration start SHA + ledger snapshot
  iter-verify [--no-patch] [--allow-artifact PATH]
                                 the five-part integration invariant; records end SHA
  rollback                       reset --hard start + clean -fd + verify; records removed
  test                           run the configured test_cmd in the worktree;
                                 failure is a breaker (skipped if none configured)
  attempt --finding F            per-finding attempt count; freezes past the cap
  record-cycle                   two-quiet convergence; new-actionable computed from
                                 the ledger snapshot and patched from the iteration
                                 SHAs (--new-actionable / --patched override); a
                                 cycle is quiet only if the iteration's persisted
                                 scheduler plan reported quota_met (the
                                 spec-tanuki-scenario-lifecycle loop amendment);
                                 on convergence, attaches the scheduler's
                                 advisory generation-trigger signals (feature
                                 drift / empty unexplored pool) so a false
                                 quiet is named, never silent; a signal that
                                 cannot be computed renders an explicit
                                 "advisory unavailable" state — non-blocking,
                                 but failure never reads as zero drift (#168)
  defer --finding F --reason "…" append to the morning queue
  log --audit "…"                append to the audit artifact
  gate-check                     integration HEAD reachable from base after the merge
  gate-push                      push the base branch to its remote (after gate-check,
                                 before materializing issues); refuses a diverged
                                 remote rather than force-pushing
  gate-pr [--title T] [--body-file F] [--draft]   PR-protected targets: push
                                 the INTEGRATION branch and open one
                                 ready-for-review PR (Draft via --draft)
                                 against the base — DELIVERY, the loop's
                                 terminal act (owner ruling 2026-07-17).
                                 Records {pr, head_sha, base_sha}; never
                                 merges, polls, or waits. Idempotent (an
                                 existing PR is reused); any failure leaves
                                 the local branch intact. Settlement (landed/
                                 pending/declined/unknown) is DERIVED later
                                 by status/init/unresolved from the forge and
                                 the current base — no closing command
  issue-get --key K              print the issue already materialized for a problem key
  issue-put --key K --issue N    record a materialized issue (idempotency)
  policy --finding F --decision "…"   record an iteration-1 judgment answer as
                                 run policy (applied unasked from iteration 2)
  finish --reason R              mark the run terminal (converged | cap |
                                 aborted; gate-ratified is compatibility only
                                 — settlement is derived, owner ruling
                                 2026-07-17) — machine-readable; also deletes
                                 merged integration branches for the target
                                 (unmerged tips kept) — issue #6. A branch still
                                 checked out in its worktree is SKIPPED, not
                                 deleted (a live worktree can't be removed): so
                                 finishing before the loop worktree is removed
                                 leaves the merged branch behind. The skip
                                 reason names the exact `git worktree remove`
                                 to run, then re-finish (F138).
                                 The FIRST computational close (converged/cap/
                                 aborted) is recorded as the run's STOP REASON
                                 and never overwritten. (`--reason aborted` is
                                 the CLI value — pass exactly that; the stop
                                 reason is then STORED/DISPLAYED as
                                 `cancelled`, which is not itself a valid
                                 --reason, F165.) Settlement is derived, never
                                 a stop reason — the two are separate facts.
                                 Execution time ends at the first close
                                 (wall_end); review/merge wait never accrues
  recover --restore | --adopt    ATTENDED recovery from the external-modification
                                 breaker (the one breaker `rollback` cannot clear:
                                 it needs an open iteration, and the breaker fires
                                 with all iterations closed). --restore resets the
                                 worktree to the last verified head_expected,
                                 discarding external commits (audited, recoverable
                                 via reflog); --adopt re-baselines, accepting the
                                 current HEAD as head_expected. Never automatic —
                                 the operator chooses.
  status                         JSON summary for the morning gate
  dashboard [--follow SECS] [--live]   operational status, one screen: health
                                 verdict, latest drive with each anomaly
                                 classified against the ledger (known/deferred/
                                 frozen vs unmatched), this-run deltas (newly
                                 observed / status→accepted / recurred),
                                 the scheduler's actual decisions (verify/explore/
                                 rotation/waiting), convergence conditions met vs
                                 missing, the computational stop reason (cap |
                                 converged | breaker | cancelled — never
                                 gate-ratified, which is a delivery settlement
                                 shown on its own line), and the concrete
                                 decisions the morning gate will ask for.
                                 --live renders only while the run is ACTIVE;
                                 a closed run degrades to the typed empty state
                                 plus one historical line — the substrate of
                                 `/tanuki <t> view live`

Sequencing is guarded: each iteration must move started -> (verified |
rolled_back) before the next iter-start, and record-cycle refuses an open
iteration — a skipped check is itself a breaker, never a silent pass.

Breakers — what actually trips each one, and where (every breaker prints
{"breaker": …, "hint": …} + exit 3; the hint names the remedy).
iter-start evaluates its breakers in a fixed PRECEDENCE — sequencing, then
cap, then wall-time, then external modification — and the FIRST match wins:
a tripped cap masks an external modification that would also have fired
(deliberate — a capped run has no next iteration to protect — but it means
a capped run's worktree is no longer guarded; re-init for a fresh guarded
run, F93):
  iteration cap reached      iter-start, when len(iterations) >= cap. NOTE:
                             rolled-back iterations count toward the cap — a
                             rollback does not give the attempt back.
  wall-time exceeded         iter-start, when now - wall_start > wall_limit_s.
  external modification      iter-start, when EITHER the worktree HEAD is not
                             the head_expected the last iter-verify recorded
                             (something committed outside the loop) OR the
                             worktree is not clean at iteration start (stray
                             uncommitted edits). Both are edits to the loop's
                             OWN worktree; a commit on the base branch does NOT
                             trip it (base is out of scope after init —
                             spec-host-snapshot). DETECTION IS DEFERRED (F41):
                             it is NOT checked when the worktree is touched and
                             NOT checked by iter-verify — only at the NEXT
                             iter-start's HEAD-vs-head_expected comparison. Two
                             corollaries: (1) an edit made after the run's last
                             iteration is never seen (no next iter-start to
                             catch it — the morning-gate diff is the backstop),
                             and (2) a foreign commit landing DURING an open
                             iteration is absorbed into head_expected when
                             iter-verify records the current HEAD, so it never
                             trips the breaker at all. Clear a tripped breaker
                             with `recover --restore|--adopt`, never `rollback`.
  sequencing violation       iter-start on an unclosed iteration, or record-cycle
                             with an iteration still open.
  test failure               test, when the configured test_cmd exits non-zero.
  worktree not clean         after commit, when test_cmd left untracked artifacts.
  integration invariant      iter-verify, when the five-part check fails —
                             including check (e), a committed build artifact
                             (issue #159; --allow-artifact declares one).
  rollback failed            rollback, when the worktree could not be reset.

NOT a breaker — base-branch drift. The base is snapshotted at `init` and is
out of scope for the rest of the run (spec-host-snapshot): a commit landing on
the base branch mid-run is INTENTIONALLY not detected — `iter-verify` succeeds
even if the base moved behind the loop's back, and no breaker fires. Base
freshness is checked once, at `init`/`doctor` (which fail closed on a stale
base), never again mid-run. So "the base changed under me" is expected
behavior, not a missed breaker; only edits to the loop's OWN worktree trip the
external-modification breaker above.

The token budget is stored but NOT enforced here — token accounting is the
runtime's; the loop treats it as an operator-supplied ceiling the harness trips.
"""

import argparse
import json
import os
import shutil
import re
import subprocess
import sys
import tempfile
import time
from datetime import date

TANUKI_ROOT = os.environ.get("TANUKI_ROOT", os.path.expanduser("~/.tanuki"))


def git(repo, *args):
    """Run git in <repo>; return (returncode, stdout minus trailing newlines).
    ONLY trailing newlines are stripped (F186): a full strip() ate the first
    `status --porcelain` line's leading status column (" M app.py" ->
    "M app.py"), so every ln[3:] parser truncated the first filename."""
    r = subprocess.run(["git", "-C", repo, *args],
                       capture_output=True, text=True)
    return r.returncode, (r.stdout or "").rstrip("\n")


def loop_dir(target, run):
    return os.path.join(TANUKI_ROOT, target, "loop", run)


def unfinished_runs(target, exclude=None):
    """Runs for <target> that never reached `finish` AND whose loop worktree
    still exists on disk — the genuinely LIVE runs that share this target's
    machine-wide state (the single `current` pointer + the ledger). A finished
    run, or one whose worktree is gone, can no longer cross-write and is not
    counted (issue #258). Returns [(run_id, worktree), …] sorted by run id."""
    base = os.path.join(TANUKI_ROOT, target, "loop")
    if not os.path.isdir(base):
        return []
    live = []
    for run in os.listdir(base):
        if run in ("current", exclude):
            continue
        sp = os.path.join(base, run, "state.json")
        if not os.path.isfile(sp):
            continue
        try:
            with open(sp, encoding="utf-8") as f:
                st = json.load(f)
        except (ValueError, OSError):
            continue
        if st.get("finished"):
            continue
        wt = st.get("worktree")
        if wt and os.path.isdir(wt):
            live.append((run, wt))
    return sorted(live)


def current_run(target):
    p = os.path.join(TANUKI_ROOT, target, "loop", "current")
    if not os.path.exists(p):
        die("no active loop run; call `init` first")
    with open(p, encoding="utf-8") as f:
        run = f.read().strip()
    # issue #258: `current` names ONE run, but a second `init` can move it out
    # from under a still-live run — so a bare (no --run) subcommand would
    # silently mutate whichever run `current` last named. When more than one
    # live run exists for the target, refuse to guess: the caller must name the
    # run with --run. A single live run (the common case) resolves unchanged,
    # so the everyday single-run path still needs only --target.
    live = unfinished_runs(target)
    if len(live) > 1:
        ids = ", ".join(r for r, _ in live)
        out({"breaker": f"ambiguous — pass --run <id>: target '{target}' has "
                        f"{len(live)} live runs ({ids}) sharing the machine-"
                        f"wide `current` pointer, so a bare subcommand cannot "
                        f"know which you mean (issue #258). `current` -> "
                        f"{run}."})
        sys.exit(3)
    return run


def load_state(target, run=None):
    run = run or current_run(target)
    with open(os.path.join(loop_dir(target, run), "state.json"),
              encoding="utf-8") as f:
        return json.load(f)


def save_state(state):
    d = loop_dir(state["target"], state["run"])
    tmp = os.path.join(d, "state.json.tmp")
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(state, f, indent=2)
    os.replace(tmp, os.path.join(d, "state.json"))


def append(target, run, name, text):
    with open(os.path.join(loop_dir(target, run), name), "a",
              encoding="utf-8") as f:
        f.write(text.rstrip("\n") + "\n")


def audit(state, msg):
    append(state["target"], state["run"], "audit.md",
           f"- [{time.strftime('%Y-%m-%d %H:%M:%S')}] {msg}")


def out(obj):
    print(json.dumps(obj, indent=2))


def die(msg):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(2)


def open_scenarios(path, target):
    """Open a scenarios config, or die naming the CANONICAL location so a
    misplaced or absent config surfaces immediately (issue #4) instead of a raw
    traceback or a silently-read stale copy. The only supported home is
    ~/.tanuki/scenarios/<target>.scenarios.json."""
    p = os.path.expanduser(path)
    if not os.path.exists(p):
        canon = os.path.join(TANUKI_ROOT, "scenarios", f"{target}.scenarios.json")
        die(f"scenarios config not found: {p}\n"
            f"  canonical location: {canon}\n"
            "  (create it with `/tanuki init`; "
            "~/.claude/templates/tanuki/ is NOT read)")
    return open(p, encoding="utf-8")


def breaker_hint(reason, worktree=None):
    """The concrete next step for a breaker, so the {"breaker": …} JSON names
    its remedy instead of forcing the operator to read the source (F4, F53).
    Matched on the reason text; None when no specific remedy applies.
    `worktree` (when the caller has state) lets a hint name the loop worktree
    path — F131: a commit landed in the base repo satisfies the operator but
    never the loop, and the hint must say where to look."""
    r = reason.lower()
    # Cap/wall-time first: the cap reason names the checks it shadowed
    # ("external modification" among them, F93), and matching that phrase
    # first would hand a capped run the recover hint.
    if "iteration cap reached" in r or "wall-time" in r:
        # F93 (attempt 3): the skipped-checks note rides the HINT too — some
        # surfaces show only the hint, and the fact that later precedence
        # checks never ran must survive every rendering of the stop.
        return ("the run hit its ceiling — proceed to the morning gate; no "
                "more iterations run. Later iter-start checks (external "
                "modification among them) were not evaluated — a capped "
                "run's worktree is no longer guarded; re-init for a fresh "
                "guarded run (F93)")
    if "external modification" in r:
        return ("run `tanuki-loop --target <t> recover` and choose --restore "
                "(discard the external change, reset to the last verified HEAD) "
                "or --adopt (accept the current HEAD as the new baseline)")
    if "sequencing violation" in r:
        # Four distinct violations used to share one hint, which was wrong for
        # half of them: told to "close the open iteration" when there is no
        # open iteration, the operator reaches for `rollback`, and THAT failure
        # overwrites last_breaker and disarms `recover` (F82, and the trigger
        # for F17). Discriminate on the reason each site already records.
        if "rollback without an open iteration" in r:
            return ("nothing to roll back — no iteration is open. If you are "
                    "trying to clear an external-modification breaker, "
                    "`rollback` is the wrong tool and running it here "
                    "overwrites the breaker `recover` needs: use "
                    "`tanuki-loop --target <t> recover --restore|--adopt`")
        if "iter-verify without an open iteration" in r:
            return ("no iteration is open to verify — start one with "
                    "`iter-start`, or the previous one is already closed")
        if "record-cycle" in r:
            return ("close the open iteration with `iter-verify` (or "
                    "`rollback`) before recording the cycle")
        return "close the open iteration with `iter-verify` or `rollback` first"
    if "test failure" in r:
        return "a test_cmd failed in the loop worktree — inspect it, then fix or `rollback`"
    if "worktree not clean after commit" in r:
        return ("test_cmd likely left untracked artifacts (e.g. __pycache__, "
                ".pyc, coverage files) — add them to .gitignore or clean them; "
                "the dirty paths are named in the breaker reason")
    if "head == start sha but a patch was expected" in r:
        # (matched lowercase: `r` is reason.lower() — the original mixed-case
        # match here never fired, handing this breaker the generic hint)
        # F131: the no-patch case has a concrete remedy — don't fall through to
        # the generic "inspect the worktree" hint the other invariant failures
        # get. The iteration simply committed nothing — OR committed somewhere
        # the loop never looks (F131 residual: a commit made in the base repo
        # instead of the loop worktree reads exactly like this).
        return ("this iteration produced no commit — stage the work and "
                "commit it; if you committed, check it landed in the loop "
                f"worktree {worktree or '<worktree>'}, not the base repo — "
                "and use `iter-verify --no-patch` when no change was "
                "expected this iteration; or `rollback` to undo the iteration")
    if "build artifacts committed" in r:
        # Check (e) has a concrete remedy — never the generic "inspect" hint
        # (the F131 lesson, applied to the new check).
        return ("the iteration's commits add regenerable build output — the "
                "paths are named in the breaker reason. Drop them (`git rm -r "
                "--cached <path>`, add them to .gitignore, commit) or "
                "`rollback` the iteration; a legitimate binary is declared "
                "deliberately with `iter-verify --allow-artifact <path>`")
    if "integration invariant" in r:
        return ("the five-part integration check failed — the iteration is in an "
                "inconsistent state; reset it with `tanuki-loop --target <t> "
                "rollback` (resets to the start SHA and cleans the worktree), or "
                "inspect the worktree against the audit trail first")
    if "rollback failed" in r:
        return "the worktree could not be reset cleanly — inspect it by hand at the start SHA"
    return None


def with_skipped_checks_note(reason):
    """F93 (attempt 3): EVERY emission of the iteration-cap breaker carries
    the skipped-checks note. iter-start writes it at the source, but a
    last_breaker persisted by a pre-note build resurfaces BARE through the
    surfaces that re-emit the stored reason (status, dashboard, _health,
    run_verdict) — that is exactly how a driven session met a bare
    'cap reached' after the source-site fix. Append on render when absent;
    a reason that already states it passes through untouched."""
    if "iteration cap reached" in reason and "not evaluated" not in reason:
        return (reason + " — later checks (wall-time, external modification) "
                "were not evaluated (F93); with no further iter-start to run "
                "it, the worktree is no longer guarded against external "
                "modification until a new run is initialized")
    return reason


def breaker(state, reason):
    # Persist machine-readably so a dashboard can answer "why did it stop?"
    hint = breaker_hint(reason, worktree=state.get("worktree"))
    entry = {"reason": reason, "at": time.strftime("%Y-%m-%d %H:%M:%S")}
    if hint:
        entry["hint"] = hint
    # A failed remedy attempt must never erase the diagnosis it was aimed at.
    # `rollback` is the reflex for "undo the bad thing", but on an
    # external-modification breaker it raises a sequencing violation (no
    # iteration is open), and overwriting last_breaker with THAT disarmed
    # `recover`, whose precondition is an external-modification breaker — the
    # operator had to re-trigger the original breaker to get unstuck (F17).
    # Keep the original diagnosis; record the attempt alongside it.
    prev = state.get("last_breaker") or {}
    guard = ("external modification" in prev.get("reason", "")
             and not prev.get("recovered")
             and "sequencing violation" in reason.lower())
    payload = {"breaker": reason}
    if guard:
        state.setdefault("failed_remedies", []).append(entry)
        note = ("the external-modification breaker from %s is still the "
                "active one and `recover` remains armed — this attempt did "
                "not clear it and has not overwritten it"
                % prev.get("at", "earlier"))
        payload["preserved_breaker"] = prev.get("reason")
        payload["note"] = note
    else:
        state["last_breaker"] = entry
    save_state(state)
    audit(state, f"BREAKER (immediate stop): {reason}"
                 + (f" | hint: {hint}" if hint else "")
                 + (" | last_breaker preserved (external modification still "
                    "active; recover still armed)" if guard else ""))
    if hint:
        payload["hint"] = hint
    out(payload)
    sys.exit(3)


def ledger_findings(target):
    """Findings currently in the target's ledger (read-only)."""
    path = os.path.join(TANUKI_ROOT, target, "ledger.json")
    if not os.path.exists(path):
        return []
    with open(path, encoding="utf-8") as f:
        return json.load(f).get("findings", [])


def ledger_finding_ids(target):
    return [fd["id"] for fd in ledger_findings(target)]


def ledger_reuse_note(target):
    """F164 / issue #237: the loop's init path shares the machine-wide target
    namespace (~/.tanuki/<target>, F94), so a slug that collides with an
    unrelated session silently inherits its ledger findings/events. tanuki-ledger
    init states this reuse; the loop's init path did not, so a fresh target was
    silently assumed. Return a one-line note (its size) or None when the
    namespace has no ledger yet. Read-only; follows the announce_new_target rule
    — states, never blocks."""
    path = os.path.join(TANUKI_ROOT, target, "ledger.json")
    if not os.path.exists(path):
        return None
    try:
        with open(path, encoding="utf-8") as f:
            led = json.load(f)
    except (OSError, ValueError):
        return None
    nf = len(led.get("findings", []) or [])
    ne = len(led.get("events", {}) or {})
    if not nf and not ne:
        return None
    return (f"reusing the existing ledger for target '{target}' "
            f"({ne} event record(s), {nf} finding(s)) — ~/.tanuki is shared "
            f"machine-wide (F94). If you expected a fresh target, stop and pick "
            f"an unused slug; this run will draw on the inherited findings")


def plan_record(state, iter_n):
    """The persisted scheduler plan for this loop iteration's drive run
    (<run>-iterN), or None for runs/schedulers that predate persisted plans."""
    spath = os.path.join(TANUKI_ROOT, state["target"], "scheduler.json")
    if not os.path.exists(spath):
        return None
    with open(spath, encoding="utf-8") as f:
        plans = json.load(f).get("plans", [])
    rid = f"{state['run']}-iter{iter_n}"
    return next((p for p in reversed(plans) if p.get("run") == rid), None)


def drove_outside_scheduler(state):
    """Run provenance for the empty-state expected-vs-gap signal (F166 /
    issue #236; spec-tanuki-view D3, spec-tanuki-loop fixed-skeleton point 2).
    A run with iterations but NO persisted plan record for any of them drove
    outside the scheduler — a manual, toy, or ad-hoc run — so an empty
    `latest drive` / `scheduler decisions` section is EXPECTED, not a gap.
    Derived purely from persisted artifacts (plan_record presence), never
    guessed. Returns False for a run with no iterations at all (that case has
    its own not-started empty states)."""
    n_iters = len(state.get("iterations") or [])
    if not n_iters:
        return False
    return all(plan_record(state, n) is None for n in range(1, n_iters + 1))


def generate_advisory(target):
    """Advisory generation-trigger signals for the convergence report (issue
    #168): uncovered plugin surface (feature drift) and an empty unexplored
    pool are the two `generate` triggers that previously surfaced nowhere near
    the moment they matter most — a loop declaring convergence (the false-quiet
    risk spec-tanuki-scenario-lifecycle §3 names). The arithmetic is owned by
    the sibling scheduler (`status` emits it as `advisories`); this only reads
    and phrases it. Non-blocking, never silent: a failure — missing sibling,
    old scheduler without advisories, bad JSON — returns an explicit
    {"unavailable": True, "reason": …} so a broken signal can never read as
    zero drift, and it never raises, so it can never break record-cycle.
    Returns {"notes": [...], "generate": "..."} when a signal fires, None
    ONLY when the scheduler answered and there is genuinely nothing to say."""
    try:
        sched_tool = os.path.join(
            os.path.dirname(os.path.abspath(__file__)), "tanuki-scheduler")
        r = subprocess.run([sys.executable, sched_tool, "--target", target,
                            "status"], capture_output=True, text=True,
                           timeout=30)
        if r.returncode != 0:
            return {"unavailable": True,
                    "reason": f"tanuki-scheduler status exited {r.returncode}"}
        adv = json.loads(r.stdout).get("advisories")
        if adv is None:
            return {"unavailable": True,
                    "reason": "scheduler status emits no advisories "
                              "(pre-#168 tool)"}
        notes = []
        if adv.get("feature_drift"):
            names = ", ".join(f"{u['kind']} {u['name']}"
                              for u in adv["feature_drift"])
            notes.append(f"uncovered plugin surface: {names}")
        if adv.get("unexplored_pool_empty"):
            notes.append("unexplored pool empty")
        if not notes:
            return None
        return {"notes": notes, "generate": adv.get("generate")}
    except Exception as e:
        return {"unavailable": True,
                "reason": f"{type(e).__name__} reading scheduler status"}


def cleanup_merged_integration_branches(repo, base, target):
    """Delete this target's integration branches whose tip is reachable from
    <base> (i.e. merged); keep unmerged tips, and skip any branch still checked
    out in a worktree. This is the owner of gate step 6's deferred "later branch
    cleanup" (issue #6) — nothing else ever deleted them, so merged
    `tanuki-loop/<target>/<ts>` branches used to accumulate until an unrelated
    tool collected them. Returns {"deleted", "kept", "skipped"}."""
    prefix = f"tanuki-loop/{target}/"
    rc, refs = git(repo, "for-each-ref", "--format=%(refname:short)",
                   f"refs/heads/{prefix}*")
    branches = [b for b in refs.splitlines()
                if b.startswith(prefix)] if rc == 0 else []
    rc_w, wt = git(repo, "worktree", "list", "--porcelain")
    # Track which worktree holds each branch, so the skip reason can name the
    # exact `git worktree remove` command instead of leaving the operator to
    # infer it (F9) — the porcelain lists `worktree <path>` before its `branch`.
    checked_out = {}
    _wt_path = None
    for ln in wt.splitlines():
        if ln.startswith("worktree "):
            _wt_path = ln[len("worktree "):]
        elif ln.startswith("branch "):
            checked_out[ln[len("branch "):].replace("refs/heads/", "")] = _wt_path
    deleted, kept, skipped = [], [], []
    # Why each branch was skipped, so the status isn't opaque on-screen (F9):
    # a live worktree can't be deleted, and a merged branch whose delete failed
    # is a different (and more alarming) situation than the routine former.
    skipped_reasons = {}
    # `kept` used to carry no reason while `skipped` did, so a reader had to
    # infer from the help that "kept" means unmerged (F143). State it, for the
    # same "never opaque on-screen" reason skipped_reasons exists.
    kept_reasons = {}
    for b in branches:
        if b in checked_out:
            skipped.append(b)                       # can't delete a live branch
            _p = checked_out[b]
            skipped_reasons[b] = (
                "checked out in a worktree — remove it first: "
                "`git worktree remove %s` (if it refuses over regenerable "
                "output like `__pycache__`/`*.pyc`, add `--force` or "
                "`git clean -fd` in the worktree then retry — that residue is "
                "not work product, F111), then re-run `tanuki-loop --target "
                "%s finish --reason <reason>` (or the next `init` will collect "
                "it)" % (_p or "<path>", target))
        elif git(repo, "merge-base", "--is-ancestor", b, base)[0] == 0:
            if git(repo, "branch", "-D", b)[0] == 0:
                deleted.append(b)
            else:
                skipped.append(b)
                skipped_reasons[b] = "merged but 'git branch -D' failed"
        else:
            kept.append(b)                          # unmerged tip — never delete
            kept_reasons[b] = ("tip not reachable from %s (unmerged) — kept "
                               "deliberately; only a merged branch is deleted "
                               "(reconcile or merge it, or `/repo-cleanup` after "
                               "an attended decision)" % base)
    return {"deleted": deleted, "kept": kept, "skipped": skipped,
            "skipped_reasons": skipped_reasons, "kept_reasons": kept_reasons}


# --- unresolved: the reconcile pass's discovery + mechanical signals ---------
# (spec-tanuki-loop "Reconcile substrate + drift notification")
#
# SIGNALS, NEVER VERDICTS. This tool must not print, return, or imply
# already-landed / superseded / conflicting / still-applicable. Those are
# semantic: on 2026-07-17 every one of 25 commits was patch-non-equivalent
# (`git cherry` called them all unmerged) while several were already landed,
# and a commit subjected "render the module docstrings in --help" carried a
# REJECTED design in another hunk. A tool guessing a verdict from patch
# identity or a subject line would be confidently wrong, and confidently wrong
# is worse than silent — it is the failure the reconcile pass exists to
# prevent. The verdicts belong to that attended pass.
#
# The closed set of field names this payload may use for per-commit facts.
# Enforced (see _assert_no_verdicts) rather than left to discipline, because
# the instinct to add "applicable": true here is exactly what the rule forbids.
_VERDICT_WORDS = ("landed", "applicable", "superseded", "conflicting",
                  "conflict", "verdict", "recommend", "should_land", "safe")


def _assert_no_verdicts(payload):
    """A verdict-shaped key is a bug, not a feature (spec: signals never
    verdicts). Fail loudly here rather than let one reach an operator who
    would reasonably trust it."""
    def walk(o, path=""):
        if isinstance(o, dict):
            for k, v in o.items():
                kl = str(k).lower()
                for w in _VERDICT_WORDS:
                    if w in kl:
                        raise AssertionError(
                            f"unresolved emitted a verdict-shaped field "
                            f"{path}{k!r}: classification is the reconcile "
                            f"pass's judgment, not this tool's "
                            f"(spec-tanuki-loop, Rules)")
                walk(v, f"{path}{k}.")
        elif isinstance(o, list):
            for i in o:
                walk(i, path)
    walk(payload)
    return payload


def _loop_repo_for(target, explicit=None):
    """The loop repo for a target: an explicit --loop-repo wins (the contract
    for scripts); otherwise the most recent run's state.json, which recorded
    it. Never guessed from cwd."""
    if explicit:
        return explicit
    d = os.path.join(TANUKI_ROOT, target, "loop")
    if not os.path.isdir(d):
        return None
    runs = sorted(r for r in os.listdir(d)
                  if os.path.isdir(os.path.join(d, r)))
    for run in reversed(runs):
        p = os.path.join(d, run, "state.json")
        if os.path.exists(p):
            try:
                with open(p, encoding="utf-8") as f:
                    return json.load(f).get("loop_repo")
            except (ValueError, OSError):
                continue
    return None


def unresolved_branches(repo, target, base=None):
    """Signals for this target's unmerged integration branches. Read-only.

    Reuses cleanup_merged_integration_branches' resolution — same prefix, same
    worktree mapping, same reachability test — so this cannot disagree with
    the sweep that decides what gets deleted.
    """
    prefix = f"tanuki-loop/{target}/"
    rc, refs = git(repo, "for-each-ref", "--format=%(refname:short)",
                   f"refs/heads/{prefix}*")
    branches = [b for b in refs.splitlines()
                if b.startswith(prefix)] if rc == 0 else []
    base = base or git(repo, "symbolic-ref", "--short", "HEAD")[1] or "main"
    # Same worktree map shape as the cleanup sweep (F9).
    checked_out, _wt = {}, None
    for ln in git(repo, "worktree", "list", "--porcelain")[1].splitlines():
        if ln.startswith("worktree "):
            _wt = ln[len("worktree "):]
        elif ln.startswith("branch "):
            checked_out[ln[len("branch "):].replace("refs/heads/", "")] = _wt
    out = []
    for b in branches:
        # Merged tips are the sweep's business, not this command's: they are
        # not a debt.
        if git(repo, "merge-base", "--is-ancestor", b, base)[0] == 0:
            continue
        ahead = git(repo, "rev-list", "--count", f"{base}..{b}")[1]
        behind = git(repo, "rev-list", "--count", f"{b}..{base}")[1]
        last = git(repo, "log", "-1", "--format=%cI", b)[1]
        days = None
        if last:
            try:
                days = (date.today() - date.fromisoformat(last[:10])).days
            except ValueError:
                days = None
        commits = []
        for line in git(repo, "log", "--format=%h%x00%s", f"{base}..{b}")[1].splitlines():
            sha, _, subj = line.partition("\0")
            files = git(repo, "show", "--name-only", "--format=", sha)[1].split()
            body = git(repo, "log", "-1", "--format=%B", sha)[1]
            commits.append({
                "sha": sha,
                # The subject is REPORTED because an operator reads it, and
                # flagged as inadmissible because they should not trust it:
                # 8f4d556's subject described one of its two hunks.
                "subject": subj,
                "files": files,
                # A fact about git, NOT a synonym for applicable. Named for
                # what it measures.
                "cherry_picks_cleanly": _picks_cleanly(repo, sha, base),
                # Findings the message cites, paired with their CURRENT status
                # — a citation of a finding now accepted-and-tombstoned is a
                # superseded *candidate* for the pass to judge, never a verdict
                # here.
                "cites_findings": _cited_findings(target, body),
            })
        wt = checked_out.get(b)
        out.append({
            "branch": b, "tip": git(repo, "rev-parse", "--short", b)[1],
            "ahead": int(ahead) if ahead.isdigit() else 0,
            "behind": int(behind) if behind.isdigit() else 0,
            "last_commit": last or None, "days_since_last_commit": days,
            "worktree": wt,
            "worktree_clean": (git(wt, "status", "--porcelain")[1] == ""
                               if wt and os.path.isdir(wt) else None),
            "commits": commits,
        })
    return sorted(out, key=lambda r: -(r["behind"]))


def _picks_cleanly(repo, sha, base):
    """Would `cherry-pick <sha>` onto <base> apply without conflict?

    Cherry-pick semantics are a three-way merge with the commit's PARENT as
    the merge base — merging <base> with <sha> directly is a different
    question (it drags in every earlier commit on the branch) and answers it
    wrong: a commit that only adds a new file reads as conflicting because
    something else on the branch touched a shared file. A field named
    `cherry_picks_cleanly` that measures a different merge is worse than no
    field at all.

    Uses the ORIGINAL `merge-tree <base-tree> <branch1> <branch2>` form, which
    is a pure three-way merge: it touches no index, no ref and no worktree, and
    exists in every git this repo could plausibly run on. The newer
    `--write-tree --merge-base=` spelling is git >= 2.38 and returns a *usage
    error* (129) on older gits — which, tested for with `rc == 0`, silently
    reports EVERY commit as conflicting. This function is a signal the
    reconcile pass reads; a fabricated one is worse than none, so it detects
    conflict from the merge output rather than an exit code whose meaning
    varies by version.

    Still NOT a verdict: 8f4d556 applied perfectly and carried a rejected
    design.
    """
    rc, merged = git(repo, "merge-tree", f"{sha}^", base, sha)
    if rc != 0:
        return None            # unknown, never a cheerful default
    return "<<<<<<<" not in merged


def _cited_findings(target, body):
    """Finding ids a commit message cites, each with its CURRENT ledger status
    (or null when the ledger has no such id). Pairing them is the point: the
    citation alone is what a subject line is — a claim, not evidence."""
    ids = sorted(set(re.findall(r"\bF\d+\b", body or "")))
    if not ids:
        return []
    statuses = {}
    p = os.path.join(TANUKI_ROOT, target, "ledger.json")
    if os.path.exists(p):
        try:
            with open(p, encoding="utf-8") as f:
                for fd in json.load(f).get("findings", []):
                    statuses[fd["id"]] = {
                        "status": fd.get("status"),
                        "tombstoned": bool(fd.get("tombstone")),
                    }
        except (ValueError, OSError):
            pass
    return [{"id": i, **(statuses.get(i) or {"status": None,
                                             "tombstoned": None})}
            for i in ids]


def drift_note(target, repo):
    """One line for stderr when a debt exists, else None.

    Never blocks, never prompts (the announce_new_target rule: unattended
    callers must keep working). States; never acts.
    """
    if not repo or not os.path.isdir(repo):
        return None
    try:
        rows = unresolved_branches(repo, target)
    except Exception:
        return None            # a notification must never break a run
    if not rows:
        return None
    worst = max(r["behind"] for r in rows)
    n = len(rows)
    # F188/F157: "behind the base" is jargon to a cold reader — gloss it
    # inline as "the base gained commits the branch never picked up".
    staleness = (f"the most stale is {worst} commit(s) behind the base "
                 f"(the base branch has since gained {worst} commit(s) this "
                 f"branch never picked up, so its work is drifting from "
                 f"current code)"
                 if worst else "none has fallen behind the base yet (the base "
                 "branch has not advanced since these were cut)")
    # F157 (recurrence): a cold reader could not tell whether this banner
    # belongs to the run rendered below or to wider state — name the scope.
    return (f"note: {n} unresolved loop branch(es) — a target-wide backlog "
            f"check across ALL of this target's past runs, independent of "
            f"the run shown below: integration branches "
            f"holding work that never merged; {staleness}. "
            f"Run the `/tanuki-loop {target} reconcile` slash command "
            f"(a Claude Code slash command, run in a Claude Code session — "
            f"not a subcommand of this tool) to report what to do "
            f"with them.")


def cmd_unresolved(args):
    repo = _loop_repo_for(args.target, getattr(args, "loop_repo", None))
    if not repo or not os.path.isdir(repo):
        body, typed = empty_state("unresolved:no-loop-repo", args.target)
        payload = _assert_no_verdicts(
            {"target": args.target, "loop_repo": repo, "branches": [],
             "empty_state": typed})
        if args.json:
            out(payload)
        else:
            print(f"unresolved — {args.target}\n  {body}")
        return
    rows = unresolved_branches(repo, args.target)
    # Settlement annotation (owner ruling 2026-07-17): a branch whose run
    # delivered a PR carries the derived outcome — `pending` is awaiting
    # review (not rot), `declined` is exactly the debt this surface exists
    # for. This is a mechanical fact from the forge and reachability, not a
    # verdict: what to DO with a declined branch stays reconcile's judgment.
    dmap = _delivered_states(args.target)
    for r in rows:
        st = dmap.get(r["branch"])
        if st:
            s = derive_settlement(st)
            r["delivered"] = {"pr": s.get("pr"), "url": s.get("url"),
                              "settlement": {k: s.get(k) for k in
                                             ("result", "detail",
                                              "observed_at", "stale")
                                             if s.get(k) is not None}}
    payload = {"target": args.target, "loop_repo": repo, "branches": rows,
               "empty_state": None}
    if not rows:
        body, typed = empty_state("unresolved:none", args.target)
        payload["empty_state"] = typed
    _assert_no_verdicts(payload)
    write_unresolved_brief(args.target, payload)
    if args.json:
        out(payload)
        return
    print(f"unresolved — {args.target}")
    if not rows:
        print(f"  {body}")
        return
    for r in rows:
        print(f"  {r['branch']}  {r['ahead']} ahead / {r['behind']} behind"
              + (f", last commit {r['days_since_last_commit']}d ago"
                 if r["days_since_last_commit"] is not None else ""))
        dv = r.get("delivered")
        if dv:
            s = dv.get("settlement", {})
            print(f"    delivered as PR #{dv.get('pr')} — settlement: "
                  f"{s.get('result', '?')}"
                  + (" (last observed "
                     f"{s.get('observed_at')})" if s.get("stale") else "")
                  + f" — {s.get('detail', '')[:100]}")
        for c in r["commits"]:
            picks = {True: "picks-clean", False: "conflicts",
                     None: "pick-unknown"}[c["cherry_picks_cleanly"]]
            cites = ", ".join(f"{x['id']}={x['status'] or '?'}"
                              + ("+tombstoned" if x["tombstoned"] else "")
                              for x in c["cites_findings"])
            print(f"    {c['sha']}  {picks:<11} {c['subject'][:52]}"
                  + (f"  [cites {cites}]" if cites else ""))
    print("\n  These are SIGNALS, not verdicts: whether a change is already "
          "landed,\n  superseded, conflicting or still applicable is judgment "
          "— and a subject\n  line is a claim, not evidence. "
          f"The `/tanuki-loop {args.target} reconcile` slash command "
          "(a Claude Code\n  slash command, run in a Claude Code session — "
          "not a subcommand of this\n  tool) classifies them.")


def write_unresolved_brief(target, payload):
    """The stable-path brief (spec: ~/.tanuki/<target>/unresolved.md — NEVER
    the target repo, which nothing may write to)."""
    d = os.path.join(TANUKI_ROOT, target)
    if not os.path.isdir(d):
        return None
    lines = [f"# Unresolved loop branches — {target}", "",
             f"_Generated by `tanuki-loop --target {target} unresolved`. "
             f"Signals only — the verdicts are the reconcile pass's._", ""]
    if not payload["branches"]:
        # F166: the brief carries the same expected-vs-gap verdict the
        # dashboard renders — a bare reason states the emptiness without
        # saying whether it is normal.
        es = payload["empty_state"]
        tag = ("expected for this run's state" if es["expected"]
               else "GAP" + (f" — `{es['next']}`" if es["next"] else ""))
        lines += [f"{es['reason']} ({tag})", ""]
    else:
        lines += [f"**{len(payload['branches'])} branch(es) hold work that "
                  f"never merged.** The `/tanuki-loop {target} reconcile` "
                  f"slash command (a Claude Code slash command, run in a "
                  f"Claude Code session — not a subcommand of this tool) "
                  f"reports what to do with each.", ""]
        for r in payload["branches"]:
            lines.append(f"## {r['branch']}")
            lines.append(f"- {r['ahead']} ahead / **{r['behind']} behind**"
                         + (f" · last commit {r['days_since_last_commit']}d ago"
                            if r["days_since_last_commit"] is not None else ""))
            if r["worktree"]:
                lines.append(f"- worktree: `{r['worktree']}`"
                             + ("" if r["worktree_clean"] else " (dirty)"))
            lines.append("")
            for c in r["commits"]:
                cites = ", ".join(f"{x['id']}={x['status'] or '?'}"
                                  for x in c["cites_findings"])
                mark = {True: "", False: " — *conflicts*",
                        None: " — *pick state unknown*"}[
                            c["cherry_picks_cleanly"]]
                lines.append(f"- `{c['sha']}` {c['subject']}{mark}"
                             + (f" — cites {cites}" if cites else ""))
            lines.append("")
    p = os.path.join(d, "unresolved.md")
    tmp = p + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        f.write("\n".join(lines) + "\n")
    os.replace(tmp, p)
    return p


# ── Deterministic disposition + port engine ──────────────────────────────────
# spec-tanuki-loop "Reconcile substrate" transition note (#210, ratified
# 2026-07-19), story 1.38 (#211). "Deterministic" = requires no owner semantic
# decision — established here by mechanical evidence per HUNK (reverse-apply,
# forward-apply, postimage containment), never by patch identity alone or a
# subject line. Anything a check cannot evidence FAILS CLOSED to the gate
# (`conflicting` with the evidence, or `needs-owner` when no evidence could be
# computed at all). This engine never merges, never pushes, never deletes a
# branch, and owns no gate — it applies onto a reconcile staging branch that
# the orchestration (#213) later gates and merges.

def _split_commit_patch(repo, sha):
    """Per-file, per-hunk decomposition of one commit.

    Returns [{"file", "header", "hunks": [hunktext...], "opaque": reason|None}]
    — `opaque` marks a file diff the engine cannot classify hunk-by-hunk
    (binary, rename/copy); an opaque file fails the whole unit closed.
    """
    rc, raw = git(repo, "show", "--format=", "--no-color", "-U3", sha)
    if rc != 0:
        return None
    files, cur = [], None
    for line in raw.splitlines():
        if line.startswith("diff --git "):
            cur = {"file": line.split(" b/", 1)[-1], "header": [line],
                   "hunks": [], "opaque": None}
            files.append(cur)
        elif cur is None:
            continue
        elif line.startswith("@@"):
            cur["hunks"].append([line])
        elif cur["hunks"]:
            cur["hunks"][-1].append(line)
        else:
            cur["header"].append(line)
            if line.startswith("Binary files"):
                cur["opaque"] = "binary"
            elif line.startswith(("rename from", "copy from")):
                cur["opaque"] = "rename-or-copy"
    for f in files:
        f["hunks"] = ["\n".join(h) + "\n" for h in f["hunks"]]
        f["header"] = "\n".join(f["header"]) + "\n"
        if not f["hunks"] and not f["opaque"]:
            f["opaque"] = "no-textual-hunks"
    return files


def _hunk_added_lines(hunk_text):
    return [ln[1:].strip() for ln in hunk_text.splitlines()
            if ln.startswith("+") and not ln.startswith("+++")
            and ln[1:].strip()]


def _classify_hunk(wt, header, hunk_text, base_file_text):
    """One hunk against the evaluation tree checked out at `wt`.

    landed          — reverse-applies: the exact change is already present.
    applicable      — forward-applies cleanly.
    landed-diverged — neither applies, but every line the hunk ADDS already
                      exists in the evaluated version of the file: the
                      behavior arrived by another route (F72's SKILL.md hunk).
    conflicting     — none of the above: a genuine divergence; escalates.
    """
    import tempfile as _tf
    patch = header + hunk_text
    with _tf.NamedTemporaryFile("w", suffix=".patch", delete=False) as f:
        f.write(patch)
        pf = f.name
    try:
        if git(wt, "apply", "--check", "--reverse", "-p1", pf)[0] == 0:
            return "landed", "reverse-apply clean"
        if git(wt, "apply", "--check", "-p1", pf)[0] == 0:
            return "applicable", "forward-apply clean"
        added = _hunk_added_lines(hunk_text)
        if added and base_file_text is not None and \
                all(a in base_file_text for a in added):
            return ("landed-diverged",
                    "every added line already present in the evaluated file")
        return "conflicting", "neither applies; added lines not all present"
    finally:
        os.unlink(pf)


def _findings_superseded(cites):
    """True when every cited finding is accepted-and-tombstoned — the spec's
    superseded *candidate* signal, used only to LABEL a unit whose hunks the
    checks already evidenced as landed. Never a verdict by itself."""
    return bool(cites) and all(
        c.get("status") == "accepted" and c.get("tombstoned") for c in cites)


def _dispose_unit(repo, wt, eval_ref, commit, branch):
    """Classify one semantic change unit (a commit, decomposed per hunk).

    Returns the unit's disposition record: disposition, action, per-hunk
    evidence, and — for ports — which hunks land and which are dropped by
    name. Fail-closed: any hunk the checks cannot evidence escalates the
    whole unit; nothing is guessed."""
    sha, subject = commit["sha"], commit["subject"]
    rec = {"sha": sha, "subject": subject, "branch": branch,
           "evaluated_against": eval_ref, "hunks": [],
           "cites_findings": commit.get("cites_findings", [])}
    files = _split_commit_patch(repo, sha)
    if files is None:
        rec.update(disposition="needs-owner", action="escalate",
                   reason="could not read the commit's patch")
        return rec
    statuses = set()
    for fd in files:
        if fd["opaque"]:
            rec["hunks"].append({"file": fd["file"], "status": "unknown",
                                 "evidence": fd["opaque"]})
            statuses.add("unknown")
            continue
        rc, shown = git(wt, "show", f"HEAD:{fd['file']}")
        base_text = shown if rc == 0 else None
        for i, h in enumerate(fd["hunks"]):
            st, ev = _classify_hunk(wt, fd["header"], h, base_text)
            rec["hunks"].append({"file": fd["file"], "hunk": i,
                                 "status": st, "evidence": ev})
            statuses.add(st)
    if "unknown" in statuses:
        rec.update(disposition="needs-owner", action="escalate",
                   reason="a hunk yielded no computable evidence "
                          "(fail closed, never guessed)")
    elif statuses <= {"landed", "landed-diverged"}:
        rec.update(
            disposition=("superseded"
                         if _findings_superseded(rec["cites_findings"])
                         else "already-landed"),
            action="drop",
            reason="every hunk evidenced as already present")
    elif "conflicting" in statuses:
        # Plain `apply` is stricter than cherry-pick's three-way merge: a
        # hunk failing only on drifted context still picks cleanly. The
        # three-way result is the arbiter; a conflict it cannot resolve is
        # a genuine divergence and escalates.
        if _picks_cleanly(repo, sha, eval_ref):
            rec.update(disposition="still-applicable", action="cherry-pick",
                       reason="three-way merge against the evaluated tree "
                              "is clean (apply-context drift only)")
        else:
            rec.update(disposition="conflicting", action="escalate",
                       reason="a hunk genuinely diverges from the "
                              "evaluated tree")
    else:
        whole = all(h["status"] == "applicable" for h in rec["hunks"])
        if whole and _picks_cleanly(repo, sha, eval_ref):
            rec.update(disposition="still-applicable", action="cherry-pick",
                       reason="every hunk applicable; three-way clean")
        else:
            # Entangled unit (F72/F10): only the applicable hunks land;
            # everything already present is dropped BY NAME.
            rec.update(disposition="still-applicable", action="port",
                       reason="applicable hunk(s) evidenced against the "
                              "evaluated tree; the rest already present")
            rec["dropped_hunks"] = [
                {"file": h["file"], "hunk": h.get("hunk"),
                 "why": h["status"]}
                for h in rec["hunks"] if h["status"] != "applicable"]
    return rec


def _staging_branch(target):
    return f"tanuki-loop/{target}/reconcile"


def _already_applied(repo, staging, sha):
    """Idempotency: a full source sha in the staging log (cherry-pick -x
    trailer or the port commit's Source: line) means this unit landed."""
    rc, full = git(repo, "rev-parse", sha)
    if rc != 0:
        return False
    rc, hits = git(repo, "log", staging, f"--grep={full.strip()}",
                   "--format=%H")
    return rc == 0 and bool(hits.strip())


def _apply_unit(repo, wt, rec, target):
    """Perform a cherry-pick or port in the staging worktree. Any failure
    reverts the worktree and demotes the unit to `conflicting` (fail closed —
    the staging tip may have diverged from what was classified)."""
    sha = rec["sha"]
    full = git(repo, "rev-parse", sha)[1].strip()
    if rec["action"] == "cherry-pick":
        rc, _msg = git(wt, "cherry-pick", "-x", sha)
        if rc != 0:
            git(wt, "cherry-pick", "--abort")
            rec.update(disposition="conflicting", action="escalate",
                       applied=False,
                       reason="cherry-pick failed against the staging tip")
            return False
        rec["applied"] = True
        rec["applied_as"] = git(wt, "rev-parse", "--short", "HEAD")[1].strip()
        return True
    import tempfile as _tf
    files = _split_commit_patch(repo, sha)
    keep = {(h["file"], h.get("hunk")) for h in rec["hunks"]
            if h["status"] == "applicable"}
    patch = "".join(
        fd["header"] + "".join(h for i, h in enumerate(fd["hunks"])
                               if (fd["file"], i) in keep)
        for fd in files
        if any((fd["file"], i) in keep for i in range(len(fd["hunks"]))))
    with _tf.NamedTemporaryFile("w", suffix=".patch", delete=False) as f:
        f.write(patch)
        pf = f.name
    try:
        if git(wt, "apply", "-p1", pf)[0] != 0:
            git(wt, "checkout", "--", ".")
            rec.update(disposition="conflicting", action="escalate",
                       applied=False,
                       reason="port apply failed against the staging tip")
            return False
        dropped = "\n".join(
            f"  dropped: {d['file']} hunk {d['hunk']} ({d['why']})"
            for d in rec.get("dropped_hunks", []))
        msg = (f"port {sha}: {rec['subject']}\n\n"
               f"Ported the applicable hunk(s) of an entangled commit; the "
               f"rest were\nevidenced as already present and dropped by "
               f"name:\n{dropped or '  (none)'}\n\n"
               f"Source: {rec['branch']}@{full} (tanuki-loop dispose)")
        git(wt, "add", "-A")
        if git(wt, "commit", "-m", msg)[0] != 0:
            rec.update(disposition="needs-owner", action="escalate",
                       applied=False, reason="port commit failed")
            return False
        rec["applied"] = True
        rec["applied_as"] = git(wt, "rev-parse", "--short", "HEAD")[1].strip()
        return True
    finally:
        os.unlink(pf)


def _write_reconcile_state(target, payload):
    d = os.path.join(TANUKI_ROOT, target)
    if not os.path.isdir(d):
        return None
    p = os.path.join(d, "reconcile.json")
    merged = {}
    if os.path.exists(p):
        try:
            with open(p, encoding="utf-8") as f:
                merged = json.load(f)
        except (ValueError, OSError):
            merged = {}
    units = merged.get("units", {})
    for r in payload["units"]:
        units[r["sha"]] = r
    merged.update(payload, units=units)
    tmp = p + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(merged, f, indent=2)
    os.replace(tmp, p)
    return p


def _dispose_run(target, repo, base=None, branch=None, apply=False):
    """The disposition engine's core, shared by `dispose` and the reconcile
    orchestration (#213 consumes #211, never re-implements it). Returns the
    payload and persists the evidence."""
    import tempfile as _tf
    base, _base_sha = resolve_base(repo, base)
    rows = unresolved_branches(repo, target, base)
    if branch:
        rows = [r for r in rows if r["branch"] == branch]
    staging = _staging_branch(target)
    have_staging = git(repo, "rev-parse", "--verify", "-q", staging)[0] == 0
    units, cls_wt, apply_wt = [], None, None
    try:
        # Classification is ALWAYS against current base behavior (#210);
        # application happens on the staging branch in its own worktree,
        # created lazily so a run with nothing to apply leaves no branch.
        cls_wt = _tf.mkdtemp(prefix="tanuki-dispose-cls-")
        rc, msg = git(repo, "worktree", "add", "--detach", cls_wt, base)
        if rc != 0:
            die(f"dispose: could not create a work tree at {base}: {msg}")
        for r in rows:
            if r["branch"] == staging:
                continue           # the staging branch is not a debt
            for c in r["commits"]:
                if have_staging and _already_applied(repo, staging,
                                                     c["sha"]):
                    units.append({"sha": c["sha"], "subject": c["subject"],
                                  "branch": r["branch"],
                                  "disposition": "already-applied",
                                  "action": "skip",
                                  "reason": "found in the staging log "
                                            "(idempotent re-run)"})
                    continue
                rec = _dispose_unit(repo, cls_wt, base, c, r["branch"])
                if apply and rec["action"] in ("cherry-pick", "port"):
                    if apply_wt is None:
                        apply_wt = _tf.mkdtemp(prefix="tanuki-dispose-apply-")
                        rc, msg = (git(repo, "worktree", "add", apply_wt,
                                       staging) if have_staging else
                                   git(repo, "worktree", "add", apply_wt,
                                       "-b", staging, base))
                        if rc != 0:
                            die("dispose: could not create the staging "
                                f"work tree: {msg}")
                        have_staging = True
                    _apply_unit(repo, apply_wt, rec, target)
                units.append(rec)
    finally:
        for w in (cls_wt, apply_wt):
            if w:
                git(repo, "worktree", "remove", "--force", w)
        git(repo, "worktree", "prune")
    payload = {"target": target, "loop_repo": repo, "base": base,
               "staging": staging if have_staging else None,
               "evaluated_against": base, "applied": bool(apply),
               "units": units,
               "escalations": [u for u in units
                               if u.get("action") == "escalate"]}
    _write_reconcile_state(target, payload)
    return payload


def cmd_dispose(args):
    """Classify every unresolved unit and (with --apply) act on the
    deterministic ones. Dry-run by default: classification + evidence only."""
    repo = _loop_repo_for(args.target, getattr(args, "loop_repo", None))
    if not repo or not os.path.isdir(repo):
        body, typed = empty_state("unresolved:no-loop-repo", args.target)
        out({"target": args.target, "loop_repo": repo, "units": [],
             "empty_state": typed})
        return
    payload = _dispose_run(args.target, repo,
                           base=getattr(args, "base", None),
                           branch=args.branch, apply=args.apply)
    units = payload["units"]
    if args.json:
        out(payload)
        return
    print(f"dispose — {args.target} (against {payload['base']}"
          + (", applied" if args.apply else ", dry-run") + ")")
    if not units:
        print("  nothing unresolved — no units to dispose")
    for u in units:
        line = (f"  {u['sha']}  {u['disposition']:<17} {u['action']:<11} "
                f"{u.get('subject', '')[:44]}")
        print(line)
        if u.get("reason"):
            print(f"      {u['reason']}")
        for d in u.get("dropped_hunks", []):
            print(f"      dropped: {d['file']} hunk {d['hunk']} ({d['why']})")
    esc = [u for u in units if u.get("action") == "escalate"]
    if esc:
        print(f"\n  {len(esc)} unit(s) escalate to the gate — genuine "
              "decisions only; evidence is in reconcile.json.")


# ── Finding-level, per-site behavior re-evaluation ───────────────────────────
# spec-tanuki-loop (#210): "a finding is not marked resolved or superseded
# until its behavior is closed at EVERY known site." Story 1.39 (#212) — the
# F77 half-fix guard: hunk-level comparison against *presence of a fix* is
# not *behavior closed at every site*. Sites are recorded once (that
# enumeration is judgment, done in the reconcile sitting via `site-record`);
# evaluation of the recorded probes is mechanical, auditable, and
# re-derivable forever after. Fail closed: a finding with no recorded sites,
# or a site whose probe cannot execute, is `needs-owner` — never assumed
# closed.

def _reconcile_state_path(target):
    return os.path.join(TANUKI_ROOT, target, "reconcile.json")


def _load_reconcile_state(target):
    p = _reconcile_state_path(target)
    if os.path.exists(p):
        try:
            with open(p, encoding="utf-8") as f:
                return json.load(f)
        except (ValueError, OSError):
            pass
    return {}


def _save_reconcile_state(target, state):
    p = _reconcile_state_path(target)
    if not os.path.isdir(os.path.dirname(p)):
        return None
    tmp = p + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(state, f, indent=2)
    os.replace(tmp, p)
    return p


def _probe_site(wt, site):
    """Evaluate one site's closure probe against the tree at `wt`.

    Returns (closed: bool|None, evidence: str). None = the probe could not
    be executed at all — that is MISSING evidence and fails closed upstream,
    distinct from a probe that ran and found the behavior live."""
    probe = site.get("probe") or {}
    kind = probe.get("type")
    if kind == "content":
        f = probe.get("file")
        want, absent = probe.get("contains"), probe.get("absent")
        if not f or (want is None and absent is None):
            return None, "malformed content probe (needs file + contains/absent)"
        path = os.path.join(wt, f)
        try:
            text = open(path, encoding="utf-8").read() \
                if os.path.exists(path) else ""
        except (OSError, UnicodeDecodeError) as e:
            return None, f"unreadable file {f}: {e}"
        if want is not None:
            ok = want in text
            return ok, (f"'{want}' {'present' if ok else 'ABSENT'} in {f}")
        ok = absent not in text
        return ok, (f"'{absent}' {'absent' if ok else 'STILL PRESENT'} "
                    f"in {f}")
    if kind == "cmd":
        cmd = probe.get("run")
        if not cmd:
            return None, "malformed cmd probe (no run)"
        try:
            r = subprocess.run(cmd, shell=True, cwd=wt,
                               capture_output=True, text=True, timeout=120)
        except (OSError, subprocess.TimeoutExpired) as e:
            return None, f"probe could not execute: {e}"
        if r.returncode in (126, 127):
            return None, (f"probe could not execute (rc {r.returncode}): "
                          f"{(r.stderr or '').strip()[:120]}")
        ok = r.returncode == 0
        return ok, (f"`{cmd}` rc {r.returncode} "
                    f"({'closed' if ok else 'behavior still reproduces'})")
    return None, f"unknown probe type {kind!r}"


def cmd_site_record(args):
    """Record one manifestation site of a finding, with the probe that
    establishes closure. The enumeration is the sitting's judgment; storing
    it makes every later verdict mechanical and re-derivable."""
    st = _load_reconcile_state(args.target)
    findings = st.setdefault("findings", {})
    rec = findings.setdefault(args.finding, {"sites": []})
    if args.contains or args.absent:
        if not args.file:
            die("site-record: a content probe needs --file")
        probe = {"type": "content", "file": args.file}
        if args.contains:
            probe["contains"] = args.contains
        else:
            probe["absent"] = args.absent
    elif args.run:
        probe = {"type": "cmd", "run": args.run}
    else:
        die("site-record: give a probe — --contains/--absent (with --file) "
            "or --run")
    sites = [s for s in rec["sites"] if s["site"] != args.site]
    sites.append({"site": args.site, "probe": probe})
    rec["sites"] = sorted(sites, key=lambda s: s["site"])
    # A re-recorded site invalidates any earlier verdict — it must be
    # re-derived, never carried over a changed probe set.
    rec.pop("verdict", None)
    if not _save_reconcile_state(args.target, st):
        die("site-record: no state directory for this target (run init)")
    out({"finding": args.finding, "sites": rec["sites"]})


def _cited_finding_ids(rows):
    ids = set()
    for r in rows:
        for c in r["commits"]:
            for x in c["cites_findings"]:
                ids.add(x["id"])
    return ids


def _reevaluate_run(target, repo, base=None, finding=None):
    """Core of `reevaluate`, shared with the reconcile orchestration (#213
    consumes #212, never re-implements it). Returns the payload and
    persists per-site verdicts + evidence."""
    import tempfile as _tf
    base, base_sha = resolve_base(repo, base)
    st = _load_reconcile_state(target)
    findings = st.setdefault("findings", {})
    ids = set(findings)
    if not finding:
        rows = unresolved_branches(repo, target, base)
        ids |= _cited_finding_ids(rows)
    else:
        ids = {finding}
    statuses = {c["id"]: c for c in
                _cited_findings(target, " ".join(sorted(ids)))}
    wt, results = None, {}
    try:
        wt = _tf.mkdtemp(prefix="tanuki-reeval-")
        rc, msg = git(repo, "worktree", "add", "--detach", wt, base)
        if rc != 0:
            die(f"reevaluate: could not create a work tree at {base}: {msg}")
        for fid in sorted(ids):
            rec = findings.setdefault(fid, {"sites": []})
            sites = rec.get("sites") or []
            if not sites:
                verdict = {"verdict": "needs-owner",
                           "reason": "no known sites recorded — closure "
                                     "cannot be assumed (fail closed); "
                                     "record them with site-record"}
            else:
                evaluated, live, unknown = [], [], []
                for s in sites:
                    closed, ev = _probe_site(wt, s)
                    evaluated.append({"site": s["site"], "probe": s["probe"],
                                      "closed": closed, "evidence": ev})
                    if closed is None:
                        unknown.append(s["site"])
                    elif not closed:
                        live.append(s["site"])
                if unknown:
                    verdict = {"verdict": "needs-owner",
                               "reason": "probe(s) could not execute at: "
                                         + ", ".join(unknown)}
                elif live:
                    verdict = {"verdict":
                               "still-applicable-at-remaining-sites",
                               "remaining_sites": live}
                else:
                    led = statuses.get(fid) or {}
                    verdict = {"verdict": ("superseded"
                                           if (led.get("status") == "accepted"
                                               and led.get("tombstoned"))
                                           else "resolved")}
                verdict["sites"] = evaluated
            verdict.update(evaluated_against=f"{base}@{base_sha[:12]}",
                           ledger_status=statuses.get(fid))
            rec["verdict"] = verdict
            results[fid] = {"sites": rec.get("sites", []), **verdict}
    finally:
        if wt:
            git(repo, "worktree", "remove", "--force", wt)
            git(repo, "worktree", "prune")
    _save_reconcile_state(target, st)
    return {"target": target, "base": base, "findings": results}


def cmd_reevaluate(args):
    """Re-evaluate findings against CURRENT base behavior, per site.

    Verdicts: resolved / superseded (closed at EVERY known site — superseded
    when the ledger already carries it accepted-and-tombstoned),
    still-applicable-at-remaining-sites (with the live sites named), or
    needs-owner (no sites recorded, or a probe that could not run — fail
    closed, never assumed closed)."""
    repo = _loop_repo_for(args.target, getattr(args, "loop_repo", None))
    if not repo or not os.path.isdir(repo):
        die("reevaluate: no loop repo (run init)")
    payload = _reevaluate_run(args.target, repo,
                              base=getattr(args, "base", None),
                              finding=args.finding)
    results = payload["findings"]
    if args.json:
        out(payload)
        return
    print(f"reevaluate — {args.target} (against {payload['base']})")
    if not results:
        print("  no findings to re-evaluate — none cited, none with "
              "recorded sites")
    for fid, r in results.items():
        print(f"  {fid}  {r['verdict']}"
              + (" — live at: " + ", ".join(r["remaining_sites"])
                 if r.get("remaining_sites") else "")
              + (f" — {r['reason']}" if r.get("reason") else ""))
        for s in (r.get("sites") or []):
            if isinstance(s, dict) and "closed" in s:
                mark = {True: "closed", False: "LIVE",
                        None: "unevidenced"}[s["closed"]]
                print(f"      {s['site']:<24} {mark:<12} {s['evidence']}")


# ── Reconcile orchestration — one invocation, one gate, terminal ─────────────
# Story 1.40 (#213), composing the disposition engine (#211) and per-site
# finding re-evaluation (#212) under the #210 terminal contract. One
# invocation: enumerate ALL unresolved runs → dispose/reevaluate to a
# FIXPOINT → verification → ONE gate holding only genuine owner decisions →
# after approval, merge → push → update state → clean up, no further
# commands. The whole flow is a persisted, resumable, idempotent transaction
# in reconcile.json: re-running never re-ports (dispose skips applied
# units), never re-merges (reachability check), never re-pushes
# (up-to-date), and never re-asks an answered gate (approval is persisted
# per item-key set). Terminal states: complete | needs-owner | blocked.

def _reconcile_report(tx, payload, as_json):
    if as_json:
        out(payload)
        return
    print(f"reconcile — {payload['target']}: {tx['state'].upper()}"
          + (f" — {tx.get('reason')}" if tx.get("reason") else ""))
    fp = tx.get("fixpoint") or {}
    if fp:
        print(f"  fixpoint: {fp.get('iterations')} iteration(s), "
              f"{fp.get('applied', 0)} unit(s) applied, "
              f"{fp.get('dropped', 0)} dropped, "
              f"{fp.get('escalated', 0)} escalated")
    v = tx.get("verify") or {}
    if v:
        print("  verify: " + (v.get("skipped") or
                              f"`{v.get('cmd')}` rc {v.get('rc')} "
                              f"at {v.get('ref')}"))
    for it in (tx.get("gate") or {}).get("open_items") or []:
        print(f"  gate: {it['kind']} {it['key']} — {it['summary']}")
    t = tx.get("terminal") or {}
    for k in ("merged", "pushed", "pr", "cleaned"):
        if t.get(k) is not None:
            print(f"  {k}: {t[k]}")
    if tx["state"] == "needs-owner":
        print("  parked at the gate — decide the items above (resolve, "
              "site-record, or discard by hand), then re-run; "
              "`reconcile --approve` proceeds with the deterministic work "
              "while they stay parked.")


def _terminal_block(target, st, tx, reason, payload, as_json):
    tx.update(state="blocked", reason=reason)
    st["transaction"] = tx
    _save_reconcile_state(target, st)
    payload["transaction"] = tx
    _reconcile_report(tx, payload, as_json)


def cmd_reconcile(args):
    """The terminal reconcile invocation (#210). No identifiers required —
    the default is ALL unresolved runs; --branch is an advanced filter and
    hashes/branch names appear only as evidence."""
    import tempfile as _tf
    repo = _loop_repo_for(args.target, getattr(args, "loop_repo", None))
    if not repo or not os.path.isdir(repo):
        die("reconcile: no loop repo (run init)")
    base, _sha = resolve_base(repo, getattr(args, "base", None))
    st = _load_reconcile_state(args.target)
    tx = st.get("transaction") or {}
    payload = {"target": args.target, "loop_repo": repo, "base": base}

    # Phase 1 — classify → apply → re-evaluate, to a fixpoint.
    iters, applied_total = 0, 0
    while True:
        iters += 1
        dp = _dispose_run(args.target, repo,
                          base=getattr(args, "base", None),
                          branch=args.branch, apply=True)
        n = sum(1 for u in dp["units"] if u.get("applied"))
        applied_total += n
        if n == 0:
            break
        if iters >= 5:
            _terminal_block(args.target, st, tx,
                            "no fixpoint after 5 disposition rounds — "
                            "evidence in reconcile.json", payload,
                            args.json)
            return
    rp = _reevaluate_run(args.target, repo,
                         base=getattr(args, "base", None))
    st = _load_reconcile_state(args.target)   # both runs persisted evidence
    tx["fixpoint"] = {
        "iterations": iters, "applied": applied_total,
        "dropped": sum(1 for u in dp["units"] if u["action"] == "drop"),
        "escalated": len(dp["escalations"])}
    staging = dp["staging"]
    payload.update(units=dp["units"], findings=rp["findings"],
                   staging=staging)

    # Phase 2 — verification, a gate condition (fail closed: something to
    # merge with no configured test_cmd is blocked, never waved through).
    try:
        run_state = load_state(args.target)
    except SystemExit:
        run_state = {}
    test_cmd = run_state.get("test_cmd")
    ref = staging or base
    if test_cmd:
        wt = _tf.mkdtemp(prefix="tanuki-reconcile-verify-")
        try:
            rc, msg = git(repo, "worktree", "add", "--detach", wt, ref)
            if rc != 0:
                _terminal_block(args.target, st, tx,
                                f"could not check out {ref} to verify: "
                                f"{msg}", payload, args.json)
                return
            try:
                r = subprocess.run(test_cmd, shell=True, cwd=wt,
                                   capture_output=True, text=True,
                                   timeout=1800)
            except subprocess.TimeoutExpired:
                _terminal_block(args.target, st, tx,
                                "verification timed out after 1800s",
                                payload, args.json)
                return
        finally:
            git(repo, "worktree", "remove", "--force", wt)
            git(repo, "worktree", "prune")
        tx["verify"] = {"cmd": test_cmd, "ref": ref, "rc": r.returncode}
        if r.returncode != 0:
            tx["verify"]["tail"] = (r.stdout + r.stderr)[-2000:]
            _terminal_block(args.target, st, tx,
                            "verification failed — nothing merged",
                            payload, args.json)
            return
    elif staging:
        _terminal_block(args.target, st, tx,
                        "applied work exists but no test_cmd is configured "
                        "in the run state — the verification gate cannot "
                        "run (fail closed)", payload, args.json)
        return
    else:
        tx["verify"] = {"skipped": "nothing applied and no test_cmd — "
                                   "nothing to verify"}

    # Phase 3 — ONE gate, genuine owner decisions only.
    items = ([{"kind": "unit", "key": u["sha"],
               "summary": f"{u['disposition']} — {u.get('reason', '')} "
                          f"({u.get('subject', '')[:48]})"}
              for u in dp["escalations"]]
             + [{"kind": "finding", "key": fid,
                 "summary": f"{r['verdict']} — "
                            + (", ".join(r.get("remaining_sites", []))
                               or r.get("reason", ""))}
                for fid, r in rp["findings"].items()
                if r["verdict"] in ("needs-owner",
                                    "still-applicable-at-remaining-sites")
                # A finding with NO recorded sites makes no closure claim —
                # its needs-owner verdict is advisory, not an owner decision
                # the gate owes; a finding with sites that are live or
                # unevidencable is a genuine one.
                and r.get("sites")])
    keys = sorted(f"{i['kind']}:{i['key']}" for i in items)
    gate = tx.get("gate") or {}
    already = set(gate.get("approved_keys") or [])
    if args.approve and items:
        gate.update(approved_keys=sorted(already | set(keys)),
                    mode="explicit")
        already = set(gate["approved_keys"])
    gate["open_items"] = items
    approved = (not items) or set(keys) <= already
    if not items:
        gate.setdefault("mode", "empty — nothing a tool could have closed")
    tx["gate"] = gate

    # Phase 4 — terminal actions after approval: merge → push → state →
    # cleanup. All idempotent; a killed run resumes without repeating any.
    term = tx.setdefault("terminal", {})
    if approved and staging:
        gate_mode = run_state.get("gate_mode", "merge")
        if gate_mode == "pr":
            # PR-protected target: the terminal "merge" is PR mechanics and
            # the forge approval is the owner's explicit decision — the
            # loop still never auto-merges (owner ruling 2026-07-17).
            if git(repo, "remote", "get-url", "origin")[0] != 0:
                _terminal_block(args.target, st, tx,
                                "gate is 'pr' but the loop repo has no "
                                "origin remote", payload, args.json)
                return
            rc, msg = git(repo, "push", "origin", f"{staging}:{staging}")
            if rc != 0:
                _terminal_block(args.target, st, tx,
                                f"could not push {staging}: {msg}",
                                payload, args.json)
                return
            rc, existing = gh(repo, "pr", "list", "--head", staging,
                              "--state", "open", "--json", "number",
                              "--jq", ".[0].number")
            if rc == 0 and existing.strip():
                term["pr"] = int(existing.strip())
            else:
                rc, o = gh(repo, "pr", "create", "--draft", "--base", base,
                           "--head", staging, "--title",
                           f"reconcile: {args.target} deterministic "
                           f"dispositions", "--body",
                           "Deterministic reconcile work (tanuki-loop "
                           "reconcile, #210). Evidence: reconcile.json.")
                if rc != 0:
                    _terminal_block(args.target, st, tx,
                                    f"could not open the PR: {o}",
                                    payload, args.json)
                    return
                term["pr"] = o.strip()
        else:
            if git(repo, "merge-base", "--is-ancestor", staging,
                   base)[0] == 0:
                term.setdefault("merged", "already reachable from base")
            else:
                head = git(repo, "symbolic-ref", "--short", "HEAD")[1]
                dirty = git(repo, "status", "--porcelain")[1].strip()
                if head != base or dirty:
                    _terminal_block(
                        args.target, st, tx,
                        f"cannot merge: the loop repo must have {base} "
                        "checked out clean", payload, args.json)
                    return
                rc, msg = git(repo, "merge", "--no-edit", staging)
                if rc != 0:
                    git(repo, "merge", "--abort")
                    _terminal_block(args.target, st, tx,
                                    f"merge of {staging} failed: {msg}",
                                    payload, args.json)
                    return
                term["merged"] = git(repo, "rev-parse", "--short",
                                     "HEAD")[1].strip()
            if git(repo, "remote", "get-url", "origin")[0] == 0:
                rc, msg = git(repo, "push", "origin", base)
                if rc != 0:
                    _terminal_block(
                        args.target, st, tx,
                        f"push refused ({msg.strip()[:200]}) — reconcile "
                        "the remote by hand; never force", payload,
                        args.json)
                    return
                term["pushed"] = True
            else:
                term["pushed"] = "no-remote"
    if approved:
        # Cleanup — the ownership /repo-cleanup formerly held (#210):
        # delete only branches whose every unit is accounted for
        # (dropped, applied, or skipped); an escalated branch survives.
        rows = {r["branch"]: r for r in
                unresolved_branches(repo, args.target, base)}
        by_branch = {}
        for u in dp["units"]:
            by_branch.setdefault(u.get("branch"), []).append(u)
        cleaned = list(term.get("cleaned") or [])
        for b, us in by_branch.items():
            if not b or any(u.get("action") == "escalate" for u in us):
                continue
            if git(repo, "rev-parse", "--verify", "-q", b)[0] != 0:
                continue           # already gone (idempotent re-run)
            wt_path = (rows.get(b) or {}).get("worktree")
            if wt_path:
                git(repo, "worktree", "remove", "--force", wt_path)
            git(repo, "branch", "-D", b)
            cleaned.append(b)
        if staging and term.get("merged") and \
                git(repo, "rev-parse", "--verify", "-q", staging)[0] == 0 \
                and git(repo, "merge-base", "--is-ancestor", staging,
                        base)[0] == 0:
            git(repo, "branch", "-d", staging)
            cleaned.append(staging)
        git(repo, "worktree", "prune")
        term["cleaned"] = cleaned

    tx["state"] = "needs-owner" if items else "complete"
    tx.pop("reason", None)
    st["transaction"] = tx
    _save_reconcile_state(args.target, st)
    payload["transaction"] = tx
    _reconcile_report(tx, payload, args.json)


def resolve_loop_config(args):
    """Per-target loop settings from the scenarios file's "loop" block, with
    CLI flags as per-run overrides — the single resolution path shared by
    `init` and `doctor`, so the validator can never disagree with the run.
    Values are None where neither source supplies them; `init` applies the
    attempt-cap default (4) after this."""
    loopcfg = {}
    if args.scenarios:
        with open_scenarios(args.scenarios, args.target) as f:
            loopcfg = json.load(f).get("loop", {})
    return {
        "cap": args.cap if args.cap is not None else loopcfg.get("iterations"),
        "test_cmd": args.test_cmd or loopcfg.get("test_cmd"),
        "wall_time_s": args.wall_time if args.wall_time is not None
        else loopcfg.get("wall_time_s"),
        "token_budget": args.token_budget if args.token_budget is not None
        else loopcfg.get("token_budget"),
        "attempt_cap": args.attempt_cap if args.attempt_cap is not None
        else loopcfg.get("attempt_cap"),
        # "merge" (default): the operator merges locally and gate-push pushes
        # the base. "pr": the base branch is push-protected, so the run's close
        # delivers a ready-for-review PR instead (gate-pr; Draft opt-in) and
        # the Human Gate moves to PR approval + merge on the forge
        # (spec-tanuki-loop "PR-protected targets").
        "gate": getattr(args, "gate", None) or loopcfg.get("gate") or "merge",
        # Ready-by-default (spec-tanuki-loop, ready-by-default amendment
        # 2026-07-20): gate-pr delivers a ready-for-review PR unless the
        # operator opts back into a Draft via the loop block's
        # gate_pr_draft:true (or the per-run `gate-pr --draft` override).
        "gate_pr_draft": bool(loopcfg.get("gate_pr_draft")),
    }


def gh(repo, *args):
    """Run the GitHub CLI in repo. Returns (rc, text): stdout on success,
    stderr (falling back to stdout) on failure; rc 127 when gh is absent —
    callers refuse with a remedy rather than tracebacking on a host without
    the forge tooling."""
    try:
        r = subprocess.run(["gh", *args], cwd=repo,
                           capture_output=True, text=True)
    except FileNotFoundError:
        return 127, "`gh` (GitHub CLI) not found on PATH"
    text = r.stdout if r.returncode == 0 else (r.stderr or r.stdout)
    return r.returncode, (text or "").strip()


def _find_merge_commit(repo, tip, base_sha):
    """The merge node that brought <tip> into base, if determinable: the commit
    on base's ancestry whose parent list contains <tip>. Returns its SHA, or
    None — a fast-forward merge leaves no merge node, which is not an error."""
    rc, o = git(repo, "rev-list", "--ancestry-path", "--parents",
                f"{tip}..{base_sha}")
    if rc != 0:
        return None
    for line in o.splitlines():
        parts = line.split()
        if len(parts) > 1 and tip in parts[1:]:
            return parts[0]
    return None


def _derive_merge_settlement(state):
    """Settle a DIRECT-MERGE (non-PR) gate run — the loop writes no delivery
    record on this path (it ends at the operator's local merge, not a forge
    PR), so status/dashboard derive it read-only, SYMMETRICALLY with gate-pr
    (spec-tanuki-loop "The direct-merge (non-PR) gate settles the same way").
    The strict test is identical — the integration tip's reachability from the
    current base — but sourced from the base alone, with no PR to consult:

      integration tip reachable from the current base -> `landed`, with
        `delivered` populated from the local merge (integration-tip SHA, base
        SHA, and the merge commit when its node is determinable);
      base readable but the tip not yet reachable (merge not run, or the base
        moved past the tip) -> `pending` — never `null`;
      base (or the integration tip) unreadable -> `unknown`, never an
        optimistic default.

    An integration branch that never diverged from its init base (no iteration
    produced a commit) has nothing to settle as a delivery: its tip is
    trivially reachable, but no merge landed, so this returns None (not
    `landed`) — the same as a run that was never delivered. The story's
    never-null guard is about a real merge that landed, not a work-free run.

    Read-only: it computes, never mutates state."""
    repo = state["loop_repo"]
    base, integ = state["base"], state["integration_branch"]
    now = time.strftime("%Y-%m-%d %H:%M:%S")
    rc_b, base_sha = git(repo, "rev-parse", base)
    if rc_b != 0 or not base_sha:
        return {"result": "unknown", "observed_at": now,
                "detail": f"base '{base}' is unreadable — settlement cannot be "
                          "derived; never assumed merged (direct-merge gate)"}
    rc_t, tip = git(repo, "rev-parse", integ)
    if rc_t != 0 or not tip:
        # F158: the optional post-merge `finish` deletes the merged branch, so
        # the ref is legitimately gone exactly when the merge landed. gate-check
        # already proves reachability from the run's recorded verified HEAD
        # (head_expected); use the same fallback here so status and gate-check
        # cannot disagree on a provable fact. A deleted branch whose recorded
        # tip is NOT reachable stays unknown — never optimistic.
        tip = state.get("head_expected")
        if (tip and tip != state.get("base_sha")
                and git(repo, "merge-base", "--is-ancestor",
                        tip, base_sha)[0] == 0):
            delivered = {"gate": "merge", "head_sha": tip,
                         "base_sha": base_sha,
                         "merge_commit": _find_merge_commit(repo, tip,
                                                            base_sha)}
            return {"result": "landed", "observed_at": now,
                    "local_synced": True, "delivered": delivered,
                    "branch_deleted": True,
                    "detail": f"branch '{integ}' is deleted but its recorded "
                              f"verified tip {tip[:12]} is reachable from "
                              f"local '{base}' (merged, then cleaned up — "
                              "direct-merge gate)"}
        return {"result": "unknown", "observed_at": now,
                "detail": f"integration branch '{integ}' does not resolve, "
                          "and no recorded verified tip is reachable from the "
                          "base — reachability cannot be proven; never "
                          "assumed merged (direct-merge gate)"}
    # No divergence from the init base ⇒ nothing was ever delivered; trivial
    # reachability is not a landed merge (this is not the null the story guards).
    if tip == state.get("base_sha"):
        return None
    if git(repo, "merge-base", "--is-ancestor", tip, base_sha)[0] == 0:
        delivered = {"gate": "merge", "head_sha": tip, "base_sha": base_sha,
                     "merge_commit": _find_merge_commit(repo, tip, base_sha)}
        return {"result": "landed", "observed_at": now, "local_synced": True,
                "delivered": delivered,
                "detail": f"integration tip {tip[:12]} is reachable from local "
                          f"'{base}' (direct-merge gate — local merge landed)"}
    return {"result": "pending", "observed_at": now,
            "detail": f"integration tip {tip[:12]} is not yet reachable from "
                      f"local '{base}' — the merge has not run, or the base "
                      "moved past the tip (direct-merge gate)"}


def derive_settlement(state, save=True, offline=False):
    """Derive a delivered run's settlement from the forge and the current base
    (owner ruling 2026-07-17, delivery boundary): the loop's own record stops
    at delivery, and no human restates the forge's decision — surfaces that
    need the outcome derive it here, when they need it.

      landed   — the delivered tip (or the forge's merge commit) is reachable
                 from the current local base; `local_synced: false` marks the
                 merged-on-forge-but-base-not-pulled window
      pending  — the PR is still open on the forge
      declined — the PR was closed without merging (the branch holds unlanded
                 work; reconcile owns its classification)
      unknown  — the forge is unreachable and no prior observation exists;
                 never an optimistic default

    A successful observation is cached in state (`settlement_observed`, with
    its timestamp) so offline views can show the LAST OBSERVED result; a
    cache served in place of a live answer always carries `stale: true` and
    the observation time — it is never presented as current truth. Returns
    None for a run that was never delivered.

    offline=True skips the forge entirely (spec-tanuki-view: a read-only
    view never polls a PR): local reachability still answers `landed`;
    anything else is the stale-marked last observation, or `unknown` — the
    same never-optimistic fallback."""
    d = state.get("delivered") or state.get("gate_pr")
    if not d:
        # No PR/delivery record. On the direct-merge (non-PR) gate the loop
        # writes none by design — it ends at the operator's LOCAL merge, not a
        # forge PR — so settlement is derived from the integration tip's
        # reachability from the current base, the SAME strict test the PR path
        # uses (spec-tanuki-loop "The direct-merge (non-PR) gate settles the
        # same way"). A gate=pr run with no delivery yet stays None (undelivered
        # — unchanged, no regression to the PR path).
        if state.get("gate_mode", "merge") == "merge":
            return _derive_merge_settlement(state)
        return None
    repo, base = state["loop_repo"], state["base"]
    now = time.strftime("%Y-%m-%d %H:%M:%S")

    def observed(result, detail, extra=None, cache=True):
        obs = {"result": result, "detail": detail, "observed_at": now}
        if cache and save:
            state["settlement_observed"] = obs
            save_state(state)
        return {**obs, **(extra or {}),
                "pr": d.get("number") or d.get("pr"), "url": d.get("url")}

    # Local reachability first: answerable offline, and the strict test that
    # finding verification / recurrence accounting is allowed to use.
    sha = d.get("head_sha")
    if sha and git(repo, "merge-base", "--is-ancestor", sha, base)[0] == 0:
        return observed("landed", f"delivered tip {sha[:12]} is reachable "
                                  f"from local '{base}'",
                        {"local_synced": True}, cache=not offline)
    if offline:
        prior = state.get("settlement_observed")
        if prior:
            return {**prior, "stale": True,
                    "pr": d.get("number") or d.get("pr"), "url": d.get("url"),
                    "detail": (prior.get("detail", "") +
                               f" — LAST OBSERVED {prior.get('observed_at')}; "
                               "offline view, forge not consulted")}
        return {"result": "unknown", "observed_at": now,
                "pr": d.get("number") or d.get("pr"), "url": d.get("url"),
                "detail": "offline view — forge not consulted and no prior "
                          "observation; never assumed merged"}
    ref = str(d.get("number") or d.get("pr") or d.get("url") or "")
    rc, o = gh(repo, "pr", "view", ref, "--json", "state,mergeCommit")
    if rc == 0:
        try:
            v = json.loads(o)
        except ValueError:
            v = {}
        st = v.get("state")
        if st == "MERGED":
            oid = (v.get("mergeCommit") or {}).get("oid") or ""
            if oid and git(repo, "merge-base", "--is-ancestor",
                           oid, base)[0] == 0:
                return observed("landed", f"merge commit {oid[:12]} is "
                                          f"reachable from local '{base}'",
                                {"local_synced": True})
            return observed("landed", f"merged on the forge; local '{base}' "
                                      "does not contain it yet — git pull "
                                      "--ff-only. Accounting must not treat "
                                      "this as landed until it is reachable "
                                      "locally",
                            {"local_synced": False})
        if st == "OPEN":
            return observed("pending", "the PR is open on the forge — "
                                       "awaiting the operator's review")
        if st == "CLOSED":
            return observed("declined", "the PR was closed without merging — "
                                        "the branch holds unlanded work "
                                        "(reconcile owns its classification)")
        return observed("unknown", f"forge reported unexpected PR state "
                                   f"{st!r}", cache=False)
    prior = state.get("settlement_observed")
    if prior:
        return {**prior, "stale": True,
                "pr": d.get("number") or d.get("pr"), "url": d.get("url"),
                "detail": (prior.get("detail", "") +
                           f" — LAST OBSERVED {prior.get('observed_at')}; "
                           "the forge is unreachable now")}
    return {"result": "unknown", "observed_at": now,
            "pr": d.get("number") or d.get("pr"), "url": d.get("url"),
            "detail": "forge unreachable and no prior observation — never "
                      "assumed merged"}


def _delivered_states(target):
    """{integration_branch: state} for every run of the target that recorded
    a delivery — the map read-only surfaces use to annotate branches with
    their derived settlement."""
    d = os.path.join(TANUKI_ROOT, target, "loop")
    found = {}
    if not os.path.isdir(d):
        return found
    for run in sorted(os.listdir(d)):
        sp = os.path.join(d, run, "state.json")
        if not os.path.isfile(sp):
            continue
        try:
            with open(sp, encoding="utf-8") as f:
                st = json.load(f)
        except ValueError:
            continue
        if st.get("delivered") or st.get("gate_pr"):
            found[st.get("integration_branch")] = st
    return found


def resolve_base(repo, base):
    """Resolve the base branch (default: the repo's checked-out branch) and
    its tip SHA, shared by `init` and `doctor`. Dies on a detached HEAD with
    no --base, or an unresolvable ref."""
    if not base:
        rc, base = git(repo, "symbolic-ref", "--short", "HEAD")
        if rc != 0:
            die("loop repo has a detached HEAD; pass --base <branch>")
    rc, base_sha = git(repo, "rev-parse", base)
    if rc != 0:
        die(f"cannot resolve base '{base}'")
    return base, base_sha


def resolve_entry_fixtures(args):
    """Stage-entry fixture declarations from the scenarios file
    (spec-host-snapshot "Stage-entry fixtures"; story 1.16): a top-level
    "entry_fixtures" registry {name: {"paths": [...], "producing_stage": s}}
    plus per-scenario "entry_fixture": <name> references. Returns
    {name: recipe} for every referenced recipe. Dies on a dangling reference
    or a path-less recipe — a run that cannot pin its declared state must
    not start (the same fail-closed rule as an uncloneable host)."""
    if not args.scenarios:
        return {}
    with open_scenarios(args.scenarios, args.target) as f:
        data = json.load(f)
    registry = data.get("entry_fixtures") or {}
    referenced = {}
    for s in data.get("scenarios") or []:
        name = s.get("entry_fixture")
        if not name:
            continue
        if name not in registry:
            die(f"scenario '{s.get('id')}' declares entry_fixture '{name}' "
                f"but the scenarios file has no entry_fixtures['{name}'] "
                "recipe")
        recipe = registry[name]
        if not recipe.get("paths"):
            die(f"entry_fixture '{name}' declares no artifact paths")
        referenced[name] = recipe
    return referenced


def pin_entry_fixtures(entry_fixtures, host_fixture_path, host_base_sha):
    """Verify each declared recipe is materializable inside the pinned host
    fixture and return its provenance record ({source_commit,
    producing_stage_version} — spec-host-snapshot "Stage-entry fixtures").
    The fixture clone is immutable, so presence at init IS the pin-once
    guarantee: every iteration sees the identical artifacts. Raises
    RuntimeError naming the missing paths otherwise (init fails closed)."""
    pinned = {}
    for name, recipe in sorted(entry_fixtures.items()):
        missing = [p for p in recipe["paths"]
                   if not os.path.exists(os.path.join(host_fixture_path, p))]
        if missing:
            raise RuntimeError(
                f"entry_fixture '{name}' cannot be materialized — missing "
                f"from the host fixture: {missing} — a run that cannot pin "
                "its declared state must not start")
        pinned[name] = {"paths": list(recipe["paths"]),
                        "source_commit": host_base_sha,
                        "producing_stage_version": recipe.get("producing_stage")}
    return pinned


def check_base_freshness(repo, base):
    """The staleness guard's measurement (issue #2), shared by `init` (which
    fails closed on it) and `doctor` (which reports it): best-effort fetch of
    <base>'s remote, then how far the local base lags its upstream. Returns
    {"upstream", "behind", "note"} — note is None when the base has an
    upstream and the fetch succeeded. Never moves any ref; apart from the
    fetch's refresh of remote-tracking refs it is read-only."""
    note, n_behind = None, 0
    rc, upstream = git(repo, "rev-parse", "--abbrev-ref",
                       "--symbolic-full-name", f"{base}@{{upstream}}")
    upstream = upstream if rc == 0 and upstream else None
    if upstream:
        rc_r, remote = git(repo, "config", "--get", f"branch.{base}.remote")
        fetched = rc_r == 0 and bool(remote) and git(repo, "fetch", remote)[0] == 0
        rc_b, behind = git(repo, "rev-list", "--count", f"{base}..{upstream}")
        n_behind = int(behind) if rc_b == 0 and behind.isdigit() else 0
        if not fetched:
            note = (f"fetch failed (offline?) — staleness checked against "
                    f"last-known {upstream}")
    else:
        note = f"base '{base}' has no upstream — staleness not checked"
    return {"upstream": upstream, "behind": n_behind, "note": note}


def resolve_host(args):
    """The scenarios file's top-level `host` path (a repo the plugin operates
    on), expanded and absolutized — or None for a hostless target. The live
    host is a CLONE SOURCE at init and nothing else, ever (spec-host-snapshot)."""
    if not args.scenarios:
        return None
    with open_scenarios(args.scenarios, args.target) as f:
        host = json.load(f).get("host")
    return os.path.abspath(os.path.expanduser(host)) if host else None


def host_freshness_note(host):
    """Read-only, informational host freshness (spec-host-snapshot): NEVER
    fetch (that writes the live host's .git) and NEVER fail closed — the host
    is an observation fixture, its staleness is the operator's business. Notes
    the uncommitted paths the fixture excludes and, best-effort via
    `git ls-remote` (no fetch), whether the host's branch differs from its
    remote. Returns a one-line note, or ''."""
    notes = []
    rc, dirty = git(host, "status", "--porcelain")
    n = len([ln for ln in dirty.splitlines() if ln.strip()]) if rc == 0 else 0
    if n:
        notes.append(f"{n} uncommitted path(s) excluded from the fixture "
                     "(committed tip only, by design)")
    rc_b, branch = git(host, "symbolic-ref", "--short", "HEAD")
    if rc_b == 0 and branch:
        rc_r, remote = git(host, "config", "--get", f"branch.{branch}.remote")
        if rc_r == 0 and remote:
            rc_l, line = git(host, "ls-remote", remote, branch)
            rc_h, local = git(host, "rev-parse", "HEAD")
            if rc_l == 0 and line and rc_h == 0 and line.split()[0] != local:
                notes.append(f"live host branch '{branch}' differs from "
                             f"{remote}/{branch} (informational; never fetched)")
    return "; ".join(notes)


def pin_host_fixture(host, dest):
    """Materialize the run-scoped host fixture: `git clone` the live host into
    <dest> (committed tip only — effectively atomic; no rsync/raw-.git copy of
    a repo another process may be writing). Returns the fixture HEAD sha. The
    caller fails the run closed if this raises — a run that cannot pin its host
    must not start."""
    if os.path.isdir(dest):
        shutil.rmtree(dest)
    rc, err = git(os.path.dirname(dest), "clone", "--quiet", "--no-hardlinks",
                  host, dest)
    if rc != 0:
        raise RuntimeError(f"host fixture clone failed: {err}")
    rc, sha = git(dest, "rev-parse", "HEAD")
    if rc != 0:
        raise RuntimeError(f"host fixture has no HEAD: {sha}")
    return sha


# --- subcommands -------------------------------------------------------------

def bad_loop_repo_message(raw, repo):
    """Build the '--loop-repo is not a git repo' error (issue #119).

    Always echoes the ABSOLUTE resolved path so a relative-resolution mistake
    (a stray `cd` earlier in the session) is visible. If the current working
    directory looks like it's inside a loop-managed worktree — a path segment
    matching `.tanuki-loop-*`, or a git toplevel that isn't the passed repo —
    say so explicitly and point back at the real repo. Read-only detection."""
    lines = [f"--loop-repo is not a git repo: {repo}"]
    if raw != repo:
        lines.append(f"  (resolved from '{raw}' relative to {os.getcwd()})")
    cwd = os.getcwd()
    stray = next((seg for seg in cwd.split(os.sep)
                  if seg.startswith(".tanuki-loop-")), None)
    rc, top = git(cwd, "rev-parse", "--show-toplevel")
    inside_other = rc == 0 and os.path.abspath(top) != repo
    if stray or inside_other:
        lines.append(f"  cwd ({cwd}) is inside another run's loop worktree"
                     + (f" ('{stray}')" if stray else "") + ";")
        lines.append("  --loop-repo resolved against it. cd back to the real "
                     "repo (or pass an absolute --loop-repo) and re-run.")
    return "\n".join(lines)


def cmd_init(args):
    repo = os.path.abspath(os.path.expanduser(args.loop_repo))
    rc, _ = git(repo, "rev-parse", "--git-dir")
    if rc != 0:
        die(bad_loop_repo_message(args.loop_repo, repo))
    # F164 / #237: the loop's init path silently reused a colliding slug's
    # ledger with no signal. State it up front (stderr, before the run is
    # cut) — mirrors tanuki-ledger init; announce_new_target rule (never blocks).
    ledger_reuse = ledger_reuse_note(args.target)
    if ledger_reuse:
        print(f"note: {ledger_reuse}", file=sys.stderr)
    # Per-target loop config from the scenarios file's "loop" block — so a
    # run needs no repo-specific flags typed each time. CLI flags override.
    cfg = resolve_loop_config(args)
    # A missing/invalid config precondition is a refusal in the tool's own
    # JSON convention (F227, sibling of the F37 recover fix), not a plain
    # argparse-style error — a scripted/headless caller parses exit-3
    # {"breaker": …} for every other refusal, so these must match.
    cap = cfg["cap"]
    if not cap:
        out({"breaker": "no iteration cap: pass --cap or set loop.iterations "
                        "in the scenarios file"})
        sys.exit(3)
    test_cmd = cfg["test_cmd"]
    wall = cfg["wall_time_s"]
    tokens = cfg["token_budget"]
    attempt_cap = cfg["attempt_cap"] if cfg["attempt_cap"] is not None else 4
    if cfg["gate"] not in ("merge", "pr"):
        out({"breaker": f"unknown gate mode '{cfg['gate']}' — one of: "
                        "merge, pr"})
        sys.exit(3)
    # One active run per target (issue #258; spec-tanuki-loop Non-negotiables).
    # A second init while another run for this target is unfinished AND its
    # worktree still exists would steal the machine-wide `current` pointer, so
    # the older run's bare subcommands then cross-write this run's state/audit
    # and inflate its convergence with the other run's findings. Fail closed —
    # the same idiom as the base-freshness guard below — unless
    # --allow-concurrent is passed to run them in parallel deliberately.
    live_before = unfinished_runs(args.target)
    if live_before and not args.allow_concurrent:
        ids = "; ".join(f"{r} (worktree {w})" for r, w in live_before)
        out({"breaker": f"target '{args.target}' already has "
                        f"{len(live_before)} unfinished run(s) with a live "
                        f"worktree: {ids}. A second run shares the machine-wide "
                        f"`current` pointer and ledger and would corrupt both "
                        f"(issue #258). Finish or abort the other run "
                        f"(`tanuki-loop --target {args.target} --run <id> "
                        f"finish --reason aborted`) and remove its worktree, or "
                        f"re-run init with --allow-concurrent to start "
                        f"alongside it deliberately.",
             "unfinished_runs": [r for r, _ in live_before]})
        sys.exit(3)
    base, base_sha = resolve_base(repo, args.base)
    # Staleness guard (issue #2): never silently dogfood code older than the
    # remote. Best-effort fetch, then FAIL CLOSED if <base> is behind its
    # upstream — every iteration would otherwise base on stale plugin code and
    # surface already-fixed findings at the morning gate. --allow-stale-base is
    # the explicit override (e.g. deliberately testing an un-pushed local
    # branch). We never silently move the base to the upstream tip; the
    # operator fast-forwards or overrides deliberately, so what is dogfooded is
    # always the ref they named.
    fresh = check_base_freshness(repo, base)
    upstream, n_behind, base_note = fresh["upstream"], fresh["behind"], fresh["note"]
    if n_behind > 0:
        if not args.allow_stale_base:
            die(f"local base '{base}' is {n_behind} commit(s) behind "
                f"'{upstream}'; the loop would dogfood stale code. "
                f"Fast-forward it (git -C {repo} merge --ff-only "
                f"{upstream}), pass --base {upstream}, or re-run with "
                "--allow-stale-base to dogfood the local tip anyway.")
        base_note = (f"{n_behind} commit(s) behind {upstream} — proceeding "
                     "under --allow-stale-base"
                     + (f"; {base_note}" if base_note else ""))
    # F171: a transient/local-only branch (no upstream) or a non-default
    # branch can be recorded as the loop base without a word — the operator
    # only discovers it at gate time. Warn (never stop: the loop still
    # dogfoods the ref the operator named) when the resolved base has no
    # upstream or differs from the repo's default branch (origin/HEAD, when
    # resolvable). The warning rides init's output AND state.json so a later
    # reader of the run's init record sees it too.
    warn_parts = []
    if not upstream:
        warn_parts.append(
            f"base '{base}' has no upstream — it may be a transient/"
            "local-only branch recorded as the loop base")
    rc_d, dflt = git(repo, "symbolic-ref", "--short",
                     "refs/remotes/origin/HEAD")
    default_branch = dflt.split("/", 1)[-1] if rc_d == 0 and dflt else None
    if default_branch and base != default_branch:
        warn_parts.append(
            f"base '{base}' is not the repo's default branch "
            f"('{default_branch}' per origin/HEAD)")
    base_warning = None
    if warn_parts:
        base_warning = ("; ".join(warn_parts)
                        + " — the loop dogfoods the ref you named; this is "
                          "a warning, not a stop (F171)")
    # Sweep merged integration branches from prior runs (issue #6) BEFORE
    # cutting this run's branch — the fresh branch starts at the base tip, so
    # doing this after would make it a deletion candidate. The next init for a
    # target is the backstop owner if a run ended without reaching `finish`.
    cleaned = cleanup_merged_integration_branches(repo, base, args.target)
    ts = time.strftime("%Y%m%d-%H%M%S")
    # Same-second re-init must not collide on the branch/run/worktree names.
    n, suffix = 2, ""
    while git(repo, "rev-parse", "--verify",
              f"refs/heads/tanuki-loop/{args.target}/{ts}{suffix}")[0] == 0:
        suffix, n = f"-{n}", n + 1
    ts += suffix
    run = f"loop-{ts}"
    integration = f"tanuki-loop/{args.target}/{ts}"
    worktree = os.path.abspath(os.path.expanduser(args.worktree)) if args.worktree \
        else os.path.join(os.path.dirname(repo), f".tanuki-loop-{args.target}-{ts}")
    rc, err = git(repo, "worktree", "add", "-b", integration, worktree, base)
    if rc != 0:
        die(f"git worktree add failed (no shared-tree fallback): {err}")

    d = loop_dir(args.target, run)
    os.makedirs(d, exist_ok=True)
    # Host fixture (spec-host-snapshot): pin the live host ONCE, here, as an
    # immutable run-scoped clone. Every drive clones from this fixture, so the
    # whole run dogfoods one host and operator activity in the real host after
    # init is invisible by construction. Hostless targets skip this entirely.
    host = resolve_host(args)
    host_fixture_path, host_base_sha, host_note = None, None, None
    if host:
        if git(host, "rev-parse", "--git-dir")[0] != 0:
            die(f"host is not a git repo: {host}")
        host_note = host_freshness_note(host)   # read-only, never fails closed
        host_fixture_path = os.path.join(d, "host-base")
        try:
            host_base_sha = pin_host_fixture(host, host_fixture_path)
        except RuntimeError as e:
            die(str(e))                          # a run that cannot pin its host must not start
    # Stage-entry fixtures (spec-host-snapshot amendment; story 1.16): pin
    # the declared stage artifacts with provenance. An entry fixture is host
    # state — on a hostless target the declaration is reported out of scope,
    # never silently ignored.
    entry_fixtures = resolve_entry_fixtures(args)
    pinned_fixtures, entry_fixtures_note = {}, None
    if entry_fixtures and not host:
        entry_fixtures_note = (
            f"entry_fixtures declared ({', '.join(sorted(entry_fixtures))}) "
            "but this target is HOSTLESS — an entry fixture is host state "
            "(spec-host-snapshot), so the declarations are out of scope and "
            "nothing was pinned")
    elif entry_fixtures:
        try:
            pinned_fixtures = pin_entry_fixtures(
                entry_fixtures, host_fixture_path, host_base_sha)
        except RuntimeError as e:
            die(str(e))
    policy = {}
    if args.policy and os.path.exists(os.path.expanduser(args.policy)):
        with open(os.path.expanduser(args.policy), encoding="utf-8") as f:
            policy = json.load(f)
    with open(os.path.join(d, "policy.json"), "w", encoding="utf-8") as f:
        json.dump(policy, f, indent=2)
    for name, head in (("audit.md", f"# tanuki-loop audit — {run}\n"),
                       ("queue.md", f"# morning review queue — {run}\n")):
        with open(os.path.join(d, name), "w", encoding="utf-8") as f:
            f.write(head)
    state = {
        "run": run, "target": args.target, "loop_repo": repo,
        "base": base, "base_sha": base_sha,
        "integration_branch": integration, "worktree": worktree,
        "phase": args.phase, "cap": cap, "attempt_cap": attempt_cap,
        "gate_mode": cfg["gate"], "gate_pr_draft": cfg["gate_pr_draft"],
        "wall_start": time.time(), "wall_limit_s": wall,
        "token_budget": tokens, "test_cmd": test_cmd,
        "iterations": [], "attempts": {}, "frozen": [], "deferred": [],
        "quiet_streak": 0, "head_expected": base_sha, "materialized": {},
        # Base provenance: the loop always dogfoods the LOCAL tip of <base>;
        # base_upstream/base_behind record what it was measured against so a
        # reader can see exactly what was dogfooded (issue #2).
        "base_tip": "local", "base_upstream": upstream,
        "base_behind": n_behind,
        # F171: init's non-fatal base warning (no upstream / non-default
        # branch), kept in the run's init record — None when the base looked
        # ordinary.
        "init_warning": base_warning,
        # Host fixture (spec-host-snapshot): the pinned clone every drive
        # sources from, and its HEAD. None for a hostless target. After init
        # the live host is out of scope — never read (except the finish drift
        # note), diffed, written, or "restored".
        "host": host, "host_fixture_path": host_fixture_path,
        "host_base_sha": host_base_sha,
        # Stage-entry fixtures pinned this run (story 1.16): {name:
        # {paths, source_commit, producing_stage_version}}. The fixture
        # clone is immutable, so these are identical for every iteration.
        "entry_fixtures": pinned_fixtures,
    }
    save_state(state)
    with open(os.path.join(TANUKI_ROOT, args.target, "loop", "current"),
              "w", encoding="utf-8") as f:
        f.write(run)
    audit(state, f"init: integration {integration} @ {base_sha[:12]} "
                 f"(base {base} [local tip]"
                 + (f", {n_behind} behind {upstream}" if n_behind else "")
                 + f") in worktree {worktree}; cap={cap} phase={args.phase}"
                 + (f" — {base_note}" if base_note else ""))
    if base_warning:
        audit(state, f"init WARNING: {base_warning}")
    # issue #258: a deliberate concurrent start is recorded so the audit shows
    # this run knowingly shares the `current` pointer with others — the reader
    # then knows every bare subcommand here is ambiguous and must pin --run.
    if live_before and args.allow_concurrent:
        audit(state, "init WARNING: --allow-concurrent — starting alongside "
                     f"{len(live_before)} other live run(s): "
                     + ", ".join(r for r, _ in live_before)
                     + " (issue #258; they share the machine-wide `current` "
                       "pointer, so pin --run on every subcommand)")
    if ledger_reuse:
        audit(state, f"init note: {ledger_reuse}")
    if host:
        audit(state, f"host fixture pinned @ {host_base_sha[:12]} from {host} "
                     f"-> {host_fixture_path}"
                     + (f" ({host_note})" if host_note else ""))
    if pinned_fixtures:
        audit(state, "entry fixtures pinned (identical for every iteration): "
                     + ", ".join(f"{n} @ {p['source_commit'][:12]}"
                                 f" (stage {p['producing_stage_version']})"
                                 for n, p in sorted(pinned_fixtures.items())))
    if entry_fixtures_note:
        audit(state, f"note: {entry_fixtures_note}")
    # Name the cap (F78) and the artifact paths (F79) on the way in: the
    # morning gate is told to present audit.md/state.json/queue.md, and the
    # ~/.tanuki/<target>/loop/<run>/ convention is otherwise undocumented —
    # operators had to find(1) them. The cap is echoed because rolled-back
    # iterations consume it, which is only discoverable by tripping the breaker.
    _ld = loop_dir(args.target, run)
    # "base" is the branch NAME, labeled and copy-pasteable into
    # `git checkout <base>` at the morning gate — inferring it from
    # base_upstream is the F100/F103 footgun.
    out({"run": run, "integration_branch": integration, "worktree": worktree,
         "base": base, "base_sha": base_sha, "base_upstream": upstream,
         "base_behind": n_behind, "warning": base_warning,
         "ledger_reuse": ledger_reuse,
         "branch_cleanup": cleaned,
         "host_fixture_path": host_fixture_path, "host_base_sha": host_base_sha,
         "host_freshness": host_note,
         "entry_fixtures": pinned_fixtures or None,
         "entry_fixtures_note": entry_fixtures_note,
         "cap": cap,
         "cap_note": ("%d iteration(s) max; rolled-back iterations count "
                      "toward the cap" % cap),
         "artifacts": {
             "dir": _ld,
             "state": os.path.join(_ld, "state.json"),
             "audit": os.path.join(_ld, "audit.md"),
             "queue": os.path.join(_ld, "queue.md"),
         }})


def _doctor_policy(args):
    """The policy a headless run would start from, read-only: an explicit
    --policy file wins; otherwise the current run's policy.json when one
    exists (the documented 'prior run's policy' path); otherwise empty.
    Returns (check-dict-or-None, decisions-set, source-label) — a malformed
    file is a failed check (an absent one is not: it just means everything
    undecided defers)."""
    path = None
    if args.policy:
        p = os.path.expanduser(args.policy)
        if not os.path.exists(p):
            return None, set(), f"missing: {p} — run would start with an EMPTY policy"
        path = p
    else:
        cur = os.path.join(TANUKI_ROOT, args.target, "loop", "current")
        if os.path.exists(cur):
            with open(cur, encoding="utf-8") as f:
                run = f.read().strip()
            p = os.path.join(loop_dir(args.target, run), "policy.json")
            if os.path.exists(p):
                path = p
    if not path:
        return None, set(), "none (empty policy)"
    try:
        with open(path, encoding="utf-8") as f:
            policy = json.load(f) or {}
    except ValueError as e:
        return ({"check": "policy-coverage", "ok": False,
                 "policy_source": path,
                 "detail": f"policy file is not valid JSON ({e}) — a headless "
                           "run would crash consulting it"},
                set(), path)
    return None, set((policy.get("decisions") or {}).keys()), path


def cmd_doctor(args):
    """READ-ONLY Phase 2/3 headless-readiness validator — answers 'is this
    target ready for an unattended run?' without running the pipeline. It
    reuses init's own resolution and guards (resolve_loop_config,
    resolve_base, check_base_freshness) so it can never disagree with the run
    it validates, and writes NO repo, ledger, loop-state, or policy data. A
    failed check follows the breaker convention ({"breaker": …} + exit 3) but
    persists nothing — there is no run state to write."""
    repo = os.path.abspath(os.path.expanduser(args.loop_repo))
    rc, _ = git(repo, "rev-parse", "--git-dir")
    if rc != 0:
        die(f"--loop-repo is not a git repo: {repo}")
    base, base_sha = resolve_base(repo, args.base)
    checks = []

    def noop_test_cmd(cmd):
        """True when test_cmd can never fail — a placeholder, not a gate
        (#140/F125). Sanctioned placeholders stay accepted (ready is
        unaffected); this only feeds the warning."""
        parts = [p.strip() for p in re.split(r"&&|;|\|\|", cmd.strip())
                 if p.strip()]
        return bool(parts) and all(
            p in ("true", ":", "exit 0") or p == "echo"
            or p.startswith("echo ")
            for p in parts)

    # 1. Required headless config — every ceiling an unattended run needs.
    #    The spec says "always ensure they're set (config or flag) for an
    #    unattended run"; init does not enforce that, doctor does.
    cfg = resolve_loop_config(args)
    required = {"test_cmd": cfg["test_cmd"], "wall_time_s": cfg["wall_time_s"],
                "token_budget": cfg["token_budget"],
                "attempt_cap": cfg["attempt_cap"], "iterations": cfg["cap"]}
    missing = sorted(k for k, v in required.items() if v is None)
    # A missing config key and the flag that sets it are named differently
    # (F31); and the keys must nest under a top-level "loop" object (F1). Spell
    # both out so the operator can act without reading resolve_loop_config().
    flag_for = {"test_cmd": "--test-cmd", "wall_time_s": "--wall-time",
                "token_budget": "--token-budget", "attempt_cap": "--attempt-cap",
                "iterations": "--cap"}
    loop_check = {
        "check": "loop-config", "ok": not missing,
        "configured": {k: v for k, v in required.items() if v is not None},
        "missing": missing,
        # Name each missing key WITH its flag inline ("iterations (--cap)"):
        # the two names for one knob were only reconcilable by cross-checking
        # the separate set_via_flag map (F86).
        "detail": ("every headless ceiling is configured" if not missing else
                   "an unattended run would have no ceiling for: "
                   + ", ".join("%s (%s)" % (k, flag_for[k]) for k in missing)
                   + " — set them in the scenarios "
                   "file's \"loop\" block (shown below, using the config key "
                   "names) or pass the init flags shown in parentheses. "
                   "Consequence: init refuses to start without them; a forced "
                   "run would be unbounded (no cap/wall-time/token ceiling) with "
                   "no regression gate (F74)"),
    }
    # #140/F125: ready:true could not be distinguished from "ready, but with
    # zero real test coverage" — the only caveat lived in prose guidance. A
    # configured no-op gets a non-fatal warning in the check detail AND as a
    # top-level report field; the sanctioned-placeholder design stands
    # (`ready` is unaffected).
    noop_warning = None
    # F176: a slug collision (an existing canonical file from another session)
    # is surfaced to the TOP-LEVEL warning, not just the nested
    # scenarios_file.existing_file field a skimming operator misses.
    collision_warning = None
    if cfg["test_cmd"] is not None and noop_test_cmd(cfg["test_cmd"]):
        noop_warning = (f"test_cmd looks like a no-op ({cfg['test_cmd']!r}) — "
                        "this headless run would have NO regression gate; "
                        "accepted by design (ready unaffected), but every "
                        "iteration's test breaker is a rubber stamp")
        loop_check["detail"] += " — WARNING: " + noop_warning
    if missing:
        loop_check["set_via_flag"] = {k: flag_for[k] for k in missing}
        loop_check["scenarios_loop_shape"] = {
            "loop": {k: "<value>" for k in required}}
        # F223: this is the placeholder SHAPE (required keys). A second,
        # filled-in copy-pasteable block lives in `doctor --help` ("sandbox
        # recipe"); tie the two together so a first-timer knows they are the
        # same block and where the ready-to-use version is, rather than
        # reconciling two disconnected skeletons.
        loop_check["scenarios_loop_shape_note"] = (
            "placeholders mark the required keys; for a filled-in, "
            "copy-pasteable sandbox block with concrete values see the "
            "'sandbox recipe' in `doctor --help`")
        if "test_cmd" in missing:
            # Nothing said what a good test_cmd validates, so a first-timer
            # could not tell whether a trivial "true" was acceptable or a
            # misconfiguration (F88).
            loop_check["test_cmd_guidance"] = (
                "test_cmd is the headless run's ONLY regression gate: it runs "
                "in the loop worktree after every iteration's commits, and a "
                "non-zero exit stops the run. Use the repo's real test/check "
                "suite (e.g. `make test`, `pytest -q`, `npm test`), minus any "
                "check that already fails on the base branch — a baseline "
                "failure is inherited state, not a regression, and would trip "
                "the breaker on iteration 1. A placeholder like `true` is "
                "accepted but leaves the run with NO regression gate; doctor "
                "cannot tell the difference, so it is your call.")
        # Name the canonical path so the operator knows WHERE the "loop" block
        # goes and that it is not auto-loaded (F38). Also say whether a file
        # already EXISTS there (F159): the scenarios dir is machine-wide
        # (F94), so a colliding target slug would silently inherit a foreign
        # loop block — existence is the signal that needs a manual ls today.
        _canon = os.path.join(
            TANUKI_ROOT, "scenarios", f"{args.target}.scenarios.json")
        _canon_exists = os.path.isfile(_canon)
        loop_check["scenarios_file"] = {
            "canonical": _canon,
            "canonical_file_exists": _canon_exists,
            "note": ("put the \"loop\" block in this file; its name must match "
                     "--target. doctor/init do NOT auto-load it — pass it with "
                     "--scenarios. $TANUKI_ROOT (default ~/.tanuki) sets the "
                     "root. canonical_file_exists says whether a file is "
                     "already there — the scenarios dir is machine-wide, so "
                     "an existing file under your slug may be another "
                     "session's config. For a scratch or sandboxed run you "
                     "may pass ANY path via --scenarios — it need not live "
                     "in this shared directory, which sidesteps the "
                     "cross-session slug collision this canonical location "
                     "is prone to (F94)."),
        }
        if _canon_exists:
            # F176: canonical_file_exists alone gave the operator nothing to
            # judge WHOSE file it is. Surface the three signals that judgment
            # needs — the file's age (a days-old mtime suggests a leftover),
            # its declared "target", and whether it carries a "loop" block at
            # all — so deciding own-file vs. another session's leftover needs
            # no manual stat/cat.
            try:
                _age_s = int(time.time() - os.path.getmtime(_canon))
            except OSError:
                _age_s = None
            _existing = {"mtime_age_s": _age_s, "target": None,
                         "has_loop_block": None}
            try:
                with open(_canon) as _f:
                    _doc = json.load(_f)
                if isinstance(_doc, dict):
                    _existing["target"] = _doc.get("target")
                    _existing["has_loop_block"] = isinstance(
                        _doc.get("loop"), dict)
                    _existing["detail"] = (
                        "existing canonical file: mtime %s ago, target=%r, "
                        "loop block %s — check these against your session "
                        "before trusting or overwriting it" % (
                            "%ds" % _age_s if _age_s is not None else "?",
                            _existing["target"],
                            "present" if _existing["has_loop_block"]
                            else "ABSENT"))
                else:
                    _existing["detail"] = ("existing canonical file parses "
                                           "but is not a JSON object")
            except (OSError, ValueError):
                _existing["detail"] = ("existing canonical file could not be "
                                       "read as JSON — likely damaged or "
                                       "mid-write by another session")
            loop_check["scenarios_file"]["existing_file"] = _existing
            # F176: promote the collision to the top-level warning when the
            # existing file declares a DIFFERENT target — the strongest signal
            # it belongs to another session's slug and must not be trusted.
            _ex_target = _existing.get("target")
            if _ex_target is not None and _ex_target != args.target:
                collision_warning = (
                    f"a canonical scenarios file already exists at {_canon} "
                    f"but declares target={_ex_target!r}, not {args.target!r} "
                    f"— likely another session's config under a colliding "
                    f"slug (the scenarios dir is machine-wide); inspect "
                    f"scenarios_file.existing_file before trusting or "
                    f"overwriting it")
    checks.append(loop_check)

    # 2. Base freshness — the same measurement init fails closed on (issue #2).
    fresh = check_base_freshness(repo, base)
    stale_ok = fresh["behind"] == 0 or args.allow_stale_base
    if fresh["behind"] == 0:
        detail = (fresh["note"] or
                  f"base '{base}' is current with {fresh['upstream']}")
    elif args.allow_stale_base:
        detail = (f"local base '{base}' is {fresh['behind']} commit(s) behind "
                  f"'{fresh['upstream']}' — acceptable only because "
                  "--allow-stale-base was given (init will need it too)")
    else:
        detail = (f"local base '{base}' is {fresh['behind']} commit(s) behind "
                  f"'{fresh['upstream']}' — init will fail closed; "
                  f"fast-forward it (git -C {repo} merge --ff-only "
                  f"{fresh['upstream']}) or plan --allow-stale-base")
    checks.append({"check": "base-freshness", "ok": stale_ok,
                   "upstream": fresh["upstream"], "behind": fresh["behind"],
                   "detail": detail})

    # 3. Baseline test_cmd on the base tip — a failure there means every
    #    iteration would trip the test breaker on inherited state, not a
    #    regression. Run in a throwaway detached worktree, removed afterward:
    #    the operator's tree is never touched and the repo nets zero change.
    if not cfg["test_cmd"]:
        # derived_from marks this as a CONSEQUENCE of loop-config, not an
        # independent fault (F112): with no test_cmd there is nothing to run,
        # so fixing loop-config fixes this too. The breaker summary reads this
        # field and names only root causes, so the operator sees one problem to
        # fix rather than two unrelated ones. The detail REFERENCES the root
        # cause rather than restating it (F112 residual): the relationship is
        # already carried structurally by derived_from / root_causes /
        # derived_failures, and a third prose copy is what the operator had
        # to read three times.
        checks.append({"check": "baseline-test", "ok": False,
                       "derived_from": "loop-config",
                       "detail": "no test_cmd to check — a consequence of "
                                 "the loop-config failure (see root_causes); "
                                 "fixing that fixes this too"})
        # Report the artifact check even when it cannot run. A check that shows
        # up only in the ready report looks like it appeared from nowhere
        # between two runs (F91) — the fixed skeleton the dashboard already
        # follows: degrade to an explicit reason, never a silent omission.
        checks.append({"check": "test-cmd-artifacts", "ok": True,
                       "artifacts": None,
                       "detail": "not checked — needs a test_cmd to run"})
    else:
        tmpdir = tempfile.mkdtemp(prefix="tanuki-doctor-")
        wt = os.path.join(tmpdir, "base")
        rc, err = git(repo, "worktree", "add", "--detach", wt, base_sha)
        if rc != 0:
            shutil.rmtree(tmpdir, ignore_errors=True)
            checks.append({"check": "test-cmd-artifacts", "ok": True,
                           "artifacts": None,
                           "detail": "not checked — the throwaway worktree "
                                     "could not be created"})
            checks.append({"check": "baseline-test", "ok": False,
                           "detail": "could not create the throwaway "
                                     f"worktree for the baseline run: {err}"})
        else:
            try:
                r = subprocess.run(cfg["test_cmd"], shell=True, cwd=wt,
                                   capture_output=True, text=True)
                tail = ((r.stdout or "") + (r.stderr or "")).strip()[-300:]
                checks.append({
                    "check": "baseline-test", "ok": r.returncode == 0,
                    "exit": r.returncode,
                    # F125: a cold operator reads this line, not the JSON
                    # warning key — a vacuous pass must say so where the pass
                    # is reported.
                    "detail": (f"test_cmd passes on the base tip "
                               f"({base_sha[:12]})"
                               + (" — but test_cmd looks like a no-op "
                                  "placeholder, so this pass is vacuous: it "
                                  "cannot catch regressions"
                                  if noop_warning else "")
                               if r.returncode == 0 else
                               f"test_cmd FAILS on the base tip (exit "
                               f"{r.returncode}) — every iteration would trip "
                               "the test breaker on inherited state, not a "
                               f"regression: …{tail}"),
                })
                # We just ran test_cmd in a pristine checkout, so anything
                # untracked here is something test_cmd sheds (__pycache__,
                # .pyc, coverage data). Mid-run that trips iter-verify's
                # clean-worktree breaker far from its cause, and recovering
                # from it burns the scenario's turn budget (F64, F89). Say so
                # now, while it is one .gitignore line. Informational, never
                # fatal: the run is still correct, just noisier.
                rc_s, dirty = git(wt, "status", "--porcelain", "--untracked-files=all")
                _lines = dirty.splitlines() if rc_s == 0 else []
                shed = sorted({ln[3:].split("/")[0] for ln in _lines
                               if ln.startswith("?? ")})
                # F111 / #242: regenerable output COMMITTED to the base before
                # the run is TRACKED, so test_cmd regenerating it shows as a
                # modification (` M`), not an untracked `??`. `git worktree
                # remove` then refuses at the last gate step (morning-gate step
                # 7) over a file that has nothing to do with the loop's work.
                # The untracked branch above never saw it. Predict it here too,
                # name the paths, and state the remedy.
                tracked = sorted({ln[3:] for ln in _lines
                                  if not ln.startswith("?? ")
                                  and is_build_artifact(ln[3:])})
                if tracked:
                    detail = (
                        "test_cmd modifies build artifact(s) TRACKED on the "
                        "base (committed before the run): %s. Regenerated in "
                        "every worktree, so `git worktree remove` refuses at "
                        "the last gate step (morning-gate step 7) over files "
                        "unrelated to the loop's work — not a breaker: use "
                        "`git worktree remove --force`, and for the durable fix "
                        "stop tracking them on the base (`git rm -r --cached "
                        "<path>` + .gitignore), which also clears the gate-push "
                        "artifact refusal for every later run"
                        % ", ".join(tracked)
                        + ("; test_cmd also sheds untracked artifact(s): %s "
                           "(.gitignore them too)" % ", ".join(shed)
                           if shed else ""))
                elif shed:
                    detail = ("test_cmd leaves untracked artifact(s) in a "
                              "pristine checkout: %s — .gitignore them, or "
                              "iter-verify's clean-worktree breaker will fire "
                              "mid-run after a commit, far from this cause"
                              % ", ".join(shed))
                else:
                    detail = "test_cmd leaves no untracked or tracked artifacts"
                checks.append({
                    "check": "test-cmd-artifacts", "ok": True,
                    "artifacts": shed,
                    "tracked_artifacts": tracked or None,
                    "detail": detail,
                })
            finally:
                git(repo, "worktree", "remove", "--force", wt)
                git(repo, "worktree", "prune")
                shutil.rmtree(tmpdir, ignore_errors=True)

    # 4. Policy coverage — which actionable findings have no policy answer and
    #    would therefore DEFER ("questions only in iteration 1"; a headless
    #    run never asks). Informational, never fatal: deferral is the
    #    designed-safe headless outcome — but a night of it is worth knowing
    #    about before launching, not at the morning gate.
    bad, decisions, source = _doctor_policy(args)
    if bad:
        checks.append(bad)
    else:
        actionable = [f for f in ledger_findings(args.target)
                      if not f.get("tombstone")
                      and f.get("status") in ("open", "proposed")]
        uncovered = [{"id": f["id"], "title": f.get("title")}
                     for f in actionable if f["id"] not in decisions]
        if not actionable:
            detail = "ledger has no actionable findings — nothing to cover"
        elif uncovered:
            detail = (f"{len(uncovered)} of {len(actionable)} actionable "
                      "finding(s) have no policy answer — each one DEFERS to "
                      "the morning queue if it needs judgment (informational)")
        else:
            detail = (f"every actionable finding ({len(actionable)}) has a "
                      "policy answer")
        checks.append({"check": "policy-coverage", "ok": True,
                       "policy_source": source,
                       "actionable": len(actionable),
                       "covered": len(actionable) - len(uncovered),
                       "would_defer": uncovered, "detail": detail})

    # 5. Host cloneable (spec-host-snapshot) — init pins a run-scoped host
    #    fixture by cloning the live host; a host that cannot be cloned must
    #    surface here, not at init. Throwaway clone, removed afterward
    #    (mirrors the baseline-test worktree pattern). Hostless: skipped.
    host = resolve_host(args)
    if not host:
        checks.append({"check": "host-cloneable", "ok": True,
                       "detail": "hostless target — no host fixture to pin"})
    elif git(host, "rev-parse", "--git-dir")[0] != 0:
        checks.append({"check": "host-cloneable", "ok": False,
                       "detail": f"host is not a git repo: {host}"})
    else:
        tmpdir = tempfile.mkdtemp(prefix="tanuki-doctor-host-")
        try:
            pin_host_fixture(host, os.path.join(tmpdir, "host-base"))
            note = host_freshness_note(host)
            checks.append({"check": "host-cloneable", "ok": True,
                           "detail": (f"host '{host}' resolves and clones"
                                      + (f" — {note}" if note else ""))})
        except RuntimeError as e:
            checks.append({"check": "host-cloneable", "ok": False,
                           "detail": str(e)})
        finally:
            shutil.rmtree(tmpdir, ignore_errors=True)

    # 6. Entry fixtures (spec-host-snapshot "Stage-entry fixtures"; story
    #    1.16) — declared stage artifacts must be materializable or init
    #    fails closed; a hostless declaration is out of scope, stated rather
    #    than silently ignored. Reported in every report (F91).
    try:
        efx = resolve_entry_fixtures(args)
    except SystemExit:
        raise
    if not efx:
        checks.append({"check": "entry-fixtures", "ok": True,
                       "detail": "no entry fixtures declared in the "
                                 "scenarios file"})
    elif not host:
        checks.append({"check": "entry-fixtures", "ok": True,
                       "detail": (f"declared ({', '.join(sorted(efx))}) but "
                                  "the target is HOSTLESS — an entry fixture "
                                  "is host state (spec-host-snapshot), so "
                                  "the declarations are out of scope; init "
                                  "will pin nothing")})
    else:
        missing = {n: [p for p in r["paths"]
                       if not os.path.exists(os.path.join(host, p))]
                   for n, r in efx.items()}
        missing = {n: m for n, m in missing.items() if m}
        if missing:
            checks.append({"check": "entry-fixtures", "ok": False,
                           "detail": "init would FAIL CLOSED — missing from "
                                     f"the live host: {missing}"})
        else:
            # Staleness vs the last pinned provenance (story 1.18): compare
            # each recipe against what the most recent run pinned. A stale
            # fixture is the operator's call — warning, `ok`/`ready`
            # unaffected (the host-drift posture); read-only throughout.
            prior = {}
            cur = os.path.join(TANUKI_ROOT, args.target, "loop", "current")
            if os.path.exists(cur):      # quiet: no prior run is expected,
                try:                     # never an error on a read-only check
                    with open(cur, encoding="utf-8") as f:
                        prior = (load_state(args.target, f.read().strip())
                                 .get("entry_fixtures") or {})
                except (OSError, ValueError):
                    pass
            rc_t, live_tip = git(host, "rev-parse", "HEAD")
            stale = []
            for n, r in sorted(efx.items()):
                p = prior.get(n)
                if not p:
                    continue
                pinned = p.get("source_commit")
                if (rc_t == 0 and pinned and live_tip != pinned):
                    rc_d, changed = git(host, "diff", "--name-only",
                                        f"{pinned}..{live_tip}", "--",
                                        *r["paths"])
                    if rc_d == 0 and changed.strip():
                        stale.append(
                            f"'{n}': artifacts changed since pinned "
                            f"{pinned[:12]} -> live {live_tip[:12]} "
                            f"({', '.join(changed.split())})")
                if r.get("producing_stage") != p.get("producing_stage_version"):
                    stale.append(
                        f"'{n}': producing stage moved "
                        f"{p.get('producing_stage_version')} -> "
                        f"{r.get('producing_stage')} — pinned artifacts may "
                        "no longer match what the current stage produces")
            entry = {"check": "entry-fixtures", "ok": True,
                     "detail": ("declared fixture(s) "
                                f"({', '.join(sorted(efx))}) all "
                                "materializable from the live host"
                                + ("" if prior else
                                   " — no prior pinned provenance to "
                                   "compare (first run: expected)"))}
            if stale:
                entry["warning"] = ("stale entry fixture(s) — informational, "
                                    "ready unaffected: " + "; ".join(stale))
            checks.append(entry)

    # PR-gate tooling (spec-tanuki-loop "PR-protected targets"): a target whose
    # gate mode is "pr" delivers its review material via `gh` — validate that
    # up front rather than discovering it at gate-pr time, after a whole
    # unattended run. Merge-mode targets skip this with a note (the fixed
    # skeleton: degrade to an explicit reason, never a silent omission).
    if cfg["gate"] == "pr":
        gh_path = shutil.which("gh")
        checks.append({"check": "gate-pr-tooling", "ok": bool(gh_path),
                       "detail": (f"gate mode 'pr': `gh` found at {gh_path}"
                                  if gh_path else
                                  "gate mode 'pr' but `gh` (GitHub CLI) is "
                                  "not on PATH — gate-pr cannot deliver the "
                                  "PR; install/auth gh or switch the "
                                  "loop block's \"gate\" to \"merge\"")})
    else:
        checks.append({"check": "gate-pr-tooling", "ok": True,
                       "detail": "gate mode 'merge' — no forge tooling "
                                 "needed; the morning gate merges locally "
                                 "and gate-push pushes the base"})

    # issue #258: one active run per target. A live unfinished run for this
    # target means a headless START would steal its `current` pointer (bare
    # init) or need --allow-concurrent. This is ADVISORY in doctor, not
    # fail-closed: doctor is read-only and is legitimately run against an
    # already-init'd run (e.g. to inspect entry-fixture staleness, story 1.18),
    # so it surfaces the conflict in the warning without flipping `ready`. The
    # fail-closed ENFORCEMENT lives in `init`, the operation that would actually
    # collide.
    live_runs = unfinished_runs(args.target)
    live_warning = None
    if live_runs:
        live_warning = (
            f"{len(live_runs)} unfinished run(s) with a live worktree already "
            f"share this target's machine-wide state "
            f"({', '.join(r for r, _ in live_runs)}) — a bare `init` would "
            "steal the `current` pointer from them; finish/abort them first, "
            "or start with init --allow-concurrent (issue #258)")
    checks.append({
        "check": "no-live-run", "ok": True,
        "detail": (live_warning if live_warning else
                   "no other unfinished run for this target — a fresh run "
                   "would own the `current` pointer alone")})

    failed = [c["check"] for c in checks if not c["ok"]]
    # Cause before consequence (F112). A derived check fails only because the
    # check it names failed; listing the two as peers reads as two unrelated
    # problems. Derived entries are still reported in full under "checks" —
    # they are demoted in the SUMMARY, never hidden.
    derived = {c["check"]: c["derived_from"] for c in checks
               if not c["ok"] and c.get("derived_from")
               and c["derived_from"] in failed}
    roots = [c for c in failed if c not in derived]
    # Always present, explicitly null when clean (the status convention,
    # F102/F106): absence and "nothing to warn about" must not be
    # indistinguishable (#140).
    # F176: combine the no-op test_cmd warning with a slug-collision warning
    # so both reach the top-level field an operator skims; null when neither
    # applies (the F102/F106 absence-vs-null convention).
    _warn = "; ".join(w for w in (noop_warning, collision_warning,
                                  live_warning) if w) or None
    report = {"phase": args.phase, "target": args.target, "base": base,
              "base_sha": base_sha, "ready": not failed,
              "warning": _warn, "checks": checks}
    if failed:
        tail = ""
        if derived:
            tail = ("; " + ", ".join(f"{c} follows from {r}"
                                     for c, r in derived.items()))
        report["breaker"] = (f"doctor: {len(roots)} check(s) failed "
                             f"({', '.join(roots)}){tail} — not ready for "
                             f"phase {args.phase} headless execution")
        report["root_causes"] = roots
        if derived:
            report["derived_failures"] = derived
        # Surface the exit-code contract in the payload so a scripted headless
        # caller learns it from the tool, not only from commands/tanuki-loop.md
        # (F34): exit 3 == not ready / breaker; exit 0 == ready.
        report["exit_code"] = 3
        out(report)
        sys.exit(3)
    report["exit_code"] = 0
    out(report)


def _worktree_head(state):
    rc, sha = git(state["worktree"], "rev-parse", "HEAD")
    return sha if rc == 0 else None


# Build artifacts a language runtime regenerates at will. They are never work
# product, so they must not make a worktree "dirty" (false friction), and they
# must never reach the integration branch (F64 / issue #71): once committed
# they trip iter-verify's not-clean breaker on a LATER iteration, far from the
# commit that introduced them, with a diagnostic that names neither the files
# nor the cause. The guard is an ignore-list, stated here and in --help.
_ARTIFACT_DIRS = ("__pycache__", ".pytest_cache", ".mypy_cache", ".ruff_cache")
_ARTIFACT_SUFFIXES = (".pyc", ".pyo")


def is_build_artifact(path):
    """True for a path git reports that is a regenerable build artifact."""
    parts = [p for p in path.replace("\\", "/").split("/") if p]
    if any(p in _ARTIFACT_DIRS for p in parts):
        return True
    return path.endswith(_ARTIFACT_SUFFIXES) or path.endswith(".egg-info")


def _dirty_split(state):
    """(real_dirty, artifact_dirty) from `git status --porcelain`.

    -uall is load-bearing: git collapses a wholly-untracked directory to one
    entry ("?? pkg/"), which would hide that its only content is __pycache__
    and make an artifact-only tree read as dirty. Listing files individually
    lets the ignore-list see real paths.
    """
    rc, o = git(state["worktree"], "status", "--porcelain", "-uall")
    if rc != 0:
        return ["?"], []
    names = [ln[3:] for ln in o.splitlines() if ln.strip()]
    real = [n for n in names if not is_build_artifact(n)]
    arts = [n for n in names if is_build_artifact(n)]
    return real, arts


def _clean(state):
    # Untracked build artifacts do not count as dirty: they are regenerable
    # and not work product. Artifacts that were COMMITTED are caught by
    # committed_artifacts() at verify, where the diagnostic can name the cause.
    real, _ = _dirty_split(state)
    return real == []


def committed_artifacts(wt, start, head):
    """Build artifacts introduced into the integration branch between start
    and head. This is the contamination that matters: an agent's `git add -A`
    sweeps __pycache__ in, and nothing notices until a later iteration."""
    rc, o = git(wt, "diff", "--name-only", f"{start}..{head}")
    if rc != 0:
        return []
    return sorted({n for n in o.splitlines() if n.strip()
                   and is_build_artifact(n)})


def iteration_commits(wt, start, head):
    """The commits an iteration landed, `(start, head]` oldest-first, each with
    its subject line and changed-file count. Recorded by `iter-verify` into
    state.json so the dashboard can show WHAT landed without ever running git
    in its render path (spec-tanuki-view D4 "render, don't compute"; the
    dashboard is a state-file-only reader). git runs HERE — in iter-verify,
    which already operates in the loop worktree. A no-patch iteration
    (head == start) records an empty list, which is distinct from a legacy
    iteration that has no `commits` key at all."""
    if head == start:
        return []
    rc, o = git(wt, "rev-list", "--reverse", f"{start}..{head}")
    if rc != 0:
        return []
    commits = []
    for sha in o.splitlines():
        sha = sha.strip()
        if not sha:
            continue
        _, subject = git(wt, "log", "-1", "--format=%s", sha)
        rc2, names = git(wt, "diff-tree", "--no-commit-id", "--name-only",
                         "-r", sha)
        files = (len([n for n in names.splitlines() if n.strip()])
                 if rc2 == 0 else 0)
        commits.append({"sha": sha, "subject": subject,
                        "files_changed": files})
    return commits


def cmd_iter_start(args):
    """Open an iteration, tripping any breaker that should stop the run first.

    Check PRECEDENCE, which is observable and worth knowing (F93): sequencing,
    then cap, then wall-time, then external modification. The order matters
    because the first match wins and stops the run — so once a run reaches its
    cap, `cap reached` shadows the external-modification check permanently, and
    an external edit to a capped run's worktree is never reported. That is
    deliberate (a capped run is over; it has no next iteration to protect) but
    it means a capped run's worktree is NOT guarded — re-`init` to get a fresh
    guarded run rather than continuing to edit a capped one. Rolled-back
    iterations consume cap slots, so a run can reach this state earlier than
    its landed-commit count suggests (F27).
    """
    state = load_state(args.target, args.run)
    if state["iterations"] and state["iterations"][-1].get("phase") == "started":
        breaker(state, "sequencing violation: previous iteration was never "
                       "closed by iter-verify or rollback")
    if len(state["iterations"]) >= state["cap"]:
        # F3 / issue #64: state the CAUSE, not just the ceiling. "cap reached"
        # alone reads like a sequencing complaint when a retry trips it, and
        # gives no way to see that rolled-back work consumed the allowance.
        # The breakdown is what distinguishes "the run did its iterations" from
        # "the run burned them undoing things". Keep the "iteration cap
        # reached" prefix: breaker_hint() matches it to name the next action.
        n = len(state["iterations"])
        verified = sum(1 for i in state["iterations"]
                       if i.get("phase") == "verified")
        rolled = sum(1 for i in state["iterations"]
                     if i.get("phase") == "rolled_back")
        breaker(state, f"iteration cap reached: {n}/{state['cap']} consumed "
                       f"({verified} verified, {rolled} rolled back) — "
                       f"rolled-back iterations count toward the cap; later "
                       f"checks (wall-time, external modification) were not "
                       f"evaluated (F93)")
    if state["wall_limit_s"] and \
            time.time() - state["wall_start"] >= state["wall_limit_s"]:
        breaker(state, "wall-time limit exceeded")
    head = _worktree_head(state)
    # F152: the breaker message states its own scope — it watches the LOOP
    # WORKTREE's HEAD and dirty state only, never the base repo (base commits
    # are out of scope after init — spec-host-snapshot).
    if head != state["head_expected"]:
        breaker(state, f"external modification of the integration worktree "
                       f"(HEAD {head} != expected {state['head_expected']}) — "
                       f"this breaker watches the loop worktree's HEAD and "
                       f"dirty state only, never the base repo")
    if not _clean(state):
        breaker(state, "external modification: worktree not clean at "
                       "iteration start — this breaker watches the loop "
                       "worktree's HEAD and dirty state only, never the "
                       "base repo")
    # F191: the base ref is only ever needed again at the gate (gate-check/
    # gate-pr/gate-push), so a base deleted or renamed mid-run used to stay
    # silent until delivery. Warn here — never a breaker: the base is out of
    # scope after init (spec-host-snapshot) and the run can proceed.
    warning = None
    rc_b, _ = git(state["loop_repo"], "rev-parse", "--verify",
                  f"{state['base']}^{{commit}}")
    if rc_b != 0:
        warning = (f"recorded base ref '{state['base']}' no longer resolves "
                   "in the loop repo — the run continues (the base is out of "
                   "scope after init), but the gate (gate-check/gate-pr/"
                   "gate-push) will need it; restore the branch before "
                   "delivery (F191)")
        audit(state, f"WARNING: {warning}")
    n = len(state["iterations"]) + 1
    state["iterations"].append({
        "n": n, "start": head, "end": None, "phase": "started", "removed": [],
        # Ledger snapshot: record-cycle derives "new actionable" from its ids,
        # so convergence never trusts a model-supplied count; status/recurrence
        # let the dashboard report this-run deltas (fixed/recurred).
        "findings_before": {fd["id"]: {"status": fd.get("status"),
                                       "recurrence": fd.get("recurrence", 1)}
                            for fd in ledger_findings(state["target"])},
    })
    save_state(state)
    audit(state, f"iter {n}: start @ {head[:12]}")
    out({"ok": True, "iteration": n, "start_sha": head, "warning": warning})


def cmd_iter_verify(args):
    state = load_state(args.target, args.run)
    if not state["iterations"] or state["iterations"][-1].get("phase") != "started":
        breaker(state, "sequencing violation: iter-verify without an open iteration")
    it = state["iterations"][-1]
    wt = state["worktree"]
    start = it["start"]
    rc, branch = git(wt, "symbolic-ref", "--short", "HEAD")
    if rc != 0 or branch != state["integration_branch"]:
        breaker(state, f"integration invariant: HEAD not on {state['integration_branch']} "
                       f"(got {branch or 'detached'})")
    head = _worktree_head(state)
    rc, _ = git(wt, "merge-base", "--is-ancestor", start, head)
    if rc != 0:
        breaker(state, "integration invariant: start SHA is not an ancestor of HEAD")
    if not args.no_patch and head == start:
        breaker(state, "integration invariant: HEAD == start SHA but a patch was expected")
    # Artifact guard — check (e) of the five-part integration invariant
    # (spec-tanuki-loop "One iteration" step 6, AMENDED 2026-07-19, triage of
    # issue #159; supersedes the 2026-07-17 report-only arbitration): commits
    # that introduce build-artifact paths are an immediate-stop breaker at the
    # commit that introduced them, not a deferred warning — doctor's
    # test-cmd-artifacts check runs only at doctor time, which Phase 1 may
    # skip, so without (e) nothing between the commit and the remote objects.
    # A legitimate binary is declared deliberately per path with
    # --allow-artifact (audited); the guard never stands down silently. The
    # pattern source is is_build_artifact() — the same list doctor and
    # gate-push read.
    arts = committed_artifacts(wt, start, head)
    it["build_artifacts_committed"] = arts or None
    if not _clean(state):
        real, _ = _dirty_split(state)
        shown = ", ".join(real[:8]) + (" …" if len(real) > 8 else "")
        breaker(state, "integration invariant: worktree not clean after commit"
                       + (f" (dirty: {shown})" if real else ""))
    allowed = list(args.allow_artifact or [])
    def _declared(p):
        return any(p == a or p.startswith(a.rstrip("/") + "/") for a in allowed)
    undeclared = [p for p in arts if not _declared(p)]
    if undeclared:
        shown = ", ".join(undeclared[:8]) + (" …" if len(undeclared) > 8 else "")
        breaker(state, "integration invariant: build artifacts committed to "
                       f"the integration branch ({shown})")
    overridden = [p for p in arts if _declared(p)]
    if overridden:
        it["artifact_override"] = {"allowed": allowed, "paths": overridden}
        audit(state, f"iter {it['n']}: check (e) override — declared build "
                     f"artifact(s) allowed: {', '.join(overridden)} "
                     f"(--allow-artifact {' '.join(allowed)})")
    it["end"] = head
    it["phase"] = "verified"
    # Story 1.10: record each landed commit's subject + changed-file count so
    # the dashboard's "this run" section can show what landed as a state-file
    # read (spec-tanuki-view D4) — git runs here, never in the render path. A
    # no-patch iteration records [] (distinct from a legacy run's absent key).
    it["commits"] = iteration_commits(wt, start, head)
    # Budget accounting at the barrier (spec-tanuki-loop "Concurrent drives";
    # story 1.22): the iteration's cost/turn totals are the SUM across every
    # drive result in its manifest — concurrent drives included — folded in
    # here, before the next iter-start's breaker evaluation, so the stored
    # harness-tripped ceiling reads the true total. Absent manifest (no drive
    # recorded) leaves the key out, exactly as before.
    mpath = os.path.join(TANUKI_ROOT, state["target"], "events",
                         f"{state['run']}-iter{it['n']}", "manifest.json")
    try:
        with open(mpath, encoding="utf-8") as f:
            _res = json.load(f).get("results", [])
        it["drive_totals"] = {
            "scenarios": len(_res),
            "cost_usd": round(sum(r.get("cost_usd") or 0 for r in _res), 4),
            "num_turns": sum(r.get("num_turns") or 0 for r in _res)}
    except (OSError, ValueError):
        pass
    state["head_expected"] = head
    save_state(state)
    audit(state, f"iter {it['n']}: verified, end @ {head[:12]}")
    payload = {"ok": True, "iteration": it["n"], "end_sha": head,
               # Always present, explicitly null when clean: absence and "no
               # artifacts" must not look identical to a reader following the
               # docs (the fixed-skeleton rule, applied to JSON).
               "build_artifacts_committed": arts or None,
               # F41: iter-verify records this HEAD as head_expected but does
               # NOT check for external modification — that runs only at the
               # next iter-start. State the deferred-detection rule here so an
               # operator reading iter-verify's output alone knows a foreign
               # commit inside this window is absorbed silently, not flagged.
               "external_modification_check": (
                   "deferred to the next iter-start (HEAD vs head_expected); "
                   "not evaluated here — a commit made in this worktree during "
                   "the iteration is folded into head_expected and never trips "
                   "the breaker"),
               "warning": None}
    if arts:
        # Only declared (--allow-artifact) paths reach this point — an
        # undeclared artifact already stopped the iteration at check (e).
        shown = ", ".join(arts[:8]) + (" …" if len(arts) > 8 else "")
        payload["warning"] = (
            f"build artifacts committed to the integration branch ({shown}) "
            "under an explicit --allow-artifact override. gate-push will "
            "still refuse to push them without --allow-artifacts.")
        audit(state, f"iter {it['n']}: WARNING build artifacts committed "
                     f"(declared): {', '.join(arts)}")
    out(payload)


def cmd_rollback(args):
    state = load_state(args.target, args.run)
    if not state["iterations"] or state["iterations"][-1].get("phase") != "started":
        breaker(state, "sequencing violation: rollback without an open iteration")
    it = state["iterations"][-1]
    wt, start = state["worktree"], it["start"]
    rc, removed = git(wt, "clean", "-nd")        # preview untracked to be removed
    removed_paths = [ln[len("Would remove "):] for ln in removed.splitlines()
                     if ln.startswith("Would remove ")]
    git(wt, "reset", "--hard", start)
    git(wt, "clean", "-fd")
    if not _clean(state) or _worktree_head(state) != start:
        breaker(state, "rollback failed to restore a clean tree at the start SHA")
    it["removed"] = removed_paths
    it["phase"] = "rolled_back"
    state["head_expected"] = start
    # F118: rollback is the documented remedy for breakers that fire with an
    # iteration open (test failure, invariant violation); once it succeeds the
    # stop is resolved, and the verdict must not keep reading "stopped"
    # against an active lifecycle. External modification stays armed — that
    # breaker is recover's, not rollback's.
    lb = state.get("last_breaker")
    if lb and not lb.get("recovered") and \
            "external modification" not in lb.get("reason", ""):
        lb["recovered"] = {"mode": "rollback",
                           "at": time.strftime("%Y-%m-%d %H:%M:%S")}
    save_state(state)
    audit(state, f"iter {it['n']}: rolled back to {start[:12]}; "
                 f"removed untracked: {removed_paths or 'none'}")
    # 'removed_untracked' names ONLY the git clean -fd paths; the reset --hard
    # also silently discards tracked/staged changes back to the start SHA, which
    # this list does not enumerate (F69).
    out({"ok": True, "reset_to": start, "removed_untracked": removed_paths})


def cmd_recover(args):
    """Attended recovery from the external-modification breaker (story 1.2;
    spec-tanuki-loop "Recovery from the external-modification breaker").
    That breaker fires at iter-start — every iteration already closed — so
    `rollback` (which needs an OPEN iteration) is structurally the wrong tool
    and its misuse overwrites last_breaker (F17). Recovery runs BETWEEN
    iterations, adjusts only head_expected/the worktree/the audit, and never
    mutates a closed iteration. Two explicit modes, no default; the operator
    chooses. Nothing here is ever invoked by the loop itself."""
    # A missing mode is a refusal in the tool's own JSON convention (F37), not
    # an argparse usage error — a scripted caller parses exit-3 {"breaker": …}.
    if not args.restore and not args.adopt:
        out({"breaker": "recover: choose exactly one mode — --restore "
                        "(discard the external change, reset to the last "
                        "verified loop state) or --adopt (re-baseline around "
                        "it)"})
        sys.exit(3)
    state = load_state(args.target, args.run)

    def refuse(msg):
        # Breaker convention (exit 3, {"breaker": ...}) WITHOUT persisting:
        # a refusal must not overwrite last_breaker or touch state/audit —
        # the whole point is preserving the original diagnosis (F17).
        out({"breaker": msg})
        sys.exit(3)

    lb = state.get("last_breaker") or {}
    if "external modification" not in lb.get("reason", ""):
        refuse("recover: last breaker is not an external-modification "
               f"breaker (got: {lb.get('reason') or 'none'})")
    if lb.get("recovered"):
        refuse(f"recover: already recovered (--{lb['recovered']['mode']} "
               f"at {lb['recovered']['at']})")
    if state["iterations"] and state["iterations"][-1].get("phase") == "started":
        refuse("recover: an iteration is still open — recovery runs only "
               "between iterations (close it with iter-verify or rollback)")

    wt, expected = state["worktree"], state["head_expected"]
    head = _worktree_head(state)
    if args.restore:
        # Restore the loop-owned snapshot: discard the external commits and
        # files from the worktree (reflog-recoverable), back to the last
        # verified head_expected. Mirror rollback's mechanics, different ref.
        rc, preview = git(wt, "clean", "-nd")
        removed = [ln[len("Would remove "):] for ln in preview.splitlines()
                   if ln.startswith("Would remove ")]
        # F168: `discarded` names external COMMITS only, but reset --hard also
        # throws away uncommitted tracked edits — list those separately or a
        # dirty-tree restore reads as a no-op ("discarded": []).
        dirty = [ln[3:] for ln in
                 git(wt, "status", "--porcelain")[1].splitlines()
                 if ln and not ln.startswith("??")]
        discarded = []
        if head and git(wt, "merge-base", "--is-ancestor", expected, head)[0] == 0:
            discarded = git(wt, "rev-list", "--oneline",
                            f"{expected}..{head}")[1].splitlines()
        git(wt, "reset", "--hard", expected)
        git(wt, "clean", "-fd")
        if not _clean(state) or _worktree_head(state) != expected:
            breaker(state, "recover --restore failed to restore a clean "
                           f"tree at {expected}")
        mode = "restore"
        note = (f"worktree reset to {expected[:12]}; discarded external "
                f"commits: {discarded or 'none'}; discarded uncommitted "
                f"edits: {dirty or 'none'}; removed untracked: "
                f"{removed or 'none'} (commits reflog-recoverable; "
                f"uncommitted edits are not)")
        result = {"ok": True, "mode": mode, "head_expected": expected,
                  "discarded": discarded,
                  "discarded_uncommitted_edits": dirty, "removed": removed}
    else:  # --adopt
        # Re-baseline around the external change: the human accepts the
        # current worktree HEAD as the loop's expected state. The adopted
        # commits become part of the integration branch the morning-gate
        # diff presents.
        if not _clean(state):
            refuse("recover --adopt: worktree not clean — commit or remove "
                   "the external changes first (or choose --restore)")
        ancestor = git(wt, "merge-base", "--is-ancestor",
                       expected, head or "")[0] == 0
        adopted = git(wt, "rev-list", "--oneline",
                      f"{expected}..{head}")[1].splitlines() if ancestor else []
        state["head_expected"] = head
        mode = "adopt"
        note = (f"head_expected re-baselined {expected[:12]} -> "
                f"{(head or '?')[:12]}; adopted external commits: "
                f"{adopted or 'none'}")
        if not ancestor:
            note += (" — WARNING: old head_expected is NOT an ancestor of "
                     "the new HEAD (history rewritten, not extended)")
        result = {"ok": True, "mode": mode, "head_expected": head,
                  "adopted": adopted, "ancestor": ancestor}
    # The original diagnosis is kept, annotated — never silently overwritten;
    # the dashboard stops treating an annotated breaker as "STOPPED".
    lb["recovered"] = {"mode": mode,
                       "at": time.strftime("%Y-%m-%d %H:%M:%S")}
    state["last_breaker"] = lb
    save_state(state)
    audit(state, f"recover --{mode}: {note}")
    out(result)


def cmd_attempt(args):
    state = load_state(args.target, args.run)
    cur = state["attempts"].get(args.finding, 0)
    if cur >= state["attempt_cap"]:
        if args.finding not in state["frozen"]:
            state["frozen"].append(args.finding)
            append(state["target"], state["run"], "queue.md",
                   f"- FROZEN {args.finding}: exceeded {state['attempt_cap']} "
                   f"fix attempts — needs human review")
            audit(state, f"froze {args.finding} after {cur} attempts")
        save_state(state)
        out({"finding": args.finding, "attempts": cur, "frozen": True})
        return
    state["attempts"][args.finding] = cur + 1
    save_state(state)
    out({"finding": args.finding, "attempts": cur + 1, "frozen": False})


def cmd_test(args):
    state = load_state(args.target, args.run)
    # Running `test` on a finished run is EXPECTED, not an error: the morning
    # gate's step 1 re-runs the suite after the unattended run closed with
    # `cap`/`converged`. So this reports the terminal state instead of guarding
    # against it (F101) — a refusal would break the documented gate. Without
    # this the call is indistinguishable from a mid-run test, while silently
    # appending to a closed run's audit.
    fin = state.get("finished")
    post = ({"run_finished": {"reason": fin.get("reason"), "at": fin.get("at"),
                              "note": "run already closed; this is expected at "
                                      "the morning gate (step 1) — the result "
                                      "is appended to the closed run's audit"}}
            if fin else {})
    cmd = state.get("test_cmd")
    if not cmd:
        audit(state, "test: no test_cmd configured — skipped "
                     "(configure one for unattended runs)")
        out({"skipped": True, **post})
        return
    r = subprocess.run(cmd, shell=True, cwd=state["worktree"],
                       capture_output=True, text=True)
    tail = ((r.stdout or "") + (r.stderr or "")).strip()[-300:]
    if r.returncode != 0:
        audit(state, f"test FAILED (exit {r.returncode}): …{tail}")
        # Name the command that failed and echo its output tail (F67), so the
        # operator sees what ran without opening the scenarios file.
        breaker(state, f"test failure (exit {r.returncode}) running `{cmd}`"
                       + (f": …{tail}" if tail else ""))
    audit(state, "test: passed")
    # Record the pass against the exact SHA it validated, so gate-pr can
    # require "final tests passed on the CURRENT integration HEAD" as a
    # mechanical precondition rather than trusting call order.
    rc_h, head = git(state["worktree"], "rev-parse", "HEAD")
    state["last_test"] = {"ok": True, "sha": head if rc_h == 0 else None,
                          "at": time.strftime("%Y-%m-%d %H:%M:%S")}
    save_state(state)
    # Echo the command that passed (F67).
    out({"ok": True, "cmd": cmd, **post})


def cmd_record_cycle(args):
    state = load_state(args.target, args.run)
    if not state["iterations"] or state["iterations"][-1].get("phase") == "started":
        breaker(state, "sequencing violation: record-cycle before the "
                       "iteration was closed by iter-verify or rollback")
    it = state["iterations"][-1]
    # Always computed — convergence never trusts a model-supplied count
    # (spec-tanuki-loop). The --new-actionable / --patched flags are advisory
    # only: if one disagrees with the computed value it is IGNORED with a stderr
    # warning, so a caller mistake can never silently corrupt convergence (F26).
    before = set(it.get("findings_before", []))
    excluded = set(state["frozen"]) | set(state.get("deferred", []))
    new_actionable = len([f for f in ledger_finding_ids(state["target"])
                          if f not in before and f not in excluded])
    patched = bool(it.get("phase") == "verified" and it.get("end")
                   and it["end"] != it["start"])
    if args.new_actionable is not None and args.new_actionable != new_actionable:
        print(f"warning: --new-actionable={args.new_actionable} ignored; "
              f"computed {new_actionable} from the ledger snapshot", file=sys.stderr)
    if args.patched is not None and args.patched != patched:
        print(f"warning: --patched={args.patched} ignored; computed "
              f"{patched} from the iteration SHAs", file=sys.stderr)
    # Loop amendment (spec-tanuki-scenario-lifecycle): a cycle counts as quiet
    # only if its scheduler plan met the exploration quota — a run that skipped
    # exploration while unexplored branches remained cannot manufacture
    # convergence. No persisted plan (pre-scheduler runs) => not gated.
    plan = plan_record(state, it["n"])
    quota_met = plan.get("quota_met", True) if plan else True
    quiet = new_actionable == 0 and not patched and quota_met
    # State the formula inline (F2): quiet requires all three, so a landed patch
    # or an unmet quota defeats an otherwise-quiet cycle. Without this the JSON
    # shows the inputs but not why quiet is false.
    if quiet:
        quiet_because = "no new actionable findings, no patch landed, quota met"
    else:
        blockers = []
        if new_actionable != 0:
            blockers.append(f"{new_actionable} new actionable finding(s)")
        if patched:
            blockers.append("a patch landed this cycle")
        if not quota_met:
            blockers.append("exploration quota not met")
        quiet_because = "not quiet — " + "; ".join(blockers)
    state["quiet_streak"] = state["quiet_streak"] + 1 if quiet else 0
    converged = state["quiet_streak"] >= 2
    # Persisted so the dashboard can explain the streak, not just count it.
    state["last_cycle"] = {"iter": it["n"], "new_actionable": new_actionable,
                           "patched": patched, "quota_met": quota_met,
                           "quiet": quiet}
    save_state(state)
    # Convergence is exactly where a false quiet would go unnoticed: every
    # scenario passed, but the plugin grew surface no charter covers or the
    # unexplored pool drained (issue #168). Attach the scheduler's advisory
    # signals to the convergence report — advisory text only; the trigger
    # stays operator-invoked and this run still never grows the matrix.
    advisory = generate_advisory(state["target"]) if converged else None
    audit(state, f"cycle: new_actionable={new_actionable} "
                 f"patched={patched} quota_met={quota_met} "
                 f"quiet_streak={state['quiet_streak']}"
                 + (" -> CONVERGED" if converged else ""))
    if advisory and advisory.get("unavailable"):
        # Explicit, never silent (#168 revision): an unavailable signal must
        # not read as zero drift — name the failure and the manual check.
        audit(state, "converged; scenario-generation advisory unavailable "
                     f"({advisory['reason']}) — this is NOT zero drift; "
                     "check `tanuki-scheduler status` by hand")
    elif advisory:
        audit(state, "converged, but: " + "; ".join(advisory["notes"])
                     + f" — consider `{advisory['generate']}`")
    out({"new_actionable": new_actionable, "patched": patched,
         "quota_met": quota_met, "quiet": quiet, "quiet_because": quiet_because,
         "quiet_streak": state["quiet_streak"], "converged": converged,
         **({"convergence_advisory": advisory} if advisory else {})})


def cmd_defer(args):
    state = load_state(args.target, args.run)
    if args.finding not in state.setdefault("deferred", []):
        state["deferred"].append(args.finding)
    save_state(state)
    append(state["target"], state["run"], "queue.md",
           f"- DEFER {args.finding}: {args.reason}")
