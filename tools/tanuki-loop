def empty_state(key, target, **fmt):
    """Render one enumerated empty state as (line_body, typed_dict).

    KeyError here is the point: an unenumerated empty state is a bug, not a
    string to invent at the call site.
    """
    m = EMPTY_STATES[key]
    reason = m["reason"].format(t=target, **fmt)
    nxt = m["next"].format(t=target, **fmt) if m["next"] else None
    # F166: EVERY render carries the expected-vs-gap verdict, not only the
    # gap side — a bare reason left the reader to infer whether emptiness was
    # normal. Expected states say so in as many words; a gap names the
    # command that closes it inside the GAP tag itself.
    if m["expected"]:
        body = f"{reason} (expected for this run's state)"
        if nxt:
            body += f" · next: `{nxt}`"
    else:
        body = (f"{reason} (GAP — `{nxt}`)" if nxt
                else f"{reason} (GAP)")
    return body, {"state": key, "expected": m["expected"], "reason": reason,
                  "next": nxt}


def emit_drift_note(target, repo):
    """Print the drift note if a debt exists. stderr, one line, never blocks —
    an unattended phase that hits this keeps running (the announce_new_target
    rule). States; never acts."""
    note = drift_note(target, repo)
    if note:
        print(note, file=sys.stderr)


def _delivery_phrase(state, lifecycle):
    """One phrase for the run's delivery, from persisted facts and the
    OFFLINE-derived settlement only (a view never polls the forge): the
    delivered PR with its settlement result, a merge-gate ratification, or
    'none'. A stale (cached) observation carries its timestamp."""
    d = lifecycle.get("delivered")
    if d:
        s = lifecycle.get("settlement") or {}
        via = (f"PR #{d.get('pr')}" if d.get("pr")
               else "local merge (direct-merge gate)")
        return (f"{s.get('result', 'unknown')} via {via}"
                + (f" [last observed {s.get('observed_at')}]"
                   if s.get("stale") else ""))
    fin = state.get("finished") or {}
    if fin.get("reason") == "gate-ratified":
        return "landed (ratified at the morning gate — local merge)"
    # F127: the empty state teaches the populated shape — the EMPTY_STATES
    # convention (state the value a non-empty render would show), applied to
    # a line that lives outside that enumeration.
    return ("none (a delivered run shows: <settlement> via PR #N, or via "
            "local merge (direct-merge gate))")


def cmd_dashboard(args):
    """Operational status (plain text, one screen). Within seconds the
    operator can answer: is the loop healthy, did anything unexpected happen,
    what did THIS run change, what is the scheduler doing and why, how far is
    convergence, and what decision comes next. Cumulative/lifetime numbers are
    a single pointer line — the long view is `tanuki-scheduler history`.
    --follow N re-renders every N seconds; reads state files only.

    --live (spec-tanuki-view D2 `live`): render the dashboard ONLY while the
    run is active (not closed). A closed run — however recent — is history,
    never live: the view degrades to the typed empty state plus ONE line of
    historical context (run id, stop reason, delivery settlement, frozen
    execution time), with none of the closed run's detail sections."""
    if args.live:
        cur = os.path.join(TANUKI_ROOT, args.target, "loop", "current")
        if not (args.run or os.path.exists(cur)):
            body, _ = empty_state("live:never-initialized", args.target)
            print(f"live — {body}")
            return
    # Drift note once, before the first render — not inside the --follow loop,
    # which would repeat it every N seconds until it stopped being read.
    _noted = False
    while True:
        state = load_state(args.target, args.run)
        if args.live and not run_lifecycle(state)["active"]:
            # A closed run is history, never live — also the --follow exit:
            # a run closing mid-follow ends the watch with the same line.
            lc = run_lifecycle(state)
            body, _ = empty_state("live:no-active-run", args.target)
            print(f"live — {body}")
            reason = lc["stop_reason"] + (
                " (closed before stop/delivery separation — see audit.md)"
                if lc["stop_reason"] == "unknown" else "")
            print(f"  latest run: {state['run']} · stop reason: {reason} · "
                  f"delivery: {_delivery_phrase(state, lc)} · "
                  f"execution: {_fmt_duration(lc['execution_s'])} "
                  "(frozen when the run closed; review/idle time not "
                  "counted)")
            return
        if not _noted:
            emit_drift_note(state["target"], state.get("loop_repo"))
            _noted = True
        findings = ledger_findings(state["target"])
        n_done = len(state["iterations"])
        # F45 / issue #63: rolled-back iterations still consume the cap, so the
        # count is what makes "N/N consumed" legible when work was undone.
        n_rolled_back = sum(1 for i in state["iterations"]
                            if i.get("phase") == "rolled_back")
        cur = state["iterations"][-1] if state["iterations"] else None
        lifecycle = run_lifecycle(state)
        # Execution time, not wall-clock-since-init: frozen at the first close,
        # so review/merge waiting never inflates it.
        elapsed = int(lifecycle["execution_s"])

        # -- (section 2) latest drive — ALWAYS present (Fixed skeleton): a
        #    missing progress.json degrades to a stated reason, never absence.
        drive_lines, driving, unmatched = [], False, 0
        # F46 / issue #65: look for the latest iteration that actually recorded
        # a drive, not only the current one. Keying on cur alone made the
        # section report "none yet" after an iteration had run — false, and the
        # reason it read wrong post-iteration.
        drive_it, ppath = None, None
        for _it in reversed(state["iterations"]):
            _p = os.path.join(TANUKI_ROOT, state["target"], "events",
                              f"{state['run']}-iter{_it['n']}", "progress.json")
            if os.path.exists(_p):
                drive_it, ppath = _it, _p
                break
        if ppath and os.path.exists(ppath):
            with open(ppath, encoding="utf-8") as f:
                p = json.load(f)
            # Only the CURRENT iteration can be mid-drive; an older recorded
            # drive is history, never "now".
            driving = (p.get("stage") != "complete"
                       and cur is not None and cur["phase"] == "started"
                       and drive_it is cur)
            if driving:
                # Concurrent drives (spec-tanuki-loop "Concurrent drives";
                # story 1.22): with several scenarios in flight there is no
                # single "current" — render every `running` entry, straight
                # from the progress substrate (render, don't compute). One
                # (or zero, for a pre-concurrency progress file) in flight
                # keeps the serial line.
                running = p.get("running") or []
                if len(running) > 1:
                    stages = ", ".join(
                        f"{e['scenario']} ({e.get('stage', '?')}"
                        + (f", {e['elapsed_s']}s"
                           if e.get("elapsed_s") is not None else "")
                        + ")" for e in running)
                    drive_lines.append(
                        f"  NOW: iter {cur['n']} driving "
                        f"[{p['done']}/{p['total']}] {len(running)} in "
                        f"parallel: {stages}")
                else:
                    drive_lines.append(
                        f"  NOW: iter {cur['n']} driving "
                        f"[{p['done']}/{p['total']}] {p.get('current')} — "
                        f"{p.get('stage')} ({p.get('elapsed_s', 0)}s, "
                        f"{p.get('captured_kb', 0)}KB)")
            # F46 / issue #65: "drive" is tanuki-drive, an internal term a cold
            # reader has never met — define it inline, the way the 'fixed'
            # counter does (F6), rather than renaming the fixed-skeleton
            # section this contract keys on.
            drive_lines.append(
                f"  latest drive (iter {drive_it['n']} — a drive is one "
                f"tanuki-drive pipeline run over the scenarios):")
            for r in p.get("results", []):
                # Both result axes side by side (story 1.26): `status` then
                # `probe`, each copied verbatim, never one merged verdict.
                line = (f"    {r['scenario']:<22} {r['status'][:28]:<28}"
                        f" {_probe_text(r)}"
                        f"  {r['events']:>3} events "
                        f"{int(r.get('duration_s') or 0):>4}s")
                if not str(r.get("status", "")).startswith("ok"):
                    known, tag = _classify_anomaly(r["scenario"],
                                                   findings, state)
                    unmatched += 0 if known else 1
                    line += f"  <- {tag}"
                drive_lines.append(line)
        # F46 / issue #65's three cases, now enumerated members rather than
        # three hand-written strings (D3). The term stays defined inline for a
        # cold reader (F46) — the enumeration governs the reason, not the
        # glossary.
        elif cur and cur["phase"] == "started":
            driving = True
            body, _ = empty_state("drive:iteration-open-not-driven",
                                  state["target"], n=cur["n"])
            drive_lines.append(f"  latest drive: {body}. {_DRIVE_IS}")
        elif state["iterations"]:
            # F166 / issue #236: run provenance flips expected-vs-gap — a run
            # that drove outside the scheduler (no persisted plan) is expected
            # here, not a gap.
            key = ("drive:manual-run-no-plan" if drove_outside_scheduler(state)
                   else "drive:iterations-ran-none-drove")
            body, _ = empty_state(key, state["target"],
                                  n=len(state["iterations"]))
            drive_lines.append(f"  latest drive: {body}. {_DRIVE_IS}")
        else:
            body, _ = empty_state("drive:no-iteration-started",
                                  state["target"])
            drive_lines.append(f"  latest drive: {body}. {_DRIVE_IS}")

        health = _health(state, driving, unmatched)
        # F188: 'convergence' can appear on this first line, a whole screen
        # before the convergence section defines it — define it at first use.
        # And defining it in terms of 'quiet cycles' just moves the undefined
        # term one word right (F188 residual): define THAT here too.
        if "converg" in health:
            health += (" (convergence = 2 consecutive quiet cycles; a cycle "
                       "is quiet when it finds no new actionable finding, "
                       "produces no patch, and met the exploration quota)")
        lines = [f"tanuki-loop — {state['target']} / {state['run']}",
                 f"  health: {health}",
                 f"  integration: {state['integration_branch']}  "
                 f"(base {state['base']})",
                 # F29: the counter is *consumed* iterations (rolled-back ones
                 # count), so "cap hit" beside it never reads as a contradiction.
                 # F45 / issue #63: state the rolled-back NUMBER — the line used
                 # to mention rolled-back iterations without ever saying how
                 # many, so a reader could not tell where a nonzero count would
                 # show. Zero is stated too, so "none" is a fact, not a guess.
                 # F190: real units, never a bare `0m`, and a frozen label
                 # that explains itself (F188's "clock frozen at close" was
                 # uninterpretable without the finish docstring).
                 f"  iterations: {n_done}/{state['cap']} consumed "
                 f"({n_rolled_back} rolled back) · execution: "
                 f"{_fmt_duration(elapsed)}"
                 + ("" if lifecycle["active"] else
                    " (frozen when the run closed; review/idle time not "
                    "counted)")]
        # F129: the same build-artifact warning `status` and `iter-verify`
        # surface, on the live screen — a cold operator monitoring only the
        # dashboard would otherwise miss regenerable output the loop's own
        # commits swept onto the integration branch, which `gate-push` will
        # refuse. Conditional like status's warning (null when empty), placed
        # high so it is read before the merge decision below.
        swept = _committed_artifacts(state)
        if swept:
            shown = ", ".join(swept[:8]) + (" …" if len(swept) > 8 else "")
            lines.append(
                f"  build-artifact WARNING: {shown} committed to the "
                "integration branch — gate-push will refuse until they are "
                "removed (also in `status`)")
        lines += drive_lines

        # -- (section 3) this run's ledger movement — ALWAYS present; lifetime
        #    totals stay a single pointer to the history view.
        deltas = _run_deltas(state, findings)
        reasons = _queue_reasons(state)
        if deltas:
            def part(label, ids):
                return f"{label} {len(ids)}" + \
                    (f" ({_fmt_ids(ids)})" if ids else "")
            lines.append("  this run: " + " · ".join((
                part("newly observed", deltas["new"]),
                part("status→accepted", deltas["accepted"]),
                part("recurred", deltas["recurred"]),
                f"deferred {len(state.get('deferred', []))}",
                # F188: "frozen findings", not bare "frozen" — the run-state
                # label above uses the same word for the execution clock.
                f"frozen findings {len(state.get('frozen', []))}")))
            # F6: define the counters inline. Every label is a ledger fact,
            # never a commit count — 'fixed' was retired because 'fixed 0'
            # beside a produced patch read as a contradiction.
            # F188 (recurrence): "ledger" itself is jargon to a cold reader
            # — define it once before using it to define the counters.
            lines.append("    (the ledger is the target's persistent findings "
                         "record; status→accepted = a finding's recorded "
                         "status changed this run — never a patch/commit "
                         "count; recurred = a known finding observed again "
                         "this run — its recurrence count bumped; "
                         "deferred/frozen = morning-queue entries in queue.md "
                         "awaiting your ruling, not ledger findings)")
            if deltas["legacy"]:
                lines.append("    (run predates status snapshots — "
                             "status→accepted/recurred not computable)")
            for fid in state.get("deferred", []):
                lines.append(f"    deferred {fid}: "
                             f"{_short(reasons.get(fid, 'see queue.md'), pointer='queue.md')}")
            for fid in state.get("frozen", []):
                lines.append(f"    frozen {fid} (attempt cap): "
                             f"{_short(reasons.get(fid, 'see queue.md'), pointer='queue.md')}")
        else:
            body, _ = empty_state("run:no-iteration-started", state["target"])
            lines.append(f"  this run: {body}")
        # Story 1.10: what the integration commit(s) changed — subjects + file
        # counts iter-verify recorded into state, so a cold reader sees what
        # landed without diffing the branch. Read SOLELY from state (no git in
        # the render path — spec-tanuki-view D4). A patch-bearing iteration
        # that predates this capture degrades to a typed one-line note; a
        # no-patch iteration shows no phantom commit line.
        verified = [it for it in state["iterations"]
                    if it.get("phase") == "verified"]
        if any("commits" not in it and it.get("end") != it.get("start")
               for it in verified):
            body, _ = empty_state("run:commits-not-recorded", state["target"])
            lines.append(f"    landed commits: {body}")
        else:
            landed = [c for it in verified for c in (it.get("commits") or [])]
            if landed:
                lines.append(f"    landed commits ({len(landed)}):")
                for c in landed:
                    fc = c.get("files_changed", 0)
                    lines.append(
                        f"      {c.get('sha', '')[:12]} "
                        f"{_short(c.get('subject', ''))} "
                        f"({fc} file{'' if fc == 1 else 's'})")
        # F188/F44: whenever deferred/frozen queue entries render near this
        # ledger line — populated OR empty — the queue-vs-ledger distinction
        # is stated, so the pairing can never read as a contradiction.
        qnote = (" (deferred/frozen items above are morning-queue entries, "
                 "not ledger findings)"
                 if state.get("deferred") or state.get("frozen") else "")
        if findings:
            by = {}
            for fd in findings:
                by[fd["status"]] = by.get(fd["status"], 0) + 1
            lines.append(f"  findings: {len(findings)} lifetime — " +
                         " · ".join(f"{k} {v}" for k, v in sorted(by.items())) +
                         f" (history: /tanuki {state['target']} --history)"
                         + qnote)
        else:
            # Deferred/frozen items live in the morning queue, not the
            # long-term ledger, so "none yet" beside a "deferred N" count is not
            # a contradiction — say so (F44), via the shared qnote above so
            # the pairing cannot render bare on either branch.
            lines.append("  findings: none in the ledger yet" + qnote)

        # -- (section 4) scheduler decisions — ALWAYS present: its DECISIONS
        #    for this iteration when a persisted plan exists; per-state pools
        #    for pre-revision runs; a stated reason when there is no state.
        spath = os.path.join(TANUKI_ROOT, state["target"], "scheduler.json")
        if not os.path.exists(spath):
            # F47 / issue #66: "run `tanuki-scheduler sync` first" named a
            # command the operator had never met and gave no signal whether
            # this was normal. Enumerated now, and the two cases differ: on a
            # fresh target it is expected; once iterations have run it is a
            # gap, because the scheduler cannot have chosen anything.
            # F166 / issue #236: run provenance flips expected-vs-gap. No
            # scheduler state after a run that drove outside the scheduler
            # (no persisted plan) is expected — the run drove an unmanaged set
            # by design; only a run that should have been scheduled is a gap.
            # No scheduler.json means the run was never scheduled: fresh
            # before any iteration, else a manual/toy/ad-hoc run that drove an
            # unmanaged set by design — expected, not a gap (F166 / issue #236).
            key = ("scheduler:manual-run-no-plan" if state["iterations"]
                   else "scheduler:never-synced-fresh")
            body, _ = empty_state(key, state["target"],
                                  n=len(state["iterations"]))
            lines.append(f"  scheduler decisions: {body}")
        else:
            with open(spath, encoding="utf-8") as f:
                sched = json.load(f)
            by = {}
            for sid, st in sched.get("scenarios", {}).items():
                by.setdefault(st["state"], []).append(sid)
            lines.append("  scenarios: " + " · ".join(
                f"{k} {len(v)}" for k, v in sorted(by.items())))
            plan = plan_record(state, cur["n"]) if cur else None
            if plan:
                picked = set(plan.get("verify", []) + plan.get("explore", [])
                             + plan.get("due_regression", []))
                rotation = [s for s in plan.get("plan", []) if s not in picked]
                lines.append(f"  scheduler decisions (iter {cur['n']} plan — "
                             "exploration quota "
                             f"{'met' if plan.get('quota_met') else 'NOT met'}):")
                # F188: 'exploration quota' was never defined for a cold
                # reader — one parenthetical at its first mention.
                lines.append("    (exploration quota = the plan's required "
                             "share of never-driven scenarios this iteration; "
                             "an unmet quota keeps the cycle from counting as "
                             "quiet)")
                lines.append("    verifying fixes (replay): "
                             f"{_fmt_ids(plan.get('verify', []))}")
                lines.append("    exploring (never driven): "
                             f"{_fmt_ids(plan.get('explore', []))}")
                lines.append(f"    active rotation:          {_fmt_ids(rotation)}")
                if plan.get("due_regression"):
                    lines.append("    regression due:           "
                                 f"{_fmt_ids(plan['due_regression'])}")
                lines.append("    waiting (future iters):   "
                             f"{_fmt_ids(plan.get('unexplored_remaining', []))}")
            else:
                if by.get("unexplored"):
                    lines.append("    unexplored: "
                                 f"{', '.join(sorted(by['unexplored'])[:6])}")
                if by.get("regression"):
                    lines.append("    regression pool: "
                                 f"{', '.join(sorted(by['regression'])[:6])}")
                if cur:
                    lines.append("    (no persisted plan for this run — "
                                 "selection reasons unavailable; states only)")

        # -- convergence: which conditions held last cycle, what's still needed
        lc = state.get("last_cycle")
        if lc is None and state["quiet_streak"] == 0:
            # F189: with record-cycle never run, a zero streak is silently
            # meaningless — say so explicitly instead of rendering it.
            # F188: name what convergence IS even when it can't be evaluated —
            # a cold reader meets the section's own subject term here first.
            lines.append("  convergence: no cycles recorded — convergence "
                         "(two quiet cycles in a row) not evaluated (run "
                         "record-cycle after each iteration)")
        else:
            # F188: the '/2' and the section title use 'convergence' before it
            # is defined — state the threshold (two quiet cycles in a row) at
            # its first appearance, then define 'quiet'.
            lines.append(f"  convergence: quiet streak "
                         f"{state['quiet_streak']}/2 — convergence is two "
                         "quiet cycles in a row; a cycle is quiet when it "
                         "finds no new actionable finding, produces no patch "
                         "commit, and met the exploration quota")
        if lc:
            held = [("no new findings" if lc["new_actionable"] == 0 else
                     f"{lc['new_actionable']} NEW actionable finding(s)"),
                    # lc["patched"] = the iteration committed to the
                    # integration branch — commits PRODUCED, nothing merged.
                    ("no patch commits" if not lc["patched"] else
                     "patch commit(s) PRODUCED (on the integration branch)"),
                    ("quota met" if lc.get("quota_met", True) else
                     "exploration quota NOT met")]
            lines.append(f"    last cycle (iter {lc['iter']}): "
                         f"{'quiet' if lc['quiet'] else 'not quiet'} — "
                         + " · ".join(held))
            # F43: this "NEW actionable" is a DIFFERENT count from "this run:
            # newly observed" above — same word, different denominators, so a
            # cold reader must not read them as a contradiction. Name each
            # scope: this line is one cycle's record-cycle snapshot (the
            # convergence input for iter {lc['iter']}), the section above is the
            # whole run's live ledger delta.
            lines.append("      (scope: one cycle's convergence snapshot — the "
                         "'this run: newly observed' count above is the live "
                         "ledger delta across the whole run; the two use "
                         "different denominators)")
            if not state.get("finished") and state["quiet_streak"] == 1:
                lines.append("    one more quiet cycle ends the run (converged)")

        # -- why stopped / the concrete next decision. Two separated facts:
        #    the computational stop reason (cap/converged/breaker/cancelled)
        #    and the settlement — what became of the delivery is never a
        #    reason execution stopped. Delivered runs get their DELIVERED/
        #    SETTLEMENT lines below (live-derived); this line renders the
        #    delivery phrase only when that block will not (e.g. a compat
        #    gate-ratified refinish, or a merge-gate ratification).
        # Delivery + settlement, live-derived (the PR path records `delivered`
        # at gate-pr; the direct-merge path derives it from the merge's
        # reachability — both surface here). The DELIVERED/SETTLEMENT block
        # replaces the local morning-gate steps only when the delivery is on
        # the forge (a PR — the decision moved there) or a direct merge has
        # already LANDED (no merge left to run); a direct-merge run still
        # pending keeps the morning-gate merge steps below.
        _deliv = lifecycle.get("delivered")
        _settle = lifecycle.get("settlement") or {}
        _is_pr = bool(_deliv and _deliv.get("pr"))
        _settle_block = bool(_deliv and (_is_pr
                                         or _settle.get("result") == "landed"))
        at_gate = False
        if state.get("finished"):
            reason = lifecycle["stop_reason"]
            if reason == "unknown":
                reason += (" (closed before stop/delivery separation — "
                           "see audit.md)")
            lines.append(f"  STOPPED — stop reason: {reason} "
                         f"(at {lifecycle['stopped_at']})")
            at_gate = state["finished"]["reason"] in ("converged", "cap")
            if not (at_gate and _settle_block):
                lines.append(
                    f"  delivery: {_delivery_phrase(state, lifecycle)}")
        elif state.get("last_breaker") and \
                not state["last_breaker"].get("recovered"):
            # F93: re-emitting the stored reason — the cap breaker's
            # skipped-checks note must survive this rendering too.
            lines.append(f"  STOPPED: breaker — "
                         f"{with_skipped_checks_note(state['last_breaker']['reason'])} "
                         f"(at {state['last_breaker']['at']})")
            if "external modification" in state["last_breaker"]["reason"]:
                lines.append("  NEXT: attended recovery — `tanuki-loop "
                             "recover --restore` (reset to the last verified "
                             "loop state) or `--adopt` (re-baseline around "
                             "the external change); never rollback")
            elif state["last_breaker"].get("hint"):
                # breaker-specific remedy carried on the breaker itself (F53)
                lines.append(f"  NEXT: {state['last_breaker']['hint']}")
            else:
                lines.append("  NEXT: inspect the audit trail, fix the "
                             "breaker cause, then resume or run the morning "
                             "gate on what already landed")
        elif cur and cur["phase"] == "started":
            lines.append(f"  NEXT: loop finishes iteration {cur['n']} "
                         "(mine -> classify -> implement -> test -> commit) — "
                         "no action needed from you")
        elif state["quiet_streak"] >= 2 or n_done >= state["cap"]:
            # F93: this is a cap-stop emission too — carry the skipped-checks
            # note so no surface ever shows a bare 'iteration cap reached'.
            reason = ("converged" if state["quiet_streak"] >= 2
                      else with_skipped_checks_note("iteration cap reached"))
            lines.append(f"  STOPPED-PENDING: {reason} — run not closed yet")
            at_gate = True
        else:
            lines.append(f"  NEXT: iteration {n_done + 1} of {state['cap']} — "
                         "no action needed from you")
        if at_gate and _settle_block:
            # Delivered runs (owner ruling 2026-07-17): the loop ended at the
            # delivered PR (decision lives on the forge) or a direct merge that has
            # already landed — the dashboard reports the DERIVED settlement
            # instead of the local gate steps.
            at_gate = False
            d, s = _deliv, _settle
            if _is_pr:
                lines.append(f"  DELIVERED: PR #{d.get('pr')} ({d.get('url')})")
            else:
                mc = d.get("merge_commit")
                lines.append(
                    f"  DELIVERED: local merge — integration tip "
                    f"{(d.get('head_sha') or '')[:12]} -> {state['base']}"
                    + (f" (merge commit {mc[:12]})" if mc else ""))
            lines.append(f"  SETTLEMENT: {s.get('result', '?')} — "
                         f"{s.get('detail', '')}"
                         + (f" [last observed {s.get('observed_at')}]"
                            if s.get("stale") else ""))
            n_rule = len(state.get("deferred", [])) + len(state.get("frozen", []))
            if s.get("result") == "pending":
                lines.append("  NEXT: review + merge the PR on the "
                             "forge (merge commit, don't squash)"
                             + (f"; rule on {n_rule} deferred/frozen item(s)"
                                if n_rule else ""))
            elif s.get("result") == "declined":
                lines.append("  NEXT: the branch holds unlanded work — the "
                             f"`/tanuki-loop {state['target']} reconcile` "
                             "slash command (a Claude Code slash command, run "
                             "in a Claude Code session — not a subcommand of "
                             "this tool) classifies it")
            elif n_rule:
                lines.append(f"  NEXT: rule on {n_rule} deferred/frozen "
                             "item(s) — reasons listed above")
        if at_gate:
            rc, ncommits = git(state["loop_repo"], "rev-list", "--count",
                               f"{state['base_sha']}..{state['head_expected']}")
            n_rule = len(state.get("deferred", [])) + len(state.get("frozen", []))
            lines.append("  NEXT: morning gate — your decisions:")
            lines.append(f"    1. review the integration diff "
                         f"({ncommits if rc == 0 else '?'} commit(s), "
                         f"{state['base']}..{state['integration_branch']})")
            if n_rule:
                lines.append(f"    2. rule on {n_rule} deferred/frozen "
                             "item(s) — reasons listed above")
            lines.append(f"    {3 if n_rule else 2}. approve or reject the "
                         f"merge {state['integration_branch']} -> "
                         f"{state['base']}")

        print("\n".join(lines))
        if not args.follow:
            return
        print("-" * 64)
        time.sleep(args.follow)


# The run's computational stop reasons — why execution ended. Settlement
# (what became of the delivery — see derive_settlement's closed results)
# never appears here: they are separate facts.
STOP_REASONS = ("cap", "converged", "breaker", "cancelled")


def execution_seconds(state):
    """Wall-clock the loop actually executed. Frozen at the first close
    (`wall_end`); review/merge waiting time never accrues here. Runs closed
    before `wall_end` existed freeze at their recorded close timestamp."""
    end = state.get("wall_end")
    if end is None and state.get("finished"):
        for rec in (state.get("stop"), state.get("finished")):
            if rec and rec.get("at"):
                try:
                    end = time.mktime(
                        time.strptime(rec["at"], "%Y-%m-%d %H:%M:%S"))
                    break
                except ValueError:
                    pass
    return round((end if end is not None else time.time())
                 - state["wall_start"], 1)


def run_lifecycle(state):
    """Typed lifecycle answer the renders derive from — they never
    re-classify: is loop execution still active, why did it stop
    (computational only — cap | converged | breaker | cancelled; never a
    settlement), how long execution actually ran, the delivery record, and
    the settlement derived WITHOUT a forge call (offline — read-only views
    must not poll a PR; spec-tanuki-view D2 `live`). A run closed as
    `gate-ratified` with no recorded stop (legacy overwrite) reports its
    stop reason as `unknown` — never a guess."""
    fin = state.get("finished")
    stop = state.get("stop")
    lb = state.get("last_breaker")
    breaker_open = bool(lb and not lb.get("recovered") and not fin)
    if stop:
        reason, at = stop.get("reason"), stop.get("at")
    elif fin:
        reason = {"cap": "cap", "converged": "converged",
                  "aborted": "cancelled"}.get(fin.get("reason"), "unknown")
        at = fin.get("at")
    elif breaker_open:
        reason, at = "breaker", lb.get("at")
    else:
        reason, at = None, None
    settlement = derive_settlement(state, save=False, offline=True)
    return {"active": not fin, "breaker_open": breaker_open,
            "stop_reason": reason, "stopped_at": at,
            "execution_s": execution_seconds(state),
            # The PR path records `delivered` at gate-pr; the direct-merge path
            # writes none (it ends at a local merge), so its delivery record is
            # derived read-only alongside its settlement — populated once the
            # merge is reachable, symmetrically with the PR path.
            "delivered": state.get("delivered")
            or (settlement or {}).get("delivered"),
            "settlement": settlement}


def run_verdict(state):
    """The run's condition as ONE typed answer: running | stopped | finished.

    An operator returning to a run they did not just drive should not have to
    infer the condition by cross-reading last_breaker, iteration counters, and
    state.json (F42). Precedence is finished > stopped > running: `finish` is
    terminal and a run may be finished after a breaker (aborted), so the
    terminal state is first-class rather than indistinguishable from a stop.
    """
    fin = state.get("finished")
    if fin:
        v = {"state": "finished", "reason": fin.get("reason"),
             "at": fin.get("at"),
             "summary": f"finished: {fin.get('reason')}"}
        # A delivered run's terminal fact is the delivery (owner ruling
        # 2026-07-17); the verdict names it so "finished: cap" on a delivered
        # run cannot read as an unopened gate. Settlement itself is derived —
        # see the status payload's `settlement` field.
        d = state.get("delivered")
        if d:
            v["delivered"] = {"pr": d.get("pr"), "at": d.get("at")}
            v["summary"] += f" · delivered: PR #{d.get('pr')}"
        return v
    lb = state.get("last_breaker")
    # F118: a RECOVERED breaker is no longer a stop — recover --restore/--adopt
    # (and the successful iter-start that follows) resumed the run. Honor the
    # `recovered` flag exactly as run_lifecycle's breaker_open does, or the
    # verdict reads "stopped" while lifecycle.active is true — a direct
    # self-contradiction on one status screen.
    if lb and not lb.get("recovered"):
        # F93: re-emitting the stored reason — carry the cap breaker's
        # skipped-checks note whichever build persisted it.
        _r = with_skipped_checks_note(lb.get("reason") or "")
        s = {"state": "stopped", "reason": _r, "at": lb.get("at"),
             "summary": f"stopped: {_r}"}
        if lb.get("hint"):
            s["hint"] = lb["hint"]
        return s
    done, cap = len(state["iterations"]), state["cap"]
    # An iteration is open iff its phase is "started" — the SAME definition
    # run_lifecycle's iterations_open uses (F149). Testing `end is None` instead
    # disagreed after a recover --restore/rollback (which can leave an iteration
    # with no `end` but a non-"started" phase), so the one-line summary read
    # "iteration N open" while lifecycle.iterations_open on the same screen was 0
    # — a direct self-contradiction of the kind F118 already guards elsewhere.
    openb = [i for i in state["iterations"] if i.get("phase") == "started"]
    # F78: when every cap slot is consumed and the run is still unclosed,
    # closing it was a manual inference from comparing iterations_done to cap
    # on one screen — name the next action instead.
    if not openb and done >= cap:
        # F93: a cap-stop emission — the summary carries the skipped-checks
        # note so no surface ever shows a bare 'cap reached'.
        return {"state": "running", "reason": None,
                "next_action": ("iteration cap consumed — close the run: "
                                "finish --reason cap (or --reason converged "
                                "if record-cycle reported converged)"),
                "summary": (f"running: {done}/{cap} iterations consumed — "
                            + with_skipped_checks_note(
                                "iteration cap reached")
                            + ", close with finish")}
    where = (f"iteration {openb[-1]['n']} open" if openb
             else f"{done}/{cap} iterations done")
    return {"state": "running", "reason": None,
            "summary": f"running (healthy): {where}, no breaker"}


def _committed_artifacts(state):
    """Build-artifact paths the loop's own commits swept onto the integration
    branch (F102). `status` surfaces these as its `warning`, `gate-push`
    refuses to push them, and the dashboard flags them (F129) so an operator
    watching only the live screen sees what the gate will later block on."""
    return sorted({p for it in state["iterations"]
                   for p in (it.get("build_artifacts_committed") or [])})


def cmd_status(args):
    state = load_state(args.target, args.run)
    # The gate reads status before approving the merge, and it is the last
    # thing between these paths and the remote — a warning that only reached
    # the audit trail would not be read in time (F102/F106). Always present,
    # explicitly null when empty: absence and "nothing to warn about" must not
    # be indistinguishable.
    swept = _committed_artifacts(state)
    warning = None
    if swept:
        shown = ", ".join(swept[:8]) + (" …" if len(swept) > 8 else "")
        warning = (f"build artifacts committed to the integration branch "
                   f"({shown}) — gate-push will refuse until they are removed")
    # Derived once: the top-level settlement AND (on the direct-merge gate) the
    # delivery record it carries, so both fields agree on one derivation.
    _status_settlement = derive_settlement(state)
    # story 1.46 / issue #240: a null settlement erased the expected-vs-gap
    # signal — a hostless target (delivery never applies) rendered identically
    # to a hosted run still awaiting delivery. Resolve the null to a typed
    # empty-state member so `delivered`/`settlement` carry the verdict, the same
    # enumerated convention (EMPTY_STATES) the dashboard uses; a real settlement
    # is left untouched. `delivered` is null exactly when settlement is (no
    # delivery ⇒ nothing to settle), so both fields carry the same member.
    if _status_settlement is None:
        if state.get("gate_mode", "merge") == "merge":
            # Direct-merge (non-PR) gate: null ⇒ no work merged, nothing to
            # deliver — hostless, expected.
            _settle_key = "settlement:n-a-hostless"
        elif state.get("finished"):
            # PR gate, run closed with no delivery ⇒ a gap.
            _settle_key = "settlement:undelivered-closed"
        else:
            # PR gate, run still active ⇒ delivery may still come.
            _settle_key = "settlement:pending-active"
        _, _empty = empty_state(_settle_key, args.target)
        _delivered_field = _empty
        _settlement_field = _empty
    else:
        _delivered_field = (state.get("delivered")
                            or _status_settlement.get("delivered"))
        _settlement_field = _status_settlement
    out({
        # Verdict leads: the condition is the question status exists to answer.
        "verdict": run_verdict(state),
        # Typed lifecycle: active vs closed, the computational stop reason
        # (never a settlement), frozen execution time, and the OFFLINE-derived
        # settlement (views read this; the live-derived answer is the
        # top-level `settlement` field below).
        "lifecycle": run_lifecycle(state),
        "warning": warning,
        "build_artifacts_committed": swept or None,
        "run": state["run"], "integration_branch": state["integration_branch"],
        "worktree": state["worktree"], "base": state["base"],
        # Operator-critical fields state.json holds but no CLI surfaced (F42):
        # base_sha is the gate diff's left side; last_breaker diagnoses a stop.
        # F93: a cap breaker persisted by a pre-note build re-surfaces here —
        # re-emit it WITH the skipped-checks note, never bare.
        "base_sha": state.get("base_sha"),
        "last_breaker": (
            {**state["last_breaker"],
             "reason": with_skipped_checks_note(
                 state["last_breaker"].get("reason") or "")}
            if state.get("last_breaker") else None),
        "finished": state.get("finished"),
        # Delivery + derived settlement (owner ruling 2026-07-17): the loop's
        # record ends at "delivered"; whether the PR landed is derived here,
        # live from the forge and the current base — never restated by a
        # closing command. The direct-merge (non-PR) gate writes no `delivered`
        # record (it ends at a local merge), so `delivered` is derived from the
        # merge's reachability alongside `settlement` — populated when landed,
        # symmetrically with the PR path; a landed direct merge never shows
        # `settlement: null`. A run with nothing to settle no longer renders a
        # bare null either: it carries a typed empty-state member (story 1.46,
        # resolved just above) so the reader can tell "n/a for this gate" from
        # "a delivery is still expected".
        "delivered": _delivered_field,
        "settlement": _settlement_field,
        # F107: iterations_done counted iterations that were still OPEN, so "2"
        # could mean two closed or one closed and one in flight — ambiguous
        # exactly where the morning gate skims it. Report closed only, with the
        # open and started counts alongside, and keep the old key meaning what
        # its name says. (The cap counts STARTED iterations: a rolled-back one
        # consumes a slot, so iterations_started is what to compare to cap.)
        "iterations_done": len([i for i in state["iterations"]
                                if i.get("phase") in ("verified",
                                                      "rolled_back")]),
        "iterations_open": len([i for i in state["iterations"]
                                if i.get("phase") == "started"]),
        "iterations_started": len(state["iterations"]),
        "cap": state["cap"],
        "quiet_streak": state["quiet_streak"], "frozen": state["frozen"],
        "attempts": state["attempts"],
        # Frozen at the first close (see execution_seconds) — review/merge
        # waiting time never accrues here.
        "elapsed_s": execution_seconds(state),
        "materialized": state["materialized"],
    })


def slug_target(value):
    """--target is a namespace slug, never a path (issues #68/#70).

    State lives under $TANUKI_ROOT/<target>/, so a path-like value either
    nests silently (os.path.join swallows an absolute path — the accidental
    "support" #68 reported) or fails deep inside a later git call with a
    low-level error (#70). Both are the same root cause: --target was never
    validated. Reject at parse time so the message names the contract.
    TANUKI_ROOT is the supported way to relocate state.
    """
    if (value and not value.startswith(".")
            and all(c.isalnum() or c in "._-" for c in value)):
        return value
    raise argparse.ArgumentTypeError(
        f"--target must be a simple namespace slug (letters, digits, "
        f"'.', '_', '-'), not a path: {value!r}. State lives under "
        f"$TANUKI_ROOT/<target>/ — set TANUKI_ROOT to relocate it.")


