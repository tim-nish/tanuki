#!/usr/bin/env python3
"""tanuki-loop: the deterministic safety substrate for unattended cumulative
dogfooding (contract: specs/spec-tanuki-loop/SPEC.md). It owns every scriptable
check, invariant, and rollback so the orchestrating model is responsible ONLY
for judgment — classification, implementation, and running the target's tests.

Zero dependencies. State lives under ~/.tanuki/<target>/loop/<run>/:
  state.json   the loop's machine state (SHAs, attempts, quiet streak, …)
  audit.md     append-only human record of what the loop did
  policy.json  iteration-1 judgment answers, applied unasked from iteration 2
  queue.md     the morning review queue (deferred / frozen items)
A `current` pointer names the active run so subcommands need only --target.

Subcommands (JSON out unless noted; a breaker prints {"breaker": …} + exit 3):
  init --loop-repo P [--scenarios F] [--cap N] [--base B] [--worktree W]
       [--phase 1|2|3] [--wall-time S] [--token-budget N] [--policy F]
       [--attempt-cap K] [--test-cmd "<shell cmd>"] [--allow-stale-base]
       --scenarios reads the per-target "loop" block from the scenarios file
       ({"test_cmd", "iterations", "wall_time_s", "token_budget",
        "attempt_cap"}) so a run needs no repo-specific flags; CLI overrides.
       Fetches <base>'s remote and FAILS CLOSED if the local base is behind
       its upstream (the loop must never dogfood stale code); --allow-stale-base
       overrides to dogfood the local tip anyway. The base is never silently
       moved to the upstream tip.
  iter-start                     cap / wall-time / external-modification breakers;
                                 records the iteration start SHA + ledger snapshot
  iter-verify [--no-patch]       the four-part integration invariant; records end SHA
  rollback                       reset --hard start + clean -fd + verify; records removed
  test                           run the configured test_cmd in the worktree;
                                 failure is a breaker (skipped if none configured)
  attempt --finding F            per-finding attempt count; freezes past the cap
  record-cycle                   two-quiet convergence; new-actionable computed from
                                 the ledger snapshot and patched from the iteration
                                 SHAs (--new-actionable / --patched override); a
                                 cycle is quiet only if the iteration's persisted
                                 scheduler plan reported quota_met (the
                                 spec-tanuki-scenario-lifecycle loop amendment)
  defer --finding F --reason "…" append to the morning queue
  log --audit "…"                append to the audit artifact
  gate-check                     integration HEAD reachable from base after the merge
  issue-get --key K              print the issue already materialized for a problem key
  issue-put --key K --issue N    record a materialized issue (idempotency)
  policy --finding F --decision "…"   record an iteration-1 judgment answer as
                                 run policy (applied unasked from iteration 2)
  finish --reason R              mark the run terminal (converged | cap |
                                 gate-ratified | aborted) — machine-readable
  status                         JSON summary for the morning gate
  dashboard [--follow SECS]      operational status, one screen: health verdict,
                                 latest drive with each anomaly classified against
                                 the ledger (known/deferred/frozen vs unmatched),
                                 this-run deltas (new/fixed/recurred findings),
                                 the scheduler's actual decisions (verify/explore/
                                 rotation/waiting), convergence conditions met vs
                                 missing, stop reason, and the concrete decisions
                                 the morning gate will ask for

Sequencing is guarded: each iteration must move started -> (verified |
rolled_back) before the next iter-start, and record-cycle refuses an open
iteration — a skipped check is itself a breaker, never a silent pass.

The token budget is stored but NOT enforced here — token accounting is the
runtime's; the loop treats it as an operator-supplied ceiling the harness trips.
"""

import argparse
import json
import os
import subprocess
import sys
import time

TANUKI_ROOT = os.environ.get("TANUKI_ROOT", os.path.expanduser("~/.tanuki"))


def git(repo, *args):
    """Run git in <repo>; return (returncode, stdout-stripped)."""
    r = subprocess.run(["git", "-C", repo, *args],
                       capture_output=True, text=True)
    return r.returncode, (r.stdout or "").strip()


def loop_dir(target, run):
    return os.path.join(TANUKI_ROOT, target, "loop", run)


def current_run(target):
    p = os.path.join(TANUKI_ROOT, target, "loop", "current")
    if not os.path.exists(p):
        die("no active loop run; call `init` first")
    with open(p, encoding="utf-8") as f:
        return f.read().strip()


def load_state(target, run=None):
    run = run or current_run(target)
    with open(os.path.join(loop_dir(target, run), "state.json"),
              encoding="utf-8") as f:
        return json.load(f)


def save_state(state):
    d = loop_dir(state["target"], state["run"])
    tmp = os.path.join(d, "state.json.tmp")
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(state, f, indent=2)
    os.replace(tmp, os.path.join(d, "state.json"))


def append(target, run, name, text):
    with open(os.path.join(loop_dir(target, run), name), "a",
              encoding="utf-8") as f:
        f.write(text.rstrip("\n") + "\n")


def audit(state, msg):
    append(state["target"], state["run"], "audit.md",
           f"- [{time.strftime('%Y-%m-%d %H:%M:%S')}] {msg}")


def out(obj):
    print(json.dumps(obj, indent=2))


def die(msg):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(2)


def breaker(state, reason):
    # Persist machine-readably so a dashboard can answer "why did it stop?"
    state["last_breaker"] = {"reason": reason,
                             "at": time.strftime("%Y-%m-%d %H:%M:%S")}
    save_state(state)
    audit(state, f"BREAKER (immediate stop): {reason}")
    out({"breaker": reason})
    sys.exit(3)


def ledger_findings(target):
    """Findings currently in the target's ledger (read-only)."""
    path = os.path.join(TANUKI_ROOT, target, "ledger.json")
    if not os.path.exists(path):
        return []
    with open(path, encoding="utf-8") as f:
        return json.load(f).get("findings", [])


def ledger_finding_ids(target):
    return [fd["id"] for fd in ledger_findings(target)]


def plan_record(state, iter_n):
    """The persisted scheduler plan for this loop iteration's drive run
    (<run>-iterN), or None for runs/schedulers that predate persisted plans."""
    spath = os.path.join(TANUKI_ROOT, state["target"], "scheduler.json")
    if not os.path.exists(spath):
        return None
    with open(spath, encoding="utf-8") as f:
        plans = json.load(f).get("plans", [])
    rid = f"{state['run']}-iter{iter_n}"
    return next((p for p in reversed(plans) if p.get("run") == rid), None)


# --- subcommands -------------------------------------------------------------

def cmd_init(args):
    repo = os.path.abspath(os.path.expanduser(args.loop_repo))
    rc, _ = git(repo, "rev-parse", "--git-dir")
    if rc != 0:
        die(f"--loop-repo is not a git repo: {repo}")
    # Per-target loop config from the scenarios file's "loop" block — so a
    # run needs no repo-specific flags typed each time. CLI flags override.
    loopcfg = {}
    if args.scenarios:
        with open(os.path.expanduser(args.scenarios), encoding="utf-8") as f:
            loopcfg = json.load(f).get("loop", {})
    cap = args.cap if args.cap is not None else loopcfg.get("iterations")
    if not cap:
        die("no iteration cap: pass --cap or set loop.iterations in the "
            "scenarios file")
    test_cmd = args.test_cmd or loopcfg.get("test_cmd")
    wall = args.wall_time if args.wall_time is not None \
        else loopcfg.get("wall_time_s")
    tokens = args.token_budget if args.token_budget is not None \
        else loopcfg.get("token_budget")
    attempt_cap = args.attempt_cap if args.attempt_cap is not None \
        else loopcfg.get("attempt_cap", 4)
    base = args.base
    if not base:
        rc, base = git(repo, "symbolic-ref", "--short", "HEAD")
        if rc != 0:
            die("loop repo has a detached HEAD; pass --base <branch>")
    rc, base_sha = git(repo, "rev-parse", base)
    if rc != 0:
        die(f"cannot resolve base '{base}'")
    # Staleness guard (issue #2): never silently dogfood code older than the
    # remote. Best-effort fetch, then FAIL CLOSED if <base> is behind its
    # upstream — every iteration would otherwise base on stale plugin code and
    # surface already-fixed findings at the morning gate. --allow-stale-base is
    # the explicit override (e.g. deliberately testing an un-pushed local
    # branch). We never silently move the base to the upstream tip; the
    # operator fast-forwards or overrides deliberately, so what is dogfooded is
    # always the ref they named.
    base_note, n_behind = None, 0
    rc, upstream = git(repo, "rev-parse", "--abbrev-ref",
                       "--symbolic-full-name", f"{base}@{{upstream}}")
    upstream = upstream if rc == 0 and upstream else None
    if upstream:
        rc_r, remote = git(repo, "config", "--get", f"branch.{base}.remote")
        fetched = rc_r == 0 and bool(remote) and git(repo, "fetch", remote)[0] == 0
        rc_b, behind = git(repo, "rev-list", "--count", f"{base}..{upstream}")
        n_behind = int(behind) if rc_b == 0 and behind.isdigit() else 0
        if not fetched:
            base_note = (f"fetch failed (offline?) — staleness checked against "
                         f"last-known {upstream}")
        if n_behind > 0:
            if not args.allow_stale_base:
                die(f"local base '{base}' is {n_behind} commit(s) behind "
                    f"'{upstream}'; the loop would dogfood stale code. "
                    f"Fast-forward it (git -C {repo} merge --ff-only "
                    f"{upstream}), pass --base {upstream}, or re-run with "
                    "--allow-stale-base to dogfood the local tip anyway.")
            base_note = (f"{n_behind} commit(s) behind {upstream} — proceeding "
                         "under --allow-stale-base"
                         + (f"; {base_note}" if base_note else ""))
    else:
        base_note = f"base '{base}' has no upstream — staleness not checked"
    ts = time.strftime("%Y%m%d-%H%M%S")
    # Same-second re-init must not collide on the branch/run/worktree names.
    n, suffix = 2, ""
    while git(repo, "rev-parse", "--verify",
              f"refs/heads/tanuki-loop/{args.target}/{ts}{suffix}")[0] == 0:
        suffix, n = f"-{n}", n + 1
    ts += suffix
    run = f"loop-{ts}"
    integration = f"tanuki-loop/{args.target}/{ts}"
    worktree = os.path.abspath(os.path.expanduser(args.worktree)) if args.worktree \
        else os.path.join(os.path.dirname(repo), f".tanuki-loop-{args.target}-{ts}")
    rc, err = git(repo, "worktree", "add", "-b", integration, worktree, base)
    if rc != 0:
        die(f"git worktree add failed (no shared-tree fallback): {err}")

    d = loop_dir(args.target, run)
    os.makedirs(d, exist_ok=True)
    policy = {}
    if args.policy and os.path.exists(os.path.expanduser(args.policy)):
        with open(os.path.expanduser(args.policy), encoding="utf-8") as f:
            policy = json.load(f)
    with open(os.path.join(d, "policy.json"), "w", encoding="utf-8") as f:
        json.dump(policy, f, indent=2)
    for name, head in (("audit.md", f"# tanuki-loop audit — {run}\n"),
                       ("queue.md", f"# morning review queue — {run}\n")):
        with open(os.path.join(d, name), "w", encoding="utf-8") as f:
            f.write(head)
    state = {
        "run": run, "target": args.target, "loop_repo": repo,
        "base": base, "base_sha": base_sha,
        "integration_branch": integration, "worktree": worktree,
        "phase": args.phase, "cap": cap, "attempt_cap": attempt_cap,
        "wall_start": time.time(), "wall_limit_s": wall,
        "token_budget": tokens, "test_cmd": test_cmd,
        "iterations": [], "attempts": {}, "frozen": [], "deferred": [],
        "quiet_streak": 0, "head_expected": base_sha, "materialized": {},
        # Base provenance: the loop always dogfoods the LOCAL tip of <base>;
        # base_upstream/base_behind record what it was measured against so a
        # reader can see exactly what was dogfooded (issue #2).
        "base_tip": "local", "base_upstream": upstream,
        "base_behind": n_behind,
    }
    save_state(state)
    with open(os.path.join(TANUKI_ROOT, args.target, "loop", "current"),
              "w", encoding="utf-8") as f:
        f.write(run)
    audit(state, f"init: integration {integration} @ {base_sha[:12]} "
                 f"(base {base} [local tip]"
                 + (f", {n_behind} behind {upstream}" if n_behind else "")
                 + f") in worktree {worktree}; cap={cap} phase={args.phase}"
                 + (f" — {base_note}" if base_note else ""))
    out({"run": run, "integration_branch": integration, "worktree": worktree,
         "base_sha": base_sha, "base_upstream": upstream,
         "base_behind": n_behind})


def _worktree_head(state):
    rc, sha = git(state["worktree"], "rev-parse", "HEAD")
    return sha if rc == 0 else None


def _clean(state):
    rc, o = git(state["worktree"], "status", "--porcelain")
    return rc == 0 and o == ""


def cmd_iter_start(args):
    state = load_state(args.target, args.run)
    if state["iterations"] and state["iterations"][-1].get("phase") == "started":
        breaker(state, "sequencing violation: previous iteration was never "
                       "closed by iter-verify or rollback")
    if len(state["iterations"]) >= state["cap"]:
        breaker(state, "iteration cap reached")
    if state["wall_limit_s"] and \
            time.time() - state["wall_start"] >= state["wall_limit_s"]:
        breaker(state, "wall-time limit exceeded")
    head = _worktree_head(state)
    if head != state["head_expected"]:
        breaker(state, f"external modification of the integration worktree "
                       f"(HEAD {head} != expected {state['head_expected']})")
    if not _clean(state):
        breaker(state, "external modification: worktree not clean at iteration start")
    n = len(state["iterations"]) + 1
    state["iterations"].append({
        "n": n, "start": head, "end": None, "phase": "started", "removed": [],
        # Ledger snapshot: record-cycle derives "new actionable" from its ids,
        # so convergence never trusts a model-supplied count; status/recurrence
        # let the dashboard report this-run deltas (fixed/recurred).
        "findings_before": {fd["id"]: {"status": fd.get("status"),
                                       "recurrence": fd.get("recurrence", 1)}
                            for fd in ledger_findings(state["target"])},
    })
    save_state(state)
    audit(state, f"iter {n}: start @ {head[:12]}")
    out({"ok": True, "iteration": n, "start_sha": head})


def cmd_iter_verify(args):
    state = load_state(args.target, args.run)
    if not state["iterations"] or state["iterations"][-1].get("phase") != "started":
        breaker(state, "sequencing violation: iter-verify without an open iteration")
    it = state["iterations"][-1]
    wt = state["worktree"]
    start = it["start"]
    rc, branch = git(wt, "symbolic-ref", "--short", "HEAD")
    if rc != 0 or branch != state["integration_branch"]:
        breaker(state, f"integration invariant: HEAD not on {state['integration_branch']} "
                       f"(got {branch or 'detached'})")
    head = _worktree_head(state)
    rc, _ = git(wt, "merge-base", "--is-ancestor", start, head)
    if rc != 0:
        breaker(state, "integration invariant: start SHA is not an ancestor of HEAD")
    if not args.no_patch and head == start:
        breaker(state, "integration invariant: HEAD == start SHA but a patch was expected")
    if not _clean(state):
        breaker(state, "integration invariant: worktree not clean after commit")
    it["end"] = head
    it["phase"] = "verified"
    state["head_expected"] = head
    save_state(state)
    audit(state, f"iter {it['n']}: verified, end @ {head[:12]}")
    out({"ok": True, "iteration": it["n"], "end_sha": head})


def cmd_rollback(args):
    state = load_state(args.target, args.run)
    if not state["iterations"] or state["iterations"][-1].get("phase") != "started":
        breaker(state, "sequencing violation: rollback without an open iteration")
    it = state["iterations"][-1]
    wt, start = state["worktree"], it["start"]
    rc, removed = git(wt, "clean", "-nd")        # preview untracked to be removed
    removed_paths = [ln[len("Would remove "):] for ln in removed.splitlines()
                     if ln.startswith("Would remove ")]
    git(wt, "reset", "--hard", start)
    git(wt, "clean", "-fd")
    if not _clean(state) or _worktree_head(state) != start:
        breaker(state, "rollback failed to restore a clean tree at the start SHA")
    it["removed"] = removed_paths
    it["phase"] = "rolled_back"
    state["head_expected"] = start
    save_state(state)
    audit(state, f"iter {it['n']}: rolled back to {start[:12]}; "
                 f"removed untracked: {removed_paths or 'none'}")
    out({"ok": True, "reset_to": start, "removed": removed_paths})


def cmd_attempt(args):
    state = load_state(args.target, args.run)
    cur = state["attempts"].get(args.finding, 0)
    if cur >= state["attempt_cap"]:
        if args.finding not in state["frozen"]:
            state["frozen"].append(args.finding)
            append(state["target"], state["run"], "queue.md",
                   f"- FROZEN {args.finding}: exceeded {state['attempt_cap']} "
                   f"fix attempts — needs human review")
            audit(state, f"froze {args.finding} after {cur} attempts")
        save_state(state)
        out({"finding": args.finding, "attempts": cur, "frozen": True})
        return
    state["attempts"][args.finding] = cur + 1
    save_state(state)
    out({"finding": args.finding, "attempts": cur + 1, "frozen": False})


def cmd_test(args):
    state = load_state(args.target, args.run)
    cmd = state.get("test_cmd")
    if not cmd:
        audit(state, "test: no test_cmd configured — skipped "
                     "(configure one for unattended runs)")
        out({"skipped": True})
        return
    r = subprocess.run(cmd, shell=True, cwd=state["worktree"],
                       capture_output=True, text=True)
    tail = ((r.stdout or "") + (r.stderr or "")).strip()[-300:]
    if r.returncode != 0:
        audit(state, f"test FAILED (exit {r.returncode}): …{tail}")
        breaker(state, f"test failure (exit {r.returncode})")
    audit(state, "test: passed")
    out({"ok": True})


def cmd_record_cycle(args):
    state = load_state(args.target, args.run)
    if not state["iterations"] or state["iterations"][-1].get("phase") == "started":
        breaker(state, "sequencing violation: record-cycle before the "
                       "iteration was closed by iter-verify or rollback")
    it = state["iterations"][-1]
    # Computed by default — convergence never trusts a model-supplied count.
    if args.new_actionable is not None:
        new_actionable = args.new_actionable
    else:
        before = set(it.get("findings_before", []))
        excluded = set(state["frozen"]) | set(state.get("deferred", []))
        new_actionable = len([f for f in ledger_finding_ids(state["target"])
                              if f not in before and f not in excluded])
    if args.patched is not None:
        patched = args.patched
    else:
        patched = bool(it.get("phase") == "verified" and it.get("end")
                       and it["end"] != it["start"])
    # Loop amendment (spec-tanuki-scenario-lifecycle): a cycle counts as quiet
    # only if its scheduler plan met the exploration quota — a run that skipped
    # exploration while unexplored branches remained cannot manufacture
    # convergence. No persisted plan (pre-scheduler runs) => not gated.
    plan = plan_record(state, it["n"])
    quota_met = plan.get("quota_met", True) if plan else True
    quiet = new_actionable == 0 and not patched and quota_met
    state["quiet_streak"] = state["quiet_streak"] + 1 if quiet else 0
    converged = state["quiet_streak"] >= 2
    # Persisted so the dashboard can explain the streak, not just count it.
    state["last_cycle"] = {"iter": it["n"], "new_actionable": new_actionable,
                           "patched": patched, "quota_met": quota_met,
                           "quiet": quiet}
    save_state(state)
    audit(state, f"cycle: new_actionable={new_actionable} "
                 f"patched={patched} quota_met={quota_met} "
                 f"quiet_streak={state['quiet_streak']}"
                 + (" -> CONVERGED" if converged else ""))
    out({"new_actionable": new_actionable, "patched": patched,
         "quota_met": quota_met, "quiet": quiet,
         "quiet_streak": state["quiet_streak"], "converged": converged})


def cmd_defer(args):
    state = load_state(args.target, args.run)
    if args.finding not in state.setdefault("deferred", []):
        state["deferred"].append(args.finding)
    save_state(state)
    append(state["target"], state["run"], "queue.md",
           f"- DEFER {args.finding}: {args.reason}")
    audit(state, f"deferred {args.finding}: {args.reason}")
    out({"ok": True})


def cmd_log(args):
    state = load_state(args.target, args.run)
    audit(state, args.audit)
    out({"ok": True})


def cmd_gate_check(args):
    state = load_state(args.target, args.run)
    repo, base = state["loop_repo"], state["base"]
    rc, integ_head = git(repo, "rev-parse", state["integration_branch"])
    rc2, _ = git(repo, "merge-base", "--is-ancestor",
                 state["integration_branch"], base)
    reachable = rc == 0 and rc2 == 0
    audit(state, f"gate-check: integration reachable from {base}: {reachable}")
    if not reachable:
        out({"reachable": False})
        sys.exit(3)
    out({"reachable": True, "integration_head": integ_head})


def cmd_issue_get(args):
    state = load_state(args.target, args.run)
    print(state["materialized"].get(args.key, ""))


def cmd_issue_put(args):
    state = load_state(args.target, args.run)
    state["materialized"][args.key] = args.issue
    save_state(state)
    audit(state, f"materialized problem '{args.key}' -> issue #{args.issue}")
    out({"ok": True, "key": args.key, "issue": args.issue})


def cmd_policy(args):
    """Record an iteration-1 judgment answer as run policy — the mechanism
    behind 'questions only in iteration 1': iterations >= 2 consult this map
    instead of asking."""
    state = load_state(args.target, args.run)
    d = loop_dir(state["target"], state["run"])
    ppath = os.path.join(d, "policy.json")
    policy = {}
    if os.path.exists(ppath):
        with open(ppath, encoding="utf-8") as f:
            policy = json.load(f) or {}
    policy.setdefault("decisions", {})[args.finding] = {
        "decision": args.decision,
        "iter": len(state["iterations"]) or 1,
    }
    with open(ppath, "w", encoding="utf-8") as f:
        json.dump(policy, f, indent=2)
    audit(state, f"policy: {args.finding} -> {args.decision}")
    out({"ok": True, "finding": args.finding})


def cmd_finish(args):
    """Mark the run terminal, machine-readably: converged | cap |
    gate-ratified | aborted. The dashboard's answer to 'why did it stop?'."""
    state = load_state(args.target, args.run)
    state["finished"] = {"reason": args.reason,
                         "at": time.strftime("%Y-%m-%d %H:%M:%S")}
    save_state(state)
    audit(state, f"run finished: {args.reason}")
    out({"ok": True, "reason": args.reason})


def _fmt_ids(ids, cap=6):
    ids = list(ids)
    if not ids:
        return "none"
    s = ", ".join(ids[:cap])
    return s + (f" +{len(ids) - cap} more" if len(ids) > cap else "")


def _short(text, n=90):
    text = " ".join((text or "").split())
    return text if len(text) <= n else text[:n - 1] + "…"


def _queue_reasons(state):
    """{finding-id: reason} parsed from the morning queue's DEFER/FROZEN lines."""
    path = os.path.join(loop_dir(state["target"], state["run"]), "queue.md")
    reasons = {}
    if os.path.exists(path):
        with open(path, encoding="utf-8") as f:
            for ln in f:
                for tag in ("- DEFER ", "- FROZEN "):
                    if ln.startswith(tag) and ":" in ln[len(tag):]:
                        fid, reason = ln[len(tag):].split(":", 1)
                        reasons[fid.strip()] = reason.strip()
    return reasons


def _classify_anomaly(scenario, findings, state):
    """Classify an anomalous drive result against the ledger: is it a known
    finding (and what was decided about it this run), or unmatched — the
    distinction between 'expected noise' and 'look at this now'."""
    tags = []
    for fd in findings:
        if scenario not in fd.get("scenarios", []) or fd.get("tombstone"):
            continue
        if fd["id"] in state.get("deferred", []):
            tags.append((0, f"{fd['id']} deferred"))
        elif fd["id"] in state.get("frozen", []):
            tags.append((0, f"{fd['id']} frozen"))
        elif fd.get("status") in ("open", "proposed"):
            tags.append((1, f"{fd['id']} open"))
    tags.sort()
    if tags:
        more = f" +{len(tags) - 3}" if len(tags) > 3 else ""
        return True, "known: " + ", ".join(t for _, t in tags[:3]) + more
    return False, "UNMATCHED — no ledger finding yet; check this iter's mining"


def _run_deltas(state, findings):
    """This-run ledger movement, from the run-start snapshot (iteration 1's
    findings_before). Legacy id-list snapshots yield only the 'new' delta."""
    if not state["iterations"]:
        return None
    snap = state["iterations"][0].get("findings_before", [])
    legacy = isinstance(snap, list)
    before = {i: None for i in snap} if legacy else snap
    cur = {fd["id"]: fd for fd in findings}
    return {
        "new": [i for i in cur if i not in before],
        "fixed": [i for i, b in before.items() if b and i in cur
                  and b.get("status") in ("open", "proposed")
                  and cur[i].get("status") == "accepted"],
        "recurred": [i for i, b in before.items() if b and i in cur
                     and cur[i].get("recurrence", 1) > b.get("recurrence", 1)],
        "legacy": legacy,
    }


def _health(state, driving, unmatched):
    """One verdict line: OK / ATTENTION / DONE, with the reason — the answer
    to 'do I need to look at anything?' before any detail is read."""
    n_done = len(state["iterations"])
    pend = []
    if state.get("deferred"):
        pend.append(f"{len(state['deferred'])} deferred decision(s)")
    if state.get("frozen"):
        pend.append(f"{len(state['frozen'])} frozen finding(s)")
    gate_note = f"; {' + '.join(pend)} await your ruling" if pend else ""
    fin = state.get("finished")
    if fin:
        return {"gate-ratified": "DONE — ratified at the morning gate",
                "converged": f"OK — converged; run the morning gate{gate_note}",
                "cap": "ATTENTION — cap hit without convergence; run the "
                       f"morning gate{gate_note}",
                }.get(fin["reason"],
                      f"ATTENTION — run ended: {fin['reason']}{gate_note}")
    if state.get("last_breaker"):
        return ("ATTENTION — stopped by breaker: "
                f"{state['last_breaker']['reason']}{gate_note}")
    if unmatched:
        return (f"ATTENTION — {unmatched} scenario anomal"
                f"{'ies' if unmatched > 1 else 'y'} match no ledger finding "
                "yet (new problem or mining not done)")
    if driving:
        return f"OK — iteration {n_done} driving; anomalies (if any) are known"
    if state["quiet_streak"] >= 2:
        return f"OK — converged; run the morning gate{gate_note}"
    if n_done >= state["cap"]:
        return ("ATTENTION — cap hit without convergence; run the morning "
                f"gate{gate_note}")
    return f"OK — between iterations ({n_done}/{state['cap']} done){gate_note}"


def cmd_dashboard(args):
    """Operational status (plain text, one screen). Within seconds the
    operator can answer: is the loop healthy, did anything unexpected happen,
    what did THIS run change, what is the scheduler doing and why, how far is
    convergence, and what decision comes next. Cumulative/lifetime numbers are
    a single pointer line — the long view is `tanuki-scheduler history`.
    --follow N re-renders every N seconds; reads state files only."""
    while True:
        state = load_state(args.target, args.run)
        findings = ledger_findings(state["target"])
        n_done = len(state["iterations"])
        cur = state["iterations"][-1] if state["iterations"] else None
        elapsed = int(time.time() - state["wall_start"])

        # -- latest drive: progress + per-scenario results, anomalies classified
        drive_lines, driving, unmatched = [], False, 0
        if cur:
            ppath = os.path.join(TANUKI_ROOT, state["target"], "events",
                                 f"{state['run']}-iter{cur['n']}",
                                 "progress.json")
            if os.path.exists(ppath):
                with open(ppath, encoding="utf-8") as f:
                    p = json.load(f)
                driving = (p.get("stage") != "complete"
                           and cur["phase"] == "started")
                if driving:
                    drive_lines.append(
                        f"  NOW: iter {cur['n']} driving "
                        f"[{p['done']}/{p['total']}] {p.get('current')} — "
                        f"{p.get('stage')} ({p.get('elapsed_s', 0)}s, "
                        f"{p.get('captured_kb', 0)}KB)")
                drive_lines.append(f"  latest drive (iter {cur['n']}):")
                for r in p.get("results", []):
                    line = (f"    {r['scenario']:<22} {r['status'][:28]:<28}"
                            f" {r['events']:>3} events "
                            f"{int(r.get('duration_s') or 0):>4}s")
                    if not str(r.get("status", "")).startswith("ok"):
                        known, tag = _classify_anomaly(r["scenario"],
                                                       findings, state)
                        unmatched += 0 if known else 1
                        line += f"  <- {tag}"
                    drive_lines.append(line)
            elif cur["phase"] == "started":
                driving = True
                drive_lines.append(f"  NOW: iter {cur['n']} in progress "
                                   "(pre-drive or mining/implementing)")

        lines = [f"tanuki-loop — {state['target']} / {state['run']}",
                 f"  health: {_health(state, driving, unmatched)}",
                 f"  integration: {state['integration_branch']}  "
                 f"(base {state['base']})",
                 f"  iterations: {n_done}/{state['cap']} · elapsed "
                 f"{elapsed // 60}m"]
        lines += drive_lines

        # -- this run's ledger movement (run-scoped; lifetime is one pointer)
        deltas = _run_deltas(state, findings)
        reasons = _queue_reasons(state)
        if deltas:
            def part(label, ids):
                return f"{label} {len(ids)}" + \
                    (f" ({_fmt_ids(ids)})" if ids else "")
            lines.append("  this run: " + " · ".join((
                part("new findings", deltas["new"]),
                part("fixed", deltas["fixed"]),
                part("recurred", deltas["recurred"]),
                f"deferred {len(state.get('deferred', []))}",
                f"frozen {len(state.get('frozen', []))}")))
            if deltas["legacy"]:
                lines.append("    (run predates status snapshots — "
                             "fixed/recurred not computable)")
            for fid in state.get("deferred", []):
                lines.append(f"    deferred {fid}: "
                             f"{_short(reasons.get(fid, 'see queue.md'))}")
            for fid in state.get("frozen", []):
                lines.append(f"    frozen {fid} (attempt cap): "
                             f"{_short(reasons.get(fid, 'see queue.md'))}")
        if findings:
            by = {}
            for fd in findings:
                by[fd["status"]] = by.get(fd["status"], 0) + 1
            lines.append(f"  findings: {len(findings)} lifetime — " +
                         " · ".join(f"{k} {v}" for k, v in sorted(by.items())) +
                         f" (history: /tanuki {state['target']} --history)")

        # -- scheduler: its DECISIONS for this iteration when a persisted plan
        #    exists; per-state pools otherwise (pre-revision runs).
        spath = os.path.join(TANUKI_ROOT, state["target"], "scheduler.json")
        if os.path.exists(spath):
            with open(spath, encoding="utf-8") as f:
                sched = json.load(f)
            by = {}
            for sid, st in sched.get("scenarios", {}).items():
                by.setdefault(st["state"], []).append(sid)
            lines.append("  scenarios: " + " · ".join(
                f"{k} {len(v)}" for k, v in sorted(by.items())))
            plan = plan_record(state, cur["n"]) if cur else None
            if plan:
                picked = set(plan.get("verify", []) + plan.get("explore", [])
                             + plan.get("due_regression", []))
                rotation = [s for s in plan.get("plan", []) if s not in picked]
                lines.append(f"  scheduler decisions (iter {cur['n']} plan — "
                             "exploration quota "
                             f"{'met' if plan.get('quota_met') else 'NOT met'}):")
                lines.append("    verifying fixes (replay): "
                             f"{_fmt_ids(plan.get('verify', []))}")
                lines.append("    exploring (never driven): "
                             f"{_fmt_ids(plan.get('explore', []))}")
                lines.append(f"    active rotation:          {_fmt_ids(rotation)}")
                if plan.get("due_regression"):
                    lines.append("    regression due:           "
                                 f"{_fmt_ids(plan['due_regression'])}")
                lines.append("    waiting (future iters):   "
                             f"{_fmt_ids(plan.get('unexplored_remaining', []))}")
            else:
                if by.get("unexplored"):
                    lines.append("    unexplored: "
                                 f"{', '.join(sorted(by['unexplored'])[:6])}")
                if by.get("regression"):
                    lines.append("    regression pool: "
                                 f"{', '.join(sorted(by['regression'])[:6])}")
                if cur:
                    lines.append("    (no persisted plan for this run — "
                                 "selection reasons unavailable; states only)")

        # -- convergence: which conditions held last cycle, what's still needed
        lines.append(f"  convergence: quiet streak {state['quiet_streak']}/2 — "
                     "a cycle is quiet when it finds no new actionable "
                     "finding, lands no patch, and met the exploration quota")
        lc = state.get("last_cycle")
        if lc:
            held = [("no new findings" if lc["new_actionable"] == 0 else
                     f"{lc['new_actionable']} NEW actionable finding(s)"),
                    ("no patch" if not lc["patched"] else "a patch LANDED"),
                    ("quota met" if lc.get("quota_met", True) else
                     "exploration quota NOT met")]
            lines.append(f"    last cycle (iter {lc['iter']}): "
                         f"{'quiet' if lc['quiet'] else 'not quiet'} — "
                         + " · ".join(held))
            if not state.get("finished") and state["quiet_streak"] == 1:
                lines.append("    one more quiet cycle ends the run (converged)")

        # -- why stopped / the concrete next decision
        at_gate = False
        if state.get("finished"):
            lines.append(f"  STOPPED: {state['finished']['reason']} "
                         f"(at {state['finished']['at']})")
            at_gate = state["finished"]["reason"] in ("converged", "cap")
        elif state.get("last_breaker"):
            lines.append(f"  STOPPED: breaker — "
                         f"{state['last_breaker']['reason']} "
                         f"(at {state['last_breaker']['at']})")
            lines.append("  NEXT: inspect the audit trail, fix the breaker "
                         "cause, then resume or run the morning gate on what "
                         "already landed")
        elif cur and cur["phase"] == "started":
            lines.append(f"  NEXT: loop finishes iteration {cur['n']} "
                         "(mine -> classify -> implement -> test -> commit) — "
                         "no action needed from you")
        elif state["quiet_streak"] >= 2 or n_done >= state["cap"]:
            reason = ("converged" if state["quiet_streak"] >= 2
                      else "iteration cap reached")
            lines.append(f"  STOPPED-PENDING: {reason} — run not closed yet")
            at_gate = True
        else:
            lines.append(f"  NEXT: iteration {n_done + 1} of {state['cap']} — "
                         "no action needed from you")
        if at_gate:
            rc, ncommits = git(state["loop_repo"], "rev-list", "--count",
                               f"{state['base_sha']}..{state['head_expected']}")
            n_rule = len(state.get("deferred", [])) + len(state.get("frozen", []))
            lines.append("  NEXT: morning gate — your decisions:")
            lines.append(f"    1. review the integration diff "
                         f"({ncommits if rc == 0 else '?'} commit(s), "
                         f"{state['base']}..{state['integration_branch']})")
            if n_rule:
                lines.append(f"    2. rule on {n_rule} deferred/frozen "
                             "item(s) — reasons listed above")
            lines.append(f"    {3 if n_rule else 2}. approve or reject the "
                         f"merge {state['integration_branch']} -> "
                         f"{state['base']}")

        print("\n".join(lines))
        if not args.follow:
            return
        print("-" * 64)
        time.sleep(args.follow)


def cmd_status(args):
    state = load_state(args.target, args.run)
    out({
        "run": state["run"], "integration_branch": state["integration_branch"],
        "worktree": state["worktree"], "base": state["base"],
        "iterations_done": len(state["iterations"]), "cap": state["cap"],
        "quiet_streak": state["quiet_streak"], "frozen": state["frozen"],
        "attempts": state["attempts"],
        "elapsed_s": round(time.time() - state["wall_start"], 1),
        "materialized": state["materialized"],
    })


def main():
    p = argparse.ArgumentParser()
    p.add_argument("--target", required=True)
    p.add_argument("--run", default=None)
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("init")
    sp.add_argument("--loop-repo", required=True)
    sp.add_argument("--scenarios", default=None)
    sp.add_argument("--cap", type=int, default=None)
    sp.add_argument("--base", default=None)
    sp.add_argument("--worktree", default=None)
    sp.add_argument("--phase", type=int, default=1)
    sp.add_argument("--wall-time", type=int, default=None)
    sp.add_argument("--token-budget", type=int, default=None)
    sp.add_argument("--policy", default=None)
    sp.add_argument("--attempt-cap", type=int, default=None)
    sp.add_argument("--test-cmd", default=None)
    sp.add_argument("--allow-stale-base", action="store_true")

    sub.add_parser("iter-start")
    sp = sub.add_parser("iter-verify"); sp.add_argument("--no-patch", action="store_true")
    sub.add_parser("rollback")
    sub.add_parser("test")
    sp = sub.add_parser("attempt"); sp.add_argument("--finding", required=True)
    sp = sub.add_parser("record-cycle")
    sp.add_argument("--new-actionable", type=int, default=None)
    sp.add_argument("--patched", dest="patched", action="store_true")
    sp.add_argument("--no-patched", dest="patched", action="store_false")
    sp.set_defaults(patched=None)
    sp = sub.add_parser("defer")
    sp.add_argument("--finding", required=True); sp.add_argument("--reason", required=True)
    sp = sub.add_parser("log"); sp.add_argument("--audit", required=True)
    sub.add_parser("gate-check")
    sp = sub.add_parser("issue-get"); sp.add_argument("--key", required=True)
    sp = sub.add_parser("issue-put")
    sp.add_argument("--key", required=True); sp.add_argument("--issue", required=True)
    sp = sub.add_parser("policy")
    sp.add_argument("--finding", required=True); sp.add_argument("--decision", required=True)
    sp = sub.add_parser("finish"); sp.add_argument("--reason", required=True)
    sp = sub.add_parser("dashboard")
    sp.add_argument("--follow", type=int, default=None)
    sub.add_parser("status")

    args = p.parse_args()
    {"init": cmd_init, "iter-start": cmd_iter_start, "iter-verify": cmd_iter_verify,
     "rollback": cmd_rollback, "test": cmd_test, "attempt": cmd_attempt,
     "record-cycle": cmd_record_cycle, "defer": cmd_defer, "log": cmd_log,
     "gate-check": cmd_gate_check, "issue-get": cmd_issue_get,
     "issue-put": cmd_issue_put, "policy": cmd_policy, "finish": cmd_finish,
     "dashboard": cmd_dashboard, "status": cmd_status}[args.cmd](args)


if __name__ == "__main__":
    sys.exit(main())
