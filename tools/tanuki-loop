def cmd_log(args):
    state = load_state(args.target, args.run)
    audit(state, args.audit)
    out({"ok": True})


def _gate_progress(state, reachable):
    """Where the morning gate stands, derived READ-ONLY from existing state
    fields and the reachability fact gate-check just computed (F97) — no new
    state, no new subcommand. Steps use the morning-gate vocabulary
    (final-tests, merge, gate-check, gate-push, issues, cleanup); a step with
    no derivable evidence is OMITTED from the completed set, never guessed —
    so `next_step` is only the first step this state cannot prove done."""
    evidence = {
        "final-tests": bool((state.get("last_test") or {}).get("ok")),
        # A reachable integration tip proves the merge landed, and proves
        # this very gate-check passed — the same fact answers both steps.
        "merge": reachable,
        "gate-check": reachable,
        "gate-push": bool(state.get("pushed")),
        "issues": bool(state.get("materialized")),
        "cleanup": bool(state.get("finished")),
    }
    order = ("final-tests", "merge", "gate-check", "gate-push",
             "issues", "cleanup")
    # last_completed_step is the end of the contiguous completed PREFIX, not
    # the globally-last step that happens to carry evidence (F224): an
    # overnight `finish --reason cap` sets state["finished"], which maps to
    # the `cleanup` step, so a naive done[-1] reads "cleanup" at the very
    # first gate-check while merge/gate-push/issues are still pending. The
    # gate is a sequence — report how far down it we have contiguously gotten.
    prefix = []
    for s in order:
        if not evidence[s]:
            break
        prefix.append(s)
    progress = {
        "last_completed_step": prefix[-1] if prefix else None,
        "next_step": next((s for s in order if not evidence[s]), None),
    }
    # F234: this derivation cannot know whether issue tooling exists for the
    # target, and the doc's steps 5-6 are skipped entirely on a trackerless
    # target — say so instead of nudging every operator toward `issues`.
    if progress["next_step"] == "issues":
        progress["next_step_note"] = (
            "the issues step applies only where forge/tracker tooling is "
            "configured for this target — a hostless/trackerless target "
            "skips it (morning-gate steps 5-6) and proceeds to cleanup")
    if not reachable:
        progress["blocker"] = ("integration tip not reachable from the base "
                               "— the merge has not landed (see hint)")
    else:
        progress["blocker"] = None
    return progress


def cmd_gate_check(args):
    state = load_state(args.target, args.run)
    repo, base = state["loop_repo"], state["base"]
    rc, integ_head = git(repo, "rev-parse", state["integration_branch"])
    # `finish` deletes the integration branch once it is merged, so a re-check
    # after a ratified run — an operator double-checking, or a crash-retry
    # re-entering the gate at this step — finds no ref and used to report a
    # bare reachable:false, indistinguishable from "the merge never landed"
    # (F61). Fall back to the HEAD the run recorded so the answer stays
    # truthful, and say which ref answered it either way.
    branch_gone = rc != 0
    finished = state.get("finished")
    if branch_gone and finished:
        integ_head = state.get("head_expected") or ""
    ref = integ_head if branch_gone else state["integration_branch"]
    if ref:
        rc2, _ = git(repo, "merge-base", "--is-ancestor", ref, base)
    else:
        rc2 = 1
    reachable = bool(ref) and rc2 == 0
    audit(state, f"gate-check: integration reachable from {base}: {reachable}"
                 + (" (branch already deleted; checked the recorded HEAD)"
                    if branch_gone and finished else ""))
    if not reachable:
        if branch_gone and not finished:
            hint = ("the integration branch is gone but this run was never "
                    "finished — it was deleted outside the loop; inspect the "
                    "reflog, or re-run the gate from a fresh `init`")
        elif branch_gone:
            hint = ("the run is finished and its branch deleted, but the "
                    "recorded HEAD is NOT an ancestor of %s — the merge did "
                    "not land; re-run the merge step" % base)
        else:
            hint = ("the integration branch is not an ancestor of %s — merge "
                    "it (`git merge --no-ff %s` on %s) before gate-push"
                    % (base, state["integration_branch"], base))
        out({"reachable": False, "checked_ref": ref or None,
             "branch_deleted": branch_gone, "run_finished": bool(finished),
             "gate_progress": _gate_progress(state, False),
             "hint": hint})
        sys.exit(3)
    res = {"reachable": True, "integration_head": integ_head,
           "gate_progress": _gate_progress(state, True)}
    if branch_gone and finished:
        res["branch_deleted"] = True
        res["note"] = ("integration branch already deleted by `finish` "
                       "(reason: %s) — reachability verified from the run's "
                       "recorded HEAD; this run is already ratified and "
                       "gate-check is idempotent"
                       % finished.get("reason", "?"))
    out(res)


def cmd_gate_push(args):
    """Push the base branch to its remote — the morning gate's FIRST
    outward-facing step, run after the merge + gate-check and BEFORE issues are
    materialized (issue #5). Until the merge commit exists on the remote, the
    issue links the gate stamps onto materialized issues 404 and "close as
    completed" cites evidence nobody can see; leaving main local-only also
    diverges the remote for the next workflow's `git pull --ff-only`. A diverged
    remote is handled explicitly — refuse and ask the operator to reconcile,
    never force-push."""
    state = load_state(args.target, args.run)
    repo, base = state["loop_repo"], state["base"]
    rc, upstream = git(repo, "rev-parse", "--abbrev-ref",
                       "--symbolic-full-name", f"{base}@{{upstream}}")
    if rc != 0 or not upstream:
        die(f"base '{base}' has no upstream to push to — set one "
            f"(git -C {repo} push -u origin {base}) then re-run gate-push")
    rc_r, remote = git(repo, "config", "--get", f"branch.{base}.remote")
    if rc_r != 0 or not remote:
        die(f"no remote configured for base '{base}'")
    git(repo, "fetch", remote)  # refresh the tracking ref before deciding
    # Build artifacts must not reach the remote (F102: __pycache__/*.pyc rode
    # the integration branch through the merge AND gate-push onto origin, with
    # nothing objecting anywhere on that path). iter-verify only WARNS — a
    # headless run must not halt over an incomplete .gitignore — so this is
    # where the deferred decision is actually enforced: the last mechanical
    # boundary before the remote, and an attended one, where the operator can
    # fix it or override deliberately. Same shape as the diverged-remote
    # refusal below: refuse and name the remedy, never rewrite anything.
    swept = [p for p in committed_artifacts(repo, upstream, base)
             if p]
    if swept and not args.allow_artifacts:
        shown = ", ".join(swept[:8]) + (" …" if len(swept) > 8 else "")
        audit(state, f"gate-push BLOCKED: build artifacts in the merged diff: "
                     f"{', '.join(swept)}")
        out({"pushed": False, "build_artifacts": swept,
             "hint": f"the merge adds build artifacts ({shown}) — regenerable "
                     f"output, not work product. Remove them (git -C {repo} rm "
                     "-r --cached <path>), add them to .gitignore, commit, "
                     "then re-run gate-push. --allow-artifacts overrides this "
                     "deliberately."})
        sys.exit(3)
    ahead = git(repo, "rev-list", "--count", f"{base}..{upstream}")[1]
    n_ahead = int(ahead) if ahead.isdigit() else 0
    if n_ahead > 0:  # remote diverged — a plain push would not fast-forward
        audit(state, f"gate-push BLOCKED: '{upstream}' is {n_ahead} commit(s) "
                     f"ahead of local '{base}' (diverged)")
        out({"pushed": False, "diverged": True, "upstream": upstream,
             "upstream_ahead": n_ahead,
             "hint": f"reconcile without force (git -C {repo} merge --no-edit "
                     f"{upstream}), re-run the final tests, then re-run "
                     "gate-push"})
        sys.exit(3)
    rc_p, err = git(repo, "push", remote, base)
    if rc_p != 0:
        die(f"push of '{base}' to '{remote}' failed (not forced): {err}")
    head = git(repo, "rev-parse", base)[1]
    state["pushed"] = {"remote": remote, "ref": upstream, "sha": head,
                       "at": time.strftime("%Y-%m-%d %H:%M:%S")}
    save_state(state)
    audit(state, f"gate-push: pushed '{base}' -> {remote} @ {head[:12]}")
    out({"pushed": True, "remote": remote, "ref": upstream, "base_sha": head})


def _gate_pr_recovery(integ, base, cause=None):
    """The documented recovery for a gate-pr failure (F192): the command is
    idempotent, so the operator can finish the delivery by hand and re-run.
    F230: the advice is cause-specific — when the base ref is missing on the
    forge, hand-creating a PR against it cannot work, so the base branch must
    be restored/pushed first; the generic hand-create path fits every other
    cause."""
    if cause == "base ref not found on forge":
        return (f"the base ref `{base}` does not exist on the forge, so a PR "
                f"`{integ} -> {base}` cannot be created against it — push/"
                f"restore the base branch first (`git push <remote> {base}`, "
                "or point the run at a base that exists), then re-run gate-pr "
                "(idempotent)")
    if cause == "no GitHub remote":
        return ("no configured git remote points to a GitHub host, so `gh` "
                "cannot create the PR anywhere — add a GitHub remote "
                "(`git remote add <name> <github-url>`) or run from a "
                "checkout that has one, then re-run gate-pr (idempotent)")
    return (f"hand-create the PR `{integ} -> {base}` on the forge, then "
            "re-run gate-pr — it is idempotent and will adopt the existing "
            "PR")


def _classify_gate_pr_failure(err):
    """Best-effort cause classification from gh/git stderr (F192): the raw
    text stays in the payload; this only names the likely bucket."""
    e = (err or "").lower()
    if "base" in e and any(t in e for t in
                           ("not found", "does not exist", "invalid",
                            "no such", "unknown", "must be a branch")):
        return "base ref not found on forge"
    # F235: gh's "none of the git remotes ... point to a known GitHub host"
    # was falling through to "other" while the hint text named the cause.
    if "github host" in e or ("remote" in e and "github" in e):
        return "no GitHub remote"
    return "other"


def cmd_gate_pr(args):
    """Deliver a finished run's review material as ONE ready-for-review PR
    (spec-tanuki-loop "PR-protected targets", ready-by-default amendment
    2026-07-20). For a base branch that refuses direct pushes, the local-merge
    + gate-push gate cannot run; instead the run's close pushes the
    INTEGRATION branch and opens a single PR integration -> base.

    Ready-for-review is the default because a Draft is inert to required
    status checks and review-request automation — the delivered PR could not
    receive the review it was delivered for until a human un-drafted it. An
    operator who wants "review material, not a request" opts back into a Draft
    via `gate_pr_draft: true` in the scenarios loop block or `gate-pr --draft`.
    Either way the PR is a proposal awaiting review, never a conclusion; the
    conclusion (the merge) is the Human Gate and never happens here.

    THE LOOP ENDS HERE (owner ruling 2026-07-17, delivery boundary). Success
    records the run as delivered — PR number, integration-tip SHA, base SHA —
    and that is the loop's terminal fact. This tool NEVER merges (no merge
    call exists anywhere in it), never polls, never comments, never waits.
    Whether the PR is ultimately merged is not the loop's to know or restate:
    settlement (landed | pending | declined | unknown) is DERIVED by the
    read-only surfaces (status, init's backstop, unresolved) from the forge
    and the current base, at the moment an operation actually needs it.

    Preconditions (all mechanical, all refuse with exit 3 and a remedy):
      - the run is finished (cap | converged) — a live run has no reviewed
        batch to deliver;
      - final tests passed on the CURRENT integration HEAD (`tanuki-loop test`
        records the SHA it validated; a stale or missing pass refuses);
      - `gh` is available.
    Failure ANYWHERE leaves the local integration branch and run state
    intact: the push is never forced, and a failed `gh pr create` after a
    successful push is re-runnable — the whole command is idempotent (an
    existing PR for the head branch, recorded in state or found on the forge,
    is reused and reported, never duplicated)."""
    state = load_state(args.target, args.run)
    repo, base, integ = state["loop_repo"], state["base"], \
        state["integration_branch"]
    # Ready-by-default (amendment 2026-07-20): the PR is opened ready for
    # review unless the operator opts into a Draft, either per-run
    # (`gate-pr --draft`) or per-target (loop block gate_pr_draft:true, stored
    # in state at init).
    draft = bool(getattr(args, "draft", False) or state.get("gate_pr_draft"))
    fin = state.get("finished")
    if not fin or fin.get("reason") not in ("cap", "converged"):
        out({"created": False,
             "hint": "gate-pr delivers a FINISHED run's review material — "
                     "close the run first (`finish --reason cap|converged`); "
                     "a run already gate-ratified has nothing left to "
                     "deliver"})
        sys.exit(3)
    rc, head = git(repo, "rev-parse", integ)
    if rc != 0:
        die(f"integration branch '{integ}' does not resolve — was it deleted "
            "outside the loop?")
    lt = state.get("last_test") or {}
    if not (lt.get("ok") and lt.get("sha") == head):
        out({"created": False, "last_test": lt or None,
             "integration_head": head,
             "hint": "final tests have not passed on the current integration "
                     "HEAD — run `tanuki-loop test` (it records the SHA it "
                     "validated), then re-run gate-pr"})
        sys.exit(3)
    if shutil.which("gh") is None:
        out({"created": False,
             "hint": "`gh` (GitHub CLI) not found on PATH — install/auth it, "
                     "or use the merge gate (gate-push) on a direct-push "
                     "target"})
        sys.exit(3)
    rc_r, remote = git(repo, "config", "--get", f"branch.{base}.remote")
    remote = remote if rc_r == 0 and remote else "origin"
    # Never force: a rejected push (remote branch moved — someone else touched
    # the loop's namespace) refuses and reports; local state is untouched.
    rc_p, err = git(repo, "push", remote, integ)
    if rc_p != 0:
        audit(state, f"gate-pr: push of '{integ}' to '{remote}' failed "
                     f"(not forced): {err}")
        # F192: a failure names what was attempted (base + integration
        # branch), the likely cause, and the documented recovery — never just
        # the raw stderr.
        out({"created": False, "pushed": False,
             "base": base, "integration_branch": integ,
             "cause": "push failure",
             "recovery": _gate_pr_recovery(integ, base, "push failure"),
             "hint": f"push of '{integ}' to '{remote}' failed (not forced; "
                     "the local branch is intact): " + err})
        sys.exit(3)
    # Idempotency, two layers: the PR this run recorded, else the forge's own
    # answer for this head branch (covers a crash between create and record).
    pr, created = state.get("gate_pr"), False
    if not pr:
        rc_l, o = gh(repo, "pr", "list", "--head", integ, "--state", "all",
                     "--json", "number,url,state,isDraft")
        if rc_l == 0 and o:
            try:
                found = json.loads(o)
            except ValueError:
                found = []
            if found:
                pr = {"number": found[0].get("number"),
                      "url": found[0].get("url")}
                audit(state, f"gate-pr: reusing existing PR #{pr['number']} "
                             f"for head '{integ}'")
    if not pr:
        title = args.title or (f"tanuki-loop: batch from {state['run']} "
                               f"({len(state['iterations'])} iteration(s))")
        if args.body_file:
            with open(os.path.expanduser(args.body_file),
                      encoding="utf-8") as f:
                body = f.read()
        else:
            _ld = loop_dir(state["target"], state["run"])
            body = (
                f"Unattended tanuki-loop run `{state['run']}` "
                f"(reason: {fin['reason']}) — "
                f"{len(state['iterations'])} iteration(s) on "
                f"`{integ}`, base `{base}` @ {state['base_sha'][:12]}.\n\n"
                f"This {'Draft ' if draft else ''}PR is the **delivery of "
                "review material (a review request), not ratification**. The "
                "Human Gate is your approval + merge; the loop never merges. "
                "Intended merge method: **create a merge commit**, so the "
                "intent-scoped commits stay visible in the base branch's "
                "history.\n\n"
                f"Audit trail: `{os.path.join(_ld, 'audit.md')}` — "
                f"morning queue: `{os.path.join(_ld, 'queue.md')}`.")
        create_args = ["pr", "create", "--base", base, "--head", integ,
                       "--title", title, "--body", body]
        if draft:
            create_args.insert(2, "--draft")
        rc_c, o = gh(repo, *create_args)
        if rc_c != 0:
            audit(state, f"gate-pr: `gh pr create` failed: {o}")
            # F192: name the attempted refs, classify the cause from the gh
            # stderr (best-effort), and state the recovery — the generic gh
            # text alone left the operator without a next action.
            _cause = _classify_gate_pr_failure(o)
            out({"created": False, "pushed": True,
                 "base": base, "integration_branch": integ,
                 "cause": _cause,
                 "recovery": _gate_pr_recovery(integ, base, _cause),
                 "hint": "the branch is pushed but `gh pr create` failed — "
                         "local state is intact and gate-pr is idempotent; "
                         "fix the cause and re-run: " + o})
            sys.exit(3)
        url = o.splitlines()[-1].strip() if o else ""
        tail = url.rstrip("/").rsplit("/", 1)[-1]
        pr = {"number": int(tail) if tail.isdigit() else None, "url": url}
        created = True
    # F193: a REUSED PR's base is the forge's fact, not local state's — the
    # PR may have been re-targeted since delivery. Read baseRefName from the
    # forge; fall back to state's base (with a note) only when the read fails.
    # The same read supplies isDraft, so a re-run can reconcile the PR's draft
    # status to the intended one (amendment 2026-07-20) — idempotent: only a
    # genuine mismatch is transitioned, and a failed transition warns rather
    # than undoing a successful delivery.
    pr_base, base_note, warning = base, None, None
    actual_draft = draft
    if not created:
        ref = str(pr.get("number") or pr.get("url") or "")
        forge_base, forge_is_draft = None, None
        rc_v, o = gh(repo, "pr", "view", ref, "--json",
                     "baseRefName,headRefName,isDraft")
        if rc_v == 0 and o:
            try:
                _v = json.loads(o) or {}
                forge_base = _v.get("baseRefName")
                forge_is_draft = _v.get("isDraft")
            except ValueError:
                forge_base = None
        if forge_base:
            pr_base = forge_base
            if forge_base != base:
                warning = (f"the forge PR's base is '{forge_base}', not "
                           f"state's recorded base '{base}' — recording the "
                           "forge's value (the PR was re-targeted, or the "
                           "base moved); review before merging (F193)")
                audit(state, f"gate-pr WARNING: {warning}")
        else:
            base_note = (f"forge read of the PR's baseRefName failed — "
                         f"falling back to state's recorded base '{base}' "
                         "(F193)")
        # Reconcile draft status to the intended one. When the forge read
        # failed we cannot know the current status (forge_is_draft is None);
        # base_note already records that failure, so we leave the PR untouched
        # rather than guessing or double-warning.
        if forge_is_draft is None:
            actual_draft = draft
        elif bool(forge_is_draft) != draft:
            rc_d, od = (gh(repo, "pr", "ready", "--undo", ref) if draft
                        else gh(repo, "pr", "ready", ref))
            if rc_d == 0:
                actual_draft = draft
                audit(state, f"gate-pr: transitioned PR #{pr.get('number')} "
                             f"to {'draft' if draft else 'ready-for-review'}")
            else:
                actual_draft = bool(forge_is_draft)
                _dw = (f"could not transition PR draft status to "
                       f"{'draft' if draft else 'ready-for-review'} (delivery "
                       f"stands): {od}")
                warning = f"{warning}; {_dw}" if warning else _dw
                audit(state, f"gate-pr WARNING: {_dw}")
        else:
            actual_draft = bool(forge_is_draft)
    pr.update({"head_sha": head, "base": pr_base, "draft": actual_draft,
               "at": time.strftime("%Y-%m-%d %H:%M:%S")})
    if base_note:
        pr["base_note"] = base_note
    state["gate_pr"] = pr
    # The DELIVERY record — the loop's terminal fact (owner ruling 2026-07-17):
    # PR number, integration-tip SHA, and the base SHA at delivery. The loop
    # ends here; whether the PR merges is derived later (derive_settlement) by
    # whichever surface needs it, never restated by a human closing command.
    rc_b, base_sha_now = git(repo, "rev-parse", pr_base)
    if rc_b != 0:
        # F191: never write a null base_sha silently — name the missing ref.
        w = (f"base ref '{pr_base}' does not resolve in the loop repo — "
             "delivered.base_sha recorded as null; restore the branch so "
             "settlement can be derived (F191)")
        warning = f"{warning}; {w}" if warning else w
        audit(state, f"gate-pr WARNING: {w}")
    state["delivered"] = {"pr": pr.get("number"), "url": pr.get("url"),
                          "head_sha": head,
                          "base_sha": base_sha_now if rc_b == 0 else None,
                          "at": pr["at"]}
    save_state(state)
    audit(state, (("gate-pr: opened %s PR " %
                   ("Draft" if actual_draft else "ready-for-review"))
                  if created else "gate-pr: reusing PR ")
                 + f"#{pr.get('number')} ({pr.get('url')}) — head "
                 f"{head[:12]}; DELIVERED — the loop ends here; settlement "
                 "(landed/pending/declined) is derived later from the forge "
                 "and the current base")
    out({"created": created, "reused": not created, "pushed": True,
         "pr": pr, "delivered": state["delivered"], "warning": warning,
         "note": "delivered — the loop's boundary. The Human Gate is PR "
                 "approval + merge on the forge; the loop never merges, "
                 "polls, or waits. status/init/unresolved derive the "
                 "settlement (landed/pending/declined/unknown) when they "
                 "need it; no closing command is required."})


