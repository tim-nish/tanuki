#!/usr/bin/env python3
"""tanuki-ledger: Tanuki's findings ledger — the deterministic substrate under
the Miner and Consolidator.

Contract: docs/tanuki-spec.md §2–3. Zero dependencies. The ledger does the
arithmetic (ingest, exact dedupe, recurrence counts, promotion thresholds);
semantic judgment (what is a finding, whether a candidate matches an existing
one, what to propose) belongs to the orchestrating model and never happens here
(deterministic-tool-over-llm-in-loop).

Ledger: ~/.tanuki/<target>/ledger.json
  {"events": {fingerprint: {…, count, first_seen, last_seen, runs[]}},
   "findings": [{id, title, kind, first_seen, last_seen, recurrence,
                 evidence[], scenarios[], status, last_seen_run}]}

Usage:
  tanuki-ledger --target <slug> init
  tanuki-ledger --target <slug> ingest <events.jsonl> [...]
      event line: {"run": <run-id>, "scenario": <slug>, "seq": <int>,
                   "type": "tool_error|note|result|…", "detail": <str>}
      (full field semantics: `ingest --help`)
  tanuki-ledger --target <slug> ingest-note --text "<human feedback>"
  tanuki-ledger --target <slug> findings [--status open|proposed|accepted|dismissed]
  tanuki-ledger --target <slug> upsert-finding --title T --kind friction|papercut|gap \
      --evidence run/scenario#seq[,…] [--match F3] [--note "…"]
  tanuki-ledger --target <slug> promote [--min-recurrence 3] [--min-scenarios 2] [--dry-run]
  tanuki-ledger --target <slug> set-status --id F3 --status open|proposed|accepted|dismissed
  tanuki-ledger --target <slug> consolidate [--status proposed,open] [--min-similarity 0.5]
  tanuki-ledger --target <slug> compact [--unseen-runs N]   # needs re-DRIVEN runs
  tanuki-ledger --target <slug> scenario-yield [--runs N]
  tanuki-ledger --target <slug> status   # human-readable "where was I?" view
  tanuki-ledger --target <slug> next     # just the derived next step
  tanuki-ledger --target <slug> stats
  tanuki-ledger --target <slug> policy-surface   # specs/spec-policy-advisory

`findings` and `promote` emit each finding with a computed `priority`
(P1/P2/P3) so the brief's ordering mirrors `status` without the caller
recomputing it. The scale is deterministic, not a judgment (F83):
  P1  recurrence >= 3 OR seen in >= 2 distinct scenarios   (chronic or broad)
  P2  recurrence == 2, OR kind == "gap"                    (repeat or a gap)
  P3  everything else                                      (seen once)
P1 uses the same bar `promote` defaults to, so a P1 open finding is exactly
one that a default `promote` would move to `proposed`.

Ledger growth policy (docs/tanuki-spec.md "Ledger growth policy").
`ledger.json` may grow indefinitely on disk, bounded by three invariants:
  1. Read-path invariant — no LLM stage ever loads ledger.json whole. Every
     model-facing access goes through a bounded subcommand VIEW (`findings`,
     `promote --dry-run`, `status`, `stats`), never a `cat ledger.json`.
     `load()` is an
     internal mechanic, not a model surface; token cost is governed by the
     views, so file size is a disk concern only.
  2. Capped evidence — an event or finding keeps first_seen, last_seen, an
     occurrence count, and at most EVIDENCE_CAP exemplar raw.jsonl pointers
     (oldest + most recent), never one pointer per occurrence. `ingest` and
     `upsert-finding` cap; the raw logs remain the complete archive.
  3. Compaction of the dead tail — `compact` turns findings that are
     dismissed, or accepted-and-unseen-for-N-runs (verified fixed), into
     one-line tombstones (id, resolution, count): kept so nothing resurfaces
     as new on dedupe, but stripped of per-run detail (which lives in
     raw.jsonl).
     "unseen for N runs" counts runs recorded under events/<run>/ with a
     manifest.json. For a REAL scenario the run must have re-driven it
     (driven-and-absent). For an ingest/no-scenario finding the elapsed-run
     fallback counts any later run. Story 1.9 / #106: `ingest` and
     `ingest-note` now write a minimal manual manifest (results: []), so a
     hand-ingested ledger advances the counter too — earlier it wrote no run
     directory and compaction could never fire on hand-written events (F65).
     A manual run drives no scenario, so it advances only the elapsed-run
     fallback, never false driven-absence for a real scenario.
"""

import argparse
import hashlib
import json
import os
import re
import subprocess
import sys
from datetime import date

TANUKI_ROOT = os.environ.get("TANUKI_ROOT", os.path.expanduser("~/.tanuki"))
KINDS = ("friction", "papercut", "gap")
STATUSES = ("open", "proposed", "accepted", "dismissed")
# Capped-evidence invariant (docs/tanuki-spec.md "Ledger growth policy"): a
# record keeps at most this many exemplar raw.jsonl pointers — the oldest (the
# first_seen exemplar) plus the most recent — never one per occurrence.
EVIDENCE_CAP = 5
# open: in the ledger, below the promotion bar
# proposed: in a brief, awaiting the human's decision
# accepted: human said yes (issue filed / will fix); recurrence still tracked
#           so a later run can verify the fix landed
# dismissed: human said no; kept for dedupe so it never resurfaces as new


#: The P1/P2/P3 rule in one line, so every surface that shows a priority can
#: also show what it means instead of leaving the operator to infer the scale
#: by watching it change (F83).
PRIORITY_LEGEND = ("P1 = recurrence >= 3 or seen in >= 2 scenarios (the "
                   "default promote bar); P2 = recurrence 2, or kind 'gap'; "
                   "P3 = seen once")


def priority(f):
    """P1/P2/P3 for display. Deterministic, no judgment; see PRIORITY_LEGEND."""
    if f["recurrence"] >= 3 or len(f["scenarios"]) >= 2:
        return "P1"
    if f["recurrence"] == 2 or f["kind"] == "gap":
        return "P2"
    return "P3"

CONFIG_DEFAULTS = {"min_recurrence": 3, "min_scenarios": 2,
                   "compaction_unseen_runs": 3}


def cap_evidence(pointers, cap=EVIDENCE_CAP):
    """Bound an evidence/runs list to a handful of exemplars while preserving
    chronology: dedupe (keeping first-seen order), then keep the oldest pointer
    plus the most recent (cap-1). The raw logs stay the complete archive."""
    seen, uniq = set(), []
    for p in pointers:
        if p and p not in seen:
            seen.add(p)
            uniq.append(p)
    if len(uniq) <= cap:
        return uniq
    return [uniq[0]] + uniq[-(cap - 1):]


# Evidence pointers are always 'run/scenario#seq' (the driver's format; the
# reserved 'ingest' pseudo-scenario carries manual ingests, e.g. 'run/ingest#seq').
# A pointer missing the '/scenario' or '#seq' segment parses silently into a
# garbage scenario/last_seen_run (upsert derived scenario from split('#')[0]
# .split('/')[-1] and the run from split('/',1)[0], so 'run1#9' yielded scenario
# 'run1' and run 'run1#9') — reject it instead of guessing (F133).
EVIDENCE_RE = re.compile(r"^[^/#\s]+/[^/#\s]+#[^/#\s]+$")


def run_of(pointer):
    """The run id embedded in an evidence pointer 'run/scenario#seq'."""
    return pointer.split("/", 1)[0] if pointer else None


def run_key(run):
    """Chronological sort key for a run id. Driven runs are '<YYYYMMDD>-<rand>'
    but manual ingests are 'manual-<YYYYMMDD>' (ingest-note), so plain lexical
    order is NOT chronological ('manual-…' would sort after every dated run
    forever, starving compaction's absence counting). Key on the embedded
    8-digit date wherever it appears; an id with no date sorts oldest."""
    m = re.search(r"\d{8}", run or "")
    return (m.group(0) if m else "00000000", run or "")


def latest_run(pointers, prior=None):
    """Chronologically-greatest run id across pointers and an optional prior
    (by run_key — see there for why lexical max is not enough)."""
    runs = [r for r in (run_of(p) for p in pointers) if r]
    if prior:
        runs.append(prior)
    return max(runs, key=run_key) if runs else prior


def load_config():
    """Promotion thresholds: built-ins overridden by ~/.tanuki/config.json
    (docs/tanuki-spec.md "Configuration"). CLI flags override both."""
    cfg = dict(CONFIG_DEFAULTS)
    path = os.path.join(TANUKI_ROOT, "config.json")
    if os.path.exists(path):
        with open(path, encoding="utf-8") as f:
            cfg.update(json.load(f))
    return cfg


def ledger_path(target):
    return os.path.join(TANUKI_ROOT, target, "ledger.json")


def load(target):
    path = ledger_path(target)
    if not os.path.exists(path):
        return {"events": {}, "findings": []}
    with open(path, encoding="utf-8") as f:
        return json.load(f)


def announce_new_target(target):
    """A bare --target slug resolves to ~/.tanuki/<slug>/ and write commands
    create it implicitly, so a typo'd slug silently forks a fresh ledger
    (issue #50 / F18). Announce the creation once, at the moment a write is
    about to bring the namespace into existence — never a prompt (unattended
    callers must keep working)."""
    tdir = os.path.join(TANUKI_ROOT, target)
    if not os.path.isdir(tdir):
        print(f"note: creating new target namespace {tdir}/", file=sys.stderr)


def save(target, ledger):
    path = ledger_path(target)
    announce_new_target(target)
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(ledger, f, indent=2, ensure_ascii=False)
    os.replace(tmp, path)


def cmd_init(args, ledger):
    # F164: init on an existing slug used to print the same "ledger ready" as
    # a fresh one, silently reusing another session's data (~/.tanuki is
    # machine-wide, F94). State the reuse and its size; never a prompt.
    existed = os.path.isfile(ledger_path(args.target))
    save(args.target, ledger)
    if existed:
        print(f"note: target '{args.target}' already exists — reusing its "
              f"ledger ({len(ledger.get('events', {}))} event record(s), "
              f"{len(ledger.get('findings', []))} finding(s)). If you "
              f"expected a fresh target, pick an unused slug: ~/.tanuki/ is "
              f"shared machine-wide.", file=sys.stderr)
    print(f"ledger ready: {ledger_path(args.target)}")


def event_fingerprint(e):
    """The exact-duplicate identity key: scenario+type+detail ONLY — run and
    seq are excluded, so the same detail seen in two runs collapses."""
    return hashlib.sha1(
        f"{e.get('scenario')}|{e.get('type')}|{e.get('detail')}"
        .encode()).hexdigest()[:16]


def ingest_event(ledger, e):
    """Record one event into the ledger; exact duplicates (same
    scenario+type+detail) collapse to a count. Returns 'new' or 'dup'. Raw
    events are facts — nothing here is a finding yet."""
    today = date.today().isoformat()
    fp = event_fingerprint(e)
    if fp in ledger["events"]:
        rec = ledger["events"][fp]
        rec["count"] += 1
        # Capped runs: exemplars, not one entry per occurrence.
        rec["runs"] = cap_evidence(rec.get("runs", []) + [e.get("run")])
        rec.setdefault("first_seen", rec.get("last_seen", today))
        rec["last_seen"] = today
        return "dup"
    e["count"], e["runs"] = 1, [e.get("run")]
    e["first_seen"] = e["last_seen"] = today
    ledger["events"][fp] = e
    return "new"


# Duplicate-collapse listing cap (issue #51 / F70): name what merged, but keep
# a large re-ingest readable — at most this many identities, then "and K more".
COLLAPSE_LIST_CAP = 10


def cmd_ingest(args, ledger):
    """Record events; exact duplicates collapse to a count — and the collapse
    names what merged into what (issue #51 / F70): each collapsed identity
    (scenario/type + truncated detail) is listed once with the record's new
    occurrence count, capped at COLLAPSE_LIST_CAP lines."""
    new, dup = 0, 0
    collapsed = {}  # fingerprint -> event dict (identity listed once)
    runs_seen = set()  # story 1.9 / #106: give each ingested run a manifest
    for path in args.files:
        with open(path, encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                e = json.loads(line)
                if e.get("run"):
                    runs_seen.add(e["run"])
                if ingest_event(ledger, e) == "new":
                    new += 1
                else:
                    dup += 1
                    fp = event_fingerprint(e)
                    collapsed.setdefault(fp, ledger["events"][fp])
    save(args.target, ledger)
    # Story 1.9 / #106: a plain `ingest` wrote no run directory, so all_run_ids
    # never counted hand-ingested runs and compact's verify-by-absence fallback
    # could not advance across manual runs. Give each ingested run a minimal
    # manual manifest (skips any run that already has a driven one).
    for run in sorted(runs_seen):
        write_manual_manifest(args.target, run)
    # flush: piped stdout is block-buffered while stderr is not, so without it
    # the collapsed detail lines (stderr) overtake this summary in a merged
    # capture and the output reads backwards (F121).
    print(f"ingested: {new} new event(s), {dup} exact duplicate(s) collapsed",
          flush=True)
    for rec in list(collapsed.values())[:COLLAPSE_LIST_CAP]:
        detail = (rec.get("detail") or "")
        if len(detail) > 60:
            detail = detail[:57] + "…"
        print(f"  collapsed: {rec.get('scenario')}/{rec.get('type')} "
              f"\"{detail}\" -> count={rec['count']}", file=sys.stderr)
    if len(collapsed) > COLLAPSE_LIST_CAP:
        print(f"  … and {len(collapsed) - COLLAPSE_LIST_CAP} more collapsed "
              f"identit(ies)", file=sys.stderr)


def cmd_ingest_note(args, ledger):
    """Record human feedback verbatim as an Event — the human never classifies
    (docs/tanuki-spec.md "Human feedback ingest"). Writes an
    unjudged `note` event (source: human, run id manual-<date>) to the run's
    events file and into the ledger. Semantic judgment — whether it yields a
    finding, its kind, bump-vs-new — is the caller's downstream extraction +
    dedupe pass, exactly as for a driven run; this tool only stores the fact."""
    text = args.text.strip()
    if not text:
        print("error: --text must be non-empty feedback", file=sys.stderr)
        sys.exit(2)
    run = "manual-" + date.today().strftime("%Y%m%d")
    run_dir = os.path.join(TANUKI_ROOT, args.target, "events", run)
    announce_new_target(args.target)
    os.makedirs(run_dir, exist_ok=True)
    events_file = os.path.join(run_dir, "ingest.events.jsonl")
    # Sequence within the day so repeated same-day ingests don't collide.
    seq = 1
    if os.path.exists(events_file):
        with open(events_file, encoding="utf-8") as f:
            seq = sum(1 for line in f if line.strip()) + 1
    e = {"run": run, "scenario": "ingest", "seq": seq, "type": "note",
         "source": "human", "detail": text, "evidence": f"{run}/ingest#{seq}"}
    with open(events_file, "a", encoding="utf-8") as f:
        f.write(json.dumps(e, ensure_ascii=False) + "\n")
    status = ingest_event(ledger, e)
    save(args.target, ledger)
    # Story 1.9 / #106: manifest the manual run so all_run_ids/compact see it.
    write_manual_manifest(args.target, run)
    # Emit where the event landed so the command can run extraction + dedupe on
    # this run dir immediately and report the delta.
    print(json.dumps({"run": run, "events_file": events_file,
                      "ingest": status, "event": e},
                     ensure_ascii=False, indent=2))


def with_priority(findings):
    """Attach the computed priority so JSON consumers never recompute it."""
    return [{**f, "priority": priority(f)} for f in findings]


def status_filter(value):
    """--status takes one of the four stored statuses, and says so.

    It used to accept anything and return [] with exit 0 — an empty list that
    looks exactly like a real answer, so a typo or a wrong word reads as "no
    such findings" (F99). Reject at parse time instead, naming the enum.

    'compacted'/'tombstoned' get a targeted message: a tombstone is a MODIFIER
    on a stored status (the record keeps accepted|dismissed and carries
    tombstone:true), never a status of its own (issue #62). Anyone reaching
    for it has read `status` and is looking for the wrong door.
    """
    if value in STATUSES:
        return value
    hint = ""
    if value in ("compacted", "tombstoned"):
        hint = (" — a tombstone is a modifier on a stored status, not a "
                "status: a compacted finding keeps accepted|dismissed and "
                "carries tombstone:true. `status` reports the count alongside "
                "its status")
    raise argparse.ArgumentTypeError(
        f"--status must be one of {'|'.join(STATUSES)}, got {value!r}{hint}")


def cmd_findings(args, ledger):
    # --status is validated at parse time by status_filter(): unknown values
    # exit 2 naming the enum, and 'compacted' is rejected with an explanation
    # (arbitration 2026-07-17 / #88). A tombstone is a MODIFIER on a stored
    # status, so a tombstoned finding still answers to `--status accepted` —
    # excluding it here would silently change what that filter means.
    rows = ledger["findings"]
    if args.status:
        rows = [f for f in rows if f["status"] == args.status]
    print(json.dumps(with_priority(rows), indent=2, ensure_ascii=False))


def cmd_upsert(args, ledger):
    evidence = [e.strip() for e in args.evidence.split(",") if e.strip()]
    # Validate the pointer shape up front: a malformed pointer used to parse
    # into a garbage scenario/last_seen_run silently (F133). Reject it with the
    # convention spelled out — including the reserved 'ingest' pseudo-scenario
    # for a manual ingest that had no driven scenario (F134).
    bad = [e for e in evidence if not EVIDENCE_RE.match(e)]
    if not evidence or bad:
        detail = f"malformed pointer(s) {bad}" if bad else "no evidence pointers"
        print(f"error: {detail}; each --evidence must be '<run>/<scenario>#<seq>' "
              f"(for a manual ingest with no driven scenario, use the reserved "
              f"'ingest' scenario, e.g. '<run>/ingest#<seq>')", file=sys.stderr)
        sys.exit(2)
    scenarios = sorted({e.split("#")[0].split("/")[-1] for e in evidence})
    if args.match:
        for f in ledger["findings"]:
            if f["id"] == args.match:
                before = f["recurrence"]
                f["recurrence"] += 1
                # Capped evidence: bounded exemplars, chronology preserved
                # (existing pointers first, new appended), never one per bump.
                f["evidence"] = cap_evidence(f["evidence"] + evidence)
                f["scenarios"] = sorted(set(f["scenarios"] + scenarios))
                f["last_seen"] = date.today().isoformat()
                f["last_seen_run"] = latest_run(evidence, f.get("last_seen_run"))
                if args.note:
                    f.setdefault("notes", []).append(args.note)
                save(args.target, ledger)
                # before->after so the Miner can report the run delta without
                # a separate pre-mine snapshot (spec §2).
                print(f"bumped {f['id']}: recurrence={before}->{f['recurrence']}, "
                      f"scenarios={len(f['scenarios'])}")
                return
        print(f"error: no finding {args.match}", file=sys.stderr)
        sys.exit(2)
    if args.kind not in KINDS:
        print(f"error: kind must be one of {KINDS}", file=sys.stderr)
        sys.exit(2)
    fid = f"F{max((int(f['id'][1:]) for f in ledger['findings']), default=0) + 1}"
    today = date.today().isoformat()
    finding = {"id": fid, "title": args.title, "kind": args.kind,
               "first_seen": today, "last_seen": today, "recurrence": 1,
               "evidence": cap_evidence(evidence), "scenarios": scenarios,
               "status": "open", "last_seen_run": latest_run(evidence)}
    if args.note:
        finding["notes"] = [args.note]
    ledger["findings"].append(finding)
    save(args.target, ledger)
    # F22: a multi-pointer creation still starts at recurrence:1 (recurrence
    # counts upsert calls, not evidence pointers — F72). Say so at the exact
    # moment the mismatch is visible, instead of leaving it to --help.
    tail = ""
    if len(evidence) > 1:
        tail = (f" ({len(evidence)} evidence pointers, recurrence:1 — "
                f"recurrence counts upsert calls, not pointers; "
                f"bump with --match {fid})")
    print(f"created {fid}: {args.title}{tail}")


def cmd_promote(args, ledger):
    """Promote findings that clear the bar. Chronic = recurrence >=
    min-recurrence; breadth = seen in >= min-scenarios distinct scenarios.
    Qualifying `open` findings transition to `proposed` (the contract's
    "Ledger status of promoted findings moves to `proposed`" — F23); findings
    already proposed/accepted/dismissed are never touched. --dry-run is the
    read-only preview: same listing, no write."""
    cfg = load_config()
    min_rec = (args.min_recurrence if args.min_recurrence is not None
               else cfg["min_recurrence"])
    min_scen = (args.min_scenarios if args.min_scenarios is not None
                else cfg["min_scenarios"])
    out = [f for f in ledger["findings"] if f["status"] == "open" and
           (f["recurrence"] >= min_rec or
            len(f["scenarios"]) >= min_scen)]
    out.sort(key=lambda f: (-f["recurrence"], -len(f["scenarios"])))
    # Name the applied thresholds on EVERY result (issue #49), not only the
    # empty one (F68) — each output is self-describing regardless of whether
    # the values came from flags or config.
    bar = f"recurrence >= {min_rec} OR scenarios >= {min_scen}"
    if not out:
        # "Widen it" alone does not explain WHY nothing qualified. The bar is
        # deliberately a chronic-only filter, so a freshly-extracted finding
        # (recurrence 1, one scenario) is unpromotable BY DESIGN — following
        # the documented ingest -> upsert -> promote lifecycle literally always
        # hits this wall, and it reads as a broken tool rather than a working
        # filter (F92). Say what the bar is for, and name the nearest miss.
        opens = [f for f in ledger["findings"] if f["status"] == "open"]
        near = max(opens, key=lambda f: (f["recurrence"], len(f["scenarios"])),
                   default=None)
        why = ("there are no open findings at all" if not opens else
               "the bar promotes CHRONIC findings only — a finding seen once "
               "(recurrence 1, one scenario) is not promotable by design; it "
               "qualifies once it recurs or turns up in a second scenario. "
               "Closest open finding: %s at recurrence %d / %d scenario(s)"
               % (near["id"], near["recurrence"], len(near["scenarios"])))
        print(f"note: no open finding met the promotion bar ({bar}) — {why}. "
              f"To promote anyway (e.g. walking the lifecycle end-to-end on a "
              f"single finding), widen with --min-recurrence 1 --min-scenarios 1",
              file=sys.stderr)
    elif args.dry_run:
        print(f"dry-run ({bar}): {len(out)} finding(s) would move to proposed "
              f"({', '.join(f['id'] for f in out)}); ledger unchanged",
              file=sys.stderr)
    else:
        for f in out:
            f["status"] = "proposed"
        save(args.target, ledger)
        print(f"promoted -> proposed ({bar}): "
              f"{', '.join(f['id'] for f in out)}", file=sys.stderr)
    print(json.dumps(with_priority(out), indent=2, ensure_ascii=False))


# Canonical lifecycle (docs/tanuki-spec.md, "Finding lifecycle"). The arrow
# path is the canonical OPERATOR path, not a tool-enforced state machine:
# set-status records any of the four states and sequencing belongs to the
# command layer (the decision pass promotes before it asks). The tool's job is
# to make a skip visible, never to block it — warn-only, spec decision
# 2026-07-17.
CANONICAL_TRANSITIONS = {("open", "proposed"), ("proposed", "accepted"),
                         ("proposed", "dismissed")}
CANONICAL_PATH = "open -> proposed -> accepted/dismissed"


def lifecycle_notice(before, after):
    """One line naming a non-canonical transition, or None when canonical.

    Never a rejection: the two direct transitions the spec names as expected
    (open -> accepted for a watching-list accept; accepted -> open for a
    regression re-open) are legitimate, so a notice tells a deliberate
    shortcut from a sequencing mistake without blocking either.
    """
    if (before, after) in CANONICAL_TRANSITIONS:
        return None
    if before == after:
        return f"note: {before} -> {after} is a no-op (already {after})"
    if after == "open":
        return (f"note: {before} -> open re-opens a decided finding — "
                f"expected when a verified-fixed finding recurs; canonical "
                f"path is {CANONICAL_PATH}")
    if before == "open":
        # open -> accepted / dismissed: the skipped state is 'proposed'.
        why = ("expected for a watching-list accept" if after == "accepted"
               else "skipping the brief")
        return (f"note: open -> {after} skips proposed — {why}; canonical "
                f"path is {CANONICAL_PATH}")
    # accepted <-> dismissed: reversing a decision already taken.
    return (f"note: {before} -> {after} reverses a decision already recorded; "
            f"canonical path is {CANONICAL_PATH}")


def cmd_set_status(args, ledger):
    if args.status not in STATUSES:
        print(f"error: status must be one of {STATUSES}", file=sys.stderr)
        sys.exit(2)
    for f in ledger["findings"]:
        if f["id"] == args.id:
            before = f.get("status")
            f["status"] = args.status
            save(args.target, ledger)
            # Notice on stderr so stdout stays the unchanged contract.
            notice = lifecycle_notice(before, args.status)
            if notice:
                print(notice, file=sys.stderr)
            print(f"{f['id']} -> {args.status}")
            return
    print(f"error: no finding {args.id}", file=sys.stderr)
    sys.exit(2)


# --- consolidate: deterministic pre-clustering (specs/spec-tanuki-solve D2) --

# Function words only — tokens like "not"/"never" carry meaning in titles and
# are kept; this list is deliberately small and fixed (determinism over IQ).
_STOPWORDS = {"a", "an", "the", "to", "of", "in", "on", "is", "are", "was",
              "it", "its", "as", "at", "by", "or", "and", "for", "with",
              "that", "this", "than", "then", "into", "from", "be", "been"}

# A subject token shared by this many candidate findings (or more) says
# nothing about relatedness within the set and is dropped as generic.
_GENERIC_SUBJECT_AT = 3


def _words(text):
    return [t for t in re.split(r"[^a-z0-9]+", text.lower()) if t]


def _subject_tokens(title):
    """Precise identifiers a title is ABOUT: backtick spans, --flags, dotted
    names (os.path.join), tanuki-* tool names. Sharing one of these is a far
    stronger relatedness signal than prose-word overlap."""
    subs = set()
    for span in re.findall(r"`([^`]+)`", title):
        subs.update(_words(span))
    subs.update(t.lstrip("-") for t in re.findall(r"--[\w][\w-]*", title))
    for dotted in re.findall(r"\b\w+(?:\.\w+)+\b", title.lower()):
        subs.add(dotted)
        subs.update(dotted.split("."))
    subs.update(re.findall(r"\btanuki-[\w-]+\b", title.lower()))
    return {s for s in subs if len(s) >= 2 and s not in _STOPWORDS}


def _content_tokens(title):
    return {t for t in _words(title) if len(t) >= 3 and t not in _STOPWORDS}


def _notes_text(finding):
    """A finding's notes[] joined for tokenizing. notes often carry the
    proposal nuance that relates or distinguishes two findings, so titles
    alone under-cluster (spec-tanuki-solve D2)."""
    return " ".join(finding.get("notes", []) or [])


def _run_ids(finding):
    """Run ids a finding was seen in, from its evidence pointers. Evidence is
    capped (bounded exemplars), so this is a bounded set by construction."""
    return {r for r in (run_of(e) for e in finding.get("evidence", [])) if r}


def _jaccard(a, b):
    return len(a & b) / len(a | b) if a or b else 0.0


def cmd_consolidate(args, ledger):
    """Read-only candidate grouping over the decision pass's input set.
    Emits groups + the mechanical reason each pair fired; merge / conflict /
    dependency classification is judgment and stays with the command layer
    (spec-tanuki-solve D2: the tool proposes, never decides). Writes nothing."""
    statuses = [s.strip() for s in args.status.split(",") if s.strip()]
    bad = [s for s in statuses if s not in STATUSES]
    if bad:
        print(f"error: status must be one of {STATUSES}, got {bad}",
              file=sys.stderr)
        sys.exit(2)
    cands = [f for f in ledger["findings"]
             if f["status"] in statuses and not f.get("tombstone")]

    subj = {f["id"]: _subject_tokens(f["title"] + " " + _notes_text(f))
            for f in cands}
    cont = {f["id"]: _content_tokens(f["title"]) for f in cands}
    # Title + notes: notes carry the nuance that relates findings whose
    # titles diverge (spec-tanuki-solve D2).
    full = {f["id"]: cont[f["id"]] | _content_tokens(_notes_text(f))
            for f in cands}
    scen = {f["id"]: set(f.get("scenarios", [])) for f in cands}
    runs = {f["id"]: _run_ids(f) for f in cands}

    # Drop subject tokens generic within THIS candidate set (e.g. the tool's
    # own name appearing in half the titles) — deterministic and self-scaling.
    freq = {}
    for toks in subj.values():
        for t in toks:
            freq[t] = freq.get(t, 0) + 1
    generic = {t for t, n in freq.items() if n >= _GENERIC_SUBJECT_AT}
    subj = {fid: toks - generic for fid, toks in subj.items()}

    min_sim = args.min_similarity
    edges = {}  # (idA, idB) -> [signal, ...]
    ids = [f["id"] for f in cands]
    for i, a in enumerate(ids):
        for b in ids[i + 1:]:
            sim = _jaccard(cont[a], cont[b])
            sim_full = _jaccard(full[a], full[b])
            shared_subj = subj[a] & subj[b]
            shared_scen = scen[a] & scen[b]
            shared_runs = runs[a] & runs[b]
            signals = []
            # Edge rules (fixed, documented in --help): strong title
            # similarity alone; or strong title+notes similarity alone (notes
            # carry the nuance a diverging title hides); or a shared precise
            # subject corroborated by weak title similarity, a shared
            # scenario, or a shared run. Scenario overlap and run overlap
            # NEVER group alone — one scenario, and one run, legitimately
            # yield many unrelated findings; they only corroborate.
            if sim >= min_sim:
                signals.append(
                    f"title-similarity {sim:.2f} "
                    f"(shared: {', '.join(sorted(cont[a] & cont[b]))})")
            elif sim_full >= min_sim:
                notes_only = sorted((full[a] & full[b]) - (cont[a] & cont[b]))
                signals.append(
                    f"notes-text similarity {sim_full:.2f} "
                    f"(shared via notes: {', '.join(notes_only)})")
            if shared_subj and (sim_full >= min_sim / 3 or shared_scen
                                or shared_runs):
                signals.append(
                    f"subject-overlap: {', '.join(sorted(shared_subj))}")
                if shared_scen:
                    signals.append(
                        f"scenario-overlap: {', '.join(sorted(shared_scen))}")
                if shared_runs:
                    signals.append(
                        f"run-overlap: {', '.join(sorted(shared_runs))}")
            if signals:
                edges[(a, b)] = signals

    # Union-find over fired edges -> candidate groups of >= 2.
    parent = {fid: fid for fid in ids}

    def find(x):
        while parent[x] != x:
            parent[x] = parent[parent[x]]
            x = parent[x]
        return x

    for a, b in edges:
        parent[find(a)] = find(b)
    groups = {}
    for fid in ids:
        groups.setdefault(find(fid), []).append(fid)

    by_id = {f["id"]: f for f in cands}
    out = []
    for members in groups.values():
        if len(members) < 2:
            continue
        members.sort(key=lambda i: int(i[1:]))
        pair_signals = []
        for (a, b), sigs in sorted(edges.items()):
            if a in members and b in members:
                pair_signals.append(
                    {"pair": [a, b], "signals": sigs})
        out.append({
            "ids": members,
            "members": [{"id": i, "title": by_id[i]["title"],
                         "kind": by_id[i]["kind"],
                         "status": by_id[i]["status"],
                         "priority": priority(by_id[i])} for i in members],
            "pairs": pair_signals,
        })
    out.sort(key=lambda g: (-len(g["ids"]), int(g["ids"][0][1:])))

    note_generic = (f"; dropped generic subject token(s): "
                    f"{', '.join(sorted(generic))}" if generic else "")
    print(f"{len(out)} candidate group(s) across {len(cands)} finding(s) "
          f"considered (statuses: {', '.join(statuses)}){note_generic}; "
          f"grouping is mechanical — merge/conflict/dependency classification "
          f"stays with the decision pass", file=sys.stderr)
    print(json.dumps({"considered": len(cands), "statuses": statuses,
                      "min_similarity": min_sim, "candidates": out},
                     indent=2, ensure_ascii=False))


def write_manual_manifest(target, run):
    """Ensure a hand-ingested run has a run manifest (story 1.9 / #106).

    `all_run_ids` and `driven_scenarios_by_run` read `events/<run>/` and its
    `manifest.json`; a plain `ingest` used to write neither, so hand-ingested
    runs were invisible and `compact`'s verify-by-absence could never advance —
    the elapsed-run fallback the spec promises ("a finding with no recorded
    scenarios falls back to elapsed-run counting", spec-tanuki-scenario-lifecycle
    "Driven-absence compaction") was unreachable. A manual run drives no
    scenarios, so `results` is empty: it advances only the elapsed-run fallback
    for ingest/no-scenario findings, never false driven-absence for a real
    scenario. Idempotent and non-destructive — an existing (driven) manifest is
    never overwritten."""
    run_dir = os.path.join(TANUKI_ROOT, target, "events", run)
    mpath = os.path.join(run_dir, "manifest.json")
    if os.path.exists(mpath):
        return
    os.makedirs(run_dir, exist_ok=True)
    manifest = {"run": run, "target": target,
                "completed_at": date.today().isoformat(),
                "source": "manual-ingest", "results": []}
    with open(mpath, "w", encoding="utf-8") as f:
        json.dump(manifest, f, indent=2)


def all_run_ids(target):
    """Every run id under events/, sorted chronologically (by run_key —
    manual-<date> ingest runs interleave with dated driven runs)."""
    events_dir = os.path.join(TANUKI_ROOT, target, "events")
    if not os.path.isdir(events_dir):
        return []
    return sorted((d for d in os.listdir(events_dir)
                   if os.path.isdir(os.path.join(events_dir, d))),
                  key=run_key)


def driven_scenarios_by_run(target):
    """{run: set(scenario ids actually driven that run)} from run manifests —
    the record of which scenarios had the chance to reproduce a finding.
    Verify-by-absence (compaction) counts a run only if a finding's scenario
    was driven in it, so absence means 'replayed and gone', not merely
    'time elapsed' (spec-tanuki-scenario-lifecycle, Verify / cap interaction)."""
    events_dir = os.path.join(TANUKI_ROOT, target, "events")
    out = {}
    if not os.path.isdir(events_dir):
        return out
    for run in os.listdir(events_dir):
        mpath = os.path.join(events_dir, run, "manifest.json")
        try:
            with open(mpath, encoding="utf-8") as fh:
                manifest = json.load(fh)
        except (json.JSONDecodeError, OSError):
            continue
        out[run] = {r.get("scenario") for r in manifest.get("results", [])
                    if r.get("scenario")}
    return out


def cmd_compact(args, ledger):
    """Compaction of the dead tail (invariant 3). A finding that is `dismissed`,
    or `accepted` and unseen for >= N *driven-and-absent* runs (its fix verified
    by replay — see verified_absent_runs, not mere elapsed time),
    collapses to a one-line tombstone — id, kind, title, resolution, count —
    kept so dedupe never lets it resurface as new, but stripped of per-run
    evidence/scenarios/notes (those live in raw.jsonl). Idempotent: an existing
    tombstone is skipped."""
    cfg = load_config()
    n = (args.unseen_runs if args.unseen_runs is not None
         else cfg["compaction_unseen_runs"])
    runs = all_run_ids(args.target)
    driven = driven_scenarios_by_run(args.target)

    def runs_since(last_run):
        # Runs recorded after the finding was last seen. A missing last_seen_run
        # is legacy data with no tracking — treat the whole history as elapsed.
        # Chronological comparison via run_key: a driven run the day after a
        # manual-<date> ingest must count as elapsed absence.
        if not last_run:
            return len(runs)
        return sum(1 for r in runs if run_key(r) > run_key(last_run))

    def verified_absent_runs(f):
        # Verify-by-absence for an ACCEPTED finding: a run counts only if one of
        # the finding's scenarios was actually DRIVEN in it (and the finding did
        # not recur — else last_seen_run would advance past it). "Unseen for N
        # runs" thus means "replayed N times and gone", never "N runs elapsed"
        # (spec-tanuki-scenario-lifecycle, Verify / cap interaction) — so a
        # verify replay the cap deferred, or a scenario dropped from the matrix,
        # can no longer manufacture a false "fixed". A finding with no
        # *replayable* scenario — none, or only the reserved `ingest` manual
        # pseudo-scenario (never driven) — has no replay signal: fall back to
        # elapsed runs (legacy; manual-reported findings still verify by time).
        # A real scenario merely absent from recent manifests keeps `scen`
        # non-empty, so it does NOT fall back — it just accrues no absence.
        scen = set(f.get("scenarios", [])) - {"ingest"}
        if not scen:
            return runs_since(f.get("last_seen_run"))
        last = f.get("last_seen_run")
        return sum(1 for r in runs
                   if (not last or run_key(r) > run_key(last))
                   and (scen & driven.get(r, set())))

    compacted = []
    for i, f in enumerate(ledger["findings"]):
        if f.get("tombstone"):
            continue
        status = f.get("status")
        if status == "dismissed":
            resolution = "dismissed"
        elif status == "accepted" and verified_absent_runs(f) >= n:
            resolution = "fixed"  # accepted + replayed-and-gone = fix verified
        else:
            continue
        if status == "dismissed" and runs_since(f.get("last_seen_run")) < n:
            continue  # freshly dismissed: keep detail until it's truly quiet
        ledger["findings"][i] = {
            "id": f["id"], "title": f["title"][:80], "kind": f["kind"],
            "status": status, "recurrence": f.get("recurrence", 1),
            "scenarios": [], "evidence": [],
            "resolution": resolution, "tombstone": True,
            # Empty scenarios/evidence is the POINT of a tombstone (the ledger
            # growth policy's bounded frontier), but a reader seeing the arrays
            # cleared assumes data loss (F85). Say it in the record itself.
            "tombstone_note": ("compacted to a one-line tombstone: evidence "
                               "and scenarios are intentionally dropped to "
                               "bound ledger growth — the id/title/resolution "
                               "are kept so this finding can never resurface "
                               "as new. Original detail remains in the run's "
                               "events under ~/.tanuki/<target>/events/."),
        }
        compacted.append((f["id"], resolution))

    save(args.target, ledger)
    if compacted:
        for fid, res in compacted:
            print(f"tombstoned {fid} ({res})")
        print(f"compacted {len(compacted)} finding(s) unseen for >= {n} run(s); "
              f"each collapsed to a one-line tombstone — evidence/scenarios "
              f"intentionally dropped (bounded growth), id/title/resolution "
              f"kept so they never resurface")
    else:
        # Story 1.9 / #106: manual ingests now write a run manifest, so a
        # hand-ingested ledger DOES advance the unseen counter — the message no
        # longer claims it never can. A finding is simply not yet unseen for the
        # threshold: its scenario must have been driven-and-absent (real
        # scenarios) or the run count must elapse (ingest/no-scenario findings).
        # One generic message used to fire for three distinct causes and forced
        # the reader into the source to tell which (F135): name the per-finding
        # cause so the caller sees exactly how far each candidate is from the bar.
        reasons = []
        for f in ledger["findings"]:
            if f.get("tombstone"):
                continue
            status = f.get("status")
            if status == "accepted":
                k = verified_absent_runs(f)
                if k >= n:
                    continue  # (would have compacted; handled above)
                scen = set(f.get("scenarios", [])) - {"ingest"}
                if scen:
                    tail = (f"{k}/{n} driven-and-absent run(s) — {n - k} more "
                            f"re-drive(s) of its scenario to verify the fix "
                            f"(hand-ingest will not advance this)")
                else:
                    tail = (f"{k}/{n} later run(s) elapsed (ingest/no-scenario) "
                            f"— {n - k} more, driven or manual")
                reasons.append(f"  {f['id']}: accepted, {tail}")
            elif status == "dismissed":
                k = runs_since(f.get("last_seen_run"))
                if k >= n:
                    continue
                reasons.append(f"  {f['id']}: dismissed, {k}/{n} run(s) elapsed "
                               f"— detail kept until it is truly quiet")
        head = (f"nothing to compact (threshold: unseen for >= {n} run(s)); an "
                f"accepted finding tombstones once its scenario was driven-and-"
                f"absent that many times, or — for ingest/no-scenario findings — "
                f"once that many later runs (driven or manual) have elapsed")
        if reasons:
            print(head + "\ncandidates below the threshold:")
            for line in reasons:
                print(line)
        else:
            print(head + "\nno accepted or dismissed findings are awaiting "
                  "compaction (nothing has been resolved yet)")


def cmd_scenario_yield(args, ledger):
    """Per-scenario yield, deterministically, for the adaptive scheduler
    (specs/spec-tanuki-scenario-lifecycle): for each scenario, its driven runs
    (from run manifests — the complete record) and, per run, the findings
    attributable to it via ledger evidence pointers plus the run's event
    count. 'Actionable' = findings touched (new or bumped) in that run.
    Caveat: capped evidence keeps the oldest + most recent pointers, so very
    old middle occurrences may under-count — recent runs (what the scheduler
    reads, --runs N, default 5) are attributed accurately."""
    events_dir = os.path.join(TANUKI_ROOT, args.target, "events")
    # (run, scenario) -> finding ids, from evidence "run/scenario#seq".
    touched = {}
    for f in ledger["findings"]:
        for ptr in f.get("evidence", []):
            run = ptr.split("/", 1)[0]
            scen = ptr.split("#")[0].split("/")[-1]
            touched.setdefault((run, scen), set()).add(f["id"])
    out = {}
    runs = sorted(os.listdir(events_dir)) if os.path.isdir(events_dir) else []
    for run in runs:
        mpath = os.path.join(events_dir, run, "manifest.json")
        if not os.path.isfile(mpath):
            continue
        try:
            with open(mpath, encoding="utf-8") as fh:
                manifest = json.load(fh)
        except (json.JSONDecodeError, OSError):
            continue
        for r in manifest.get("results", []):
            scen = r.get("scenario")
            if not scen:
                continue
            fids = sorted(touched.get((run, scen), ()))
            out.setdefault(scen, []).append({
                "run": run, "events": r.get("events", 0),
                "findings": fids, "actionable": len(fids)})
    print(json.dumps({scen: hist[-args.runs:] for scen, hist in out.items()},
                     indent=2))


# The closed enumeration of ledger states (story 4.3 — F24/F36/F76). The
# next-step hint was fixed twice and regressed twice as patched string logic;
# it is now derived: classify_ledger() maps a ledger to exactly one of these
# states, render_next() maps each state to exactly one next command, and
# tools/tests/test-ledger-next pins one fixture per state. A state outside
# the enumeration fails loudly instead of falling through to a wrong hint.
LEDGER_STATES = (
    "fresh",               # no events, no findings — nothing ingested yet
    "events-no-findings",  # runs ingested, nothing extracted yet
    "proposed-awaiting",   # proposals await the human gate
    "accepted-awaiting",   # accepted findings await fix verification
    "watching-only",       # only open (below-bar) findings remain
    "all-decided",         # findings exist; every one decided/tombstoned
)


def known_runs(target, ledger):
    """All run ids for a target: events/<run>/ dirs unioned with the run ids
    carried by the ledger's own event records — a plain `ingest` records
    events without creating a run directory (F21), so neither source alone
    is complete."""
    events_dir = os.path.join(TANUKI_ROOT, target, "events")
    dir_runs = set(os.listdir(events_dir)) if os.path.isdir(events_dir) else set()
    ingested_runs = {r for e in ledger["events"].values()
                     for r in e.get("runs", []) if r}
    return sorted(dir_runs | ingested_runs, key=run_key)


def classify_ledger(ledger, runs):
    """Map a ledger to exactly one LEDGER_STATES member. Decision-bearing
    states win over passive ones: proposed > accepted-awaiting > watching."""
    by = {s: [f for f in ledger["findings"] if f["status"] == s]
          for s in STATUSES}
    # Tombstoned accepted findings are verified-fixed — not awaiting (F76).
    awaiting = [f for f in by["accepted"] if not f.get("tombstone")]
    if by["proposed"]:
        return "proposed-awaiting"
    if awaiting:
        return "accepted-awaiting"
    if by["open"]:
        return "watching-only"
    if ledger["findings"]:
        return "all-decided"
    if runs:
        return "events-no-findings"
    return "fresh"


def render_next(state, target, ledger):
    """The single next command for an enumerated state — a /tanuki form where
    one exists, the tool form otherwise. Raises on a state outside the
    enumeration rather than guessing (the F24/F36/F76 regression mode was a
    fall-through to advice for a state you were not in)."""
    by = {s: [f for f in ledger["findings"] if f["status"] == s]
          for s in STATUSES}
    awaiting = [f for f in by["accepted"] if not f.get("tombstone")]
    hints = {
        "fresh": "ingest a run's events to start surfacing findings",
        "events-no-findings": (
            "events are ingested but no findings yet — extract one with "
            "upsert-finding --title … --evidence <run>/<scenario>#<seq>"),
        # `/tanuki …` is the PLUGIN's slash command, driven from Claude Code —
        # not something this CLI implements, and not runnable from the shell
        # you are reading this in (F84). Name the CLI equivalent first, then
        # the slash command, and say which is which.
        "proposed-awaiting": (
            f"decide the {len(by['proposed'])} proposed item(s): "
            f"`findings --status proposed` to read them, then `set-status "
            f"--id <F> --status accepted|dismissed` for each "
            f"(or the /tanuki {target} decide slash command in Claude Code "
            f"for the guided pass)"),
        # tanuki-drive is a SIBLING tool next to this one, not a subcommand —
        # naming it bare just moved the dead end (F90): the operator went
        # looking for it in `tanuki-ledger --help` and did not find it. Say
        # where it lives.
        "accepted-awaiting": (
            f"re-run the pipeline to verify the {len(awaiting)} accepted "
            f"item(s) stop recurring: `tanuki-drive` (a sibling tool beside "
            f"this one in the plugin's tools/ dir, not a subcommand of it) "
            f"then `ingest` its events here "
            f"(or the /tanuki {target} slash command in Claude Code, which "
            f"drives both)"),
        "watching-only": (
            "promote chronic/high-confidence open findings with "
            "'promote --min-recurrence N', then decide them with the "
            f"/tanuki {target} decide slash command in Claude Code "
            "(not a tanuki-ledger subcommand)"),
        "all-decided": (
            # "compacted" is NOT a status — a tombstoned finding is still
            # accepted or dismissed (issue #62 / F25; the F99 regression was
            # naming it here as a peer, which `findings --status compacted`
            # then rejects).
            "all findings are decided (accepted/dismissed, some tombstoned) — "
            f"re-run the pipeline (`tanuki-drive`, the sibling tool beside "
            f"this one, then `ingest` here; or the /tanuki {target} slash "
            f"command in Claude Code) to surface any new ones"),
    }
    if state not in hints:
        raise ValueError(f"unenumerated ledger state: {state!r} "
                         f"(known: {LEDGER_STATES})")
    return hints[state]


def next_step(target, ledger):
    """Derivation used by both `status` (trailing line) and `next` — one
    derivation, two surfaces."""
    return render_next(classify_ledger(ledger, known_runs(target, ledger)),
                       target, ledger)


def cmd_next(args, ledger):
    print(next_step(args.target, ledger))


def cmd_status(args, ledger):
    """Human-readable state of a target: what awaits a decision, what's being
    watched, what happened last. The answer to 'where was I?'."""
    tdir = os.path.join(TANUKI_ROOT, args.target)
    runs = known_runs(args.target, ledger)
    briefs_dir = os.path.join(tdir, "briefs")
    briefs = sorted(os.listdir(briefs_dir)) if os.path.isdir(briefs_dir) else []

    by = {s: [f for f in ledger["findings"] if f["status"] == s]
          for s in STATUSES}

    # Tombstone is a MODIFIER on a stored status, never a status of its own
    # (F25 / issue #62). A compacted finding keeps status accepted|dismissed
    # plus tombstone:true, so labelling a "compacted" bucket here would teach
    # a vocabulary `findings --status` rejects — the F99 regression. Report
    # the marker alongside the real status instead.
    def tomb(items):
        return sum(1 for f in items if f.get("tombstone"))

    counts = " / ".join(
        f"{s} {len(by[s])}" + (f" ({tomb(by[s])} tombstoned)" if tomb(by[s])
                               else "")
        for s in STATUSES)
    total_tomb = tomb(ledger["findings"])
    print(f"tanuki status — {args.target}")
    print(f"  runs: {len(runs)}" + (f" (latest: {runs[-1]})" if runs else ""))
    print(f"  latest brief: {os.path.join(briefs_dir, briefs[-1])}"
          if briefs else
          "  latest brief: none (a brief is the consolidated findings "
          "report `consolidate` writes; none has been produced yet)")
    print(f"  findings: {len(ledger['findings'])} ({counts})")
    if total_tomb:
        print(f"  tombstoned: {total_tomb} — compacted to one-line records "
              f"(terminal: verified-fixed or dismissed); they keep their "
              f"status for dedupe and are not awaiting anything")

    if by["proposed"]:
        print("\n  AWAITING YOUR DECISION (proposed — accept or dismiss):")
        for f in sorted(by["proposed"], key=lambda f: (-f["recurrence"],
                                                       -len(f["scenarios"]))):
            print(f"    {priority(f)} {f['id']} [{f['kind']}] "
                  f"rec:{f['recurrence']} scen:{len(f['scenarios'])} — "
                  f"{f['title'][:90]}")
    # Tombstoned accepted findings are already verified-fixed — not awaiting.
    awaiting = [f for f in by["accepted"] if not f.get("tombstone")]
    if awaiting:
        print("\n  ACCEPTED — awaiting fix verification (should stop recurring):")
        for f in awaiting:
            print(f"    {f['id']} rec:{f['recurrence']} — {f['title'][:90]}")
    watching = sorted(by["open"], key=lambda f: (-f["recurrence"],
                                                 -len(f["scenarios"])))
    if watching:
        print(f"\n  WATCHING (open, top {min(5, len(watching))} of "
              f"{len(watching)}):")
        for f in watching[:5]:
            # scen: renders here as well as in AWAITING (F110): the priority
            # badge is derived from recurrence AND scenario count, so omitting
            # scen: leaves the badge unexplained by the line that carries it.
            print(f"    {priority(f)} {f['id']} [{f['kind']}] "
                  f"rec:{f['recurrence']} scen:{len(f['scenarios'])} — "
                  f"{f['title'][:90]}")
    # Derived, never patched string logic (F24/F36/F76): the same closed-
    # enumeration derivation the `next` subcommand exposes alone.
    print(f"\n  next: {next_step(args.target, ledger)}")


# specs/spec-policy-advisory: the read allowlist is capped and code-enforced.
POLICY_FILES_CAP = 4


def load_policy_source(target):
    """The optional policy_source block, normal precedence: ~/.tanuki/config.json
    < the target scenarios file's "defaults" block. None when unset — the
    feature then does not exist (zero behavior change anywhere)."""
    block = None
    path = os.path.join(TANUKI_ROOT, "config.json")
    if os.path.exists(path):
        with open(path, encoding="utf-8") as f:
            block = json.load(f).get("policy_source", block)
    spath = os.path.join(TANUKI_ROOT, "scenarios", f"{target}.scenarios.json")
    if os.path.exists(spath):
        with open(spath, encoding="utf-8") as f:
            block = json.load(f).get("defaults", {}).get("policy_source", block)
    return block


def cmd_policy_surface(args, ledger):
    """Bounded, pinned, read-only policy reader (specs/spec-policy-advisory §2).
    Reads ONLY the configured `files` allowlist under policy_source.path, pins
    the checkout (`git rev-parse HEAD`), and emits numbered lines to stdout so
    the consolidate/decide pass can quote file:line@commit. Stdout only: a
    judgment-time input for the brief and the human gate — nothing here reads
    or writes the ledger, events, or scheduler state, and this subcommand is
    never invoked at ingest, drive, or extraction. Degradation (enhancer,
    never a dependency): unset -> {"configured": false}; path unusable -> one
    stderr line + {"available": false}. A malformed block is a configuration
    error and fails loud."""
    block = load_policy_source(args.target)
    if block is None:
        print(json.dumps({"configured": False}))
        return
    if not isinstance(block, dict) or not isinstance(block.get("path"), str):
        print("error: policy_source must be an object with a string 'path' and "
              "a 'files' list — see specs/spec-policy-advisory", file=sys.stderr)
        sys.exit(2)
    files = block.get("files")
    if (not isinstance(files, list) or not files
            or len(files) > POLICY_FILES_CAP
            or not all(isinstance(x, str) for x in files)):
        print(f"error: policy_source.files must be a non-empty list of at most "
              f"{POLICY_FILES_CAP} repo-relative markdown paths", file=sys.stderr)
        sys.exit(2)
    for rel in files:
        if os.path.isabs(rel) or ".." in rel.split("/") or not rel.endswith(".md"):
            print(f"error: policy_source.files entry {rel!r} must be a "
                  "repo-relative .md path (no absolute paths, no '..')",
                  file=sys.stderr)
            sys.exit(2)
    root = os.path.realpath(os.path.expanduser(block["path"]))
    try:
        sha = subprocess.run(
            ["git", "-C", root, "rev-parse", "--short=12", "HEAD"],
            capture_output=True, text=True, check=True).stdout.strip()
    except (subprocess.CalledProcessError, OSError):
        print(f"policy_source unavailable: {block['path']} is missing or not a "
              "git checkout — advisory off for this run", file=sys.stderr)
        print(json.dumps({"configured": True, "available": False}))
        return
    try:
        emit_policy_lines(root, sha, files)
    except BrokenPipeError:
        # Downstream (e.g. `| head`) closed the pipe — normal, not an error.
        os.dup2(os.open(os.devnull, os.O_WRONLY), sys.stdout.fileno())


def emit_policy_lines(root, sha, files):
    print(f"pin: {os.path.basename(root)}@{sha}")
    for rel in files:
        fpath = os.path.realpath(os.path.join(root, rel))
        # Containment despite symlinks: every allowlist entry must resolve
        # inside the checkout; anything else is refused, not followed.
        if not fpath.startswith(root + os.sep):
            print(f"refused: {rel} resolves outside the policy checkout",
                  file=sys.stderr)
            continue
        if not os.path.isfile(fpath):
            print(f"skipped: {rel} not present in the policy checkout",
                  file=sys.stderr)
            continue
        print(f"== {rel} @{sha} ==")
        with open(fpath, encoding="utf-8") as f:
            for n, line in enumerate(f, 1):
                print(f"{n}: {line.rstrip()}")


def cmd_stats(args, ledger):
    by_status = {}
    # Tombstone is a modifier on a stored status, not a status (F25 / issue
    # #62): a compacted finding still counts under accepted|dismissed, and
    # tombstoned_by_status says how many of each are terminal. No "compacted"
    # key — that would be a vocabulary `findings --status` rejects (F99).
    tombstoned_by_status = {}
    for f in ledger["findings"]:
        by_status[f["status"]] = by_status.get(f["status"], 0) + 1
        if f.get("tombstone"):
            tombstoned_by_status[f["status"]] = \
                tombstoned_by_status.get(f["status"], 0) + 1
    print(json.dumps({
        "events": len(ledger["events"]),
        "event_occurrences": sum(e["count"] for e in ledger["events"].values()),
        "findings": len(ledger["findings"]),
        "by_status": by_status,
        "tombstoned": sum(tombstoned_by_status.values()),
        "tombstoned_by_status": tombstoned_by_status,
        "live": len(ledger["findings"]) - sum(tombstoned_by_status.values()),
    }, indent=2))


def slug_target(value):
    """--target is a namespace slug, never a path (issues #68/#70).

    State lives under $TANUKI_ROOT/<target>/, so a path-like value either
    nests silently (os.path.join swallows an absolute path — the accidental
    "support" #68 reported) or fails deep inside a later git call with a
    low-level error (#70). Both are the same root cause: --target was never
    validated. Reject at parse time so the message names the contract.
    TANUKI_ROOT is the supported way to relocate state.
    """
    if (value and not value.startswith(".")
            and all(c.isalnum() or c in "._-" for c in value)):
        return value
    raise argparse.ArgumentTypeError(
        f"--target must be a simple namespace slug (letters, digits, "
        f"'.', '_', '-'), not a path: {value!r}. State lives under "
        f"$TANUKI_ROOT/<target>/ — set TANUKI_ROOT to relocate it.")


def main():
    # See tanuki-loop's main() — same fix, same reason (F98): the evidence
    # schema, the ledger growth policy and the P1/P2/P3 legend live in the
    # module docstring and never reached --help without this.
    p = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter)
    # --target is a short namespace slug, NOT a filesystem path (F18): state
    # lives under $TANUKI_ROOT/<target>/ (default ~/.tanuki/<target>/), so the
    # current directory is ignored and a path-like value nests silently.
    p.add_argument("--target", required=True, type=slug_target,
                   help="target namespace slug (not a path; path-like values "
                        "are rejected); state lives under "
                        "$TANUKI_ROOT/<target>/ (default ~/.tanuki/<target>/)")
    sub = p.add_subparsers(dest="cmd", required=True)
    sub.add_parser("init")
    sp = sub.add_parser(
        "ingest",
        help="record events from JSONL file(s); exact dupes collapse to a count",
        description=(
            "Record events into the ledger from one or more JSONL files (one "
            "JSON object per line). Each event object: "
            "{run: <run-id>, scenario: <slug>, seq: <int>, type: "
            "tool_error|note|result|..., detail: <str>}. The evidence pointer "
            "for a finding is formed as '<run>/<scenario>#<seq>'. Exact "
            "duplicates collapse to an occurrence count rather than creating "
            "separate records; the identity key is scenario+type+detail ONLY — "
            "run and seq are NOT part of it, so the same detail seen in two "
            "different runs collapses into one record with count=2 (F70)."))
    sp.add_argument("files", nargs="+",
                    help="one or more JSONL files to ingest; any filename "
                         "works — '.events.jsonl' is only the drive "
                         "pipeline's naming convention, not enforced (F150)")
    sp = sub.add_parser("ingest-note"); sp.add_argument("--text", required=True)
    sp = sub.add_parser(
        "findings",
        help="list findings as JSON, each with a computed priority",
        description=(
            f"List findings as JSON. --status filters to one of "
            f"{'|'.join(STATUSES)} and rejects anything else at parse time "
            f"(an unknown value used to yield [] with exit 0 — indis"
            f"tinguishable from a real 'none match'). Tombstoned findings are "
            f"NOT a separate bucket: a compacted record keeps its stored "
            f"status and carries tombstone:true, so --status accepted "
            f"includes them and `status`/`stats` report the tombstoned count "
            f"alongside."))
    sp.add_argument("--status", type=status_filter,
                    help=f"only findings with this stored status "
                         f"({'|'.join(STATUSES)})")
    sp = sub.add_parser(
        "upsert-finding",
        description=(
            "Create a finding (--title) or accumulate onto an existing one "
            "(--match <id>). NOTE: 'recurrence' counts the number of "
            "upsert-finding calls that touched the finding (i.e. how many times "
            "it was observed-and-recorded), NOT the number of --evidence "
            "pointers or underlying event occurrences — a creation with two "
            "--evidence pointers is still recurrence:1 (F72)."))
    sp.add_argument("--title")
    # List the valid enum so it's discoverable from --help, not only from a
    # rejection error (F33). choices= also produces a clear argparse message.
    sp.add_argument("--kind", default="friction", choices=KINDS,
                    help=f"finding kind (default: friction); one of {KINDS}")
    # Show the comma-joined form here too, so multi-evidence is discoverable
    # from `upsert-finding --help` and not only from the top-level usage (F124).
    sp.add_argument("--evidence", required=True,
                    help="one or more run/scenario#seq pointers, comma-joined "
                         "(e.g. runA/scen#1,runB/scen#2); for a manual ingest "
                         "with no driven scenario use the reserved 'ingest' "
                         "scenario, e.g. runA/ingest#1. A malformed pointer is "
                         "rejected, never silently parsed (F133/F134)")
    # --match takes an existing finding id to accumulate onto (bumps recurrence
    # and scenario spread) instead of creating a duplicate (F62); omit it to
    # create a new finding (then --title is required).
    sp.add_argument("--match",
                    help="existing finding id to bump (accumulate recurrence) "
                         "instead of creating a new one; omit to create")
    sp.add_argument("--note")
    cfg = load_config()  # promote's default thresholds, named in --help (F68)
    sp = sub.add_parser(
        "promote",
        help="move open findings meeting the recurrence OR scenario threshold "
             "to `proposed` (--dry-run for a read-only preview)",
        description=(
            "Promote findings that qualify by recurrence or scenario-spread: "
            "the two thresholds are combined with OR, not AND — a finding "
            "qualifies when `recurrence >= --min-recurrence` OR it was seen "
            "in `>= --min-scenarios` distinct scenarios, so clearing either "
            "bar alone is enough. Each qualifying `open` finding's status "
            "moves to `proposed`, awaiting the human gate's accept/dismiss "
            "decision (dispositions still go through `set-status`). Findings "
            "already proposed/accepted/dismissed are never touched. With "
            "--dry-run the same listing is printed and nothing is written. "
            "Defaults: --min-recurrence %(mr)s, --min-scenarios %(ms)s (from "
            "config); the applied bar is always named in the output."
            % {"mr": cfg["min_recurrence"], "ms": cfg["min_scenarios"]}))
    # Keep "(default: N)" early in each help string: argparse wraps this column
    # at ~56 chars, and a trailing default can split across lines mid-token.
    sp.add_argument("--min-recurrence", type=int, default=None,
                    help="chronic threshold (default: %s); OR'd with "
                         "--min-scenarios" % cfg["min_recurrence"])
    sp.add_argument("--min-scenarios", type=int, default=None,
                    help="breadth threshold (default: %s); OR'd with "
                         "--min-recurrence" % cfg["min_scenarios"])
    sp.add_argument("--dry-run", action="store_true",
                    help="preview only: list qualifying findings without "
                         "changing any status")
    sp = sub.add_parser(
        "set-status",
        help="record a finding's decision state (any transition; never "
             "rejected on lifecycle grounds)",
        description=(
            f"Record a finding's status. The canonical operator path is "
            f"{CANONICAL_PATH} — but that is the OPERATOR path, not a "
            f"tool-enforced state machine: sequencing belongs to the command "
            f"layer (the decision pass promotes before it asks). Any "
            f"transition is recorded and a non-canonical one prints a "
            f"one-line notice on stderr naming the skipped state; it is "
            f"NEVER rejected. Two direct transitions are expected and "
            f"legitimate: open -> accepted (accepting a below-bar finding "
            f"straight off the watching list) and accepted -> open "
            f"(re-opening when a verified-fixed finding recurs). See "
            f"docs/tanuki-spec.md, \"Finding lifecycle\"."))
    sp.add_argument("--id", required=True)
    # Enumerate valid statuses in --help (F60), not only via a rejection error;
    # choices= also yields a clear argparse message on a bad value.
    sp.add_argument("--status", required=True, choices=STATUSES,
                    help=f"new status; one of {STATUSES}. Canonical path: "
                         f"{CANONICAL_PATH}; non-canonical transitions are "
                         f"recorded with a notice, never rejected")
    sp = sub.add_parser(
        "consolidate",
        help="read-only: emit candidate groups of related findings (JSON) for "
             "the solve pass's consolidation stage; proposes groups with "
             "mechanical reasons, never decides merge/conflict",
        description=(
            "Pre-cluster the decision pass's candidate findings "
            "(spec-tanuki-solve D2). Deterministic signals only: title-token "
            "Jaccard similarity, title+notes similarity (notes[] carry the "
            "nuance a diverging title hides), shared precise subject tokens "
            "(backtick spans, --flags, dotted names, tanuki-* names, over "
            "title and notes; tokens generic within the candidate set are "
            "dropped), and scenario overlap plus shared run ids (from "
            "evidence pointers) as corroboration. Edge rules: title "
            "similarity >= --min-similarity alone; or title+notes similarity "
            ">= --min-similarity alone; or a shared subject token "
            "corroborated by weak similarity (>= min/3), a shared scenario, "
            "or a shared run. Scenario overlap and run overlap NEVER group "
            "alone — one scenario, and one run, legitimately yield many "
            "unrelated findings. Output groups are CANDIDATES for the "
            "command layer's judgment (merge / conflict / dependency / "
            "discard) — this tool never classifies and never writes."))
    sp.add_argument("--status", default="proposed,open",
                    help="comma list of statuses to consider "
                         f"(default proposed,open; each one of {STATUSES})")
    sp.add_argument("--min-similarity", type=float, default=0.5,
                    help="title-token Jaccard threshold for a "
                         "similarity-alone edge (default 0.5)")
    sp = sub.add_parser(
        "compact",
        help="tombstone accepted/dismissed findings verified-absent for enough "
             "re-driven runs; keeps the ledger's frontier small",
        description=(
            "Archive (tombstone) a decided finding once it has been "
            "verified-absent — i.e. its scenario was RE-DRIVEN (a run with a "
            "manifest.json listing that scenario) without the finding "
            "recurring. --unseen-runs N is that threshold: the count of "
            "re-driven runs the finding must be absent from, NOT wall-clock "
            "runs elapsed. A hand-written `ingest` now writes a run manifest "
            "(Story 1.9), so a finding with NO real scenario (only the reserved "
            "`ingest` pseudo-scenario) advances on each later run, driven or "
            "manual. A finding evidenced against a REAL scenario is different: "
            "only a run that actually RE-DRIVES that scenario counts, so "
            "hand-ingestion alone can never tombstone it — re-drive the scenario "
            "with `tanuki-drive` (F140/F141; supersedes the stale F75 note)."))
    sp.add_argument("--unseen-runs", type=int, default=None,
                    help="re-driven runs the finding must be absent from before "
                         "tombstoning (default from config)")
    sp = sub.add_parser("scenario-yield")
    sp.add_argument("--runs", type=int, default=5)
    sub.add_parser("stats")
    sub.add_parser("status")
    sub.add_parser(
        "next",
        help="print only the derived next step (the same line `status` ends "
             "with — one derivation, two surfaces)",
        description=(
            "Derive the single next command from the ledger's state — a "
            "closed enumeration (fresh / events-no-findings / "
            "proposed-awaiting / accepted-awaiting / watching-only / "
            "all-decided); a state outside it errors rather than guessing."))
    sub.add_parser(
        "policy-surface",
        help="read-only: print the operator's pinned policy source (the "
             "allowlisted files under policy_source in the scenarios config) "
             "as numbered lines, a judgment-time input for classification; "
             "prints {\"configured\": false} when no policy_source is set",
        description=(
            "Emit the operator's advisory policy as numbered file:line lines "
            "so classification can quote it. Reads ONLY the `files` allowlist "
            "under `policy_source` in the target's scenarios config, pins the "
            "checkout, and never touches the ledger/events/scheduler. It is an "
            "enhancer, not a dependency: unset policy_source -> "
            "{\"configured\": false}; unusable path -> {\"available\": false}. "
            "See specs/spec-policy-advisory."))
    args = p.parse_args()

    if args.cmd == "upsert-finding" and not args.match and not args.title:
        print("error: --title required when creating (no --match)", file=sys.stderr)
        return 2

    ledger = load(args.target)
    {"init": cmd_init, "ingest": cmd_ingest, "ingest-note": cmd_ingest_note,
     "findings": cmd_findings, "upsert-finding": cmd_upsert,
     "promote": cmd_promote, "set-status": cmd_set_status,
     "consolidate": cmd_consolidate,
     "compact": cmd_compact, "scenario-yield": cmd_scenario_yield,
     "stats": cmd_stats, "policy-surface": cmd_policy_surface,
     "status": cmd_status, "next": cmd_next}[args.cmd](args, ledger)
    return 0


if __name__ == "__main__":
    sys.exit(main())
