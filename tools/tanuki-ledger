                    help="staging file slug (sanitized to [a-z0-9-]; "
                         "default tanuki-<target>-<finding id>)")
    args = p.parse_args()

    if args.cmd == "upsert-finding" and not args.match and not args.title:
        print("error: --title required when creating (no --match)", file=sys.stderr)
        return 2

    ledger = load(args.target)
    {"init": cmd_init, "ingest": cmd_ingest, "ingest-note": cmd_ingest_note,
     "findings": cmd_findings, "upsert-finding": cmd_upsert,
     "promote": cmd_promote, "set-status": cmd_set_status,
