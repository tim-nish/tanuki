#!/usr/bin/env bash
# Fixture for `tanuki-loop status`'s run verdict (story 1.3 / issue #69,
# ledger finding F42): status states the run's condition explicitly —
# running (healthy) | stopped (breaker) | finished (reason) — as a typed JSON
# field, so an operator returning to a run they did not just drive never has
# to infer it from last_breaker, iteration counters, or state.json.
# Also covers the operator-critical fields F42 named: base_sha (the gate
# diff's left side) and last_breaker (diagnosing a stop).
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
root="$(mktemp -d)"; trap 'rm -rf "$root"' EXIT
export TANUKI_ROOT="$root"
L=("$here/tanuki-loop" --target t)
jget() { python3 -c "import json,sys; d=json.load(sys.stdin); print(d$1)"; }

repo="$root/repo"; mkdir -p "$repo"
git init -q "$repo"; git -C "$repo" config user.email a@b.c
git -C "$repo" config user.name t
echo x > "$repo/f"; git -C "$repo" add -A; git -C "$repo" commit -qm init

init_out="$("${L[@]}" init --loop-repo "$repo" --cap 3)"
wt="$(echo "$init_out" | jget '["worktree"]')"
gwt() { git -C "$wt" "$@"; }

# --- running (healthy) --------------------------------------------------------
s="$("${L[@]}" status)"
[ "$(echo "$s" | jget '["verdict"]["state"]')" = "running" ] \
  || fail "fresh run should read running, got: $(echo "$s" | jget '["verdict"]')"
echo "$s" | jget '["verdict"]["summary"]' | grep -qi "healthy" \
  || fail "running verdict should say healthy explicitly, not merely omit a breaker"
pass "running: fresh run leads with an explicit healthy verdict"

# An OPEN iteration bracket is still healthy, and the verdict says where it is.
"${L[@]}" iter-start >/dev/null
s="$("${L[@]}" status)"
[ "$(echo "$s" | jget '["verdict"]["state"]')" = "running" ] \
  || fail "open breaker-free bracket should read running"
echo "$s" | jget '["verdict"]["summary"]' | grep -q "iteration 1 open" \
  || fail "verdict should name the open bracket: $(echo "$s" | jget '["verdict"]')"
pass "running: an open, breaker-free iteration bracket reads healthy"

# base_sha + last_breaker are surfaced by status itself (F42's fields).
[ "$(echo "$s" | jget '["base_sha"]')" = "$(git -C "$repo" rev-parse HEAD)" ] \
  || fail "status must surface base_sha (the gate diff's left side)"
echo "$s" | jget '["last_breaker"]' >/dev/null \
  || fail "status must surface last_breaker (null when none)"
pass "status surfaces base_sha and last_breaker (F42's operator-critical fields)"

# --- stopped (breaker) --------------------------------------------------------
# Trip a real breaker through a real path: an external commit in the worktree,
# caught at the next iter-start. Assert against the breaker that ACTUALLY
# fired rather than a hardcoded reason — the verdict's job is to report the
# run's real breaker, whichever one the loop tripped.
echo external > "$wt/f"; gwt commit -qam external-change
rc=0; b="$("${L[@]}" iter-start 2>&1)" || rc=$?
[ "$rc" = "3" ] || fail "expected a breaker (exit 3) at iter-start, got $rc"
fired="$(echo "$b" | jget '["breaker"]')"
[ -n "$fired" ] || fail "iter-start breaker emitted no reason: $b"

s="$("${L[@]}" status)"
[ "$(echo "$s" | jget '["verdict"]["state"]')" = "stopped" ] \
  || fail "run with a breaker should read stopped, got: $(echo "$s" | jget '["verdict"]')"
[ "$(echo "$s" | jget '["verdict"]["reason"]')" = "$fired" ] \
  || fail "stopped verdict must name the breaker that fired ('$fired')"
echo "$s" | jget '["verdict"]["summary"]' | grep -q "stopped" \
  || fail "stopped verdict summary must say the run is stopped"
[ "$(echo "$s" | jget '["last_breaker"]["reason"]')" = "$fired" ] \
  || fail "verdict reason must agree with the last_breaker detail (no second story)"
pass "stopped: verdict names the breaker that fired and agrees with last_breaker"

# --- finished (terminal, first-class) ----------------------------------------
# finish AFTER a breaker: the terminal state must win, not read as stopped —
# a run can legitimately be finished (aborted) once it has broken.
"${L[@]}" finish --reason aborted >/dev/null
s="$("${L[@]}" status)"
[ "$(echo "$s" | jget '["verdict"]["state"]')" = "finished" ] \
  || fail "finished must take precedence over a prior breaker, got: $(echo "$s" | jget '["verdict"]')"
[ "$(echo "$s" | jget '["verdict"]["reason"]')" = "aborted" ] \
  || fail "finished verdict must carry its reason"
# No regression: the breaker detail is still there for diagnosis.
[ "$(echo "$s" | jget '["last_breaker"]["reason"]')" = "$fired" ] \
  || fail "finishing must not erase last_breaker"
pass "finished: terminal state is first-class and outranks a prior breaker"

# Every finish reason reports as finished with that reason.
for reason in converged cap gate-ratified; do
  "${L[@]}" finish --reason "$reason" >/dev/null
  s="$("${L[@]}" status)"
  [ "$(echo "$s" | jget '["verdict"]["state"]')" = "finished" ] \
    || fail "finish --reason $reason should read finished"
  [ "$(echo "$s" | jget '["verdict"]["reason"]')" = "$reason" ] \
    || fail "finished verdict should carry reason=$reason"
done
pass "finished: every finish reason (converged/cap/gate-ratified/aborted) reports"

echo "ALL PASS"
