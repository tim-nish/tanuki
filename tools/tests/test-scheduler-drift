#!/usr/bin/env bash
# Fixture for the feature-drift signal (story 1.12 / spec-tanuki-scenario-
# lifecycle §3 third generation trigger). The scheduler's `history` surface
# is READ-ONLY and ADVISORY: it names each plugin surface (skill/command) that
# no scenario charter or prompt covers and points at the `generate`
# invocation. It must NOT fire on complete coverage (no false positives),
# must never mutate scheduler state or the matrix, and must degrade gracefully
# when the plugin / its surface dirs are absent (hostless target).
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
sched="$here/tanuki-scheduler"
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
export TANUKI_ROOT="$tmp/root"
jget() { python3 -c "import json,sys;print(json.load(sys.stdin)$1)"; }

# --- a target plugin repo with two skills and one command ---------------------
plugin="$tmp/work/demo-plugin"
mkdir -p "$plugin/skills/alpha" "$plugin/skills/beta" "$plugin/commands"
echo "# alpha" > "$plugin/skills/alpha/SKILL.md"
echo "# beta"  > "$plugin/skills/beta/SKILL.md"
echo "# do-thing" > "$plugin/commands/do-thing.md"

canon="$TANUKI_ROOT/scenarios/demo.scenarios.json"
mkdir -p "$(dirname "$canon")"

write_matrix() {  # write_matrix <charter-text>
  cat > "$canon" <<EOF
{"target":"demo","plugin":"$plugin",
 "scenarios":[{"id":"s1","charter":"$1","prompt":"exercise it"}]}
EOF
}

# --- (a) drift IS reported for surface absent from every charter --------------
# Charter mentions only the "alpha" skill; beta + do-thing are uncovered.
write_matrix "First run covers the alpha skill only."
h="$("$sched" --target demo history --json)"
echo "$h" | python3 -c '
import json, sys
d = json.load(sys.stdin)["feature_drift"]
names = {(u["kind"], u["name"]) for u in d["uncovered"]}
assert ("skill", "beta") in names, d
assert ("command", "do-thing") in names, d
assert ("skill", "alpha") not in names, d      # mentioned -> covered
assert d["generate"] == "/tanuki demo generate", d
' || fail "drift must name every uncovered skill/command + the generate invocation"
# human-readable render carries the signal + the exact invocation
"$sched" --target demo history | grep -q "feature-drift" \
  || fail "human render must show the feature-drift line"
"$sched" --target demo history | grep -q "/tanuki demo generate" \
  || fail "human render must include the generate invocation"
pass "drift reported: names each uncovered surface + points at generate"

# --- signal is read-only: history must not create/mutate scheduler state ------
[ ! -e "$TANUKI_ROOT/demo/scheduler.json" ] \
  || fail "history must not write scheduler state (read-only signal)"
pass "read-only: drift signal never writes scheduler state"

# --- (b) drift is NOT reported when every surface is covered -------------------
write_matrix "Covers the alpha skill, the beta skill, and the do-thing command."
h="$("$sched" --target demo history --json)"
echo "$h" | python3 -c '
import json, sys
d = json.load(sys.stdin)["feature_drift"]
assert d["uncovered"] == [], d
' || fail "complete coverage must yield no drift (no false positives)"
"$sched" --target demo history | grep -q "feature-drift" \
  && fail "human render must emit no feature-drift line on complete coverage" || true
pass "no false positive: complete coverage yields no drift signal"

# --- hostless / missing plugin dir degrades gracefully (no crash, no drift) ---
cat > "$canon" <<EOF
{"target":"demo","plugin":"$tmp/work/does-not-exist",
 "scenarios":[{"id":"s1","charter":"c","prompt":"p"}]}
EOF
h="$("$sched" --target demo history --json)" || fail "missing plugin dir must not crash"
echo "$h" | python3 -c '
import json, sys
d = json.load(sys.stdin)["feature_drift"]
assert d["uncovered"] == [], d
' || fail "absent plugin dir must report no drift, not raise"
pass "graceful degrade: absent plugin dir -> no drift, no crash"

# --- absent scenarios config also degrades (different target) -----------------
h="$("$sched" --target ghost history --json)" || fail "absent config must not crash"
echo "$h" | python3 -c '
import json, sys
d = json.load(sys.stdin)["feature_drift"]
assert d["uncovered"] == [] and d["generate"] == "/tanuki ghost generate", d
' || fail "absent scenarios config must report no drift"
pass "graceful degrade: absent scenarios config -> no drift"

# --- (#169) matching is exact/structured, never substring ----------------------
# "betamax" must not cover the beta skill; "do" must not cover do-thing.
write_matrix "Exercise the betamax workflow and do a run of alpha."
h="$("$sched" --target demo history --json)"
echo "$h" | python3 -c '
import json, sys
d = json.load(sys.stdin)["feature_drift"]
names = {(u["kind"], u["name"]) for u in d["uncovered"]}
assert ("skill", "beta") in names, "substring betamax must not cover beta: %r" % d
assert ("command", "do-thing") in names, "token do must not cover do-thing: %r" % d
assert ("skill", "alpha") not in names, "whole-token alpha must cover: %r" % d
' || fail "coverage must be whole-token, never substring"
pass "(#169) substring mentions no longer count as coverage"

# An exact covers tag counts as structured coverage without any prose mention.
cat > "$canon" <<EOF
{"target":"demo","plugin":"$plugin",
 "scenarios":[{"id":"s1","charter":"c","prompt":"p",
               "covers":["alpha","beta","do-thing"]}]}
EOF
h="$("$sched" --target demo history --json)"
echo "$h" | python3 -c '
import json, sys
d = json.load(sys.stdin)["feature_drift"]
assert d["uncovered"] == [], d
' || fail "exact covers tags must count as coverage"
pass "(#169) exact covers tags are structured coverage"

# --- (#168) status carries the advisory trigger signals ------------------------
# No scheduler state yet: drift renders, but zero scenarios is onboarding,
# never an "empty pool".
write_matrix "First run covers the alpha skill only."
"$sched" --target demo status | python3 -c '
import json, sys
a = json.load(sys.stdin)["advisories"]
assert {(u["kind"], u["name"]) for u in a["feature_drift"]} \
    == {("skill", "beta"), ("command", "do-thing")}, a
assert a["unexplored_pool_empty"] is False, a
assert a["generate"] == "/tanuki demo generate", a
' || fail "status must emit drift advisories and no pool-empty before any state"
pass "(#168) status advisories: drift named, zero-scenario state is not pool-empty"

# First sync marks s1 active -> the unexplored pool is genuinely empty.
"$sched" --target demo sync --scenarios "$canon" > /dev/null
"$sched" --target demo status | python3 -c '
import json, sys
a = json.load(sys.stdin)["advisories"]
assert a["unexplored_pool_empty"] is True, a
' || fail "an all-active state must report unexplored_pool_empty"
"$sched" --target demo history | grep -q "unexplored pool empty" \
  || fail "history text must name the empty pool (a named generation trigger)"
"$sched" --target demo history | grep -q "/tanuki demo generate" \
  || fail "the pool-empty line must point at the generate invocation"
"$sched" --target demo history --json | python3 -c '
import json, sys
assert json.load(sys.stdin)["unexplored_pool_empty"] is True
' || fail "history --json must carry unexplored_pool_empty"
pass "(#168) empty pool renders in status + history, pointing at generate"

# A later sync adds s2 as unexplored -> the pool is no longer empty.
cat > "$canon" <<EOF
{"target":"demo","plugin":"$plugin",
 "scenarios":[{"id":"s1","charter":"alpha only","prompt":"p"},
              {"id":"s2","charter":"beta too","prompt":"p"}]}
EOF
"$sched" --target demo sync --scenarios "$canon" > /dev/null
"$sched" --target demo status | python3 -c '
import json, sys
a = json.load(sys.stdin)["advisories"]
assert a["unexplored_pool_empty"] is False, a
' || fail "an unexplored scenario must clear the pool-empty advisory"
"$sched" --target demo history | grep -q "unexplored pool empty" \
  && fail "history must not print pool-empty while unexplored scenarios exist" || true
pass "(#168) an unexplored scenario clears the pool-empty advisory"

echo "all checks passed"
