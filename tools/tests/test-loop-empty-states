#!/usr/bin/env bash
# Fixture for the D3 empty-state enumeration (specs/spec-tanuki-view D3;
# OPEN-1 resolved 2026-07-17; issue #66 / F47 is its first instance).
#
# Every dashboard section that can render empty resolves to exactly ONE member
# of a closed set, each carrying an expected-vs-gap verdict and a reason. This
# fixture holds ONE CASE PER MEMBER — that is the whole point of the rule: the
# class has been reported three times (F5, F47/#66, F46/#65) because the text
# was prose no test could check. A new member without a case here, or a
# regression in an existing one, must fail loudly.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
loop="$here/tanuki-loop"
root="$(mktemp -d)"; trap 'rm -rf "$root"' EXIT
export TANUKI_ROOT="$root"
L=("$loop" --target t)
jget() { python3 -c "import json,sys;print(json.load(sys.stdin)$1)"; }

repo="$root/repo"; git init -q "$repo"
git -C "$repo" config user.email a@b.c; git -C "$repo" config user.name t
echo v0 > "$repo/f"; git -C "$repo" add -A; git -C "$repo" commit -qm base

# Branch-only gate (two-outcomes-only, #262/#263): this target commits work but
# its base is never merged here, so it derives a real reachability settlement
# (`pending`) — the non-null case the guard at the end must leave untouched. The
# default gate is now "pr", which would derive no settlement without a forge.
wt="$("${L[@]}" init --loop-repo "$repo" --cap 5 --gate branch | jget '["worktree"]')"

# --- the enumeration is closed and every member is covered here ---------------
# Read the members out of the tool itself, so ADDING one without a case below
# fails this fixture rather than shipping unchecked prose.
members="$(python3 - "$loop" <<'EOF'
import re, sys
src = open(sys.argv[1]).read()
block = re.search(r"EMPTY_STATES = \{(.*?)\n\}\n", src, re.S).group(1)
print("\n".join(sorted(re.findall(r'"([a-z]+:[a-z-]+)": dict\(', block))))
EOF
)"
covered="drive:iteration-open-not-driven
drive:iterations-ran-none-drove
drive:manual-run-no-plan
drive:no-iteration-started
live:never-initialized
live:no-active-run
run:commits-not-recorded
run:no-iteration-started
scheduler:manual-run-no-plan
scheduler:never-synced-fresh
settlement:n-a-hostless
settlement:pending-active
settlement:undelivered-closed
unresolved:no-loop-repo
unresolved:none"
[ "$members" = "$covered" ] || fail "EMPTY_STATES membership changed — add a case below.
tool:    $(echo "$members" | tr '\n' ' ')
fixture: $(echo "$covered" | tr '\n' ' ')"
pass "the enumeration is closed and every member has a case in this fixture"
# The unresolved:* members are exercised in tools/tests/test-loop-unresolved
# (they need loop branches to reason about, which this fixture has no use for).
# Named here so the membership guard above stays the single registry.

# --- fresh target: three EXPECTED members ------------------------------------
out="$("${L[@]}" dashboard)"

# drive:no-iteration-started
grep -q "latest drive: no iteration has started yet — expected" <<<"$out" \
  || fail "drive:no-iteration-started must read as expected: $(grep 'latest drive' <<<"$out")"
# F166: every EXPECTED render carries the verdict tag in as many words, not
# just a reason the reader must classify themselves.
grep -q "latest drive: .*(expected for this run's state)" <<<"$out" \
  || fail "expected states must carry the verdict tag (F166): $(grep 'latest drive' <<<"$out")"
grep -q "A drive is one tanuki-drive pipeline run" <<<"$out" \
  || fail "the 'drive' term must stay defined for a cold reader (F46)"
pass "drive:no-iteration-started — expected, term defined"

# run:no-iteration-started
grep -q "this run: no ledger movement yet — no iteration has started" <<<"$out" \
  || fail "run:no-iteration-started missing: $(grep 'this run' <<<"$out")"
pass "run:no-iteration-started — expected"

# scheduler:never-synced-fresh — issue #66 / F47, the first instance of D3.
sched="$(grep 'scheduler decisions' <<<"$out")"
grep -q "expected on a fresh target" <<<"$sched" \
  || fail "#66: a fresh target's empty scheduler state must read as EXPECTED: $sched"
grep -q "GAP" <<<"$sched" && fail "#66: a fresh target is not a gap: $sched"
# The command it names must be explained where it is named.
grep -q "reads the scenarios file" <<<"$sched" \
  || fail "#66: 'tanuki-scheduler sync' must be explained, not just named: $sched"
grep -q "you do not run it by hand" <<<"$sched" \
  || fail "#66: must say the operator does not run sync themselves: $sched"
pass "scheduler:never-synced-fresh — #66: expected, and the command is explained"

# --- iteration open: drive:iteration-open-not-driven --------------------------
"${L[@]}" iter-start >/dev/null
out2="$("${L[@]}" dashboard)"
grep -q "iteration 1 started but its drive has not begun yet" <<<"$out2" \
  || fail "drive:iteration-open-not-driven missing: $(grep 'latest drive' <<<"$out2")"
grep -q "latest drive: GAP" <<<"$out2" && fail "mid-bracket is expected, not a gap"
pass "drive:iteration-open-not-driven — expected mid-bracket"

# --- after an iteration ran OUTSIDE the scheduler: two EXPECTED members -------
# This hand-run bracket persists no scheduler plan, so the run's provenance is
# manual/toy/ad-hoc — its empty drive/scheduler sections are EXPECTED, not
# gaps (F166 / issue #236; provenance derived from plan_record absence).
echo v1 > "$wt/f"; git -C "$wt" commit -qam iter1
"${L[@]}" iter-verify >/dev/null
out3="$("${L[@]}" dashboard)"

# drive:manual-run-no-plan
d="$(grep 'latest drive' <<<"$out3")"
grep -q "GAP" <<<"$d" && fail "a manual run's empty drive is expected, not a GAP: $d"
grep -q "1 iteration(s) ran outside the scheduler" <<<"$d" \
  || fail "drive:manual-run-no-plan reason wrong: $d"
grep -q "(expected for this run's state)" <<<"$d" \
  || fail "drive:manual-run-no-plan must carry the expected verdict: $d"
pass "drive:manual-run-no-plan — expected (provenance: no persisted plan)"

# scheduler:manual-run-no-plan
s3="$(grep 'scheduler decisions' <<<"$out3")"
grep -q "GAP" <<<"$s3" && fail "a manual run's empty scheduler is expected, not a GAP: $s3"
grep -q "ran outside the scheduler" <<<"$s3" \
  || fail "scheduler:manual-run-no-plan reason wrong: $s3"
grep -q "(expected for this run's state)" <<<"$s3" \
  || fail "scheduler:manual-run-no-plan must carry the expected verdict: $s3"
pass "scheduler:manual-run-no-plan — expected (provenance: drove an unmanaged set)"

# --- a SCHEDULED run whose iteration did not drive: the real GAP -------------
# When a plan WAS persisted for the iteration (a scheduled run) but no drive
# was recorded, the empty drive section is a genuine gap (F166 / issue #236:
# a scheduled run that should have driven and did not stays expected:false).
run_id="$(cat "$TANUKI_ROOT/t/loop/current")"
python3 - "$TANUKI_ROOT/t/scheduler.json" "$run_id" <<'EOF'
import json, os, sys
p, run = sys.argv[1], sys.argv[2]
data = {"scenarios": {}, "plans": [
    {"run": f"{run}-iter1", "plan": [], "verify": [], "explore": [],
     "quota_met": True}]}
os.makedirs(os.path.dirname(p), exist_ok=True)
json.dump(data, open(p, "w"))
EOF
out4="$("${L[@]}" dashboard)"
d4="$(grep 'latest drive' <<<"$out4")"
grep -q "GAP" <<<"$d4" \
  || fail "a scheduled run with no drive must be a GAP: $d4"
grep -q "1 iteration(s) ran and none recorded a drive" <<<"$d4" \
  || fail "drive:iterations-ran-none-drove reason wrong: $d4"
pass "drive:iterations-ran-none-drove — GAP (a scheduled run that did not drive)"

# run:commits-not-recorded — a run predating story 1.10's subject capture: a
# verified, patch-bearing iteration with no `commits` key must degrade to the
# typed one-line note, never crash and never invent subjects (spec-tanuki-view
# D4). Strip the key to simulate the legacy state, then re-render.
run="$(cat "$TANUKI_ROOT/t/loop/current")"
python3 - "$TANUKI_ROOT/t/loop/$run/state.json" <<'EOF'
import json, sys
p = sys.argv[1]; s = json.load(open(p))
for it in s["iterations"]:
    it.pop("commits", None)
json.dump(s, open(p, "w"))
EOF
out_legacy="$("${L[@]}" dashboard)" \
  || fail "run:commits-not-recorded must not crash the dashboard"
grep -q "landed commits: commit subjects were not recorded for this run" <<<"$out_legacy" \
  || fail "run:commits-not-recorded reason wrong: $(grep 'landed commits' <<<"$out_legacy")"
grep -q "landed commits: GAP" <<<"$out_legacy" \
  && fail "a legacy run's missing subjects is expected, not a gap: $out_legacy"
pass "run:commits-not-recorded — expected; typed note, never a crash"

# --- the expected/gap verdict is the whole point ------------------------------
# Same empty 'latest drive' section, opposite verdicts by RUN PROVENANCE: a
# manual run (no persisted plan) is EXPECTED; a scheduled run that did not
# drive is a GAP. That is what "expected vs gap" means (F166 / issue #236),
# and what prose kept failing to carry. (For the scheduler section both empty
# cases — fresh and manual — are expected: an absent scheduler.json only ever
# means the run was not scheduled.)
grep -q "expected on a fresh target" <<<"$out" \
  || fail "fresh scheduler state should be expected"
grep -q "(expected for this run's state)" <<<"$d" \
  || fail "a manual run's empty drive should be expected: $d"
grep -q "GAP" <<<"$d4" \
  || fail "a scheduled run's empty drive should be a gap: $d4"
pass "one empty drive section, two verdicts — expected (manual) vs GAP (scheduled)"

# --- live view members (spec-tanuki-view D2 `live`: live = an ACTIVE run) -----

# live:never-initialized — a target that has never run a loop at all.
out_l1="$("$loop" --target t2 dashboard --live)"
grep -q "live — no loop run has ever been initialized" <<<"$out_l1" \
  || fail "live:never-initialized missing: $out_l1"
grep -q "GAP" <<<"$out_l1" && fail "a never-initialized target is expected, not a gap"
grep -q "init creates the run" <<<"$out_l1" \
  || fail "the command live:never-initialized names must be explained: $out_l1"
pass "live:never-initialized — expected, init explained"

# live:no-active-run — a closed run is history, never live.
"${L[@]}" finish --reason cap >/dev/null
out_l2="$("${L[@]}" dashboard --live)"
grep -q "live — no active loop" <<<"$out_l2" \
  || fail "live:no-active-run missing: $out_l2"
grep -q "GAP" <<<"$out_l2" && fail "between runs is expected, not a gap"
grep -q "latest run: " <<<"$out_l2" \
  || fail "the one-line historical summary must render: $out_l2"
# Historical context is ONE line — none of the closed run's detail sections.
for sec in "latest drive" "this run:" "scheduler decisions" "convergence" "NEXT:"; do
  grep -q "$sec" <<<"$out_l2" \
    && fail "live must not render the closed run's '$sec' section: $out_l2"
done
pass "live:no-active-run — expected; one historical line, no closed-run sections"

# --- status delivered/settlement empty-states (story 1.46 / issue #240) -------
# `status` rendered `delivered`/`settlement` as a bare null with nothing to
# settle, conflating a hostless (branch-only gate — no forge) target with a
# hosted (PR gate) run still awaiting delivery. Each null now resolves to one
# enumerated member; the discriminator is the GATE, and the hosted verdict
# flips with the run's state — the whole point. (Two-outcomes-only delivery,
# triage of #262/#263: the default gate is now "pr"; the hostless case is the
# branch-only gate, selected with --gate branch.)

# settlement:n-a-hostless — a fresh branch-only target that produced no work:
# hostless (no forge), EXPECTED, and both fields carry the member.
# issue #200 / story 1.56: these sub-tests deliberately run several
# TARGETS against one toy repo while an earlier run is still live, so
# init's per-repo guard would refuse. The sharing is intentional here
# (the fixture asserts on the earlier run), which is exactly what
# --allow-concurrent declares — do not copy it into real usage.
"$loop" --target th init --loop-repo "$repo" --allow-concurrent --cap 5 --gate branch >/dev/null
sh="$("$loop" --target th status)"
[ "$(jget '["settlement"]["state"]' <<<"$sh")" = "settlement:n-a-hostless" ] \
  || fail "direct-merge/no-work settlement must be typed n-a-hostless: $(jget '["settlement"]' <<<"$sh")"
[ "$(jget '["settlement"]["expected"]' <<<"$sh")" = "True" ] \
  || fail "a hostless target's absent settlement is EXPECTED, not a gap: $sh"
[ "$(jget '["delivered"]["state"]' <<<"$sh")" = "settlement:n-a-hostless" ] \
  || fail "delivered must carry the same member as settlement: $(jget '["delivered"]' <<<"$sh")"
grep -q "n/a" <<<"$(jget '["settlement"]["reason"]' <<<"$sh")" \
  || fail "the hostless reason must read as n/a: $sh"
pass "settlement:n-a-hostless — expected, both fields typed, reads n/a"

# settlement:pending-active — a HOSTED (PR gate) run, still active, no delivery
# yet: EXPECTED (it may still deliver), distinct from the hostless N/A case.
"$loop" --target thp init --loop-repo "$repo" --allow-concurrent --cap 5 >/dev/null
runp="$(cat "$TANUKI_ROOT/thp/loop/current")"
python3 - "$TANUKI_ROOT/thp/loop/$runp/state.json" <<'EOF'
import json, sys
p = sys.argv[1]; s = json.load(open(p))
s["gate_mode"] = "pr"   # hosted (forge), undelivered
json.dump(s, open(p, "w"))
EOF
shp="$("$loop" --target thp status)"
[ "$(jget '["settlement"]["state"]' <<<"$shp")" = "settlement:pending-active" ] \
  || fail "hosted+active+undelivered must be pending-active: $(jget '["settlement"]' <<<"$shp")"
[ "$(jget '["settlement"]["expected"]' <<<"$shp")" = "True" ] \
  || fail "an active hosted run's absent delivery is EXPECTED: $shp"
pass "settlement:pending-active — expected, distinct from the hostless N/A"

# settlement:undelivered-closed — the SAME hosted target but the run has
# closed without delivering: now a GAP (a delivery was expected but did not
# take). Same absent field, opposite verdict — that is "expected vs gap".
"$loop" --target thc init --loop-repo "$repo" --allow-concurrent --cap 5 >/dev/null
runc="$(cat "$TANUKI_ROOT/thc/loop/current")"
python3 - "$TANUKI_ROOT/thc/loop/$runc/state.json" <<'EOF'
import json, sys
p = sys.argv[1]; s = json.load(open(p))
s["gate_mode"] = "pr"
s["finished"] = {"reason": "cap", "at": "2026-01-01 00:00:00"}   # closed, undelivered
json.dump(s, open(p, "w"))
EOF
shc="$("$loop" --target thc status)"
[ "$(jget '["settlement"]["state"]' <<<"$shc")" = "settlement:undelivered-closed" ] \
  || fail "hosted+closed+undelivered must be undelivered-closed: $(jget '["settlement"]' <<<"$shc")"
[ "$(jget '["settlement"]["expected"]' <<<"$shc")" = "False" ] \
  || fail "a closed hosted run that never delivered is a GAP: $shc"
pass "settlement:undelivered-closed — GAP; one absent field, verdict flips with run state"

# A real settlement is left untouched — the guard only fires on a null.
sr="$("${L[@]}" status)"
[ "$(jget '["settlement"].get("state") is None' <<<"$sr")" = "True" ] \
  || fail "a derived settlement must not be rewritten as an empty-state: $(jget '["settlement"]' <<<"$sr")"
pass "a derived (non-null) settlement is untouched"

# --- an unenumerated state is a bug, not an invented string -------------------
python3 - "$loop" <<'EOF'
import importlib.util, sys
spec = importlib.util.spec_from_loader("tl", loader=None)
m = importlib.util.module_from_spec(spec)
src = open(sys.argv[1]).read()
# Pull just the table + helper so we can exercise the KeyError contract.
import re
tbl = re.search(r"EMPTY_STATES = \{.*?\n\}\n", src, re.S).group(0)
fn = re.search(r"def empty_state\(.*?\n\n\n", src, re.S).group(0)
exec(tbl + "\n" + fn, m.__dict__)
try:
    m.empty_state("scheduler:invented-on-the-spot", "t")
except KeyError:
    sys.exit(0)
sys.exit("an unenumerated empty state must raise, not render")
EOF
[ "$?" = "0" ] || fail "empty_state() accepted an unenumerated member"
pass "an unenumerated empty state raises — it cannot be invented at a call site"

echo "ALL PASS"
