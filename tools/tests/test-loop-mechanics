#!/usr/bin/env bash
# Fixture for tanuki-loop's deterministic safety substrate (the layer that must
# be scripted so an unattended run doesn't rely on the model): sequencing
# guards, the four-part integration invariant, rollback of tracked + untracked
# changes, per-finding attempt freezing, tool-computed two-consecutive-quiet
# convergence, the deterministic test runner, the cap breaker, the
# external-modification breaker, and the post-merge reachability gate.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
loop="$here/tanuki-loop"
ledger="$here/tanuki-ledger"
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
export TANUKI_ROOT="$tmp/root"
jget() { python3 -c "import json,sys;print(json.load(sys.stdin)$1)"; }

# A loop repo on main.
repo="$tmp/repo"
git init -q "$repo" && git -C "$repo" config user.email t@e && git -C "$repo" config user.name t
git -C "$repo" checkout -qb main && echo v0 > "$repo/f" && git -C "$repo" add -A && git -C "$repo" commit -qm base

L=("$loop" --target t)
# One active run per target (issue #258): init now fails closed while a prior
# run for the target is unfinished. These sub-tests each want a fresh run, so
# retire the current one before re-initing — exactly what real usage does at
# the morning gate. A single live run means the bare `finish` resolves.
retire() { "${L[@]}" finish --reason aborted >/dev/null 2>&1 || true; }
wt="$("${L[@]}" init --loop-repo "$repo" --cap 8 | jget '["worktree"]')"
[ -d "$wt" ] || fail "worktree not created at $wt"
gwt() { git -C "$wt" "$@"; }
pass "init created the integration worktree"

# --- happy path: start -> commit -> verify ----------------------------------
"${L[@]}" iter-start >/dev/null
echo v1 > "$wt/f"; gwt commit -qam iter1
"${L[@]}" iter-verify | jget '["ok"]' | grep -q True || fail "iter-verify should pass on a real commit"
pass "iter-start / commit / iter-verify happy path"

# --- sequencing guard: iter-start with the previous iteration still open -----
"${L[@]}" iter-start >/dev/null
rc=0; "${L[@]}" iter-start >/tmp/seq.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "sequencing violation" /tmp/seq.json || fail "expected sequencing breaker on double iter-start"
pass "sequencing guard: an unclosed iteration blocks the next iter-start"

# --- integration invariant catches "no patch when one was expected" ----------
rc=0; "${L[@]}" iter-verify >/tmp/iv.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "HEAD == start" /tmp/iv.json || fail "expected no-patch invariant breaker (exit 3)"
# F131 (residual): the hint must say a commit may have landed OUTSIDE the loop
# worktree — a commit made in the base repo reads exactly like "no commit" —
# and name the worktree path to check.
grep -q "check it landed in the loop worktree" /tmp/iv.json \
  || fail "no-patch breaker hint must point at the loop worktree (F131)"
grep -q "$wt" /tmp/iv.json \
  || fail "no-patch breaker hint must name the worktree path (F131): $(cat /tmp/iv.json)"
"${L[@]}" iter-verify --no-patch | jget '["ok"]' | grep -q True || fail "--no-patch should accept an unchanged HEAD"
pass "integration invariant: breaks on missing patch; --no-patch accepts no-op"

# --- rollback removes tracked AND untracked iteration changes -----------------
"${L[@]}" iter-start >/dev/null
echo dirty > "$wt/f"             # tracked modification
echo junk > "$wt/untracked.txt"  # untracked new file
"${L[@]}" rollback >/dev/null
[ "$(cat "$wt/f")" = "v1" ] || fail "rollback did not restore the tracked file"
[ ! -e "$wt/untracked.txt" ] || fail "rollback left an untracked file behind"
[ -z "$(gwt status --porcelain)" ] || fail "tree not clean after rollback"
pass "rollback restores tracked file and removes untracked file"

# --- external-modification breaker at the top of an iteration ----------------
echo tampered > "$wt/f"   # external edit, no iter-start yet
rc=0; "${L[@]}" iter-start >/tmp/is.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "external modification" /tmp/is.json || fail "expected external-modification breaker"
gwt checkout -- f   # undo tamper
pass "external modification of the worktree trips a breaker"

# --- per-finding attempts: 4 allowed, then frozen ----------------------------
# (F99: must not collide with real ledger ids used below — frozen findings are
# rightly excluded from record-cycle's new-actionable count)
for i in 1 2 3 4; do
  "${L[@]}" attempt --finding F99 | jget '["frozen"]' | grep -q False || fail "attempt $i should not be frozen"
done
"${L[@]}" attempt --finding F99 | jget '["frozen"]' | grep -q True || fail "5th attempt should freeze F99"
pass "attempt cap: 4 attempts allowed, then the finding freezes"

# --- tool-computed record-cycle + two-consecutive-quiet convergence ----------
# Busy cycle: a real finding lands in the ledger AND a patch is committed.
"$ledger" --target t init >/dev/null
"${L[@]}" iter-start >/dev/null
"$ledger" --target t upsert-finding --title "New friction" --kind friction \
  --evidence "r1/s1#1" >/dev/null
echo v2 > "$wt/f"; gwt commit -qam iter-busy
"${L[@]}" iter-verify >/dev/null
"${L[@]}" record-cycle > /tmp/rc1.json
grep -q '"new_actionable": 1' /tmp/rc1.json && grep -q '"patched": true' /tmp/rc1.json \
  || fail "busy cycle not computed from ledger+SHAs: $(cat /tmp/rc1.json)"
[ "$(jget '["converged"]' < /tmp/rc1.json)" = "False" ] || fail "busy cycle must not converge"
pass "record-cycle computes new-actionable from the ledger and patched from SHAs"

# Quiet cycle 1: nothing new, no patch.
"${L[@]}" iter-start >/dev/null
"${L[@]}" iter-verify --no-patch >/dev/null
"${L[@]}" record-cycle | jget '["converged"]' | grep -q False || fail "one quiet cycle must not converge"
# Quiet cycle 2 -> converged. A deferred finding must not block convergence.
"${L[@]}" iter-start >/dev/null
"$ledger" --target t upsert-finding --title "Spec-shaped" --kind gap \
  --evidence "r2/s1#1" >/dev/null
"${L[@]}" defer --finding F2 --reason "spec decision, no policy answer" >/dev/null
"${L[@]}" iter-verify --no-patch >/dev/null
"${L[@]}" record-cycle | jget '["converged"]' | grep -q True \
  || fail "two consecutive quiet cycles (with only a deferred finding) must converge"
pass "convergence needs two consecutive quiet cycles; deferred findings don't block it"

# --- deterministic test runner ------------------------------------------------
retire
"${L[@]}" init --loop-repo "$repo" --cap 1 --test-cmd "test -f f" >/dev/null
"${L[@]}" test | jget '["ok"]' | grep -q True || fail "configured passing test_cmd should pass"
retire
"${L[@]}" init --loop-repo "$repo" --cap 1 --test-cmd "false" >/dev/null
rc=0; "${L[@]}" test >/tmp/tc.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "test failure" /tmp/tc.json || fail "failing test_cmd must be a breaker"
pass "test subcommand: passes on ok test_cmd, breaker on failure"

# --- init --scenarios pulls the per-target loop block; CLI overrides ---------
cat > "$tmp/scen.json" <<'EOF'
{"loop": {"test_cmd": "test -f f", "iterations": 7, "wall_time_s": 1234}}
EOF
retire
"${L[@]}" init --loop-repo "$repo" --scenarios "$tmp/scen.json" >/dev/null
st="$("${L[@]}" status)"
[ "$(echo "$st" | jget '["cap"]')" = "7" ] || fail "cap not taken from loop block"
"${L[@]}" test | jget '["ok"]' | grep -q True || fail "test_cmd not taken from loop block"
retire
"${L[@]}" init --loop-repo "$repo" --scenarios "$tmp/scen.json" --cap 3 >/dev/null
[ "$("${L[@]}" status | jget '["cap"]')" = "3" ] || fail "CLI --cap should override loop block"
rc=0; "${L[@]}" init --loop-repo "$repo" >/tmp/nocap.json 2>&1 || rc=$?
[ "$rc" = "3" ] || fail "init without any cap source must be an exit-3 refusal (F227)"
grep -q '"breaker": "no iteration cap' /tmp/nocap.json \
  || fail "init no-cap refusal must use the {\"breaker\": …} convention (F227)"
pass "init --scenarios reads loop block (cap+test_cmd); CLI overrides; no-cap is a breaker refusal"

# --- policy + finish + breaker persistence + dashboard ------------------------
"${L[@]}" policy --finding F2 --decision "defer to morning: spec altitude" >/dev/null
run="$(cat "$TANUKI_ROOT/t/loop/current")"
grep -q "spec altitude" "$TANUKI_ROOT/t/loop/$run/policy.json" || fail "policy.json not recorded"
"${L[@]}" finish --reason cap >/dev/null
# Scheduler state present -> dashboard shows the per-scenario section.
mkdir -p "$TANUKI_ROOT/t"
cat > "$TANUKI_ROOT/t/scheduler.json" <<'EOF'
{"scenarios": {"s1": {"state": "active"}, "s2": {"state": "unexplored"},
               "s3": {"state": "regression"}}, "runs_recorded": []}
EOF
"${L[@]}" dashboard > /tmp/dash.txt
grep -q "STOPPED — stop reason: cap" /tmp/dash.txt || fail "dashboard missing finish reason"
grep -q "findings: " /tmp/dash.txt || fail "dashboard missing findings summary"
grep -q "iterations: 0/3" /tmp/dash.txt || fail "dashboard missing iteration count"
# F29: the cap-hit health verdict states the numbers it used, with the SAME
# numerator/denominator as the iterations line — beside "iterations: 0/3
# consumed", a bare "cap hit" read as a contradiction.
grep -q "cap hit (0/3 consumed) without convergence" /tmp/dash.txt \
  || fail "cap-hit health line must state N/N consumed (F29): $(grep 'health' /tmp/dash.txt)"
grep -q "scenarios: active 1 · regression 1 · unexplored 1" /tmp/dash.txt \
  || fail "dashboard missing scheduler section"
grep -q "unexplored: s2" /tmp/dash.txt || fail "dashboard missing unexplored list"
pass "policy recorded; finish + dashboard show stop reason, findings, iterations, scheduler"

# --- quota-gated quiet + dashboard operational status --------------------------
"${L[@]}" init --loop-repo "$repo" --cap 4 >/dev/null
run2="$(cat "$TANUKI_ROOT/t/loop/current")"
cat > "$TANUKI_ROOT/t/scheduler.json" <<EOF
{"scenarios": {"s1": {"state": "active"}, "s2": {"state": "unexplored"}},
 "runs_recorded": [],
 "plans": [{"run": "${run2}-iter1", "plan": ["s1"], "quota_met": false,
            "verify": [], "explore": [], "due_regression": [],
            "unexplored_remaining": ["s2"]},
           {"run": "${run2}-iter2", "plan": ["s1", "s2"], "quota_met": true,
            "verify": ["s1"], "explore": ["s2"], "due_regression": [],
            "unexplored_remaining": []}]}
EOF
"${L[@]}" iter-start >/dev/null
"${L[@]}" iter-verify --no-patch >/dev/null
"${L[@]}" record-cycle > /tmp/rcq.json
grep -q '"quota_met": false' /tmp/rcq.json && grep -q '"quiet": false' /tmp/rcq.json \
  || fail "a cycle whose plan missed the exploration quota must not be quiet"
"${L[@]}" iter-start >/dev/null
"${L[@]}" iter-verify --no-patch >/dev/null
"${L[@]}" record-cycle | jget '["quiet"]' | grep -q True \
  || fail "a quota-met quiet cycle must count toward the streak"
pass "record-cycle gates quiet on the persisted plan's exploration quota"

"${L[@]}" dashboard > /tmp/dash2.txt
grep -q "health: " /tmp/dash2.txt || fail "dashboard missing health verdict"
grep -q "this run: newly observed" /tmp/dash2.txt || fail "dashboard missing run deltas"
grep -q "scheduler decisions (iter 2 plan — exploration quota met)" /tmp/dash2.txt \
  || fail "dashboard missing scheduler decisions from the persisted plan"
grep -q "verifying fixes (replay): s1" /tmp/dash2.txt || fail "dashboard missing verify set"
grep -q "exploring (never driven): s2" /tmp/dash2.txt || fail "dashboard missing exploration pick"
grep -q "last cycle (iter 2): quiet — no new findings · no patch commits · quota met" /tmp/dash2.txt \
  || fail "dashboard missing convergence explanation"
pass "dashboard: health verdict, run deltas, scheduler decisions, convergence explanation"

# --- staleness guard (issue #2): never dogfood a base behind its upstream ------
# A loop repo whose local main tracks an origin that has since moved ahead.
origin="$tmp/origin"; git init -q --bare "$origin"
git -C "$origin" symbolic-ref HEAD refs/heads/main
repo2="$tmp/repo2"
git init -q "$repo2" && git -C "$repo2" config user.email t@e && git -C "$repo2" config user.name t
git -C "$repo2" checkout -qb main && echo a > "$repo2/f" && git -C "$repo2" add -A \
  && git -C "$repo2" commit -qm c0
git -C "$repo2" remote add origin "$origin" && git -C "$repo2" push -qu origin main
# Advance origin/main via a second clone, so repo2's local main falls behind.
other="$tmp/other"; git clone -q "$origin" "$other"
git -C "$other" config user.email t@e && git -C "$other" config user.name t
git -C "$other" checkout -q main
echo b >> "$other/f" && git -C "$other" commit -qam c1 && git -C "$other" push -q origin main

Lb=("$loop" --target tb)
# init fetches, sees local main 1 behind origin/main, and FAILS CLOSED.
rc=0; "${Lb[@]}" init --loop-repo "$repo2" --cap 2 >/tmp/stale.json 2>&1 || rc=$?
[ "$rc" = "2" ] && grep -q "behind" /tmp/stale.json \
  || fail "init must fail closed when the local base is behind its upstream: $(cat /tmp/stale.json)"
[ ! -e "$TANUKI_ROOT/tb/loop/current" ] || fail "fail-closed init must not create run state"
pass "staleness guard: init fails closed when the local base is behind its upstream"

# --allow-stale-base is the explicit override; it proceeds and records the gap,
# and the base is the LOCAL tip (never silently moved to the upstream tip).
outb="$("${Lb[@]}" init --loop-repo "$repo2" --cap 2 --allow-stale-base)"
[ "$(echo "$outb" | jget '["base_behind"]')" = "1" ] \
  || fail "--allow-stale-base should proceed and record base_behind=1: $outb"
[ "$(echo "$outb" | jget '["base_sha"]')" = "$(git -C "$repo2" rev-parse main)" ] \
  || fail "override must dogfood the LOCAL base tip, not the upstream tip"
pass "staleness guard: --allow-stale-base overrides, records the gap, keeps the local tip"

# Once fast-forwarded, the base is current and init succeeds cleanly.
git -C "$repo2" merge -q --ff-only origin/main
"${Lb[@]}" finish --reason aborted >/dev/null 2>&1 || true   # retire the prior tb run (#258)
out2b="$("${Lb[@]}" init --loop-repo "$repo2" --cap 2)"
[ "$(echo "$out2b" | jget '["base_behind"]')" = "0" ] \
  || fail "an up-to-date base must init with base_behind=0: $out2b"
pass "staleness guard: a fast-forwarded (current) base inits cleanly"

"${L[@]}" defer --finding F5 --reason "needs operator judgment" >/dev/null
"${L[@]}" finish --reason cap >/dev/null
"${L[@]}" dashboard > /tmp/dash3.txt
grep -q "NEXT: morning gate — your decisions:" /tmp/dash3.txt \
  || fail "dashboard missing the morning-gate decision list"
grep -q "deferred F5: needs operator judgment" /tmp/dash3.txt \
  || fail "dashboard missing the deferred item's reason"
grep -q "ATTENTION" /tmp/dash3.txt || fail "cap-without-convergence should be ATTENTION"
pass "dashboard: finished run lists the concrete morning-gate decisions"

# --- cap breaker + gate-check on a fresh cap-1 run ----------------------------
"${L[@]}" init --loop-repo "$repo" --cap 1 >/dev/null
wt2="$("${L[@]}" status | jget '["worktree"]')"
"${L[@]}" iter-start >/dev/null
echo v3 > "$wt2/f"; git -C "$wt2" commit -qam iter1
"${L[@]}" iter-verify >/dev/null
rc=0; "${L[@]}" iter-start >/tmp/cap.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "iteration cap reached" /tmp/cap.json || fail "expected cap breaker"
pass "cap breaker fires once the fixed iteration ceiling is hit"

# --- F3 / issue #64: the cap breaker states its CAUSE and a next action -------
# "cap reached" alone reads like a sequencing complaint on a retry and gives no
# way to see that rolled-back work consumed the allowance.
grep -q "1/1 consumed (1 verified, 0 rolled back)" /tmp/cap.json \
  || fail "cap breaker must state the consumption breakdown: $(cat /tmp/cap.json)"
grep -q "proceed to the morning gate" /tmp/cap.json \
  || fail "cap breaker must name the next action: $(cat /tmp/cap.json)"
pass "issue #64: cap breaker states the cause (n/cap, verified/rolled back) + next action"

# The issue's exact scenario: both iterations consumed, one verified and one
# ROLLED BACK — the case where the breakdown carries real information.
retire   # the prior cap-1 run is still open (cap breaker, never finished) (#258)
"${L[@]}" init --loop-repo "$repo" --cap 2 >/dev/null
wt3="$("${L[@]}" status | jget '["worktree"]')"
"${L[@]}" iter-start >/dev/null
echo v4 > "$wt3/f"; git -C "$wt3" commit -qam iter1
"${L[@]}" iter-verify >/dev/null
"${L[@]}" iter-start >/dev/null
echo v5 > "$wt3/f"; git -C "$wt3" commit -qam iter2
"${L[@]}" rollback >/dev/null
rc=0; "${L[@]}" iter-start >/tmp/cap2.json 2>&1 || rc=$?
[ "$rc" = "3" ] || fail "expected the cap breaker on a consumed run, got $rc"
grep -q "2/2 consumed (1 verified, 1 rolled back)" /tmp/cap2.json \
  || fail "breakdown must count the rolled-back iteration: $(cat /tmp/cap2.json)"
pass "issue #64: rolled-back work is visible in the cap breakdown (1 verified, 1 rolled back)"

# A cap breaker must NOT masquerade as a sequencing violation, or vice versa:
# the two are distinct causes and the sequencing check runs first, so an open
# bracket reports sequencing even when the cap is also exhausted.
grep -qi "sequencing" /tmp/cap2.json \
  && fail "cap breaker must not read as a sequencing violation: $(cat /tmp/cap2.json)"
retire   # the prior cap-2 run is still open (cap breaker, never finished) (#258)
"${L[@]}" init --loop-repo "$repo" --cap 1 >/dev/null
"${L[@]}" iter-start >/dev/null
rc=0; "${L[@]}" iter-start >/tmp/seq.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "sequencing violation" /tmp/seq.json \
  || fail "a double iter-start must report sequencing, not the cap: $(cat /tmp/seq.json)"
grep -q "iteration cap reached" /tmp/seq.json \
  && fail "sequencing violation masked by the cap breaker (issue #64)"
pass "issue #64: cap and sequencing stay distinct causes; neither masks the other"

integ="$("${L[@]}" status | jget '["integration_branch"]')"
git -C "$repo" merge -q --no-ff "$integ" -m "merge integration"
"${L[@]}" gate-check | jget '["reachable"]' | grep -q True || fail "gate-check should see integration reachable from base"
pass "gate-check confirms integration reachable from base after merge"

# --- #282 / F61: an unresolvable base is UNDETERMINED, never "did not land" --
# `merge-base --is-ancestor` exits non-zero both when the ref is not an
# ancestor and when <base> does not exist at all, so a base deleted after init
# used to report a bare reachable:false — indistinguishable from a genuine
# "not merged yet" and pointing the operator at the wrong remedy.
retire
"${L[@]}" init --loop-repo "$repo" --cap 1 --base main >/dev/null
wtb="$("${L[@]}" status | jget '["worktree"]')"
"${L[@]}" iter-start >/dev/null
echo v9 > "$wtb/f"; git -C "$wtb" commit -qam iter1
"${L[@]}" iter-verify >/dev/null
# Move off main and delete it: the recorded base no longer resolves.
git -C "$repo" checkout -q --detach
git -C "$repo" branch -qD main
rc=0; "${L[@]}" gate-check >/tmp/gcbase.json 2>&1 || rc=$?
[ "$rc" = "3" ] || fail "gate-check must still exit 3 on an unresolvable base, got $rc"
[ "$(jget '["base_missing"]' </tmp/gcbase.json)" = "True" ] \
  || fail "gate-check must flag base_missing when the base does not resolve: $(cat /tmp/gcbase.json)"
[ "$(jget '["base"]' </tmp/gcbase.json)" = "main" ] \
  || fail "gate-check must name the base it tried to use: $(cat /tmp/gcbase.json)"
grep -qi "not a 'did not land' verdict" /tmp/gcbase.json \
  || fail "the hint must say the result is undetermined, not negative: $(cat /tmp/gcbase.json)"
jget '["gate_progress"]["blocker"]' </tmp/gcbase.json | grep -qi "UNDETERMINED" \
  || fail "gate_progress.blocker must not claim 'not landed yet' for an unaskable question: $(cat /tmp/gcbase.json)"
pass "#282/F61: unresolvable base reports its own cause (base_missing + undetermined), not 'did not land'"
# Restore main so later sub-tests keep their base.
git -C "$repo" branch -q main "$(git -C "$repo" rev-parse HEAD)"
git -C "$repo" checkout -q main

# --- #5: gate-push is RETIRED (two-outcomes-only delivery, triage of #262/ ----
# #263) — the loop never merges to main. gate-push must refuse (exit 3), push
# NOTHING, and never land loop output on the base. The subcommand survives only
# to give a legacy caller a clear, non-mutating refusal instead of a stale
# success.
gorigin="$tmp/gorigin"; git init -q --bare "$gorigin"
git -C "$gorigin" symbolic-ref HEAD refs/heads/main
grepo="$tmp/grepo"
git init -q "$grepo" && git -C "$grepo" config user.email t@e && git -C "$grepo" config user.name t
git -C "$grepo" checkout -qb main && echo g0 > "$grepo/f" && git -C "$grepo" add -A \
  && git -C "$grepo" commit -qm g0
git -C "$grepo" remote add origin "$gorigin" && git -C "$grepo" push -qu origin main
origin_before="$(git -C "$gorigin" rev-parse main)"
Lg=("$loop" --target gg)
wtg="$("${Lg[@]}" init --loop-repo "$grepo" --cap 1 | jget '["worktree"]')"
git -C "$wtg" commit -q --allow-empty -m iter
rc=0; "${Lg[@]}" gate-push >/tmp/gp.json 2>&1 || rc=$?
[ "$rc" = "3" ] || fail "retired gate-push must exit 3, got $rc: $(cat /tmp/gp.json)"
grep -q '"pushed": false' /tmp/gp.json \
  || fail "retired gate-push must report pushed:false: $(cat /tmp/gp.json)"
grep -q '"retired": true' /tmp/gp.json \
  || fail "retired gate-push must mark itself retired: $(cat /tmp/gp.json)"
[ "$(git -C "$gorigin" rev-parse main)" = "$origin_before" ] \
  || fail "retired gate-push must push NOTHING — the remote base must not move"
pass "#5: gate-push is retired — refuses, pushes nothing, never lands on main"

# --- #6: finish/init delete merged integration branches, keep unmerged tips --
crepo="$tmp/crepo"
git init -q "$crepo" && git -C "$crepo" config user.email t@e && git -C "$crepo" config user.name t
git -C "$crepo" checkout -qb main && echo x > "$crepo/f" && git -C "$crepo" add -A \
  && git -C "$crepo" commit -qm c0
git -C "$crepo" branch "tanuki-loop/cc/20200101-000000" main       # merged (== main tip)
git -C "$crepo" branch "tanuki-loop/cc/20200102-000000" main       # will become unmerged
git -C "$crepo" checkout -q "tanuki-loop/cc/20200102-000000"
git -C "$crepo" commit -q --allow-empty -m unmerged
git -C "$crepo" checkout -q main
Lc=("$loop" --target cc)
initout="$("${Lc[@]}" init --loop-repo "$crepo" --cap 1)"
echo "$initout" | python3 -c "import json,sys;c=json.load(sys.stdin)['branch_cleanup'];assert 'tanuki-loop/cc/20200101-000000' in c['deleted'],c;assert 'tanuki-loop/cc/20200102-000000' in c['kept'],c" \
  || fail "init should delete the merged integration branch and keep the unmerged one: $initout"
git -C "$crepo" show-ref --verify -q "refs/heads/tanuki-loop/cc/20200101-000000" \
  && fail "merged branch still present after init sweep"
git -C "$crepo" show-ref --verify -q "refs/heads/tanuki-loop/cc/20200102-000000" \
  || fail "unmerged branch was wrongly deleted"
pass "#6: init sweeps merged integration branches, keeps unmerged tips"

# finish deletes THIS run's branch once it's merged into base.
Ld=("$loop" --target dd)
# issue #200 / story 1.56: these sub-tests deliberately run several
# TARGETS against one toy repo while an earlier run is still live, so
# init's per-repo guard would refuse. The sharing is intentional here
# (the fixture asserts on the earlier run), which is exactly what
# --allow-concurrent declares — do not copy it into real usage.
wtd="$("${Ld[@]}" init --loop-repo "$crepo" --cap 1 --allow-concurrent | jget '["worktree"]')"
ibrd="$("${Ld[@]}" status | jget '["integration_branch"]')"
git -C "$wtd" commit -q --allow-empty -m iter
git -C "$crepo" merge -q --no-ff "$ibrd" -m "gate merge"
git -C "$crepo" worktree remove --force "$wtd"                     # gate step 6, pre-finish
finout="$("${Ld[@]}" finish --reason gate-ratified)"
echo "$finout" | python3 -c "import json,sys;assert '$ibrd' in json.load(sys.stdin)['branch_cleanup']['deleted']" \
  || fail "finish should delete the ratified run's merged integration branch: $finout"
git -C "$crepo" show-ref --verify -q "refs/heads/$ibrd" \
  && fail "ratified run's merged branch still present after finish"
pass "#6: finish deletes the ratified run's merged integration branch"

echo "all checks passed"
