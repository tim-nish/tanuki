#!/usr/bin/env bash
# spec-host-snapshot "Stage-entry fixtures" / story 1.17: tanuki-drive
# verifies a scenario's declared entry fixture inside the disposable host
# clone BEFORE the driver's first turn, records what the scenario entered
# from in the manifest ({name, paths, source_commit,
# producing_stage_version}; null when none), fails the scenario
# informatively when the artifacts are absent, and rejects hostless or
# dangling declarations as usage errors up front.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
drive="$here/tanuki-drive"
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
export TANUKI_ROOT="$tmp/root"

# Stub claude CLI so scenarios "run" without the API.
mkdir -p "$tmp/bin"
cat > "$tmp/bin/claude" <<'EOF'
#!/bin/sh
cat <<'JSON'
{"type":"assistant","message":{"content":[{"type":"text","text":"FRICTION LOG: none"}]}}
{"type":"result","subtype":"success","num_turns":1,"duration_ms":10,"total_cost_usd":0.001,"is_error":false,"result":"done"}
JSON
EOF
chmod +x "$tmp/bin/claude"
export PATH="$tmp/bin:$PATH"

for r in plugin host; do
  git init -q "$tmp/$r" && git -C "$tmp/$r" config user.email t@e && git -C "$tmp/$r" config user.name t
  git -C "$tmp/$r" checkout -qb main
done
echo x > "$tmp/plugin/x" && git -C "$tmp/plugin" add -A && git -C "$tmp/plugin" commit -qm base
mkdir -p "$tmp/host/facts" && echo harvested > "$tmp/host/facts/sheet.md"
git -C "$tmp/host" add -A && git -C "$tmp/host" commit -qm h0
host_tip="$(git -C "$tmp/host" rev-parse HEAD)"

cat > "$tmp/scenarios.json" <<'EOF'
{"entry_fixtures":{"harvested":{"paths":["facts/sheet.md"],
                                "producing_stage":"harvest-v1"}},
 "scenarios":[
  {"id":"s-staged","charter":"c","prompt":"p","max_turns":3,
   "entry_fixture":"harvested"},
  {"id":"s-plain","charter":"c","prompt":"p","max_turns":3}
]}
EOF

# --- estimate plan: staged-state entry is visible at the approval gate (#204)
"$drive" --target t --plugin "$tmp/plugin" --host "$tmp/host" \
  --scenarios "$tmp/scenarios.json" --run r0 --estimate \
  | python3 -c '
import json, sys
plan = {s["id"]: s for s in json.load(sys.stdin)["scenarios"]}
assert plan["s-staged"]["entry_fixture"] == "harvested", plan["s-staged"]
assert "entry_fixture" not in plan["s-plain"], plan["s-plain"]
' || fail "--estimate must name each scenario's entry fixture, absent when none"
pass "--estimate plan carries entry_fixture per scenario"

# --- hosted drive: fixture verified pre-turn, recorded in the manifest -------
"$drive" --target t --plugin "$tmp/plugin" --host "$tmp/host" \
  --scenarios "$tmp/scenarios.json" --run r1 --timeout 60 >"$tmp/r1.out" \
  || fail "drive exited non-zero"
grep -q "driving s-staged (entry fixture: harvested)" "$tmp/r1.out" \
  || fail "drive start line must name the fixture being entered"
grep -q "driving s-plain …" "$tmp/r1.out" \
  || fail "a fixture-less scenario keeps the plain start line"
python3 - "$TANUKI_ROOT/t/events/r1/manifest.json" "$host_tip" <<'PY' || fail "manifest entry_fixture wrong"
import json, sys
m = json.load(open(sys.argv[1]))
by = {r["scenario"]: r for r in m["results"]}
ef = by["s-staged"]["entry_fixture"]
assert ef["name"] == "harvested" and ef["paths"] == ["facts/sheet.md"], ef
assert ef["source_commit"] == sys.argv[2], ef
assert ef["producing_stage_version"] == "harvest-v1", ef
assert by["s-plain"]["entry_fixture"] is None, by["s-plain"]
assert by["s-staged"]["status"] == "ok", by["s-staged"]["status"]
PY
pass "manifest records the entered fixture (provenance) / null when undeclared"

# --- missing artifact: the scenario fails informatively, siblings unaffected -
git -C "$tmp/host" rm -q facts/sheet.md && git -C "$tmp/host" commit -qm rm
rc=0; "$drive" --target t --plugin "$tmp/plugin" --host "$tmp/host" \
  --scenarios "$tmp/scenarios.json" --run r2 --timeout 60 >/dev/null 2>&1 || rc=$?
[ "$rc" != "0" ] || fail "a failed scenario must fail the drive invocation"
python3 - "$TANUKI_ROOT/t/events/r2/manifest.json" <<'PY' || fail "missing-artifact handling wrong"
import json, sys
m = json.load(open(sys.argv[1]))
by = {r["scenario"]: r for r in m["results"]}
assert by["s-staged"]["status"].startswith("entry-fixture-missing"), by["s-staged"]["status"]
assert "facts/sheet.md" in by["s-staged"]["status"]
assert by["s-plain"]["status"] == "ok", by["s-plain"]["status"]
PY
pass "missing artifact fails that scenario by name; the plain sibling still drives"

# --- hostless declaration: usage error up front ------------------------------
rc=0; "$drive" --target t --plugin "$tmp/plugin" \
  --scenarios "$tmp/scenarios.json" --run r3 >/tmp/def1.out 2>&1 || rc=$?
[ "$rc" = "2" ] || fail "hostless + entry_fixture must be a usage error (got $rc)"
grep -q "HOSTLESS" /tmp/def1.out || fail "hostless error must say why: $(cat /tmp/def1.out)"
pass "hostless declaration is rejected up front as out of scope"

# --- dangling reference: usage error up front --------------------------------
python3 - "$tmp/scenarios.json" "$tmp/dangling.json" <<'PY'
import json, sys
d = json.load(open(sys.argv[1])); d.pop("entry_fixtures")
json.dump(d, open(sys.argv[2], "w"))
PY
rc=0; "$drive" --target t --plugin "$tmp/plugin" --host "$tmp/host" \
  --scenarios "$tmp/dangling.json" --run r4 >/tmp/def2.out 2>&1 || rc=$?
[ "$rc" = "2" ] || fail "a dangling entry_fixture reference must be a usage error (got $rc)"
grep -q "no entry_fixtures" /tmp/def2.out || fail "dangling error must name the recipe"
pass "dangling recipe reference is a usage error before any clone"

echo "ALL PASS"
