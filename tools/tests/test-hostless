#!/usr/bin/env bash
# Fixture for hostless drives: a host repo exists only for plugins that operate
# on a repository's content — a SELF-CONTAINED plugin has no host, and
# tanuki-drive (no --host) must fabricate an empty, isolated, git-init'd
# workspace per scenario instead of requiring one.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
drive="$here/tanuki-drive"
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
export TANUKI_ROOT="$tmp/root"

# Stub claude CLI (writes a file into its cwd so the pollution counter sees
# host-workspace writes, which are expected product behavior).
mkdir -p "$tmp/bin"
cat > "$tmp/bin/claude" <<'EOF'
#!/bin/sh
echo "artifact" > produced.txt
cat <<'JSON'
{"type":"assistant","message":{"content":[{"type":"text","text":"FRICTION LOG: none"}]}}
{"type":"result","subtype":"success","num_turns":1,"duration_ms":10,"total_cost_usd":0.001,"is_error":false,"result":"done"}
JSON
EOF
chmod +x "$tmp/bin/claude"
export PATH="$tmp/bin:$PATH"

# A self-contained plugin repo; NO host repo anywhere.
git init -q "$tmp/plugin" && git -C "$tmp/plugin" config user.email t@e && git -C "$tmp/plugin" config user.name t
git -C "$tmp/plugin" checkout -qb main && echo x > "$tmp/plugin/x" && git -C "$tmp/plugin" add -A && git -C "$tmp/plugin" commit -qm base

cat > "$tmp/scenarios.json" <<'EOF'
{"scenarios": [{"id": "solo", "charter": "c", "prompt": "p", "max_turns": 3}]}
EOF

"$drive" --target t --plugin "$tmp/plugin" \
  --scenarios "$tmp/scenarios.json" --run r1 --timeout 60 >/dev/null \
  || fail "hostless drive exited non-zero"

python3 - "$TANUKI_ROOT/t/events/r1/manifest.json" <<'PY' || fail "hostless manifest wrong"
import json, sys
m = json.load(open(sys.argv[1]))
assert m["host"] is None, m["host"]
r = m["results"][0]
assert r["status"] == "ok", r
assert r["events"] > 0
# the stub wrote into the fabricated workspace: pollution counter must see it
assert r["host_clone_changes"] >= 1, r
assert r["plugin_clone_dirty"] is False, r
PY
pass "no --host: fabricated workspace, scenario ok, pollution check still works"

ws="$TANUKI_ROOT/t/ws/r1/solo/host"
[ -d "$ws/.git" ] || fail "fabricated host workspace is not git-init'd"
[ -f "$ws/produced.txt" ] || fail "scenario did not run inside the fabricated workspace"
pass "fabricated workspace is git-init'd and was the scenario cwd"

echo "all checks passed"
