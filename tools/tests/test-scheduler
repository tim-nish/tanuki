#!/usr/bin/env bash
# Fixture for the adaptive scenario scheduler + registry
# (specs/spec-tanuki-scenario-lifecycle): registry register/resolve with
# parent-dir walk, first-sync backward compat (all active), later-sync new ids
# unexplored, plan priority order + exploration quota, demotion hysteresis
# (2 consecutive low-yield runs), re-promotion on an actionable finding,
# regression-pool cadence, and tanuki-ledger scenario-yield attribution.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
sched="$here/tanuki-scheduler"
ledger="$here/tanuki-ledger"
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
export TANUKI_ROOT="$tmp/root"
jget() { python3 -c "import json,sys;print(json.load(sys.stdin)$1)"; }
S=("$sched" --target t)

# --- registry: register + resolve with parent walk ----------------------------
mkdir -p "$tmp/work/myplugin/sub/dir"
"${S[@]}" register --repo "$tmp/work/myplugin" >/dev/null
[ "$("$sched" resolve --cwd "$tmp/work/myplugin/sub/dir" | jget '["target"]')" = "t" ] \
  || fail "resolve should walk up to the registered repo"
[ "$("$sched" resolve --cwd "$tmp/work" | jget '["target"]')" = "None" ] \
  || fail "resolve above the repo must yield null"
pass "registry: register + resolve (parent-dir walk, null outside)"

# --- matrix + first sync = all active (backward compat) -----------------------
cat > "$tmp/m.json" <<'EOF'
{"scenarios": [{"id":"a","charter":"c","prompt":"p"},
               {"id":"b","charter":"c","prompt":"p"},
               {"id":"c","charter":"c","prompt":"p"}]}
EOF
"${S[@]}" sync --scenarios "$tmp/m.json" | jget '["first_sync"]' | grep -q True || fail "first sync flag"
[ "$("${S[@]}" status | jget '["by_state"]["active"]')" = "['a', 'b', 'c']" ] \
  || fail "first sync must mark a hand-written matrix all active"
pass "first sync: hand-written matrix -> all active (no behavior change)"

# --- later sync: new id enters unexplored -------------------------------------
cat > "$tmp/m.json" <<'EOF'
{"scenarios": [{"id":"a","charter":"c","prompt":"p"},
               {"id":"b","charter":"c","prompt":"p"},
               {"id":"c","charter":"c","prompt":"p"},
               {"id":"d-new","charter":"c","prompt":"p"}]}
EOF
"${S[@]}" sync --scenarios "$tmp/m.json" >/dev/null
"${S[@]}" status | jget '["by_state"]["unexplored"]' | grep -q "d-new" \
  || fail "later sync must mark new ids unexplored"
pass "later sync: generated scenario enters unexplored"

# --- adhoc- prefix reserved ----------------------------------------------------
cat > "$tmp/bad.json" <<'EOF'
{"scenarios": [{"id":"adhoc-1","charter":"c","prompt":"p"}]}
EOF
rc=0; "${S[@]}" sync --scenarios "$tmp/bad.json" >/dev/null 2>&1 || rc=$?
[ "$rc" = "2" ] || fail "adhoc- matrix id must be rejected"
pass "adhoc- prefix is reserved for one-off scenarios"

# --- plan: exploration quota + priority order ---------------------------------
plan="$("${S[@]}" plan --scenarios "$tmp/m.json" --max 3)"
echo "$plan" | jget '["plan"]' | grep -q "d-new" || fail "plan must include the unexplored scenario (quota)"
echo "$plan" | jget '["quota_met"]' | grep -q True || fail "quota_met should be true"
pass "plan honors the exploration quota (unexplored always scheduled while any exist)"

# --- record-run: hysteresis demotion needs 2 consecutive low-yield runs -------
"$ledger" --target t init >/dev/null
mkrun() {  # mkrun <run-id> <scenario...>: manifest with those scenarios driven
  local run="$1"; shift
  mkdir -p "$TANUKI_ROOT/t/events/$run"
  python3 - "$TANUKI_ROOT/t/events/$run/manifest.json" "$@" <<'PY'
import json, sys
path, scens = sys.argv[1], sys.argv[2:]
json.dump({"results": [{"scenario": s, "events": 2} for s in scens]}, open(path, "w"))
PY
}
mkrun r001 a b
"${S[@]}" record-run --run r001 >/dev/null           # low yield #1 for a,b
[ "$("${S[@]}" status | jget '["scenarios"]["a"]["state"]')" = "active" ] \
  || fail "one low-yield run must NOT demote (hysteresis)"
mkrun r002 a b
"$ledger" --target t upsert-finding --title "b friction" --kind friction \
  --evidence "r002/b#1" >/dev/null                    # b actionable in r002
"${S[@]}" record-run --run r002 >/dev/null            # a: low #2 -> demote; b: reset
st="$("${S[@]}" status)"
[ "$(echo "$st" | jget '["scenarios"]["a"]["state"]')" = "regression" ] \
  || fail "2 consecutive low-yield runs must demote to regression"
[ "$(echo "$st" | jget '["scenarios"]["b"]["state"]')" = "active" ] \
  || fail "an actionable finding must keep the scenario active"
pass "demotion hysteresis: 2 consecutive low runs demote; a finding resets the streak"

# --- regression cadence + re-promotion ----------------------------------------
for r in r003 r004 r005; do mkrun "$r" b; "${S[@]}" record-run --run "$r" >/dev/null; done
plan="$("${S[@]}" plan --scenarios "$tmp/m.json" --max 6)"
echo "$plan" | jget '["plan"]' | grep -q "'a'" || fail "regression member due after regression_every runs must be planned"
pass "regression pool: member re-enters the plan after regression_every undriven runs"
mkrun r006 a
"$ledger" --target t upsert-finding --title "a regressed" --kind friction \
  --evidence "r006/a#1" >/dev/null
"${S[@]}" record-run --run r006 | jget '["transitions"]["a"]' | grep -q "active" \
  || fail "an actionable finding must re-promote a regression scenario"
pass "re-promotion: a finding pulls a regression scenario back to active"

# --- verify never starves the exploration quota (spec: Verify / cap interaction)
# A verify backlog as large as the cap must not consume every slot: the
# exploration quota is reserved first, verify fills the remainder LRU, and the
# overflow surfaces as verify_deferred (bounded WIP) rather than silent drop.
V=("$sched" --target v)
cat > "$tmp/v.json" <<'EOF'
{"scenarios":[{"id":"v1","charter":"c","prompt":"p"},
              {"id":"v2","charter":"c","prompt":"p"},
              {"id":"v3","charter":"c","prompt":"p"}]}
EOF
"${V[@]}" sync --scenarios "$tmp/v.json" >/dev/null          # first sync -> all active
cat > "$tmp/v.json" <<'EOF'
{"scenarios":[{"id":"v1","charter":"c","prompt":"p"},
              {"id":"v2","charter":"c","prompt":"p"},
              {"id":"v3","charter":"c","prompt":"p"},
              {"id":"u1","charter":"c","prompt":"p"}]}
EOF
"${V[@]}" sync --scenarios "$tmp/v.json" >/dev/null          # later sync -> u1 unexplored
"$ledger" --target v init >/dev/null
for s in v1 v2 v3; do
  "$ledger" --target v upsert-finding --title "acc $s" --kind gap \
    --evidence "r001/$s#1" >/dev/null
done
for id in F1 F2 F3; do "$ledger" --target v set-status --id "$id" --status accepted >/dev/null; done
plan="$("${V[@]}" plan --scenarios "$tmp/v.json" --max 3)"      # verify(3) == cap(3)
echo "$plan" | jget '["plan"]' | grep -q "u1" \
  || fail "reserved exploration quota crowded out by the verify backlog"
echo "$plan" | jget '["quota_met"]' | grep -q True \
  || fail "quota_met must hold even when verify fills the cap"
plen="$(echo "$plan" | python3 -c "import json,sys;print(len(json.load(sys.stdin)['plan']))")"
[ "$plen" = "3" ] || fail "plan must respect max_scenarios (got $plen)"
vdef="$(echo "$plan" | python3 -c "import json,sys;print(len(json.load(sys.stdin)['verify_deferred']))")"
[ "$vdef" = "1" ] || fail "overflowed verify must surface as verify_deferred, got $vdef"
pass "verify reserves the exploration quota, stays within the cap, surfaces overflow as verify_deferred"

# --- history: persisted yield snapshots, transitions, plans, coverage ---------
"${S[@]}" plan --scenarios "$tmp/m.json" --run r007 >/dev/null   # persisted plan record
hist="$("${S[@]}" history --json)"
echo "$hist" | python3 -c '
import json, sys
h = json.load(sys.stdin)
rows = {r["scenario"]: r for r in h["scenarios"]}
# execution counts + last run from manifests: a in r001,r002,r006; b in r001-r005
assert rows["a"]["driven"] == 3 and rows["b"]["driven"] == 5, (rows["a"]["driven"], rows["b"]["driven"])
assert rows["a"]["last_run"] == "r006" and rows["b"]["last_run"] == "r005"
# cumulative recurrence flows from the ledger
assert rows["b"]["cumulative_recurrence"] >= 1
# selection history persisted with reasons + run id
plans = h["selection_history"]
assert any(p.get("run") == "r007" and "quota_met" in p for p in plans), plans
# coverage buckets exist
assert "unexplored" in h["coverage"] and "productive" in h["coverage"]
# a: actionable finding in r006 (its last 3 executions) -> recently productive;
# b: last 3 executions r003-r005 all quiet -> not productive
assert "a" in h["coverage"]["productive"] and "b" not in h["coverage"]["productive"]
' || fail "repo-wide history wrong"
pass "history (repo-wide): executions, cumulative recurrence, coverage, persisted plans"

"${S[@]}" history --scenario a --json > /tmp/hista.json
python3 - /tmp/hista.json <<'PY' || fail "per-scenario history wrong"
import json, sys
d = json.load(open(sys.argv[1]))
assert d["state"] == "active"          # re-promoted in r006
runs = [e["run"] for e in d["executions"]]
assert runs == ["r001", "r002", "r006"], runs
# exact (snapshotted) yield: no approx flag on recorded runs
assert all(e["approx"] is False for e in d["executions"])
r6 = d["executions"][-1]
assert r6["actionable"] == 1 and r6["findings"] == ["F2"], r6
# transition log carries why + when
kinds = [(t["run"], t["to"]) for t in d["transitions"]]
assert ("r002", "regression") in kinds and ("r006", "active") in kinds, kinds
reasons = " ".join(t["reason"] for t in d["transitions"])
# F203: the demotion reason counts driven executions, not scheduling rounds
assert "consecutive driven low-yield executions" in reasons \
    and "actionable finding" in reasons
PY
pass "history (--scenario): exact per-execution yield, transition log with reasons"

# --- history rejects the removed --scenarios flag ------------------------------
# Axis coverage / exploration debt / coverage diff were REMOVED 2026-07-18
# (operator decision; spec-tanuki-view D2 amendment). The flag must fail
# loudly, not silently ignore a matrix.
if "${S[@]}" history --scenarios "$tmp/m.json" >/dev/null 2>&1; then
  fail "history must reject the removed --scenarios flag"
fi
h="$("${S[@]}" history --json)"
echo "$h" | python3 -c '
import json, sys
h = json.load(sys.stdin)
for k in ("axes_coverage", "debt", "recommendations", "coverage_diff"):
    assert k not in h, f"removed key {k} still emitted"
' || fail "removed coverage keys still in history --json"
pass "coverage removal: --scenarios rejected; no coverage keys in history"

# --- scenario-yield attribution -------------------------------------------------
"$ledger" --target t scenario-yield --runs 9 > /tmp/yield.json
python3 - /tmp/yield.json <<'PY' || fail "scenario-yield attribution wrong"
import json, sys
y = json.load(open(sys.argv[1]))
r2 = next(h for h in y["b"] if h["run"] == "r002")
assert r2["actionable"] == 1 and r2["findings"] == ["F1"], r2
r1 = next(h for h in y["a"] if h["run"] == "r001")
assert r1["actionable"] == 0, r1
PY
pass "tanuki-ledger scenario-yield attributes findings to (run, scenario) correctly"

# --- missing scenarios config fails closed naming the canonical path (issue #4)
rc=0; "$here/tanuki-scheduler" --target demo sync \
  --scenarios "$TANUKI_ROOT/scenarios/demo.scenarios.json" >/tmp/miss.txt 2>&1 || rc=$?
[ "$rc" = "2" ] || fail "missing scenarios config must exit 2 (got $rc)"
grep -q "canonical location: $TANUKI_ROOT/scenarios/demo.scenarios.json" /tmp/miss.txt \
  || fail "missing-config error must name the canonical path: $(cat /tmp/miss.txt)"
grep -q "templates/tanuki/ is NOT read" /tmp/miss.txt \
  || fail "missing-config error should warn the undocumented path is not read"
pass "loader fails closed on a missing scenarios config, naming the canonical path"

# --- F201/F202/F205: plan JSON clarity ----------------------------------------
# tiebreak named on a cap cut among equal last_planned; verify reason names a
# regression-pool pick; regression_pool lists proximity for every pool member.
P=("$sched" --target p)
cat > "$tmp/p.json" <<'EOF'
{"scenarios":[{"id":"x","charter":"c","prompt":"p"},
              {"id":"y","charter":"c","prompt":"p"},
              {"id":"z","charter":"c","prompt":"p"}]}
EOF
"${P[@]}" sync --scenarios "$tmp/p.json" >/dev/null      # first sync: all active
"${P[@]}" plan --scenarios "$tmp/p.json" --max 2 --dry-run | python3 -c '
import json, sys
r = json.load(sys.stdin)
tb = {t["group"]: t["rule"] for t in r.get("tiebreak", [])}
assert "active" in tb and "insertion order" in tb["active"], r.get("tiebreak")
' || fail "a --max cut among equal last_planned must emit the tie-break rule"
pass "F201: cap cut among equal last_planned names the applied tie-break"
for q in q1 q2; do                                       # two quiet drives of x
  mkdir -p "$TANUKI_ROOT/p/events/$q"
  echo '{"results":[{"scenario":"x","events":2}]}' \
    > "$TANUKI_ROOT/p/events/$q/manifest.json"
  "${P[@]}" record-run --run "$q" >/dev/null
done                                                     # -> x demoted
"$ledger" --target p init >/dev/null
"$ledger" --target p upsert-finding --title "x bug" --kind gap \
  --evidence "q1/x#1" >/dev/null
"$ledger" --target p set-status --id F1 --status accepted >/dev/null
"${P[@]}" plan --scenarios "$tmp/p.json" --max 3 --dry-run | python3 -c '
import json, sys
r = json.load(sys.stdin)
sel = {e["finding"]: e for e in r["verify_selection"]}
assert sel["F1"]["scenario"] == "x", sel
assert sel["F1"]["reason"].endswith("(from regression pool)"), sel
pool = {e["scenario"]: e for e in r["regression_pool"]}
assert pool["x"] == {"scenario": "x", "since_regression": 0,
                     "runs_until_due": 3}, pool
' || fail "pool-state verify reason / regression_pool proximity wrong"
pass "F202/F205: verify reason names the pool pick; regression_pool shows proximity"

# --- F222: the scenarios file's own target field is consulted (warn only) -----
cat > "$tmp/other.json" <<'EOF'
{"target": "somebody-else",
 "scenarios": [{"id":"w1","charter":"c","prompt":"p"}]}
EOF
"$sched" --target w sync --scenarios "$tmp/other.json" >/tmp/f222.json 2>/tmp/f222.err
grep -q "somebody-else" /tmp/f222.err && grep -q "'w'" /tmp/f222.err \
  || fail "target mismatch must warn naming both values: $(cat /tmp/f222.err)"
grep -q "CLI value wins" /tmp/f222.err || fail "F222 warning must state CLI wins"
jget '["first_sync"]' < /tmp/f222.json | grep -q True \
  || fail "F222 must warn, never block"
"$sched" --target w plan --scenarios "$tmp/other.json" --dry-run \
  >/dev/null 2>/tmp/f222p.err
grep -q "somebody-else" /tmp/f222p.err || fail "plan must also warn on mismatch"
pass "F222: file target vs --target mismatch warns (both named; CLI wins)"

# --- F94: later sync into colliding pre-existing state warns ------------------
C=("$sched" --target coll)
cat > "$tmp/proj1.json" <<'EOF'
{"scenarios": [{"id":"p1-a","charter":"c","prompt":"p"},
               {"id":"p1-b","charter":"c","prompt":"p"}]}
EOF
"${C[@]}" sync --scenarios "$tmp/proj1.json" >/dev/null 2>&1
cat > "$tmp/proj2.json" <<'EOF'
{"scenarios": [{"id":"p2-x","charter":"c","prompt":"p"}]}
EOF
"${C[@]}" sync --scenarios "$tmp/proj2.json" >/tmp/f94.json 2>/tmp/f94.err
grep -q "pre-existing scheduler state" /tmp/f94.err \
  || fail "colliding sync must warn on stderr: $(cat /tmp/f94.err)"
grep -q "p1-a, p1-b" /tmp/f94.err \
  || fail "F94 warning must name the existing ids absent from this file"
grep -q "proj1.json" /tmp/f94.err \
  || fail "F94 warning must name the prior scenarios-file path"
jget '["warning"]' < /tmp/f94.json | grep -q "pre-existing" \
  || fail "F94 warning must also appear in the JSON"
jget '["first_sync"]' < /tmp/f94.json | grep -q False \
  || fail "F94 must never block the sync"
# re-sync of the SAME file into matching state stays silent
"$sched" --target quiet sync --scenarios "$tmp/proj1.json" >/dev/null 2>&1
"$sched" --target quiet sync --scenarios "$tmp/proj1.json" >/dev/null 2>/tmp/f94q.err
[ -s /tmp/f94q.err ] && fail "matching re-sync must not warn: $(cat /tmp/f94q.err)"
pass "F94: sync collision (stale ids / different file) warns; clean re-sync silent"

# --- F218: record-run with no manifest warns loudly, still records ------------
r218="$("${S[@]}" record-run --run ghost-run 2>/tmp/f218.err)"
echo "$r218" | jget '["ok"]' | grep -q True || fail "no-manifest record must stay ok:true"
echo "$r218" | jget '["warning"]' \
  | grep -q "no manifest found for run ghost-run" \
  || fail "F218: JSON must carry the no-manifest warning: $r218"
echo "$r218" | jget '["warning"]' | grep -q "cannot be re-recorded" \
  || fail "F218 warning must say the record is permanent"
grep -q "no manifest found for run ghost-run" /tmp/f218.err \
  || fail "F218 warning must also hit stderr"
"${S[@]}" record-run --run ghost-run 2>/tmp/f218b.err | jget '["already_recorded"]' \
  | grep -q ghost-run || fail "no-manifest run must still be recorded"
[ -s /tmp/f218b.err ] && fail "already-recorded no-op must not re-warn"
pass "F218: manifest-less record-run keeps ok:true but warns in JSON and stderr"

# --- F219: inline findings in a manifest result are named as ignored ----------
mkdir -p "$TANUKI_ROOT/t/events/r008"
echo '{"results":[{"scenario":"b","events":2,"findings":["inline attempt"]}]}' \
  > "$TANUKI_ROOT/t/events/r008/manifest.json"
"${S[@]}" record-run --run r008 >/dev/null 2>/tmp/f219.err
grep -q "inline findings are ignored" /tmp/f219.err \
  || fail "F219: yield-shaped result keys must warn: $(cat /tmp/f219.err)"
grep -q "ledger evidence pointers" /tmp/f219.err \
  || fail "F219 warning must point at the real yield source"
"${S[@]}" record-run --help > /tmp/f219h.txt
grep -q '"results"' /tmp/f219h.txt && grep -q "evidence pointer" /tmp/f219h.txt \
  || fail "F219: record-run --help must document the consumed manifest shape"
grep -qi "inline" /tmp/f219h.txt \
  || fail "F219: --help must state inline findings are not read"
pass "F219: manifest schema in --help; inline-findings attempt flagged on stderr"

# --- F220: an empty plan explains itself ---------------------------------------
E=("$sched" --target empt)
cat > "$tmp/e.json" <<'EOF'
{"scenarios": [{"id":"e1","charter":"c","prompt":"p"}]}
EOF
"${E[@]}" sync --scenarios "$tmp/e.json" >/dev/null
for r in e001 e002; do                                   # two quiet drives -> regression
  mkdir -p "$TANUKI_ROOT/empt/events/$r"
  echo '{"results":[{"scenario":"e1","events":2}]}' \
    > "$TANUKI_ROOT/empt/events/$r/manifest.json"
  "${E[@]}" record-run --run "$r" >/dev/null
done
"${E[@]}" plan --scenarios "$tmp/e.json" --dry-run | python3 -c '
import json, sys
r = json.load(sys.stdin)
assert r["plan"] == [], r["plan"]
assert "all 1 scenarios resting in regression cooldown" in r["note"], r["note"]
assert "nearest due in 3 runs" in r["note"] and "regression_pool" in r["note"], r["note"]
' || fail "empty plan (regression cooldown) must carry an explanatory note"
# persisted (non-dry-run) record carries the same note
"${E[@]}" plan --scenarios "$tmp/e.json" --run e003 >/dev/null
"${E[@]}" history --json | python3 -c '
import json, sys
p = json.load(sys.stdin)["selection_history"][-1]
assert p["plan"] == [] and "regression cooldown" in p["note"], p
' || fail "empty-plan note must persist in the selection history"
pass "F220: empty plan names the cause (cooldown + nearest due) in a top-level note"

# --- F221: history orders runs chronologically, not lexically -----------------
K=("$sched" --target chron)
cat > "$tmp/k.json" <<'EOF'
{"scenarios": [{"id":"g","charter":"c","prompt":"p"}]}
EOF
"${K[@]}" sync --scenarios "$tmp/k.json" >/dev/null
# lexically 'manual-…' sorts AFTER any dated id; chronologically it is older
for r in manual-20260105-120000 20260401-zz; do
  mkdir -p "$TANUKI_ROOT/chron/events/$r"
  echo '{"results":[{"scenario":"g","events":2}]}' \
    > "$TANUKI_ROOT/chron/events/$r/manifest.json"
  "${K[@]}" record-run --run "$r" >/dev/null
done
"${K[@]}" history --scenario g --json | python3 -c '
import json, sys
d = json.load(sys.stdin)
runs = [e["run"] for e in d["executions"]]
assert runs == ["manual-20260105-120000", "20260401-zz"], runs
assert d["last_execution"]["run"] == "20260401-zz", d["last_execution"]
' || fail "history --scenario must sort executions by embedded date (F221)"
"${K[@]}" history --json | python3 -c '
import json, sys
rows = {r["scenario"]: r for r in json.load(sys.stdin)["scenarios"]}
assert rows["g"]["last_run"] == "20260401-zz", rows["g"]
' || fail "repo-wide history last_run must be chronological (F221)"
pass "F221: last_execution/last_run keyed on the embedded YYYYMMDD date"

echo "all checks passed"
