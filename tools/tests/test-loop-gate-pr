#!/usr/bin/env bash
# Fixture for the PR-protected-target gate flow (spec-tanuki-loop
# "PR-protected targets"). The contract under test:
#   - gate-pr refuses (exit 3, nothing pushed) before the run is finished,
#     and when final tests have not passed on the CURRENT integration HEAD;
#   - on a finished+tested run it pushes the integration branch and opens ONE
#     ready-for-review PR (ready-by-default amendment 2026-07-20) — the
#     delivery of review material, not ratification;
#   - the Draft is opt-in (`gate-pr --draft` or loop block gate_pr_draft:true),
#     and a re-run reconciles an existing PR's draft status to the intended one;
#   - it is idempotent: a re-run reuses the recorded PR, never duplicates;
#   - a push failure leaves the local integration branch intact;
#   - it NEVER merges (the fake gh records every invocation; no merge call
#     may appear);
#   - finish --reason gate-ratified refuses while the PR is unmerged, refuses
#     when the PR merged but local base does not contain the merge, and
#     passes only when both hold;
#   - doctor's gate-pr-tooling check is ok (skipped) for branch mode, and
#     fails in pr mode when gh is absent.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
root="$(mktemp -d)"; trap 'rm -rf "$root"' EXIT
export TANUKI_ROOT="$root"
L=("$here/tanuki-loop" --target t)
jget() { python3 -c "import json,sys; d=json.load(sys.stdin); print(d$1)"; }

# --- fake gh: scripted by files, records every call --------------------------
# $root/gh-state/pr_state   -> what `pr view` reports (OPEN | MERGED)
# $root/gh-state/calls.log  -> every gh invocation, one per line
mkdir -p "$root/bin" "$root/gh-state"
echo "OPEN" > "$root/gh-state/pr_state"
cat > "$root/bin/gh" <<SHIM
#!/usr/bin/env bash
state_dir="$root/gh-state"
echo "\$*" >> "\$state_dir/calls.log"
case "\$1 \$2" in
  "pr list")   echo "[]" ;;
  "pr create") echo "https://example.invalid/owner/repo/pull/7" ;;
  "pr ready")  echo "ready toggled" ;;   # covers \`pr ready\` and \`pr ready --undo\`
  "pr view")
    if echo "\$*" | grep -q "baseRefName"; then
      if [ -f "\$state_dir/pr_base" ]; then
        # isDraft defaults to false (a PR created ready-for-review); the draft
        # transition tests script pr_isdraft to drive reconciliation.
        isd="\$(cat "\$state_dir/pr_isdraft" 2>/dev/null || echo false)"
        echo "{\"baseRefName\": \"\$(cat "\$state_dir/pr_base")\", \"headRefName\": \"h\", \"isDraft\": \$isd}"
      else
        echo "fake gh: pr_base not scripted" >&2; exit 1
      fi
      exit 0
    fi
    st="\$(cat "\$state_dir/pr_state")"
    if [ "\$st" = "MERGED" ]; then
      oid="\$(cat "\$state_dir/merge_oid" 2>/dev/null || echo "")"
      echo "{\"state\": \"MERGED\", \"mergeCommit\": {\"oid\": \"\$oid\"}}"
    else
      echo "{\"state\": \"\$st\", \"mergeCommit\": null}"
    fi ;;
  *) echo "fake gh: unscripted call: \$*" >&2; exit 1 ;;
esac
SHIM
chmod +x "$root/bin/gh"
export PATH="$root/bin:$PATH"

# --- repo with a bare origin --------------------------------------------------
repo="$root/repo"; mkdir -p "$repo"
git init -q "$repo"; git -C "$repo" config user.email a@b.c
git -C "$repo" config user.name t
echo x > "$repo/f.txt"; git -C "$repo" add -A; git -C "$repo" commit -qm init
base="$(git -C "$repo" rev-parse --abbrev-ref HEAD)"
bare="$root/remote.git"; git init -q --bare "$bare"
git -C "$repo" remote add origin "$bare"
git -C "$repo" push -q -u origin "$base"

# --- doctor: gate-pr-tooling check -------------------------------------------
scen="$root/scen.json"
cat > "$scen" <<JSON
{"target": "t", "loop": {"test_cmd": "true", "iterations": 3,
 "wall_time_s": 600, "token_budget": 1000, "attempt_cap": 2, "gate": "pr"}}
JSON
"${L[@]}" doctor --loop-repo "$repo" --scenarios "$scen" \
  | jget '["checks"]' | grep -q "gate mode 'pr': \`gh\` found" \
  || fail "doctor must report gh found for a pr-gate target"
pass "doctor: gate-pr-tooling ok when gh present (pr mode)"

# A PATH with git but genuinely no gh (the host may have gh installed).
mkdir -p "$root/nogh"
ln -s "$(command -v git)" "$root/nogh/git"
# The REAL interpreter, not a version-manager shim (a pyenv shim re-resolves
# through PATH and dies inside the restricted environment).
ln -s "$(python3 -c 'import sys; print(sys.executable)')" "$root/nogh/python3"
ln -s "$(command -v bash)" "$root/nogh/bash"
ln -s "$(command -v sh)" "$root/nogh/sh"
out="$(PATH="$root/nogh" "$here/tanuki-loop" --target t doctor \
       --loop-repo "$repo" --scenarios "$scen" || true)"
echo "$out" | grep -q "gate-pr-tooling" \
  && echo "$out" | grep -q "not on PATH" \
  || fail "doctor must fail gate-pr-tooling when gh is absent in pr mode"
pass "doctor: gate-pr-tooling fails when gh absent (pr mode)"

# Branch-only gate needs no forge tooling — doctor says so explicitly (the
# removed "merge" gate is auto-migrated to "pr", so --gate merge would NOT
# skip; the hostless case is now --gate branch). Two-outcomes-only, #262/#263.
"${L[@]}" doctor --loop-repo "$repo" --scenarios "$scen" --gate branch \
  | jget '["checks"]' | grep -q "gate mode 'branch'" \
  || fail "doctor must note branch mode needs no forge tooling"
pass "doctor: gate-pr-tooling explicit skip note in branch mode"

# --- init (pr mode) + one verified iteration ---------------------------------
wt="$("${L[@]}" init --loop-repo "$repo" --scenarios "$scen" \
      | jget '["worktree"]')"
integ="$(cat "$root/t/loop/$(cat "$root/t/loop/current")/state.json" \
         | jget '["integration_branch"]')"
"${L[@]}" iter-start >/dev/null
echo work >> "$wt/f.txt"; git -C "$wt" commit -qam "loop work"
"${L[@]}" test >/dev/null
"${L[@]}" iter-verify >/dev/null

# --- gate-pr refuses on an unfinished run ------------------------------------
if "${L[@]}" gate-pr >/dev/null 2>&1; then
  fail "gate-pr must refuse while the run is not finished"
fi
pass "gate-pr refuses before finish (run not closed)"

"${L[@]}" finish --reason cap >/dev/null

# --- gate-pr refuses on a stale test pass ------------------------------------
# The recorded pass predates this new commit, so the SHA no longer matches.
echo more >> "$wt/f.txt"; git -C "$wt" commit -qam "post-test drift"
if "${L[@]}" gate-pr >/dev/null 2>&1; then
  fail "gate-pr must refuse when last_test.sha != integration HEAD"
fi
pass "gate-pr refuses a stale final-test pass (SHA mismatch)"
"${L[@]}" test >/dev/null   # re-validate the current HEAD

# --- push failure leaves the local branch intact ------------------------------
git -C "$repo" remote set-url origin "$root/nonexistent.git"
if pf="$("${L[@]}" gate-pr 2>/dev/null)"; then
  fail "gate-pr must fail when the push fails"
fi
git -C "$repo" rev-parse --verify -q "$integ" >/dev/null \
  || fail "a failed push must leave the local integration branch intact"
pass "push failure: exit 3, local integration branch intact"
# F192: the failure payload names the attempted refs, a cause classification,
# and the documented recovery — never just the raw gh/git stderr.
[ "$(echo "$pf" | jget '["base"]')" = "$base" ] \
  && [ "$(echo "$pf" | jget '["integration_branch"]')" = "$integ" ] \
  || fail "failure payload must name the attempted base + integration branch"
[ "$(echo "$pf" | jget '["cause"]')" = "push failure" ] \
  || fail "failure payload must classify the cause (push failure)"
echo "$pf" | jget '["recovery"]' | grep -q "hand-create the PR" \
  || fail "failure payload must carry the documented recovery"
pass "push failure payload: refs + cause + recovery (F192)"

# --- F230: the recovery advice is cause-specific ------------------------------
# A missing base ref on the forge cannot be fixed by hand-creating a PR against
# it — the recovery must say to restore/push the base first; every other cause
# keeps the generic hand-create path.
python3 - "$here/tanuki-loop" <<'PY' || fail "gate-pr recovery must be cause-aware (F230)"
import importlib.machinery, importlib.util, sys
loader = importlib.machinery.SourceFileLoader("tl", sys.argv[1])
spec = importlib.util.spec_from_loader("tl", loader)
tl = importlib.util.module_from_spec(spec); loader.exec_module(tl)
miss = tl._gate_pr_recovery("intg", "feat", "base ref not found on forge")
assert "does not exist on the forge" in miss and "push/restore" in miss, miss
assert "hand-create the PR `intg -> feat`" not in miss, miss
for c in (None, "push failure", "other"):
    gen = tl._gate_pr_recovery("intg", "feat", c)
    assert "hand-create the PR `intg -> feat`" in gen, (c, gen)
print("ok")
PY
pass "F230: gate-pr recovery is cause-specific (missing base ref vs generic)"
git -C "$repo" remote set-url origin "$bare"

# --- happy path: push + ONE ready-for-review PR (ready-by-default) ------------
res="$("${L[@]}" gate-pr)"
[ "$(echo "$res" | jget '["created"]')" = "True" ] \
  || fail "gate-pr must create the PR on first success"
[ "$(echo "$res" | jget '["pr"]["number"]')" = "7" ] \
  || fail "gate-pr must record the PR number"
[ "$(echo "$res" | jget '["pr"]["draft"]')" = "False" ] \
  || fail "the delivered PR must be ready-for-review by default (not a Draft)"
git -C "$repo" rev-parse --verify -q "refs/remotes/origin/${integ#refs/heads/}" \
  >/dev/null 2>&1 || git -C "$bare" rev-parse --verify -q "$integ" >/dev/null \
  || fail "the integration branch must be on the remote"
grep -q "pr create" "$root/gh-state/calls.log" \
  || fail "gate-pr must create the PR"
if grep -q "pr create --draft" "$root/gh-state/calls.log"; then
  fail "the PR must NOT be a Draft by default (ready-by-default 2026-07-20)"
fi
pass "finished+tested run: branch pushed, one ready-for-review PR opened"

# --- the delivery record is the loop's terminal fact --------------------------
[ "$(echo "$res" | jget '["delivered"]["pr"]')" = "7" ] \
  || fail "gate-pr must record delivered.pr"
[ -n "$(echo "$res" | jget '["delivered"]["head_sha"]')" ] \
  || fail "gate-pr must record delivered.head_sha"
[ -n "$(echo "$res" | jget '["delivered"]["base_sha"]')" ] \
  || fail "gate-pr must record delivered.base_sha"
pass "delivery recorded: {pr, head_sha, base_sha} — the loop ends here"

# --- settlement is DERIVED, not declared --------------------------------------
[ "$(("${L[@]}" status) | jget '["settlement"]["result"]')" = "pending" ] \
  || fail "status must derive settlement=pending while the PR is open"
pass "status derives settlement: pending (PR open on the forge)"

# Offline: the forge is unreachable — show the LAST OBSERVED result with its
# timestamp, marked stale; never an optimistic default.
off="$(PATH="$root/nogh" "$here/tanuki-loop" --target t status)"
[ "$(echo "$off" | jget '["settlement"]["result"]')" = "pending" ] \
  || fail "offline status must serve the last observed settlement"
[ "$(echo "$off" | jget '["settlement"]["stale"]')" = "True" ] \
  || fail "an offline-served observation must be marked stale"
pass "offline: last observed settlement served, marked stale with timestamp"

# --- idempotency: re-run reuses, never duplicates -----------------------------
# F193: a reused PR's base comes from the FORGE (baseRefName), never restated
# from local state.
echo "$base" > "$root/gh-state/pr_base"
res2="$("${L[@]}" gate-pr)"
[ "$(echo "$res2" | jget '["reused"]')" = "True" ] \
  || fail "a second gate-pr must reuse the recorded PR"
[ "$(grep -c "pr create" "$root/gh-state/calls.log")" = "1" ] \
  || fail "gate-pr must never create a second PR for the same head"
pass "idempotent: re-run reuses PR #7, no duplicate create"

# --- F193: the reused PR's base is the forge's fact ---------------------------
[ "$(echo "$res2" | jget '["pr"]["base"]')" = "$base" ] \
  || fail "reuse must stamp the forge's baseRefName"
[ "$(echo "$res2" | jget '["warning"]')" = "None" ] \
  || fail "no warning when the forge base matches state's base"
# Re-targeted on the forge: record the forge's value, with a warning.
echo "retargeted-base" > "$root/gh-state/pr_base"
res3="$("${L[@]}" gate-pr)"
[ "$(echo "$res3" | jget '["pr"]["base"]')" = "retargeted-base" ] \
  || fail "a re-targeted PR must record the forge's base, not state's"
echo "$res3" | jget '["warning"]' | grep -q "retargeted-base" \
  || fail "a forge/state base mismatch must carry a warning"
# The re-targeted base does not resolve locally: delivered.base_sha is null,
# but never silently — the warning names the missing ref (F191).
echo "$res3" | jget '["warning"]' | grep -q "does not resolve" \
  || fail "an unresolvable base must be named in the warning, never silent"
pass "reuse reads baseRefName from the forge; mismatch warned (F193/F191)"
# Forge read failure: fall back to state's base, with a note.
rm -f "$root/gh-state/pr_base"
resf="$("${L[@]}" gate-pr)"
[ "$(echo "$resf" | jget '["pr"]["base"]')" = "$base" ] \
  || fail "a failed forge read must fall back to state's base"
echo "$resf" | jget '["pr"]["base_note"]' | grep -q "falling back" \
  || fail "the fallback must carry a note that the forge read failed"
pass "forge read failure: local base fallback, noted (F193)"
echo "$base" > "$root/gh-state/pr_base"
"${L[@]}" gate-pr >/dev/null   # restore the recorded base for the tests below

# --- draft status is reconciled on re-run (ready-by-default + --draft opt-in) -
# The delivered PR is ready (isDraft=false on the forge). Opting into a Draft
# on a re-run must transition the existing PR via `gh pr ready --undo`, never
# create a second PR.
echo false > "$root/gh-state/pr_isdraft"
: > "$root/gh-state/calls.log"
resd="$("${L[@]}" gate-pr --draft)"
[ "$(echo "$resd" | jget '["reused"]')" = "True" ] \
  || fail "gate-pr --draft on a delivered run must reuse, not recreate"
[ "$(echo "$resd" | jget '["pr"]["draft"]')" = "True" ] \
  || fail "gate-pr --draft must record the PR as a Draft"
grep -q "pr ready --undo" "$root/gh-state/calls.log" \
  || fail "a ready->draft transition must call \`gh pr ready --undo\`"
if grep -q "pr create" "$root/gh-state/calls.log"; then
  fail "a draft transition must never create a second PR"
fi
pass "reuse: ready->draft reconciled via \`pr ready --undo\`, no new PR"

# Now the forge PR is a Draft; the default (ready) re-run must un-draft it via
# `gh pr ready` (no --undo).
echo true > "$root/gh-state/pr_isdraft"
: > "$root/gh-state/calls.log"
resr="$("${L[@]}" gate-pr)"
[ "$(echo "$resr" | jget '["pr"]["draft"]')" = "False" ] \
  || fail "default gate-pr must reconcile a Draft PR back to ready-for-review"
grep -q "pr ready" "$root/gh-state/calls.log" \
  || fail "a draft->ready transition must call \`gh pr ready\`"
if grep -q "pr ready --undo" "$root/gh-state/calls.log"; then
  fail "a draft->ready transition must not pass --undo"
fi
pass "reuse: draft->ready reconciled via \`pr ready\` (no --undo)"

# Idempotent: when the forge already matches the intended status, no transition
# call is made.
echo false > "$root/gh-state/pr_isdraft"
: > "$root/gh-state/calls.log"
"${L[@]}" gate-pr >/dev/null
if grep -q "pr ready" "$root/gh-state/calls.log"; then
  fail "no draft transition when the PR is already in the intended state"
fi
pass "reuse: already-ready PR is a no-op (no \`pr ready\` call)"
rm -f "$root/gh-state/pr_isdraft"
echo "$base" > "$root/gh-state/pr_base"
"${L[@]}" gate-pr >/dev/null   # re-restore recorded base for the tests below

# --- opt-in via the loop block: gate_pr_draft:true delivers a Draft on CREATE -
# Validates the whole opt-in chain: loop_config reads gate_pr_draft, init
# stores it in run state, and gate-pr passes --draft to `gh pr create`.
scend="$root/scend.json"
cat > "$scend" <<JSON
{"target": "td", "loop": {"test_cmd": "true", "iterations": 3,
 "wall_time_s": 600, "token_budget": 1000, "attempt_cap": 2, "gate": "pr",
 "gate_pr_draft": true}}
JSON
LD=("$here/tanuki-loop" --target td)
wtd="$("${LD[@]}" init --loop-repo "$repo" --scenarios "$scend" | jget '["worktree"]')"
[ "$(cat "$root/td/loop/$(cat "$root/td/loop/current")/state.json" \
     | jget '["gate_pr_draft"]')" = "True" ] \
  || fail "init must store the loop block's gate_pr_draft opt-in in run state"
"${LD[@]}" iter-start >/dev/null
echo w >> "$wtd/f.txt"; git -C "$wtd" commit -qam "td work"
"${LD[@]}" test >/dev/null
"${LD[@]}" iter-verify >/dev/null
"${LD[@]}" finish --reason cap >/dev/null
: > "$root/gh-state/calls.log"
resdc="$("${LD[@]}" gate-pr)"
[ "$(echo "$resdc" | jget '["pr"]["draft"]')" = "True" ] \
  || fail "gate_pr_draft:true must deliver a Draft PR on create"
grep -q "pr create --draft" "$root/gh-state/calls.log" \
  || fail "the loop block opt-in must pass --draft to \`gh pr create\`"
pass "loop block gate_pr_draft:true delivers a Draft on create (opt-in chain)"

# --- unresolved annotates a delivered branch with its settlement --------------
unres="$("${L[@]}" unresolved --json)"
[ "$(echo "$unres" | jget '["branches"][0]["delivered"]["settlement"]["result"]')" = "pending" ] \
  || fail "unresolved must annotate a delivered branch as pending, not rot"
pass "unresolved: delivered branch annotated settlement=pending (not debt)"

# --- dashboard: a delivered run reports settlement, not local gate steps ------
dash="$("${L[@]}" dashboard)"
echo "$dash" | grep -q "DELIVERED: PR #7" \
  || fail "dashboard must show the delivery"
echo "$dash" | grep -q "SETTLEMENT: pending" \
  || fail "dashboard must show the derived settlement"
echo "$dash" | grep -q "review + merge the PR" \
  || fail "dashboard NEXT must point at the forge, not local merge steps"
if echo "$dash" | grep -q "approve or reject the merge"; then
  fail "a delivered run must not show the local morning-gate steps"
fi
pass "dashboard: delivered run shows settlement + forge NEXT, no local gate"

# --- declined: closed without merging is derivable debt -----------------------
echo "CLOSED" > "$root/gh-state/pr_state"
[ "$(("${L[@]}" status) | jget '["settlement"]["result"]')" = "declined" ] \
  || fail "status must derive settlement=declined for a closed-unmerged PR"
pass "status derives settlement: declined (closed without merge)"
echo "OPEN" > "$root/gh-state/pr_state"

# --- compatibility: finish gate-ratified is NOT a workflow step ---------------
# It survives only as a guard: invoked anyway, it refuses unless the delivery
# verifiably landed in the local base.
if "${L[@]}" finish --reason gate-ratified >/dev/null 2>&1; then
  fail "compat finish gate-ratified must refuse while the PR is open"
fi
pass "compat guard: gate-ratified refuses while settlement=pending"

# Operator merges ON THE REMOTE only (clone, merge, push): forge says MERGED
# but local base lacks the merge commit.
clone="$root/clone"; git clone -q "$bare" "$clone"
git -C "$clone" config user.email a@b.c; git -C "$clone" config user.name t
git -C "$clone" checkout -q "$base"
git -C "$clone" merge -q --no-ff -m "operator merges the PR" "origin/$integ"
git -C "$clone" push -q origin "$base"
git -C "$clone" rev-parse HEAD > "$root/gh-state/merge_oid"
echo "MERGED" > "$root/gh-state/pr_state"
st="$("${L[@]}" status)"
[ "$(echo "$st" | jget '["settlement"]["result"]')" = "landed" ] \
  || fail "settlement must be landed once the forge reports MERGED"
[ "$(echo "$st" | jget '["settlement"]["local_synced"]')" = "False" ] \
  || fail "merged-but-unsynced must carry local_synced=false"
if "${L[@]}" finish --reason gate-ratified >/dev/null 2>&1; then
  fail "compat finish must refuse until local base contains the merge"
fi
pass "merged on forge, base unsynced: landed + local_synced=false; compat refuses"

# Synchronized: settlement fully landed; the compat path now passes too.
git -C "$repo" pull -q --ff-only origin "$base"
st="$("${L[@]}" status)"
[ "$(echo "$st" | jget '["settlement"]["result"]')" = "landed" ] \
  && [ "$(echo "$st" | jget '["settlement"]["local_synced"]')" = "True" ] \
  || fail "settlement must be landed+local_synced after the base syncs"
"${L[@]}" finish --reason gate-ratified >/dev/null \
  || fail "compat finish must pass once the delivery verifiably landed"
pass "synced: settlement landed (local_synced=true); compat path passes"

# --- the loop never merges ----------------------------------------------------
# Match the gh SUBCOMMAND (line start), not the whole argv — the PR body
# legitimately contains the word "merge".
if grep -qE "^(pr merge|merge)" "$root/gh-state/calls.log"; then
  fail "gate-pr/finish must never invoke a merge via gh"
fi
pass "no gh merge call anywhere in the flow"

echo "all gate-pr fixtures passed"
