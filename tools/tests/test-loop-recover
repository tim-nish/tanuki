#!/usr/bin/env bash
# Fixture for `tanuki-loop recover` (story 1.2; spec-tanuki-loop "Recovery
# from the external-modification breaker"): the attended recovery path for a
# run stopped by external modification of the integration worktree. Covers:
# restore, adopt, adopt-on-dirty-tree refusal, wrong-breaker refusal,
# open-iteration refusal, double-recover refusal, refusals writing nothing,
# and closed-iteration immutability across both modes.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
loop="$here/tanuki-loop"
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
export TANUKI_ROOT="$tmp/root"
jget() { python3 -c "import json,sys;print(json.load(sys.stdin)$1)"; }
state() { cat "$TANUKI_ROOT/t/loop/"*/state.json; }
iters() { state | python3 -c "import json,sys;print(json.dumps(json.load(sys.stdin)['iterations'],sort_keys=True))"; }

# A loop repo on main, one verified iteration so head_expected != base.
repo="$tmp/repo"
git init -q "$repo" && git -C "$repo" config user.email t@e && git -C "$repo" config user.name t
git -C "$repo" checkout -qb main && echo v0 > "$repo/f" && git -C "$repo" add -A && git -C "$repo" commit -qm base

L=("$loop" --target t)
wt="$("${L[@]}" init --loop-repo "$repo" --cap 8 | jget '["worktree"]')"
gwt() { git -C "$wt" "$@"; }
"${L[@]}" iter-start >/dev/null
echo v1 > "$wt/f"; gwt commit -qam iter1
"${L[@]}" iter-verify >/dev/null
expected="$(gwt rev-parse HEAD)"

# --- refusal: no external-modification breaker present ------------------------
rc=0; "${L[@]}" recover --restore >/tmp/r0.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "not an external-modification breaker" /tmp/r0.json \
  || fail "expected wrong-breaker refusal (exit 3)"
pass "refusal: recover without an external-modification breaker"

# --- trip the breaker with an external commit ---------------------------------
echo external > "$wt/f"; gwt commit -qam external-change
external="$(gwt rev-parse HEAD)"
rc=0; "${L[@]}" iter-start >/tmp/b1.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "external modification" /tmp/b1.json \
  || fail "expected external-modification breaker at iter-start"
pass "external commit trips the breaker at iter-start"
iters_before="$(iters)"

# --- refusal: recover requires exactly one mode -------------------------------
# No mode routes through the tool's {"breaker": ...} JSON convention (F37),
# exit 3 — not argparse's plain-text usage error.
rc=0; "${L[@]}" recover >/tmp/rn.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q '"breaker".*choose exactly one mode' /tmp/rn.json \
  || fail "recover without a mode should refuse via the JSON breaker convention (F37)"
rc=0; "${L[@]}" recover --restore --adopt >/dev/null 2>&1 || rc=$?
[ "$rc" != "0" ] || fail "recover with both modes should be rejected"
pass "no mode refuses via JSON breaker (F37); both modes rejected"

# --- refusals write nothing: last_breaker + audit + state preserved -----------
echo junk > "$wt/untracked.txt"            # dirt: makes --adopt refuse
breaker_before="$(state | python3 -c "import json,sys;print(json.load(sys.stdin)['last_breaker']['reason'])")"
audit_before="$(wc -l < "$TANUKI_ROOT"/t/loop/*/audit.md)"
rc=0; "${L[@]}" recover --adopt >/tmp/r1.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "not clean" /tmp/r1.json || fail "expected dirty-tree adopt refusal here"
breaker_after="$(state | python3 -c "import json,sys;print(json.load(sys.stdin)['last_breaker']['reason'])")"
audit_after="$(wc -l < "$TANUKI_ROOT"/t/loop/*/audit.md)"
[ "$breaker_before" = "$breaker_after" ] || fail "a refusal overwrote last_breaker"
[ "$audit_before" = "$audit_after" ] || fail "a refusal wrote to the audit"
pass "refusals write nothing: last_breaker and audit preserved"

# --- restore: worktree back to head_expected, external commit discarded -------
out="$("${L[@]}" recover --restore)"
echo "$out" | jget '["ok"]' | grep -q True || fail "recover --restore did not succeed"
[ "$(gwt rev-parse HEAD)" = "$expected" ] || fail "restore did not reset to head_expected"
[ "$(cat "$wt/f")" = "v1" ] || fail "restore did not restore file content"
[ ! -e "$wt/untracked.txt" ] || fail "restore left an untracked file behind"
[ -z "$(gwt status --porcelain)" ] || fail "tree not clean after restore"
echo "$out" | grep -q "external-change" || fail "discarded range not reported"
[ "$(iters)" = "$iters_before" ] || fail "restore mutated a closed iteration"
pass "recover --restore: reset to head_expected, discard reported, iterations immutable"

# --- after restore: iter-start passes, dashboard no longer STOPPED ------------
"${L[@]}" iter-start >/dev/null || fail "iter-start should pass after restore"
"${L[@]}" iter-verify --no-patch >/dev/null
"${L[@]}" dashboard | grep -q "STOPPED: breaker" && fail "recovered breaker still shows STOPPED" || true
pass "post-restore: iter-start passes and the dashboard moves on"

# --- double-recover refusal ----------------------------------------------------
echo external2 > "$wt/f"; gwt commit -qam external-2
rc=0; "${L[@]}" iter-start >/dev/null 2>&1 || rc=$?
[ "$rc" = "3" ] || fail "expected second external-modification breaker"
"${L[@]}" recover --restore >/dev/null
rc=0; "${L[@]}" recover --restore >/tmp/r2.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "already recovered" /tmp/r2.json \
  || fail "expected already-recovered refusal"
pass "refusal: a breaker is recovered at most once"

# --- adopt: dirty tree refused, clean tree re-baselines ------------------------
echo external3 > "$wt/f"; gwt commit -qam external-3
new_head="$(gwt rev-parse HEAD)"
rc=0; "${L[@]}" iter-start >/dev/null 2>&1 || rc=$?
[ "$rc" = "3" ] || fail "expected third external-modification breaker"
echo dirt > "$wt/scratch.txt"
rc=0; "${L[@]}" recover --adopt >/tmp/r3.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "not clean" /tmp/r3.json || fail "expected dirty-tree adopt refusal"
rm "$wt/scratch.txt"
iters_before="$(iters)"
out="$("${L[@]}" recover --adopt)"
echo "$out" | jget '["ok"]' | grep -q True || fail "recover --adopt did not succeed"
echo "$out" | jget '["ancestor"]' | grep -q True || fail "extended history should report ancestor: true"
he_now="$(state | python3 -c "import json,sys;print(json.load(sys.stdin)['head_expected'])")"
[ "$he_now" = "$new_head" ] || fail "adopt did not re-baseline head_expected"
[ "$(iters)" = "$iters_before" ] || fail "adopt mutated a closed iteration"
"${L[@]}" iter-start >/dev/null || fail "iter-start should pass after adopt"
"${L[@]}" iter-verify --no-patch >/dev/null
pass "recover --adopt: dirty refusal, clean re-baseline, iterations immutable, iter-start passes"

# --- adopt on rewritten history flags non-ancestor -----------------------------
gwt reset -q --hard "$expected"            # external rewrite: history moved sideways
rc=0; "${L[@]}" iter-start >/dev/null 2>&1 || rc=$?
[ "$rc" = "3" ] || fail "expected breaker after history rewrite"
out="$("${L[@]}" recover --adopt)"
echo "$out" | jget '["ancestor"]' | grep -q False || fail "rewritten history should report ancestor: false"
grep -q "NOT an ancestor" "$TANUKI_ROOT/t/loop/"*/audit.md || fail "non-ancestor warning missing from audit"
pass "recover --adopt: rewritten history is adopted with a loud non-ancestor warning"

# --- refusal: open iteration ----------------------------------------------------
"${L[@]}" iter-start >/dev/null
# fabricate breaker state while an iteration is open (never happens naturally;
# guards must still refuse)
python3 - "$TANUKI_ROOT" <<'EOF'
import json, os, sys, glob
p = glob.glob(os.path.join(sys.argv[1], "t", "loop", "loop-*", "state.json"))[0]
s = json.load(open(p))
s["last_breaker"] = {"reason": "external modification (fabricated for test)",
                     "at": "2026-01-01 00:00:00"}
json.dump(s, open(p, "w"))
EOF
rc=0; "${L[@]}" recover --restore >/tmp/r4.json 2>&1 || rc=$?
[ "$rc" = "3" ] && grep -q "iteration is still open" /tmp/r4.json \
  || fail "expected open-iteration refusal"
pass "refusal: recovery runs only between iterations"

echo "all recover checks passed"
