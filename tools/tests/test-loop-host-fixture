#!/usr/bin/env bash
# spec-host-snapshot / story 2.1: the loop pins a run-scoped HOST FIXTURE at
# init and the live host is out of scope afterward. init clones the live host
# once (committed tip), records host_base_sha + host_fixture_path in state; a
# later commit to the live host does NOT change the fixture; finish emits a
# read-only drift note; doctor's host-cloneable check passes for a hosted
# target and is skipped for a hostless one.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
loop="$here/tanuki-loop"
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
export TANUKI_ROOT="$tmp/root"
jget() { python3 -c "import json,sys;print(json.load(sys.stdin)$1)"; }

# loop repo (plugin) on main
repo="$tmp/repo"
git init -q "$repo" && git -C "$repo" config user.email t@e && git -C "$repo" config user.name t
git -C "$repo" checkout -qb main && echo v0 > "$repo/f" && git -C "$repo" add -A && git -C "$repo" commit -qm base

# live host repo with one commit
host="$tmp/host"
git init -q "$host" && git -C "$host" config user.email t@e && git -C "$host" config user.name t
git -C "$host" checkout -qb main && echo h0 > "$host/data" && git -C "$host" add -A && git -C "$host" commit -qm h0
host_tip="$(git -C "$host" rev-parse HEAD)"

# hosted scenarios file
sc="$tmp/hosted.scenarios.json"
cat > "$sc" <<EOF
{"target":"h","plugin":"$repo","host":"$host",
 "loop":{"iterations":2},
 "scenarios":[{"id":"s1","charter":"c","prompt":"p"}]}
EOF

# --- init pins the fixture ---------------------------------------------------
"$loop" --target h init --loop-repo "$repo" --scenarios "$sc" --cap 2 > /tmp/init.json 2>&1 \
  || { cat /tmp/init.json; fail "hosted init exited non-zero"; }
run="$(jget "['run']" < /tmp/init.json)"
fix="$(jget "['host_fixture_path']" < /tmp/init.json)"
sha="$(jget "['host_base_sha']" < /tmp/init.json)"
[ "$sha" = "$host_tip" ] || fail "host_base_sha ($sha) != live host tip ($host_tip)"
[ -d "$fix/.git" ] || fail "host fixture was not cloned to $fix"
[ "$(git -C "$fix" rev-parse HEAD)" = "$host_tip" ] || fail "fixture HEAD != pinned sha"
# state.json carries the fixture keys
state="$TANUKI_ROOT/h/loop/$run/state.json"
grep -q "\"host_base_sha\": \"$host_tip\"" "$state" || fail "state.json missing host_base_sha"
pass "init pins a run-scoped host fixture (committed tip) and records it in state"

# --- the live host moving after init does NOT change the fixture -------------
echo h1 > "$host/data2" && git -C "$host" add -A && git -C "$host" commit -qm h1
host_tip2="$(git -C "$host" rev-parse HEAD)"
[ "$host_tip2" != "$host_tip" ] || fail "test setup: live host did not move"
[ "$(git -C "$fix" rev-parse HEAD)" = "$host_tip" ] \
  || fail "fixture drifted after a live-host commit — it must be immutable"
pass "a commit to the live host after init leaves the pinned fixture unchanged"

# --- finish emits a read-only drift note, never a breaker --------------------
"$loop" --target h --run "$run" finish --reason aborted > /tmp/fin.json 2>&1 \
  || { cat /tmp/fin.json; fail "finish exited non-zero"; }
jget "['host_drift']" < /tmp/fin.json | grep -q "live host moved during the run" \
  || fail "finish must report live-host drift informationally"
# the live host was never written by the loop
[ "$(git -C "$host" rev-parse HEAD)" = "$host_tip2" ] || fail "loop wrote the live host"
pass "finish emits an informational host-drift note and never touches the live host"

# --- doctor: host-cloneable passes for hosted, skipped for hostless ----------
cat >> "$sc".tmp <<EOF
{"target":"h","plugin":"$repo","host":"$host",
 "loop":{"iterations":2,"test_cmd":"true","wall_time_s":60,"token_budget":100,"attempt_cap":2},
 "scenarios":[{"id":"s1","charter":"c","prompt":"p"}]}
EOF
mv "$sc".tmp "$sc"
"$loop" --target h doctor --loop-repo "$repo" --scenarios "$sc" > /tmp/doc.json 2>&1 || true
python3 -c "
import json
r=json.load(open('/tmp/doc.json'))
c=next(c for c in r['checks'] if c['check']=='host-cloneable')
assert c['ok'] is True, c
assert 'resolves and clones' in c['detail'], c
" || fail "doctor host-cloneable must pass for a resolvable hosted target"

# hostless scenarios file -> host-cloneable skipped-but-ok
sc2="$tmp/hostless.scenarios.json"
cat > "$sc2" <<EOF
{"target":"hl","plugin":"$repo",
 "loop":{"iterations":2,"test_cmd":"true","wall_time_s":60,"token_budget":100,"attempt_cap":2},
 "scenarios":[{"id":"s1","charter":"c","prompt":"p"}]}
EOF
"$loop" --target hl doctor --loop-repo "$repo" --scenarios "$sc2" > /tmp/doc2.json 2>&1 || true
python3 -c "
import json
r=json.load(open('/tmp/doc2.json'))
c=next(c for c in r['checks'] if c['check']=='host-cloneable')
assert c['ok'] is True and 'hostless' in c['detail'], c
" || fail "doctor host-cloneable must be a skipped-ok for a hostless target"
pass "doctor host-cloneable: passes hosted, skipped for hostless"

echo "all checks passed"
