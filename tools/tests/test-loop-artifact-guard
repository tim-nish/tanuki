#!/usr/bin/env bash
# Fixture for the loop's build-artifact guard (story 1.4 / issue #71 + ledger
# findings F64/F102; check (e) of the five-part integration invariant —
# spec-tanuki-loop AMENDED 2026-07-19, triage of issue #159, superseding the
# 2026-07-17 report-only arbitration). Regenerable output is not work product:
#   - untracked artifacts never make the worktree "dirty" (no false friction);
#   - artifacts COMMITTED to the integration branch are an immediate-stop
#     BREAKER at the commit that introduced them — named, with the cause and a
#     concrete remedy hint — because doctor's test-cmd-artifacts check runs
#     only at doctor time, which Phase 1 may skip;
#   - a legitimate binary is declared per path with --allow-artifact; the
#     override is audited and check (e) passes for declared paths only;
#   - gate-pr STILL refuses to push an integration branch carrying artifacts
#     (belt-and-suspenders past an overridden check (e)); the F102 guard moved
#     from the retired gate-push to gate-pr under two-outcomes-only delivery
#     (triage of #262/#263 — the loop never merges to main; gate-pr pushes the
#     integration branch, so that is now the last boundary before the remote);
#   - a clean bracket is unaffected (iter-start -> work -> iter-verify).
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
root="$(mktemp -d)"; trap 'rm -rf "$root"' EXIT
export TANUKI_ROOT="$root"
L=("$here/tanuki-loop" --target t)
jget() { python3 -c "import json,sys; d=json.load(sys.stdin); print(d$1)"; }

repo="$root/repo"; mkdir -p "$repo"
git init -q "$repo"; git -C "$repo" config user.email a@b.c
git -C "$repo" config user.name t
echo x > "$repo/f.py"; git -C "$repo" add -A; git -C "$repo" commit -qm init
# gate-pr pushes the integration branch to a real remote.
base="$(git -C "$repo" rev-parse --abbrev-ref HEAD)"
bare="$root/remote.git"; git init -q --bare "$bare"
git -C "$repo" remote add origin "$bare"
git -C "$repo" push -q -u origin "$base"

wt="$("${L[@]}" init --loop-repo "$repo" --cap 9 --test-cmd true | jget '["worktree"]')"
gwt() { git -C "$wt" "$@"; }

# --- clean path: no regression ------------------------------------------------
"${L[@]}" iter-start >/dev/null
echo "work" >> "$wt/f.py"; gwt commit -qam "real work"
"${L[@]}" iter-verify >/dev/null || fail "clean bracket must verify unchanged"
pass "clean path: an artifact-free bracket verifies unchanged"

# --- untracked artifacts are not 'dirty' -------------------------------------
# The runtime regenerates these constantly; they must add no friction.
"${L[@]}" iter-start >/dev/null
mkdir -p "$wt/pkg/__pycache__"
echo junk > "$wt/pkg/__pycache__/mod.cpython-311.pyc"
echo junk > "$wt/stray.pyc"
mkdir -p "$wt/.pytest_cache"; echo junk > "$wt/.pytest_cache/v"
echo "more work" >> "$wt/f.py"; gwt commit -qam "work with artifacts lying around"
"${L[@]}" iter-verify >/dev/null \
  || fail "untracked build artifacts must not make the worktree dirty"
pass "untracked artifacts (__pycache__, *.pyc, .pytest_cache) never read as dirty"

# A REAL untracked file still makes it dirty — the guard must not blanket-ignore.
"${L[@]}" iter-start >/dev/null
echo "more" >> "$wt/f.py"; gwt commit -qam "work"
echo "genuinely uncommitted" > "$wt/real-leftover.txt"
rc=0; b="$("${L[@]}" iter-verify 2>&1)" || rc=$?
[ "$rc" = "3" ] || fail "a real untracked file must still trip not-clean, got $rc"
echo "$b" | grep -q "real-leftover.txt" \
  || fail "not-clean breaker should still name real dirty paths: $b"
echo "$b" | grep -q "worktree not clean" \
  || fail "expected the not-clean breaker for a real dirty file: $b"
pass "a real dirty file still trips not-clean (guard is not a blanket ignore)"
rm -f "$wt/real-leftover.txt"
"${L[@]}" rollback >/dev/null 2>&1 || true

# --- committed artifacts: check (e) is an immediate-stop breaker --------------
# The actual contamination path: an agent's `git add -A` sweeps them in.
"${L[@]}" iter-start >/dev/null
mkdir -p "$wt/pkg/__pycache__"
echo junk > "$wt/pkg/__pycache__/mod.cpython-311.pyc"
echo "work" >> "$wt/f.py"
gwt add -A                      # the mistake this guard exists to catch
gwt commit -qm "work + swept-in artifacts"
rc=0; b="$("${L[@]}" iter-verify 2>&1)" || rc=$?
[ "$rc" = "3" ] \
  || fail "committed artifacts must stop the iteration (check (e)), got $rc"
echo "$b" | grep -q "build artifacts committed" \
  || fail "breaker must name the cause: $b"
echo "$b" | grep -q "pkg/__pycache__/mod.cpython-311.pyc" \
  || fail "breaker must name the swept paths: $b"
echo "$b" | grep -q "allow-artifact" \
  || fail "breaker hint must name the deliberate override remedy: $b"
pass "committed artifacts break at the commit that introduced them (check (e))"

# --- the override: declared paths only, audited -------------------------------
rc=0; b="$("${L[@]}" iter-verify --allow-artifact stray-other.bin 2>&1)" || rc=$?
[ "$rc" = "3" ] \
  || fail "an override for a DIFFERENT path must not admit the artifact, got $rc"
pass "--allow-artifact admits declared paths only (no blanket stand-down)"

rc=0; b="$("${L[@]}" iter-verify --allow-artifact pkg/__pycache__ 2>&1)" || rc=$?
[ "$rc" = "0" ] || fail "a declared artifact must verify (deliberate override), got $rc: $b"
[ "$(echo "$b" | jget '["ok"]')" = "True" ] || fail "the iteration should verify: $b"
echo "$b" | jget '["build_artifacts_committed"]' \
  | grep -q "pkg/__pycache__/mod.cpython-311.pyc" \
  || fail "iter-verify must still name the committed paths: $b"
echo "$b" | jget '["warning"]' | grep -qi "allow-artifact" \
  || fail "the override must be visible in the output, never silent: $b"
grep -q "check (e) override" "$root/t/loop/"*/audit.md \
  || fail "the override must be recorded in the audit trail"
pass "the override is per-path, visible in output, and audited"

# The record must reach the morning gate — status is what the operator reads
# before approving the merge.
s="$("${L[@]}" status)"
echo "$s" | jget '["build_artifacts_committed"]' | grep -q "mod.cpython-311.pyc" \
  || fail "status must name the swept paths for the gate"
pass "the committed-artifact record reaches status, which the morning gate reads"

# --- gate-pr STILL refuses: belt-and-suspenders past the override -------------
# The F102 guard moved from the retired gate-push to gate-pr (two-outcomes-only,
# #262/#263). Set up a minimal fake gh so gate-pr's tooling precondition passes
# and the artifact guard is the thing under test.
mkdir -p "$root/bin"
cat > "$root/bin/gh" <<'SHIM'
#!/usr/bin/env bash
case "$1 $2" in
  "pr list") echo "[]" ;;
  "pr create") echo "https://example.test/pr/1" ;;
  *) echo "fake gh: unscripted $*" >&2; exit 1 ;;
esac
SHIM
chmod +x "$root/bin/gh"
export PATH="$root/bin:$PATH"

integ="$("${L[@]}" status | jget '["integration_branch"]')"
"${L[@]}" test >/dev/null                 # record a pass on the current HEAD
"${L[@]}" finish --reason cap >/dev/null   # gate-pr delivers a finished run
rc=0; g="$("${L[@]}" gate-pr 2>&1)" || rc=$?
[ "$rc" = "3" ] || fail "gate-pr must refuse an integration branch carrying artifacts, got $rc: $g"
[ "$(echo "$g" | jget '["pushed"]')" = "False" ] || fail "nothing may be pushed: $g"
echo "$g" | jget '["build_artifacts"]' | grep -q "mod.cpython-311.pyc" \
  || fail "gate-pr must name the offending paths: $g"
[ "$(git -C "$bare" for-each-ref --format='%(refname)' 2>/dev/null | grep -c "$integ")" = "0" ] \
  || fail "the integration branch reached the remote — F102 reproduced"
pass "gate-pr still refuses; the artifact never reaches the remote (F102 closed)"

# The push-side override exists and is deliberate.
rc=0; "${L[@]}" gate-pr --allow-artifacts >/dev/null 2>&1 || rc=$?
[ "$rc" = "0" ] || fail "--allow-artifacts must permit a deliberate delivery, got $rc"
pass "--allow-artifacts is the deliberate delivery-side override"

echo "ALL PASS"
