#!/usr/bin/env bash
# Fixture for the loop's build-artifact guard (story 1.4 / issue #71 + ledger
# findings F64/F102; arbitration 2026-07-17). Regenerable output is not work
# product:
#   - untracked artifacts never make the worktree "dirty" (no false friction);
#   - artifacts COMMITTED to the integration branch are REPORTED at the commit
#     that introduced them — named, with the cause, in iter-verify's output and
#     in status — but are NEVER a breaker: halting there would add a fifth halt
#     to the documented four-part integration invariant and would stop an
#     unattended run over a merely-incomplete .gitignore;
#   - gate-push REFUSES to push a merge carrying artifacts. That is the
#     enforcement point: the last mechanical boundary before the remote, and an
#     attended one. F102's incident was artifacts riding through the merge AND
#     gate-push onto origin with nothing objecting anywhere on that path;
#   - a clean bracket is unaffected (iter-start -> work -> iter-verify).
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
root="$(mktemp -d)"; trap 'rm -rf "$root"' EXIT
export TANUKI_ROOT="$root"
L=("$here/tanuki-loop" --target t)
jget() { python3 -c "import json,sys; d=json.load(sys.stdin); print(d$1)"; }

repo="$root/repo"; mkdir -p "$repo"
git init -q "$repo"; git -C "$repo" config user.email a@b.c
git -C "$repo" config user.name t
echo x > "$repo/f.py"; git -C "$repo" add -A; git -C "$repo" commit -qm init
# gate-push needs a real upstream to refuse against.
base="$(git -C "$repo" rev-parse --abbrev-ref HEAD)"
bare="$root/remote.git"; git init -q --bare "$bare"
git -C "$repo" remote add origin "$bare"
git -C "$repo" push -q -u origin "$base"

wt="$("${L[@]}" init --loop-repo "$repo" --cap 9 | jget '["worktree"]')"
gwt() { git -C "$wt" "$@"; }

# --- clean path: no regression ------------------------------------------------
"${L[@]}" iter-start >/dev/null
echo "work" >> "$wt/f.py"; gwt commit -qam "real work"
"${L[@]}" iter-verify >/dev/null || fail "clean bracket must verify unchanged"
pass "clean path: an artifact-free bracket verifies unchanged"

# --- untracked artifacts are not 'dirty' -------------------------------------
# The runtime regenerates these constantly; they must add no friction.
"${L[@]}" iter-start >/dev/null
mkdir -p "$wt/pkg/__pycache__"
echo junk > "$wt/pkg/__pycache__/mod.cpython-311.pyc"
echo junk > "$wt/stray.pyc"
mkdir -p "$wt/.pytest_cache"; echo junk > "$wt/.pytest_cache/v"
echo "more work" >> "$wt/f.py"; gwt commit -qam "work with artifacts lying around"
"${L[@]}" iter-verify >/dev/null \
  || fail "untracked build artifacts must not make the worktree dirty"
pass "untracked artifacts (__pycache__, *.pyc, .pytest_cache) never read as dirty"

# A REAL untracked file still makes it dirty — the guard must not blanket-ignore.
"${L[@]}" iter-start >/dev/null
echo "more" >> "$wt/f.py"; gwt commit -qam "work"
echo "genuinely uncommitted" > "$wt/real-leftover.txt"
rc=0; b="$("${L[@]}" iter-verify 2>&1)" || rc=$?
[ "$rc" = "3" ] || fail "a real untracked file must still trip not-clean, got $rc"
echo "$b" | grep -q "real-leftover.txt" \
  || fail "not-clean breaker should still name real dirty paths: $b"
echo "$b" | grep -q "worktree not clean" \
  || fail "expected the not-clean breaker for a real dirty file: $b"
pass "a real dirty file still trips not-clean (guard is not a blanket ignore)"
rm -f "$wt/real-leftover.txt"
"${L[@]}" rollback >/dev/null 2>&1 || true

# --- committed artifacts: REPORTED at the commit, never a breaker -------------
# The actual contamination path: an agent's `git add -A` sweeps them in.
"${L[@]}" iter-start >/dev/null
mkdir -p "$wt/pkg/__pycache__"
echo junk > "$wt/pkg/__pycache__/mod.cpython-311.pyc"
echo "work" >> "$wt/f.py"
gwt add -A                      # the mistake this guard exists to catch
gwt commit -qm "work + swept-in artifacts"
rc=0; b="$("${L[@]}" iter-verify 2>&1)" || rc=$?
[ "$rc" = "0" ] \
  || fail "committed artifacts must NOT halt the iteration (4-part invariant), got $rc"
[ "$(echo "$b" | jget '["ok"]')" = "True" ] || fail "the iteration should verify: $b"
echo "$b" | jget '["build_artifacts_committed"]' \
  | grep -q "pkg/__pycache__/mod.cpython-311.pyc" \
  || fail "iter-verify must name the swept paths: $b"
echo "$b" | jget '["warning"]' | grep -qi "build artifacts committed" \
  || fail "iter-verify must warn, naming the cause: $b"
pass "committed artifacts are reported at the commit, never fatal (invariant stays 4-part)"

# The warning must reach the morning gate — status is what the operator reads
# before approving the merge. Always present, explicitly null when clean.
s="$("${L[@]}" status)"
echo "$s" | jget '["warning"]' | grep -qi "build artifacts" \
  || fail "status must carry the artifact warning for the gate: $s"
echo "$s" | jget '["build_artifacts_committed"]' | grep -q "mod.cpython-311.pyc" \
  || fail "status must name the swept paths"
pass "the warning reaches status, which the morning gate reads"

# --- gate-push REFUSES: the enforcement point ---------------------------------
# F102: artifacts rode the integration branch through the merge AND gate-push
# onto the remote, with nothing objecting anywhere along that path.
integ="$("${L[@]}" status | jget '["integration_branch"]')"
git -C "$repo" merge -q --no-ff "$integ" -m "merge integration"
rc=0; g="$("${L[@]}" gate-push 2>&1)" || rc=$?
[ "$rc" = "3" ] || fail "gate-push must refuse a merge carrying artifacts, got $rc"
[ "$(echo "$g" | jget '["pushed"]')" = "False" ] || fail "nothing may be pushed: $g"
echo "$g" | jget '["build_artifacts"]' | grep -q "mod.cpython-311.pyc" \
  || fail "gate-push must name the offending paths: $g"
[ "$(git -C "$bare" ls-tree -r --name-only "$base" 2>/dev/null | grep -c pycache)" = "0" ] \
  || fail "an artifact reached the remote — F102 reproduced"
pass "gate-push refuses; the artifact never reaches the remote (F102 closed)"

# The override exists and is deliberate.
rc=0; "${L[@]}" gate-push --allow-artifacts >/dev/null 2>&1 || rc=$?
[ "$rc" = "0" ] || fail "--allow-artifacts must permit a deliberate push, got $rc"
pass "--allow-artifacts is the deliberate override"

echo "ALL PASS"
