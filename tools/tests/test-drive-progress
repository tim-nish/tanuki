#!/usr/bin/env bash
# Fixture for tanuki-drive's background-liveness progress file: while a drive
# runs (typically backgrounded for ~20 min), <run-dir>/progress.json must
# carry total/done, current scenario + stage, and per-scenario results so the
# orchestrating session can relay real progress instead of a silent wait.
# Runs a real 2-scenario drive against a stub `claude` on PATH.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
drive="$here/tanuki-drive"
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
export TANUKI_ROOT="$tmp/root"

# Stub claude CLI: emits a minimal stream-json transcript and exits 0.
mkdir -p "$tmp/bin"
cat > "$tmp/bin/claude" <<'EOF'
#!/bin/sh
cat <<'JSON'
{"type":"assistant","message":{"content":[{"type":"text","text":"FRICTION LOG: none"}]}}
{"type":"result","subtype":"success","num_turns":1,"duration_ms":10,"total_cost_usd":0.001,"is_error":false,"result":"done"}
JSON
EOF
chmod +x "$tmp/bin/claude"
export PATH="$tmp/bin:$PATH"

# Tiny plugin + host repos.
for r in plugin host; do
  git init -q "$tmp/$r" && git -C "$tmp/$r" config user.email t@e && git -C "$tmp/$r" config user.name t
  git -C "$tmp/$r" checkout -qb main && echo x > "$tmp/$r/x" && git -C "$tmp/$r" add -A && git -C "$tmp/$r" commit -qm base
done

cat > "$tmp/scenarios.json" <<'EOF'
{"scenarios": [
  {"id": "s-one", "charter": "c", "prompt": "p", "max_turns": 3},
  {"id": "s-two", "charter": "c", "prompt": "p", "max_turns": 3}
]}
EOF

"$drive" --target t --plugin "$tmp/plugin" --host "$tmp/host" \
  --scenarios "$tmp/scenarios.json" --run r1 --timeout 60 >/dev/null \
  || fail "drive exited non-zero"

prog="$TANUKI_ROOT/t/events/r1/progress.json"
[ -f "$prog" ] || fail "progress.json not written"
python3 - "$prog" <<'PY' || fail "progress.json content wrong"
import json, sys
p = json.load(open(sys.argv[1]))
assert p["total"] == 2 and p["done"] == 2, (p["total"], p["done"])
assert p["stage"] == "complete", p["stage"]
assert [r["scenario"] for r in p["results"]] == ["s-one", "s-two"]
assert all(r["status"] == "ok" for r in p["results"]), p["results"]
assert all(isinstance(r["events"], int) and r["events"] > 0 for r in p["results"])
assert "updated" in p
PY
pass "progress.json: total/done=2/2, stage=complete, per-scenario ok results"

echo "all checks passed"
