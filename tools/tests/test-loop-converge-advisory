#!/usr/bin/env bash
# Fixture for the convergence advisory (issue #168 / spec-tanuki-scenario-
# lifecycle §3 "Surfacing"): when a loop run converges, record-cycle attaches
# the scheduler's advisory generation-trigger signals (feature-drift uncovered
# surfaces, unexplored-pool-empty) so a false quiet is named, never silent.
# The arithmetic is OWNED by tanuki-scheduler (`status` -> `advisories`);
# tanuki-loop's generate_advisory() only reads and phrases it. Non-blocking,
# never silent: a failure returns an explicit {"unavailable": true, reason}
# (a broken signal must not read as zero drift) and never raises — an
# advisory must never break record-cycle. None means the scheduler answered
# and there is genuinely nothing to say.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
export TANUKI_ROOT="$tmp/root"

# --- a target plugin with one covered and one uncovered skill ------------------
plugin="$tmp/work/demo-plugin"
mkdir -p "$plugin/skills/alpha" "$plugin/skills/beta"
echo "# alpha" > "$plugin/skills/alpha/SKILL.md"
echo "# beta"  > "$plugin/skills/beta/SKILL.md"
canon="$TANUKI_ROOT/scenarios/demo.scenarios.json"
mkdir -p "$(dirname "$canon")"
cat > "$canon" <<EOF
{"target":"demo","plugin":"$plugin",
 "scenarios":[{"id":"s1","charter":"covers the alpha skill","prompt":"p"}]}
EOF
# First sync -> s1 active -> the unexplored pool is empty.
"$here/tanuki-scheduler" --target demo sync --scenarios "$canon" > /dev/null

python3 - "$here/tanuki-loop" <<'PY' || fail "generate_advisory contract"
import importlib.machinery, importlib.util, sys
loader = importlib.machinery.SourceFileLoader("tl", sys.argv[1])
spec = importlib.util.spec_from_loader("tl", loader)
tl = importlib.util.module_from_spec(spec); loader.exec_module(tl)

# Both signals fire: the beta skill is uncovered and the pool is empty; the
# advisory names each and points at the generate invocation.
adv = tl.generate_advisory("demo")
assert adv is not None, "both trigger signals present -> advisory expected"
assert any("beta" in n for n in adv["notes"]), adv
assert any("unexplored pool empty" in n for n in adv["notes"]), adv
assert adv["generate"] == "/tanuki demo generate", adv

# Nothing to say -> None (a fresh target: no drift computable, no state).
assert tl.generate_advisory("ghost") is None, \
    "a target with no signals must yield no advisory"
PY
pass "advisory names drift + empty pool and points at generate; quiet target -> None"

# --- advisory failure is explicit and non-blocking, never silence --------------
python3 - "$here/tanuki-loop" <<'PY' || fail "advisory unavailable state"
import importlib.machinery, importlib.util, os, sys
loader = importlib.machinery.SourceFileLoader("tl", sys.argv[1])
spec = importlib.util.spec_from_loader("tl", loader)
tl = importlib.util.module_from_spec(spec); loader.exec_module(tl)
# A path-like target is rejected by the scheduler's slug validation (exit 2);
# the advisory must not raise AND must not look like zero drift — it names
# the failure as an explicit unavailable state.
adv = tl.generate_advisory("../not-a-slug")
assert adv is not None, "failure must never be silent (would read as zero drift)"
assert adv.get("unavailable") is True, adv
assert "exited 2" in adv["reason"], adv
assert "notes" not in adv, "an unavailable advisory must carry no signal notes"
PY
pass "sibling failure -> explicit unavailable state; non-blocking, never silence"

echo "all checks passed"
