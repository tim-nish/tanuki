#!/usr/bin/env bash
# spec-tanuki-loop "Concurrent drives within one iteration" / story 1.22:
# the dashboard's latest-drive NOW line aggregates the progress file's
# `running` entries under drive_concurrency > 1 (never a fabricated single
# "current"), keeps the serial line at one-in-flight, and iter-verify folds
# the iteration's drive cost/turn totals (summed across ALL manifest
# results) into the iteration record at the barrier.
set -euo pipefail

fail() { echo "FAIL: $1" >&2; exit 1; }
pass() { echo "ok: $1"; }

here="$(cd "$(dirname "$0")/.." && pwd)"   # tools/
loop="$here/tanuki-loop"
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
export TANUKI_ROOT="$tmp/root"
jget() { python3 -c "import json,sys;print(json.load(sys.stdin)$1)"; }

repo="$tmp/repo"
git init -q "$repo" && git -C "$repo" config user.email t@e && git -C "$repo" config user.name t
git -C "$repo" checkout -qb main && echo v0 > "$repo/f" && git -C "$repo" add -A && git -C "$repo" commit -qm base

"$loop" --target agg init --loop-repo "$repo" --cap 2 --test-cmd true > /tmp/agg-init.json
run="$(jget "['run']" < /tmp/agg-init.json)"
wt="$(jget "['worktree']" < /tmp/agg-init.json)"
"$loop" --target agg iter-start >/dev/null

pdir="$TANUKI_ROOT/agg/events/$run-iter1"
mkdir -p "$pdir"

# --- N>1 mid-drive: NOW line lists every running entry -----------------------
cat > "$pdir/progress.json" <<'EOF'
{"run": "x", "total": 6, "done": 3, "current": null,
 "stage": "2 scenario(s) running",
 "running": [{"scenario": "s2", "stage": "scenario running", "elapsed_s": 80},
             {"scenario": "s5", "stage": "scenario running", "elapsed_s": 40}],
 "results": [], "updated": 1}
EOF
dash="$("$loop" --target agg dashboard)"
echo "$dash" | grep -q "2 in parallel" || fail "NOW line must aggregate: $dash"
echo "$dash" | grep -q "s2 (scenario running, 80s)" || fail "must list s2 with stage+elapsed"
echo "$dash" | grep -q "s5 (scenario running, 40s)" || fail "must list s5"
echo "$dash" | grep -q "None" && fail "must not fabricate a single 'None' current" || true
pass "N>1: NOW aggregates the running list, no fabricated current"

# --- one in flight: serial line unchanged ------------------------------------
cat > "$pdir/progress.json" <<'EOF'
{"run": "x", "total": 6, "done": 5, "current": "s6",
 "stage": "scenario running",
 "running": [{"scenario": "s6", "stage": "scenario running", "elapsed_s": 12}],
 "results": [], "updated": 1}
EOF
dash2="$("$loop" --target agg dashboard)"
echo "$dash2" | grep -q "\[5/6\] s6 — scenario running" \
  || fail "one-in-flight must keep the serial NOW line: $dash2"
pass "N=1: serial NOW line unchanged"

# --- iter-verify folds summed drive totals into the iteration record ---------
cat > "$pdir/manifest.json" <<'EOF'
{"results": [
  {"scenario": "s2", "status": "ok", "cost_usd": 0.5, "num_turns": 10},
  {"scenario": "s5", "status": "ok", "cost_usd": 0.25, "num_turns": 7},
  {"scenario": "s6", "status": "ok", "cost_usd": null, "num_turns": 3}
]}
EOF
echo change > "$wt/f" && git -C "$wt" add -A && git -C "$wt" commit -qm iter1
"$loop" --target agg iter-verify >/dev/null
python3 - "$TANUKI_ROOT/agg/loop/$run/state.json" <<'PY' || fail "drive_totals wrong"
import json, sys
s = json.load(open(sys.argv[1]))
t = s["iterations"][0]["drive_totals"]
assert t["scenarios"] == 3 and t["num_turns"] == 20, t
assert abs(t["cost_usd"] - 0.75) < 1e-9, t
PY
pass "iter-verify sums cost/turns across all drive results at the barrier"

echo "ALL PASS"
