#!/usr/bin/env python3
"""tanuki-scheduler: deterministic scenario scheduling + target registry
(contract: specs/spec-tanuki-scenario-lifecycle/SPEC.md). All selection and
demotion arithmetic lives here; charter *generation* and ad-hoc framing are
the orchestrating model's (frontier) judgment and never happen in this tool.

Zero dependencies. State:
  ~/.tanuki/registry.json                repo path -> target slug (init/resolve)
  ~/.tanuki/<target>/scheduler.json      per-scenario state machine

Per-scenario state machine:
  unexplored --first drive--> active --demote_after consecutive
                                ^        low-yield runs--> regression
                                |                             |
                                +--- actionable finding <-----+
                                     (re-promotion)     driven every
                                                        regression_every runs
Scenarios are NEVER deleted — regression pool, not removal.

Subcommands (JSON out):
  --target T register --repo P     map a repo path to a target (Tanuki-owned;
                                   never writes into the repo)
  resolve --cwd P                  target for P or any parent, else null
  sync --scenarios F [--generation J]
                                   absorb the matrix: first sync marks every
                                   scenario active (backward compat for
                                   hand-written matrices); later syncs mark
                                   NEW ids unexplored. --generation appends
                                   the generate workflow's finalized pass
                                   record (trigger/proposed/rejected — open
                                   vocabulary) to a persisted `generations`
                                   list; `added`/`at` are computed here, never
                                   trusted from the caller. A bare sync that
                                   added ids records a membership-only
                                   `source: "sync"` entry (#170)
  plan --scenarios F [--max N] [--run R]
                                   next run's scenario set, priority-ordered:
                                   verify set (accepted findings awaiting
                                   absence) -> exploration quota (unexplored)
                                   -> active LRU -> due regression members;
                                   the composition is persisted (selection
                                   history with reasons)
  record-run --run R               fold the run's yield into streaks and apply
                                   the state machine (demotion needs
                                   demote_after consecutive low runs; any
                                   actionable finding re-promotes); persists
                                   the per-scenario yield snapshot and every
                                   state transition {run, from, to, reason}
  history [--scenario ID] [--trajectory [--run R]] [--json]
                                   cross-run monitoring from persisted
                                   artifacts: per-scenario executions (dates,
                                   pins, yield, approx for pre-revision runs),
                                   cumulative findings/recurrence, transition
                                   log; repo-wide scenario states (unexplored/
                                   long-unrun/productive) + selection history.
                                   --scenario ID --trajectory: the step-by-
                                   step path view (choices, errors,
                                   recoveries, outcome) per run, newest
                                   first, from event files alone — reads no
                                   ledger, writes nothing; pre-trajectory
                                   runs degrade to the error/result chain.
                                   (Axis coverage / exploration debt /
                                   coverage diff REMOVED 2026-07-18 —
                                   operator decision; spec-tanuki-view D2
                                   amendment)
  candidates [--scenario ID] [--json]
                                   the generate command's deterministic
                                   candidate pool. (1) trajectory-observed
                                   unexplored decision-point branches:
                                   per recorded run, a `user_choice` event
                                   names the point, the selected alternative,
                                   and the alternatives; an alternative NO run
                                   ever selected is surfaced (scenario, point,
                                   untaken alternative). A fully-explored point
                                   yields none. (2) repo-wide only (#171):
                                   `uncovered_findings` — live ledger findings
                                   no matrix scenario probes (empty / all-
                                   adhoc / unknown scenario links), ad-hoc
                                   promotion candidates flagged, host tags
                                   passed through. Read-only — event files,
                                   ledger, and scheduler state are read; no
                                   state or matrix mutation, ever.
  status                           machine-readable scheduler state, plus
                                   `advisories` — the read-only generation-
                                   trigger signals (feature-drift uncovered
                                   surfaces, unexplored-pool-empty) and the
                                   generate invocation they point at (#168)

Config (~/.tanuki/config.json, all optional): demote_after 2 ·
regression_every 3 · exploration_quota 1 · low_yield_threshold 0 ·
max_scenarios 6.
"""

import argparse
import json
import os
import re
import sys
import time

TANUKI_ROOT = os.environ.get("TANUKI_ROOT", os.path.expanduser("~/.tanuki"))
CONFIG_DEFAULTS = {"demote_after": 2, "regression_every": 3,
                   "exploration_quota": 1, "low_yield_threshold": 0,
                   "max_scenarios": 6}
STATES = ("unexplored", "active", "regression")


def load_config():
    cfg = dict(CONFIG_DEFAULTS)
    path = os.path.join(TANUKI_ROOT, "config.json")
    if os.path.exists(path):
        with open(path, encoding="utf-8") as f:
            cfg.update(json.load(f))
    return cfg


def read_json(path, default):
    if not os.path.exists(path):
        return default
    with open(path, encoding="utf-8") as f:
        return json.load(f)


def write_json(path, obj):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(obj, f, indent=2)
    os.replace(tmp, path)


def sched_path(target):
    return os.path.join(TANUKI_ROOT, target, "scheduler.json")


def registry_path():
    return os.path.join(TANUKI_ROOT, "registry.json")


def load_ledger(target):
    return read_json(os.path.join(TANUKI_ROOT, target, "ledger.json"),
                     {"events": {}, "findings": []})


def matrix_data(scenarios_file, target=None):
    """{id: scenario dict} for the whole matrix — the substrate for covers
    tags and cost keys (story 1.19), sharing matrix_ids' adhoc guard."""
    with open_scenarios(scenarios_file, target) as f:
        data = json.load(f)
    by_id = {}
    for s in data["scenarios"]:
        if s["id"].startswith("adhoc-"):
            die(f"matrix id '{s['id']}' uses the reserved adhoc- prefix")
        by_id[s["id"]] = s
    return by_id


def matrix_ids(scenarios_file, target=None):
    return list(matrix_data(scenarios_file, target))


def scenario_cost(s):
    """Deterministic verify cost: an explicit "cost" key, else max_turns,
    else the drive's default turn budget (40) — spec-tanuki-scenario-
    lifecycle "Cheapest covering verify"."""
    return s.get("cost") or s.get("max_turns") or 40


def run_yield(target, run):
    """(scenario -> {actionable, findings}) for one run — same attribution as
    tanuki-ledger scenario-yield: manifest for driven scenarios, ledger
    evidence pointers for findings. Snapshotted into scheduler.json at
    record-run time, while evidence is fresh (capping erodes it later)."""
    manifest = read_json(os.path.join(TANUKI_ROOT, target, "events", run,
                                      "manifest.json"), {})
    driven = [r.get("scenario") for r in manifest.get("results", [])
              if r.get("scenario")]
    touched = {}
    for f in load_ledger(target)["findings"]:
        for ptr in f.get("evidence", []):
            if ptr.split("/", 1)[0] == run:
                scen = ptr.split("#")[0].split("/")[-1]
                touched.setdefault(scen, set()).add(f["id"])
    return {s: {"actionable": len(touched.get(s, ())),
                "findings": sorted(touched.get(s, ()))} for s in driven}


def out(obj):
    print(json.dumps(obj, indent=2))


def die(msg):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(2)


def open_scenarios(path, target):
    """Open a scenarios config, or die naming the CANONICAL location so a
    misplaced or absent config surfaces immediately (issue #4). The only
    supported home is ~/.tanuki/scenarios/<target>.scenarios.json."""
    p = os.path.expanduser(path)
    if not os.path.exists(p):
        canon = os.path.join(TANUKI_ROOT, "scenarios",
                             f"{target or '<target>'}.scenarios.json")
        die(f"scenarios config not found: {p}\n"
            f"  canonical location: {canon}\n"
            "  (create it with `/tanuki init`; "
            "~/.claude/templates/tanuki/ is NOT read)")
    return open(p, encoding="utf-8")


# --- subcommands -------------------------------------------------------------

def cmd_register(args):
    repo = os.path.realpath(os.path.expanduser(args.repo))
    reg = read_json(registry_path(), {})
    reg[repo] = args.target
    write_json(registry_path(), reg)
    out({"ok": True, "repo": repo, "target": args.target})


def cmd_resolve(args):
    reg = read_json(registry_path(), {})
    path = os.path.realpath(os.path.expanduser(args.cwd))
    while True:
        if path in reg:
            out({"target": reg[path], "repo": path})
            return
        parent = os.path.dirname(path)
        if parent == path:
            out({"target": None})
            return
        path = parent


def cmd_sync(args):
    """First sync: every matrix scenario -> active (a hand-written matrix
    keeps today's behavior). Later syncs: new ids -> unexplored (generated
    charters enter as exploration candidates). Ids never leave the state.

    Membership history (issue #170): the generate workflow is the AUTHOR of
    generation metadata — at plan-gate close it passes the finalized record
    via --generation, and sync appends it to a `generations` list alongside
    what only the tool knows (`added`, computed from the matrix diff and never
    trusted from the caller; the timestamp). A bare sync appends a
    membership-only `source: "sync"` entry when it added ids — hand-edits are
    recorded but never dressed up as generation passes that didn't happen.
    Same posture as `transitions`/`plans`: persisted, not just printed."""
    gen = None
    if args.generation:
        try:
            gen = json.loads(args.generation)
        except ValueError as e:
            die(f"--generation must be a JSON object: {e}")
        if not isinstance(gen, dict):
            die("--generation must be a JSON object")
        if not isinstance(gen.get("trigger", ""), str):
            die("--generation trigger must be a string (open vocabulary: "
                "init, drift, pool-empty, on-demand, host-change, …)")
        # `added` and `at` are the tool's to compute — a caller-supplied value
        # is discarded, never merged.
        gen.pop("added", None)
        gen.pop("at", None)
        gen.pop("source", None)
    first = not os.path.exists(sched_path(args.target))
    sched = read_json(sched_path(args.target), {"scenarios": {}, "runs_recorded": []})
    added = []
    for sid, s in matrix_data(args.scenarios, args.target).items():
        if sid not in sched["scenarios"]:
            sched["scenarios"][sid] = {
                "state": "active" if first else "unexplored",
                "low_streak": 0, "runs_driven": 0,
                "last_planned": 0, "since_regression": 0,
            }
            added.append(sid)
        # covers tags (story 1.19): target-local vocabulary, refreshed from
        # the matrix on every sync (the file is the source of truth), no
        # normalization — visible in status/history.
        sched["scenarios"][sid]["covers"] = list(s.get("covers") or [])
    entry = None
    if gen is not None or added:
        entry = {"at": time.strftime("%Y-%m-%dT%H:%M:%S"), "added": added,
                 "source": "generate" if gen is not None else "sync",
                 **(gen or {})}
        sched.setdefault("generations", []).append(entry)
    write_json(sched_path(args.target), sched)
    out({"first_sync": first, "added": added,
         "total": len(sched["scenarios"]),
         **({"generation_recorded": entry} if entry else {})})


def cmd_plan(args):
    cfg = load_config()
    cap = args.max or cfg["max_scenarios"]
    sched = read_json(sched_path(args.target), None)
    if sched is None:
        die("no scheduler state; run `sync --scenarios <file>` first")
    matrix = matrix_data(args.scenarios, args.target)
    known = set(matrix)
    scen = {k: v for k, v in sched["scenarios"].items() if k in known}
    tick = len(sched["runs_recorded"]) + 1

    # 1. Verify set — CHEAPEST COVERING scenario per accepted finding
    #    (spec-tanuki-scenario-lifecycle "Cheapest covering verify"; story
    #    1.19). Candidates: scenarios whose covers tags include the
    #    finding's surface tag, plus the originating scenarios; pick the
    #    cheapest by scenario_cost. The originating scenario is the fallback
    #    (no tag / no cheaper cover) and wins outright when the finding is
    #    pinned (verify_pin). Deterministic arithmetic only; slot counts and
    #    rotation are untouched — covers change WHICH scenario fills a
    #    verify slot, never how many slots verify gets.
    verify, verify_selection = set(), []
    for f in load_ledger(args.target)["findings"]:
        if f.get("status") != "accepted" or f.get("tombstone"):
            continue
        orig = [s for s in f.get("scenarios", []) if s in scen]
        if not orig:
            continue
        orig_best = min(orig, key=lambda s: (scenario_cost(matrix[s]), s))
        tag = f.get("surface")
        if f.get("verify_pin"):
            choice, reason = orig_best, "pinned to its originating scenario"
        else:
            covering = [sid for sid in scen
                        if tag and tag in (matrix[sid].get("covers") or [])]
            cands = set(covering) | set(orig)
            choice = min(cands, key=lambda s: (scenario_cost(matrix[s]), s))
            if choice in orig:
                reason = ("originating scenario"
                          + (f" (no cheaper cover for surface '{tag}')"
                             if tag else " (no surface tag)"))
            else:
                reason = (f"cheapest covering scenario for surface '{tag}' "
                          f"(cost {scenario_cost(matrix[choice])} vs "
                          f"originating {scenario_cost(matrix[orig_best])})")
        verify.add(choice)
        verify_selection.append({"finding": f["id"], "scenario": choice,
                                 "reason": reason})
    # 2. Exploration quota — the anti-Goodhart guard. Reserved BEFORE verify
    #    (spec "Verify / cap interaction"): a large verify backlog must never
    #    consume the whole cap and starve coverage exploration.
    unexplored = sorted(s for s, st in scen.items() if st["state"] == "unexplored")
    explore = unexplored[:cfg["exploration_quota"]]
    # 3. Active rotation, least-recently-planned first.
    active = sorted((s for s, st in scen.items() if st["state"] == "active"),
                    key=lambda s: scen[s]["last_planned"])
    # 4. Regression pool members that are due.
    due = sorted(s for s, st in scen.items() if st["state"] == "regression"
                 and st["since_regression"] >= cfg["regression_every"])

    # Verify fills the budget left after the reserved quota, least-recently-
    # planned first so every accepted-finding scenario eventually replays and
    # the backlog drains — bounded, never a silent truncation. Overflow is
    # surfaced as `verify_deferred` (a bounded WIP signal); driven-absence
    # compaction makes a deferred replay safe (it accrues no false absence).
    verify_lru = sorted(verify, key=lambda s: (scen[s]["last_planned"], s))
    verify_budget = max(0, cap - len(explore))
    verify_sel = verify_lru[:verify_budget]
    verify_deferred = verify_lru[verify_budget:]

    plan, seen = [], set()
    for group in (verify_sel, explore, active, due):
        for s in group:
            if s not in seen and len(plan) < cap:
                plan.append(s)
                seen.add(s)
    quota_met = (not unexplored) or any(s in seen for s in unexplored)
    record = {"run": args.run, "plan": plan, "quota_met": quota_met,
              "verify": sorted(verify & seen),
              # Which finding each verify entry verifies and why that
              # scenario was chosen (story 1.19) — selections whose scenario
              # was deferred by the cap still appear (their entry names a
              # scenario in verify_deferred).
              "verify_selection": verify_selection,
              "verify_deferred": sorted(verify_deferred),
              "explore": [s for s in explore if s in seen],
              "due_regression": [s for s in due if s in seen],
              "unexplored_remaining": [s for s in unexplored if s not in seen]}
    # F162: a what-if plan must be possible without mutating rotation order or
    # the selection history — --dry-run computes the identical record and
    # persists nothing.
    if args.dry_run:
        out({**record, "dry_run": True,
             "note": "nothing persisted — rotation counters and the plan "
                     "history are untouched"})
        return
    for s in plan:
        scen[s]["last_planned"] = tick
    # Selection history with reasons — persisted, not just printed.
    sched.setdefault("plans", []).append(record)
    write_json(sched_path(args.target), sched)
    out(record)


def cmd_record_run(args):
    cfg = load_config()
    sched = read_json(sched_path(args.target), None)
    if sched is None:
        die("no scheduler state; run `sync` first")
    if args.run in sched["runs_recorded"]:
        out({"ok": True, "already_recorded": args.run})
        return
    yields = run_yield(args.target, args.run)
    changes = {}

    def transition(sid, st, to, reason):
        # Persisted, per the History & coverage revision: the durable answer
        # to "why and when did this scenario's priority change?"
        st.setdefault("transitions", []).append(
            {"run": args.run, "from": st["state"], "to": to, "reason": reason})
        changes[sid] = f"{st['state']} -> {to} ({reason})"
        st["state"] = to

    for sid, st in sched["scenarios"].items():
        if sid in yields:
            st["runs_driven"] += 1
            st["since_regression"] = 0
            if yields[sid]["actionable"] > cfg["low_yield_threshold"]:
                st["low_streak"] = 0
                if st["state"] != "active":
                    transition(sid, st, "active", "actionable finding")
            else:
                if st["state"] == "unexplored":
                    transition(sid, st, "active", "first drive")
                st["low_streak"] += 1
                if st["state"] == "active" and st["low_streak"] >= cfg["demote_after"]:
                    st["low_streak"] = 0
                    transition(sid, st, "regression",
                               f"{cfg['demote_after']} consecutive low-yield runs")
        elif st["state"] == "regression":
            st["since_regression"] += 1
    sched["runs_recorded"].append(args.run)
    # Durable per-execution yield snapshot (evidence capping erodes late
    # recomputation — this is the exact record).
    sched.setdefault("history", {})[args.run] = yields
    write_json(sched_path(args.target), sched)
    out({"ok": True, "run": args.run, "yield": yields, "transitions": changes})


def all_manifests(target):
    """[(run, manifest)] for every recorded run dir, chronological."""
    events_dir = os.path.join(TANUKI_ROOT, target, "events")
    outp = []
    if os.path.isdir(events_dir):
        for run in sorted(os.listdir(events_dir)):
            m = read_json(os.path.join(events_dir, run, "manifest.json"), None)
            if m is not None:
                outp.append((run, m))
    return outp


TRAJECTORY_TYPES = ("user_choice", "recovery", "outcome")


def trajectory_view(target, sid, run_filter, as_json):
    """`history --scenario <id> --trajectory` (spec-tanuki-trajectory §3):
    render each run of the scenario, newest first, as a seq-ordered path —
    one compact line per step. Reads only the per-run event files (plus the
    manifest for the date header); prints and exits. It writes nothing,
    judges nothing, scores nothing, and loads no ledger."""
    events_dir = os.path.join(TANUKI_ROOT, target, "events")
    runs = []
    if os.path.isdir(events_dir):
        for run in sorted(os.listdir(events_dir), reverse=True):  # newest first
            if run_filter and run != run_filter:
                continue
            path = os.path.join(events_dir, run, f"{sid}.events.jsonl")
            if not os.path.exists(path):
                continue
            events = []
            with open(path, encoding="utf-8", errors="replace") as f:
                for line in f:
                    try:
                        events.append(json.loads(line))
                    except json.JSONDecodeError:
                        continue
            manifest = read_json(os.path.join(events_dir, run,
                                              "manifest.json"), {})
            typed = any(e.get("type") in TRAJECTORY_TYPES and
                        (e.get("type") != "user_choice" or e.get("point"))
                        for e in events)
            runs.append({"run": run,
                         "at": manifest.get("completed_at")
                         or (run.split("-")[0][:8] or "?"),
                         "events": len(events), "typed": typed,
                         "steps": events})
    if as_json:
        json_runs = []
        for r in runs:
            keep = (TRAJECTORY_TYPES if r["typed"]
                    else ("tool_error", "permission_block", "result"))
            json_runs.append({"run": r["run"], "at": r["at"],
                              "events": r["events"], "typed": r["typed"],
                              "steps": [e for e in r["steps"]
                                        if e.get("type") in keep]})
        out({"scenario": sid, "runs": json_runs})
        return
    if not runs:
        print(f"no runs recorded for scenario {sid}"
              + (f" (run {run_filter})" if run_filter else ""))
        return
    for r in runs:
        print(f"{r['run']}  ({r['at']}, {r['events']} events)")
        if not r["typed"]:
            # Runs that predate typed events degrade to the error/result
            # chain — choices were never recorded, nothing is backfilled.
            for e in r["steps"]:
                if e.get("type") in ("tool_error", "permission_block"):
                    print(f"  #{e.get('seq')} error    {e.get('detail', '')[:110]}")
                elif e.get("type") == "result":
                    print(f"  #{e.get('seq')} result   {e.get('detail', '')[:110]}")
            print("  (pre-trajectory run — choices not recorded)")
            continue
        for e in r["steps"]:
            t, seq = e.get("type"), e.get("seq")
            if t == "user_choice" and e.get("point"):
                alt = ("        (alt: " + "|".join(e["alternatives"]) + ")"
                       if e.get("alternatives") else "")
                print(f"  #{seq} user_choice {e['point']}: "
                      f"selected={e.get('selected')}{alt}")
            elif t in ("tool_error", "permission_block"):
                print(f"  #{seq} error    {e.get('detail', '')[:110]}")
            elif t == "recovery":
                print(f"  #{seq} recovery {e.get('detail', '')[:110]}")
            elif t == "outcome":
                syn = " (synthesized)" if e.get("synthesized") else ""
                print(f"  #{seq} outcome  {e.get('disposition')} — "
                      f"{e.get('detail', '')[:110]}{syn}")


def unexplored_branches(target, scenario_filter=None):
    """Derive trajectory-observed unexplored decision-point branches, READ-ONLY
    (spec-tanuki-scenario-lifecycle §3, generation candidate source). Across
    every recorded run's per-scenario event file, each decision point records
    which alternative that run took (a `user_choice` event with `point`,
    `selected`, `alternatives` — the same markers trajectory_view renders). The
    union of a point's alternatives minus the union of alternatives any run ever
    SELECTED = the branches no recorded run explored. Each surviving branch is a
    regeneration candidate naming the scenario, the decision point, and the
    untaken alternative. A point whose alternatives were all taken contributes
    nothing. Reads per-run event files only — loads no ledger, touches no
    scheduler state, mutates no matrix. Degrades to [] for targets/scenarios
    with no recorded trajectories and for pre-trajectory runs (no `user_choice`
    events), never raising."""
    events_dir = os.path.join(TANUKI_ROOT, target, "events")
    # scenario -> point -> {"alternatives": set, "selected": set}
    seen = {}
    if os.path.isdir(events_dir):
        for run in sorted(os.listdir(events_dir)):
            run_dir = os.path.join(events_dir, run)
            if not os.path.isdir(run_dir):
                continue
            for fn in sorted(os.listdir(run_dir)):
                if not fn.endswith(".events.jsonl"):
                    continue
                sid = fn[: -len(".events.jsonl")]
                if scenario_filter and sid != scenario_filter:
                    continue
                with open(os.path.join(run_dir, fn), encoding="utf-8",
                          errors="replace") as f:
                    for line in f:
                        try:
                            e = json.loads(line)
                        except json.JSONDecodeError:
                            continue
                        if e.get("type") != "user_choice" or not e.get("point"):
                            continue
                        rec = seen.setdefault(sid, {}).setdefault(
                            e["point"],
                            {"alternatives": set(), "selected": set()})
                        alts = e.get("alternatives")
                        if isinstance(alts, list):
                            rec["alternatives"].update(a for a in alts
                                                       if a is not None)
                        if e.get("selected") is not None:
                            # A selected value is by definition an alternative
                            # that was taken, even if the marker omitted it.
                            rec["selected"].add(e["selected"])
                            rec["alternatives"].add(e["selected"])
    candidates = []
    for sid in sorted(seen):
        for point in sorted(seen[sid]):
            rec = seen[sid][point]
            untaken = sorted(rec["alternatives"] - rec["selected"])
            if untaken:
                candidates.append({"scenario": sid, "point": point,
                                   "untaken": untaken,
                                   "taken": sorted(rec["selected"])})
    return candidates


def uncovered_findings(target):
    """Ledger-seeded generation candidates, READ-ONLY (issue #171 — the
    spec's second candidate source, previously a prose obligation on the
    orchestrating session): live findings that NO matrix scenario probes —
    scenario links empty, all `adhoc-*` (the §2 promotion path, flagged
    `adhoc_origin`), or referencing ids absent from scheduler state
    (`unknown_scenarios`). Tombstoned and dismissed findings are dead, not
    candidates. With no scheduler state, membership is unknowable — durable
    links are then assumed covered (errs toward silence, like feature_drift).
    A finding-level `host` tag passes through untouched (#172 interim rule:
    where the friction was observed is the plan gate's to weigh, never
    arithmetic here). Enumeration only — framing charters from these stays
    frontier judgment behind the plan gate."""
    sched = read_json(sched_path(target), None)
    known = set(sched["scenarios"]) if sched else None
    found = []
    for f in load_ledger(target)["findings"]:
        if f.get("tombstone") or f.get("status") == "dismissed":
            continue
        scens = f.get("scenarios", [])
        durable = [s for s in scens if not s.startswith("adhoc-")]
        unknown = [s for s in durable if known is not None and s not in known]
        if [s for s in durable if known is None or s in known]:
            continue  # a matrix scenario probes it — not a gap
        entry = {"id": f["id"], "kind": f.get("kind"),
                 "status": f.get("status"),
                 "recurrence": f.get("recurrence", 1),
                 "scenarios": scens,
                 "adhoc_origin": any(s.startswith("adhoc-") for s in scens),
                 "evidence": f.get("evidence", [])[:3]}
        if unknown:
            entry["unknown_scenarios"] = sorted(unknown)
        if f.get("host"):
            entry["host"] = f["host"]
        found.append(entry)
    return found


def cmd_candidates(args):
    """The `generate` command's machine surface for its deterministic
    candidate pool (read-only; the operator still approves at the plan gate):
    trajectory-observed unexplored branches, plus — repo-wide only — the
    ledger-seeded sections (uncovered friction / ad-hoc promotion, #171).
    Reads event files, the ledger, and scheduler state; mutates nothing."""
    cands = unexplored_branches(args.target, args.scenario)
    data = {"candidates": cands}
    if not args.scenario:
        data["uncovered_findings"] = uncovered_findings(args.target)
    if args.json:
        out(data)
        return
    if not cands:
        print("no unexplored trajectory branches")
    for c in cands:
        print(f"{c['scenario']}  {c['point']}: untaken "
              f"{', '.join(c['untaken'])} "
              f"(taken {', '.join(c['taken']) or '-'})")
    if args.scenario:
        return
    if not data["uncovered_findings"]:
        print("no uncovered friction findings")
        return
    print("uncovered friction (no matrix scenario probes these):")
    for f in data["uncovered_findings"]:
        tags = []
        if f["adhoc_origin"]:
            tags.append("ad-hoc origin — promotion candidate")
        if f.get("unknown_scenarios"):
            tags.append("links unknown scenario(s) "
                        + ", ".join(f["unknown_scenarios"]))
        if f.get("host"):
            tags.append(f"host {f['host']}")
        print(f"  {f['id']} [{f.get('kind') or '?'}] {f['status']} "
              f"rec:{f['recurrence']}"
              + (f"  via {', '.join(f['scenarios'])}" if f["scenarios"]
                 else "  (no scenario link)")
              + (("  (" + "; ".join(tags) + ")") if tags else ""))


def plugin_surface(plugin_path):
    """Enumerate the target plugin's coverage-checkable surface, READ-ONLY:
    skill names (skills/*/SKILL.md directory names) and command names
    (commands/*.md basenames). Returns [] when the plugin path or a surface
    dir is absent (hostless target / missing checkout) — never raises."""
    surface = []
    if not plugin_path:
        return surface
    root = os.path.expanduser(plugin_path)
    skills_dir = os.path.join(root, "skills")
    if os.path.isdir(skills_dir):
        for name in sorted(os.listdir(skills_dir)):
            if os.path.exists(os.path.join(skills_dir, name, "SKILL.md")):
                surface.append(("skill", name))
    commands_dir = os.path.join(root, "commands")
    if os.path.isdir(commands_dir):
        for fn in sorted(os.listdir(commands_dir)):
            if fn.endswith(".md"):
                surface.append(("command", fn[:-3]))
    return surface


def feature_drift(target):
    """Advisory, READ-ONLY feature-drift signal (spec-tanuki-scenario-lifecycle
    §3, third generation trigger): name each plugin surface that NO scenario
    covers, and point at the generate invocation. Reads the canonical
    scenarios config and the target plugin checkout; writes nothing, mutates
    nothing, triggers nothing.

    Scope and matching per the #169 narrow-the-spec ruling (2026-07-19):
    drift is computed over STATICALLY ENUMERABLE surface only — skills and
    commands; observed decision-point gaps are `candidates`' business, never
    drift's. A surface is covered iff its name equals a scenario's `covers`
    tag (exact, case-insensitive) or appears as a whole token —
    `[a-z0-9_-]`-bounded, case-insensitive — in a charter or prompt. Never a
    bare substring: "do" does not cover "do-thing", "betamax" does not cover
    "beta". Mention-as-coverage remains the documented heuristic limit (a
    charter that merely names a command counts as covering it). The signal is
    advisory, so it errs toward silence: an empty `uncovered` (complete
    coverage, absent config, or hostless target with no surface dirs) emits no
    drift."""
    scen_path = os.path.join(TANUKI_ROOT, "scenarios",
                             f"{target}.scenarios.json")
    try:
        data = read_json(scen_path, None)
    except (OSError, ValueError):
        data = None
    generate = f"/tanuki {target} generate"
    if not isinstance(data, dict):
        return {"uncovered": [], "generate": generate}
    surface = plugin_surface(data.get("plugin"))
    scenarios = data.get("scenarios", [])
    corpus = " ".join(f"{s.get('charter', '')} {s.get('prompt', '')}"
                      for s in scenarios).lower()
    tags = {str(t).lower() for s in scenarios for t in (s.get("covers") or [])}

    def covered(name):
        n = name.lower()
        return n in tags or re.search(
            rf"(?<![a-z0-9_-]){re.escape(n)}(?![a-z0-9_-])", corpus)

    uncovered = [{"kind": kind, "name": name} for kind, name in surface
                 if not covered(name)]
    return {"uncovered": uncovered, "generate": generate}


def cmd_history(args):
    """Cross-run scenario monitoring from persisted artifacts only.
    Default: the repo-wide scenario-state summary + selection history.
    --scenario: the single-scenario deep view; with --trajectory, the
    step-by-step path view (spec-tanuki-trajectory §3) rendered from event
    files alone. (Axis coverage / exploration debt / coverage diff REMOVED
    2026-07-18 — operator decision; the view catalog shrank with it.) Runs
    recorded before the yield-snapshot revision are reconstructed from
    manifests + (capped) ledger evidence and labeled approx. --json for the
    machine-readable form."""
    if args.trajectory:
        # Strictly additive mode: renders from per-run event files only and
        # returns before any scheduler/ledger/manifest aggregation below —
        # the verified no-ledger-read guarantee.
        if not args.scenario:
            die("--trajectory requires --scenario <id>")
        trajectory_view(args.target, args.scenario, args.run, args.json)
        return
    sched = read_json(sched_path(args.target),
                      {"scenarios": {}, "runs_recorded": [], "history": {},
                       "plans": []})
    ledger = load_ledger(args.target)
    manifests = all_manifests(args.target)
    snap = sched.get("history", {})

    # Per (run, scenario): executions from manifests (the complete record).
    executions = {}   # scenario -> [execution dict]
    for run, m in manifests:
        when = m.get("completed_at") or (run.split("-")[0][:8] or "?")
        for r in m.get("results", []):
            sid = r.get("scenario")
            if not sid:
                continue
            if run in snap and sid in snap[run]:
                y = snap[run][sid]
                approx = False
            else:  # pre-revision run: best-effort from capped evidence
                y = {"actionable": 0, "findings": []}
                for f in ledger["findings"]:
                    for ptr in f.get("evidence", []):
                        if ptr.split("/", 1)[0] == run and \
                                ptr.split("#")[0].split("/")[-1] == sid:
                            y["findings"].append(f["id"])
                y["findings"] = sorted(set(y["findings"]))
                y["actionable"] = len(y["findings"])
                approx = True
            pins = r.get("decision_points")
            # A manifest result with no "status" is legal (the field is not
            # required anywhere); default it here so every renderer below can
            # assume a string — history --scenario crashed on None[:16] (F161).
            executions.setdefault(sid, []).append({
                "run": run, "at": when, "events": r.get("events", 0),
                "status": r.get("status") or "(no status)",
                "actionable": y["actionable"],
                "findings": y["findings"],
                "decision_points": pins if isinstance(pins, list) else [],
                "approx": approx})

    # Cumulative findings/recurrence per scenario, from the ledger.
    cumulative = {}
    for f in ledger["findings"]:
        for sid in f.get("scenarios", []):
            c = cumulative.setdefault(sid, {"findings": [], "recurrence": 0})
            c["findings"].append({"id": f["id"], "kind": f.get("kind"),
                                  "status": f.get("status"),
                                  "recurrence": f.get("recurrence", 1)})
            c["recurrence"] += f.get("recurrence", 1)

    if args.scenario:
        sid = args.scenario
        st = sched["scenarios"].get(sid, {})
        # Membership record (#170): the generations entry that added this id
        # — when it entered and under which trigger. None for pre-revision
        # entries (the lossiness boundary, stated not hidden).
        entered = next((g for g in sched.get("generations", [])
                        if sid in g.get("added", [])), None)
        data = {"scenario": sid,
                "state": st.get("state", "(not in scheduler)"),
                "entered": entered,
                "covers": st.get("covers", []),
                "low_streak": st.get("low_streak", 0),
                "runs_driven": len(executions.get(sid, [])),
                "last_execution": (executions.get(sid) or [{}])[-1],
                "executions": executions.get(sid, []),
                "cumulative": cumulative.get(sid, {"findings": [],
                                                   "recurrence": 0}),
                "transitions": st.get("transitions", [])}
        if args.json:
            out(data)
            return
        print(f"scenario {sid} — {data['state']} · driven "
              f"{data['runs_driven']}x · low streak {data['low_streak']} · "
              f"cumulative recurrence {data['cumulative']['recurrence']}")
        if entered:
            print(f"  entered [{entered['at']}] via {entered['source']}"
                  + (f" trigger={entered['trigger']}"
                     if entered.get("trigger") else ""))
        for e in data["executions"]:
            pins = "; ".join(f"{p.get('point')}={p.get('choice')}"
                             if isinstance(p, dict) else str(p)
                             for p in e["decision_points"]) or "-"
            print(f"  {e['run']:<28} {e['at']:<20} {e['status'][:16]:<16} "
                  f"events {e['events']:>3}  actionable {e['actionable']}"
                  f"{' ~' if e['approx'] else ''}  pins: {pins}"
                  + (f"  findings: {', '.join(e['findings'])}" if e["findings"] else ""))
        for t in data["transitions"]:
            print(f"  [{t['run']}] {t['from']} -> {t['to']}: {t['reason']}")
        for f in data["cumulative"]["findings"]:
            print(f"  finding {f['id']} [{f['kind']}] {f['status']} "
                  f"rec:{f['recurrence']}")
        return

    # Repo-wide scenario-state summary.
    recorded = sched.get("runs_recorded", [])
    rows, cover = [], {"unexplored": [], "long_unrun": [], "productive": []}
    for sid, st in sorted(sched["scenarios"].items()):
        ex = executions.get(sid, [])
        last = ex[-1] if ex else None
        recent_actionable = sum(e["actionable"] for e in ex[-3:])
        rows.append({"scenario": sid, "state": st["state"],
                     "driven": len(ex),
                     "last_run": last["run"] if last else None,
                     "last_at": last["at"] if last else None,
                     "low_streak": st.get("low_streak", 0),
                     "recent_actionable": recent_actionable,
                     "cumulative_recurrence":
                         cumulative.get(sid, {}).get("recurrence", 0),
                     "transitions": len(st.get("transitions", []))})
        if st["state"] == "unexplored":
            cover["unexplored"].append(sid)
        if ex and recorded and last["run"] not in recorded[-3:] \
                and len(recorded) >= 3:
            cover["long_unrun"].append(sid)
        if recent_actionable:
            cover["productive"].append(sid)
    drift = feature_drift(args.target)
    # Pool-empty is a named generation trigger (spec §3) — render its firing
    # condition, don't leave emptiness silent (issue #168). Zero scenarios is
    # onboarding, not an empty pool.
    pool_empty = bool(rows) and not cover["unexplored"]
    data = {"scenarios": rows, "coverage": cover,
            "feature_drift": drift,
            "unexplored_pool_empty": pool_empty,
            # Membership history (#170): when and why charters entered the
            # matrix. Legacy state without the list renders nothing — same
            # lossiness boundary as the yield-snapshot revision.
            "generations": sched.get("generations", [])[-args.plans:],
            "selection_history": sched.get("plans", [])[-args.plans:]}
    if args.json:
        out(data)
        return
    print(f"tanuki history — {args.target} · {len(rows)} scenarios · "
          f"{len(recorded)} runs recorded")
    for r in rows:
        print(f"  {r['scenario']:<24} {r['state']:<11} driven {r['driven']:>2}"
              f"  last {r['last_run'] or '-':<28} streak {r['low_streak']}"
              f"  recent-actionable {r['recent_actionable']}"
              f"  cum-rec {r['cumulative_recurrence']}")
    if cover["unexplored"]:
        print(f"  unexplored: {', '.join(cover['unexplored'])}")
    elif pool_empty:
        print(f"  unexplored pool empty — run `{drift['generate']}` "
              "to widen the matrix")
    if cover["long_unrun"]:
        print(f"  long-unrun: {', '.join(cover['long_unrun'])}")
    if cover["productive"]:
        print(f"  recently productive: {', '.join(cover['productive'])}")
    if drift["uncovered"]:
        names = ", ".join(f"{u['kind']} {u['name']}"
                          for u in drift["uncovered"])
        print(f"  feature-drift: uncovered {names} — "
              f"run `{drift['generate']}` to charter it")
    for g in data["generations"]:
        if g.get("source") == "generate":
            counts = ", ".join(f"{k} {g[k]}" for k in ("proposed", "rejected")
                               if k in g)
            print(f"  generation [{g['at']}] trigger={g.get('trigger', '?')} "
                  f"added: {', '.join(g['added']) or '-'}"
                  + (f" ({counts})" if counts else ""))
        else:
            print(f"  matrix-edit [{g['at']}] added: {', '.join(g['added'])}")
    for p in data["selection_history"]:
        print(f"  plan [{p.get('run') or '?'}] -> {', '.join(p['plan'])} "
              f"(verify {len(p['verify'])}, explore {len(p['explore'])}, "
              f"quota_met {p['quota_met']})")


def cmd_status(args):
    sched = read_json(sched_path(args.target), {"scenarios": {}, "runs_recorded": []})
    by_state = {}
    for sid, st in sched["scenarios"].items():
        by_state.setdefault(st["state"], []).append(sid)
    # Advisory generation-trigger signals (issue #168): the same read-only
    # feature-drift arithmetic history renders, plus the pool-empty condition
    # — a named generation trigger that previously surfaced nowhere. status is
    # the cheap machine surface, so consumers (the loop's convergence report,
    # the status view) read the signals here instead of re-deriving them.
    # A target with no scenarios at all is onboarding, not an empty pool.
    drift = feature_drift(args.target)
    out({"runs_recorded": len(sched["runs_recorded"]),
         "by_state": {k: sorted(v) for k, v in sorted(by_state.items())},
         "scenarios": sched["scenarios"],
         "advisories": {"feature_drift": drift["uncovered"],
                        "unexplored_pool_empty":
                            bool(sched["scenarios"])
                            and not by_state.get("unexplored"),
                        "generate": drift["generate"]}})


def slug_target(value):
    """--target is a namespace slug, never a path (issues #68/#70).

    State lives under $TANUKI_ROOT/<target>/, so a path-like value either
    nests silently (os.path.join swallows an absolute path — the accidental
    "support" #68 reported) or fails deep inside a later git call with a
    low-level error (#70). Both are the same root cause: --target was never
    validated. Reject at parse time so the message names the contract.
    TANUKI_ROOT is the supported way to relocate state.
    """
    if (value and not value.startswith(".")
            and all(c.isalnum() or c in "._-" for c in value)):
        return value
    raise argparse.ArgumentTypeError(
        f"--target must be a simple namespace slug (letters, digits, "
        f"'.', '_', '-'), not a path: {value!r}. State lives under "
        f"$TANUKI_ROOT/<target>/ — set TANUKI_ROOT to relocate it.")


def main():
    p = argparse.ArgumentParser()
    p.add_argument("--target", default=None, type=slug_target)
    sub = p.add_subparsers(dest="cmd", required=True)
    sp = sub.add_parser("register")
    sp.add_argument("--repo", required=True)
    sp = sub.add_parser("resolve"); sp.add_argument("--cwd", required=True)
    sp = sub.add_parser("sync")
    sp.add_argument("--scenarios", required=True)
    sp.add_argument("--generation", default=None,
                    help="finalized generation-pass record (JSON object: "
                         "trigger/proposed/rejected…) from the generate "
                         "workflow at plan-gate close; added/at are computed "
                         "here, never trusted from the caller (#170)")
    sp = sub.add_parser("plan")
    sp.add_argument("--scenarios", required=True)
    sp.add_argument("--max", type=int, default=None)
    sp.add_argument("--run", default=None)
    sp.add_argument("--dry-run", action="store_true",
                    help="compute the plan without persisting it — rotation "
                         "counters and the selection history are untouched "
                         "(a plain plan call is stateful, F162)")
    sp = sub.add_parser("record-run"); sp.add_argument("--run", required=True)
    sp = sub.add_parser("history")
    sp.add_argument("--scenario", default=None)
    sp.add_argument("--trajectory", action="store_true",
                    help="with --scenario: render each run's step-by-step "
                         "path from its event files (newest first)")
    sp.add_argument("--run", default=None,
                    help="with --trajectory: filter to one run")
    sp.add_argument("--plans", type=int, default=10)
    sp.add_argument("--json", action="store_true")
    sp = sub.add_parser("candidates")
    sp.add_argument("--scenario", default=None,
                    help="restrict to one scenario id (default: all)")
    sp.add_argument("--json", action="store_true")
    sub.add_parser("status")
    args = p.parse_args()
    if args.cmd != "resolve" and not args.target:
        die("--target is required for this subcommand")
    {"register": cmd_register, "resolve": cmd_resolve, "sync": cmd_sync,
     "plan": cmd_plan, "record-run": cmd_record_run, "history": cmd_history,
     "candidates": cmd_candidates, "status": cmd_status}[args.cmd](args)


if __name__ == "__main__":
    sys.exit(main())
